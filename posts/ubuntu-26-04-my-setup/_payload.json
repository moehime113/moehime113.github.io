[{"data":1,"prerenderedAt":1817},["ShallowReactive",2],{"post-ubuntu-26-04-my-setup":3,"all-posts":136},{"id":4,"title":5,"body":6,"categories":119,"cover":122,"date":123,"description":124,"extension":125,"meta":126,"navigation":127,"path":128,"seo":129,"stem":130,"tags":131,"__hash__":135},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":7,"value":8,"toc":111},"minimark",[9,13,17,20,27,43,46,78,82,93,97],[10,11,12],"h2",{"id":12},"我的配置清单",[14,15,16],"p",{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[14,18,19],{},"惯例先附上系统信息：",[14,21,22],{},[23,24],"img",{"alt":25,"src":26},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[28,29,30,34,37,40],"ul",{},[31,32,33],"li",{},"OS：Ubuntu 26.04 LTS",[31,35,36],{},"Kernel：Linux 7.0.0-15-generic",[31,38,39],{},"CPU：Intel Core i7-14700H",[31,41,42],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[10,44,45],{"id":45},"系统与桌面环境",[28,47,48,51,54,57,60,63,66,69,72,75],{},[31,49,50],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[31,52,53],{},"桌面协议：Wayland",[31,55,56],{},"窗口管理：Mutter",[31,58,59],{},"Shell：zsh 5.9",[31,61,62],{},"终端：Ghostty",[31,64,65],{},"输入法：Fcitx5（小鹤音形）",[31,67,68],{},"主题：Orchis-dark",[31,70,71],{},"壁纸：Variety",[31,73,74],{},"截图：Flameshot",[31,76,77],{},"VPN：v2rayN（Linux 版本）",[10,79,81],{"id":80},"工作-学习","工作 \u002F 学习",[28,83,84,87,90],{},[31,85,86],{},"办公：WPS",[31,88,89],{},"编辑器：VS Code",[31,91,92],{},"AI 工具管理：CCSwitch（ccswitch）",[10,94,96],{"id":95},"生活-游戏","生活 \u002F 游戏",[28,98,99,102,105,108],{},[31,100,101],{},"游戏：Steam",[31,103,104],{},"兼容层：Proton GE",[31,106,107],{},"浏览器：Edge",[31,109,110],{},"聊天：微信 \u002F QQ",{"title":112,"searchDepth":113,"depth":113,"links":114},"",2,[115,116,117,118],{"id":12,"depth":113,"text":12},{"id":45,"depth":113,"text":45},{"id":80,"depth":113,"text":81},{"id":95,"depth":113,"text":96},[120,121],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单","md",{},true,"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":5,"description":124},"posts\u002Fubuntu-26-04-my-setup",[132,133,134],"Ubuntu","Wayland","桌面配置","yZYlhwCbitmtIMFYkRlb5os9JMJpWZH5UyymJQNZyxc",[137,481,1062,1738],{"id":138,"title":139,"body":140,"categories":472,"cover":473,"date":474,"description":475,"extension":125,"meta":476,"navigation":127,"path":477,"seo":478,"stem":479,"tags":472,"__hash__":480},"posts\u002Fposts\u002Fbpe-tokenization-algorithm.md","BPE 分词算法原理讲解：大模型背后的词表构建基石",{"type":7,"value":141,"toc":463},[142,146,149,170,184,191,194,198,204,207,212,219,245,258,294,313,348,351,353,356,359,365,371,406,420,422,426,429,435,446,449],[10,143,145],{"id":144},"词表危机llm-如何认识世界","词表危机：LLM 如何认识世界？",[14,147,148],{},"在把人类语言喂给 Transformer 等深度学习模型之前，我们必须先将其切分成离散的“词元”（Token）。这个切分过程往往面临两难：",[14,150,151,152,156,157,161,162,165,166,169],{},"如果",[153,154,155],"strong",{},"按词切分（Word-level）","，比如把 ",[158,159,160],"code",{},"machine learning"," 变成 ",[158,163,164],{},"[machine, learning]","，随着语料丰富，词汇表会膨胀到天文数字大小。而且在遇到网络造词、罕见拼写变形时，模型只能用 ",[158,167,168],{},"\u003CUNK>"," (未知) 符号糊弄过去，丢失极大的信息。",[14,171,172,173,176,177,180,181,183],{},"如果退而求其次",[153,174,175],{},"按字符切分（Character-level）","，比如拆成 ",[158,178,179],{},"[m, a, c, h, i, n, e, ...]","，虽然词表变小了且没有 ",[158,182,168],{}," 问题，但每个句子的序列长度会暴增。这直接会导致 Transformer 昂贵的注意力机制算力爆炸，且单个字母也很难承载复杂的语义。",[14,185,186,187,190],{},"那么，有没有一种两全其美的办法，既能把常见词当成整体处理，又能把生僻词拆成合理的词根？",[153,188,189],{},"BPE（字节对编码）"," 应运而生。",[192,193],"hr",{},[10,195,197],{"id":196},"bpe-是如何炼成的","BPE 是如何炼成的？",[14,199,200,201],{},"BPE（Byte Pair Encoding）原本是用于数据压缩的古老算法。其核心思路非常纯粹：",[153,202,203],{},"将文本中最高频出现的相邻符号对，合并成一个新的大符号。",[14,205,206],{},"通过在语料库上持续进行“频率统计 $\\to$ 贪心合并”，模型可以自动学出一套包含不同粒度的子词（Subword）词表。",[208,209,211],"h3",{"id":210},"模拟训练构造一个迷你词表","模拟训练：构造一个迷你词表",[14,213,214,215,218],{},"假设我们手头只有以下 4 个单词及其词频，为了清楚边界，我们给每个词结尾加一个特殊标记 ",[158,216,217],{},"\u003C\u002Fw>","：",[28,220,221,227,233,239],{},[31,222,223,226],{},[158,224,225],{},"low\u003C\u002Fw>"," （出现 5 次）",[31,228,229,232],{},[158,230,231],{},"lower\u003C\u002Fw>"," （出现 2 次）",[31,234,235,238],{},[158,236,237],{},"newest\u003C\u002Fw>"," （出现 6 次）",[31,240,241,244],{},[158,242,243],{},"widest\u003C\u002Fw>"," （出现 3 次）",[14,246,247,250,253,254,257],{},[153,248,249],{},"Step 1：拆成原子字符",[251,252],"br",{},"\n一开始，我们把所有词打碎，此时的基础词表只有拆开的单字符：",[158,255,256],{},"l, o, w, e, r, n, s, t, i, d, \u003C\u002Fw>","。",[14,259,260,263,265,266,269,270,273,274,277,278,281,282,285,286,289,290,293],{},[153,261,262],{},"Step 2：寻找最高频组合",[251,264],{},"\n扫描这批打碎的语料，统计相邻两两字符的出现频率。\n我们注意到 ",[158,267,268],{},"(e, s)"," 相邻的频率非常高：在 ",[158,271,272],{},"newest"," 中出现了 6 次，在 ",[158,275,276],{},"widest"," 中出现了 3 次，总计 ",[153,279,280],{},"9次","。\n由于它是最高频对，我们将 ",[158,283,284],{},"e"," 和 ",[158,287,288],{},"s"," 合并为新词元 ",[158,291,292],{},"es","，并将其郑重写入我们的词汇表中。",[14,295,296,299,301,302,305,306,309,310,257],{},[153,297,298],{},"Step 3：不断迭代",[251,300],{},"\n此时数据变成了 ",[158,303,304],{},"n e w es t \u003C\u002Fw>"," 等。我们继续扫描，发现 ",[158,307,308],{},"(es, t)"," 又紧挨着出现了 9 次。\n继续合并：我们得到新词元 ",[158,311,312],{},"est",[14,314,315,316,319,320,323,324,327,328,285,331,334,335,338,339,285,341,344,345,257],{},"之后 ",[158,317,318],{},"(est, \u003C\u002Fw>)"," 会被合并为 ",[158,321,322],{},"est\u003C\u002Fw>","，因为英文里 ",[158,325,326],{},"-est"," 作为后缀经常出现在词尾。再往后，",[158,329,330],{},"l",[158,332,333],{},"o"," 会合并为 ",[158,336,337],{},"lo","，接着 ",[158,340,337],{},[158,342,343],{},"w"," 合并为 ",[158,346,347],{},"low",[14,349,350],{},"只要我们将这个循环跑下去，设定一个目标词表大小（比如 32,000 或 64,000），算法就会在拼满后自动停止。最终生成的词汇库里，既有基础的单字符，也会包含大量高频的前缀、后缀和常用单词。",[192,352],{},[10,354,355],{"id":355},"推理阶段的切词艺术",[14,357,358],{},"词表炼成之后，对于任意一段全新的用户输入，BPE 是如何进行拆解的呢？",[14,360,361,362],{},"规则其实是死板而严格的：",[153,363,364],{},"绝对服从训练时生成的合并记录，依次尝试将字符组合起来。",[14,366,367,368,257],{},"举个例子，用户输入了一个模型从未在训练语料里见过的生造词 ",[158,369,370],{},"lowest",[372,373,374,380,394],"ol",{},[31,375,376,377],{},"BPE 先把它切得粉碎：",[158,378,379],{},"l o w e s t \u003C\u002Fw>",[31,381,382,383,385,386,388,389,385,391,393],{},"根据训练时学到的优先级，首先套用 ",[158,384,268],{}," $\\to$ ",[158,387,292],{}," 的规则，接着套用 ",[158,390,308],{},[158,392,312],{}," 的规则。",[31,395,396,397,285,400,403,404,257],{},"前半部分套用 ",[158,398,399],{},"(l, o)",[158,401,402],{},"(lo, w)"," 的规则，得到 ",[158,405,347],{},[14,407,408,409,411,412,285,414,416,417,419],{},"奇迹发生了——新造词 ",[158,410,370],{}," 被切成了 ",[158,413,347],{},[158,415,312],{}," 两个 Subword。模型虽然没背过这个词，但顺理成章地理解了这是“低”的“最高级”，不仅完全避免了抛出 ",[158,418,168],{}," 的尴尬，还精准洞察了它的词根逻辑。",[192,421],{},[10,423,425],{"id":424},"进化版bbpebyte-level-bpe","进化版：BBPE（Byte-Level BPE）",[14,427,428],{},"传统的 BPE 一般建立在 Unicode 字符上。然而，世界上的语言、符号极度繁杂，各种稀奇古怪的 emoji 层出不穷，光是把单字符穷举出来就已经是一个庞大的基座了。",[14,430,431,432],{},"后来，OpenAI 在设计 GPT-2 时另辟蹊径：",[153,433,434],{},"任何文本，在计算机底层不全是由 UTF-8 编码的字节（Byte）拼接而成的吗？",[14,436,437,438,441,442,445],{},"既然 1 个字节只有 256 种可能的取值，那就直接把这 ",[153,439,440],{},"256 个基础字节","作为最底层的原子字符！这就诞生了更加通用的 ",[153,443,444],{},"BBPE","（Byte-Level BPE）。",[14,447,448],{},"在这种架构下：",[28,450,451,457],{},[31,452,453,456],{},[153,454,455],{},"永远告别 OOV（未登录词）","：哪怕遇到一段乱码或者罕见的外星文，最后也一定兜底退化成这 256 种字节基础单元的拼接。",[31,458,459,462],{},[153,460,461],{},"词表空间极大释放","：把原本因为处理各国冷门文字而浪费的槽位省出来，让词表更加紧凑纯粹。现代绝大多数万亿参数的巨兽模型，都在沿用这项革命性的改进设计。",{"title":112,"searchDepth":113,"depth":113,"links":464},[465,466,470,471],{"id":144,"depth":113,"text":145},{"id":196,"depth":113,"text":197,"children":467},[468],{"id":210,"depth":469,"text":211},3,{"id":355,"depth":113,"text":355},{"id":424,"depth":113,"text":425},null,"\u002Fimg\u002Fpostcard4.jpg","2026-05-19","深入 Byte Pair Encoding (BPE) 的工作流程，理解从字符到子词的合并机制，探讨它为何成为现代 LLM 的标配",{},"\u002Fposts\u002Fbpe-tokenization-algorithm",{"title":139,"description":475},"posts\u002Fbpe-tokenization-algorithm","9zCuC2wb6rMfJiMOWGrAIjJ9BmpdIxbHF1vYD1t29oM",{"id":482,"title":483,"body":484,"categories":472,"cover":1054,"date":1055,"description":1056,"extension":125,"meta":1057,"navigation":127,"path":1058,"seo":1059,"stem":1060,"tags":472,"__hash__":1061},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":485,"toc":1030},[486,490,493,497,500,507,510,521,523,527,534,624,628,635,639,654,656,659,663,674,683,694,698,704,710,729,733,736,740,749,751,754,758,764,778,782,788,805,808,888,891,897,920,992,995,998,1009,1012,1014,1017,1020,1026],[10,487,489],{"id":488},"为什么要离开-hexo","为什么要离开 Hexo？",[14,491,492],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[208,494,496],{"id":495},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[14,498,499],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[14,501,502,503,506],{},"问题根源在于：",[153,504,505],{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[208,508,509],{"id":509},"构建速度与生态",[14,511,512,513,516,517,520],{},"文章数量上来之后，",[158,514,515],{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[153,518,519],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[192,522],{},[10,524,526],{"id":525},"为什么选-nuxt","为什么选 Nuxt？",[14,528,529,530,533],{},"看过 VitePress、Astro、Next.js，最终选了 ",[153,531,532],{},"Nuxt 4 SSG","。核心考量：",[535,536,537,552],"table",{},[538,539,540],"thead",{},[541,542,543,546,549],"tr",{},[544,545],"th",{},[544,547,548],{},"Hexo",[544,550,551],{},"Nuxt 4",[553,554,555,569,582,595,608],"tbody",{},[541,556,557,563,566],{},[558,559,560],"td",{},[153,561,562],{},"构建机制",[558,564,565],{},"CLI 全量生成静态文件",[558,567,568],{},"Nitro 引擎预渲染 + 增量构建",[541,570,571,576,579],{},[558,572,573],{},[153,574,575],{},"模板\u002F组件",[558,577,578],{},"EJS\u002FPug，无组件化",[558,580,581],{},"Vue 3 组件，自动导入",[541,583,584,589,592],{},[558,585,586],{},[153,587,588],{},"内容管理",[558,590,591],{},"front-matter + markdown",[558,593,594],{},"@nuxt\u002Fcontent v3，类型安全查询",[541,596,597,602,605],{},[558,598,599],{},[153,600,601],{},"交互",[558,603,604],{},"内联 script，靠 CDN",[558,606,607],{},"完整的 Vue 响应式生态",[541,609,610,615,621],{},[558,611,612],{},[153,613,614],{},"路由",[558,616,617,620],{},[158,618,619],{},"_config.yml"," permalink 配置",[558,622,623],{},"文件系统路由，动态参数",[208,625,627],{"id":626},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[14,629,630,631,634],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[153,632,633],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[208,636,638],{"id":637},"vue-生态的开发体验","Vue 生态的开发体验",[14,640,641,642,645,646,649,650,653],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[158,643,644],{},"useAsyncData"," + ",[158,647,648],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[158,651,652],{},"\u003Cscript>"," 标签。",[192,655],{},[10,657,658],{"id":658},"迁移过程",[208,660,662],{"id":661},"内容层零改动搬过来","内容层：零改动搬过来",[14,664,665,666,669,670,673],{},"所有 markdown 文件从 Hexo 的 ",[158,667,668],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[158,671,672],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[675,676,681],"pre",{"className":677,"code":679,"language":680},[678],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[158,682,679],{"__ignoreMap":112},[14,684,685,686,689,690,693],{},"多了 ",[158,687,688],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[158,691,692],{},"tags","。内容正文一个字没改。",[208,695,697],{"id":696},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[14,699,700,701,703],{},"Hexo 的 URL 靠 ",[158,702,619],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[675,705,708],{"className":706,"code":707,"language":680},[678],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[158,709,707],{"__ignoreMap":112},[14,711,712,713,716,717,720,721,724,725,728],{},"Nuxt 路由由 ",[158,714,715],{},"pages\u002F"," 目录结构决定，",[158,718,719],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[158,722,723],{},"trailingSlash: true"," 保证 URL 一致性，",[158,726,727],{},"[...slug].vue"," 兜底 404。",[208,730,732],{"id":731},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[14,734,735],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[208,737,739],{"id":738},"部署ci-保持不变","部署：CI 保持不变",[14,741,742,743,745,746,257],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[158,744,515],{}," 替换为 ",[158,747,748],{},"npm run build",[192,750],{},[10,752,753],{"id":753},"架构对比",[208,755,757],{"id":756},"hexo-的架构","Hexo 的架构",[675,759,762],{"className":760,"code":761,"language":680},[678],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[158,763,761],{"__ignoreMap":112},[14,765,766,767,770,771,773,774,777],{},"Hexo 是",[153,768,769],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[158,772,619],{},"、",[158,775,776],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[208,779,781],{"id":780},"nuxt-的架构","Nuxt 的架构",[675,783,786],{"className":784,"code":785,"language":680},[678],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[158,787,785],{"__ignoreMap":112},[14,789,790,791,794,795,797,798,800,801,804],{},"Nuxt 是",[153,792,793],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[158,796,648],{}," 查询内容，",[158,799,644],{}," 管理异步数据，",[158,802,803],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[208,806,807],{"id":807},"数据流对比",[535,809,810,822],{},[538,811,812],{},[541,813,814,817,819],{},[544,815,816],{},"环节",[544,818,548],{},[544,820,821],{},"Nuxt",[553,823,824,837,850,866,877],{},[541,825,826,829,832],{},[558,827,828],{},"内容获取",[558,830,831],{},"读文件 → 模板注入变量",[558,833,834],{},[158,835,836],{},"queryCollection('posts').all()",[541,838,839,842,845],{},[558,840,841],{},"数据管理",[558,843,844],{},"无，模板即数据",[558,846,847,849],{},[158,848,644],{}," + 响应式",[541,851,852,855,860],{},[558,853,854],{},"站点配置",[558,856,857,859],{},[158,858,619],{}," + 主题 config",[558,861,862,865],{},[158,863,864],{},"useSite()"," composable",[541,867,868,871,874],{},[558,869,870],{},"主题",[558,872,873],{},"Stylus 变量 → 编译到 CSS",[558,875,876],{},"CSS 自定义属性 → 运行时切换",[541,878,879,882,885],{},[558,880,881],{},"交互状态",[558,883,884],{},"全局变量 + DOM 操作",[558,886,887],{},"Vue 响应式 + composables",[208,889,890],{"id":890},"预渲染策略",[14,892,893,894,896],{},"Hexo 每次 ",[158,895,515],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[14,898,899,900,903,904,907,908,911,912,915,916,919],{},"Nitro 的 ",[158,901,902],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[158,905,906],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[153,909,910],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[158,913,914],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[158,917,918],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[675,921,925],{"className":922,"code":923,"language":924,"meta":112,"style":112},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[158,926,927,940,955,986],{"__ignoreMap":112},[928,929,932,936],"span",{"class":930,"line":931},"line",1,[928,933,935],{"class":934},"sVyAn","prerender",[928,937,939],{"class":938},"sn6KH",": {\n",[928,941,942,945,948,952],{"class":930,"line":113},[928,943,944],{"class":934},"  crawlLinks",[928,946,947],{"class":938},": ",[928,949,951],{"class":950},"sVC51","true",[928,953,954],{"class":938},",\n",[928,956,957,960,963,967,970,973,975,978,980,983],{"class":930,"line":469},[928,958,959],{"class":934},"  routes",[928,961,962],{"class":938},": [",[928,964,966],{"class":965},"subq3","'\u002F'",[928,968,969],{"class":938},", ",[928,971,972],{"class":965},"'\u002Fabout'",[928,974,969],{"class":938},[928,976,977],{"class":965},"'\u002Fposts'",[928,979,969],{"class":938},[928,981,982],{"class":965},"'\u002Flinks'",[928,984,985],{"class":938},"],\n",[928,987,989],{"class":930,"line":988},4,[928,990,991],{"class":938},"}\n",[10,993,994],{"id":994},"迁移成本远低于预期",[14,996,997],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[372,999,1000,1003,1006],{},[31,1001,1002],{},"搭建 Nuxt 项目骨架",[31,1004,1005],{},"设计 CSS token 系统",[31,1007,1008],{},"编写几个核心组件",[14,1010,1011],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[192,1013],{},[10,1015,1016],{"id":1016},"总结",[14,1018,1019],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[14,1021,1022,1025],{},[153,1023,1024],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[1027,1028,1029],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":112,"searchDepth":113,"depth":113,"links":1031},[1032,1036,1040,1046,1052,1053],{"id":488,"depth":113,"text":489,"children":1033},[1034,1035],{"id":495,"depth":469,"text":496},{"id":509,"depth":469,"text":509},{"id":525,"depth":113,"text":526,"children":1037},[1038,1039],{"id":626,"depth":469,"text":627},{"id":637,"depth":469,"text":638},{"id":658,"depth":113,"text":658,"children":1041},[1042,1043,1044,1045],{"id":661,"depth":469,"text":662},{"id":696,"depth":469,"text":697},{"id":731,"depth":469,"text":732},{"id":738,"depth":469,"text":739},{"id":753,"depth":113,"text":753,"children":1047},[1048,1049,1050,1051],{"id":756,"depth":469,"text":757},{"id":780,"depth":469,"text":781},{"id":807,"depth":469,"text":807},{"id":890,"depth":469,"text":890},{"id":994,"depth":113,"text":994},{"id":1016,"depth":113,"text":1016},"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":483,"description":1056},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",{"id":1063,"title":1064,"body":1065,"categories":472,"cover":1731,"date":474,"description":1732,"extension":125,"meta":1733,"navigation":127,"path":1734,"seo":1735,"stem":1736,"tags":472,"__hash__":1737},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":7,"value":1066,"toc":1711},[1067,1071,1077,1080,1085,1099,1106,1113,1115,1119,1128,1131,1139,1142,1145,1171,1173,1176,1179,1182,1199,1202,1204,1208,1211,1265,1268,1271,1277,1279,1283,1289,1293,1296,1299,1302,1305,1309,1312,1315,1321,1324,1328,1331,1334,1339,1343,1466,1469,1471,1475,1478,1482,1485,1488,1491,1499,1503,1506,1598,1601,1605,1608,1611,1614,1616,1620,1623,1666,1669,1674,1676,1679,1705],[10,1068,1070],{"id":1069},"前置知识什么是哈希hash算法","前置知识：什么是哈希（Hash）算法？",[14,1072,1073,1074,257],{},"在深入 LSH 之前，我们需要先理解基础的",[153,1075,1076],{},"哈希算法",[14,1078,1079],{},"简单来说，哈希函数（Hash Function）就像是一个“数字指纹生成器”。它接收任意长度的数据（如一段文本、一篇文档），并将其映射为一个固定长度的较短字符串或数值（即哈希值或签名）。",[14,1081,1082],{},[153,1083,1084],{},"传统哈希算法（如 MD5、SHA-256）的核心特征是：",[372,1086,1087,1093],{},[31,1088,1089,1092],{},[153,1090,1091],{},"唯一性与确定性","：绝对相同的输入，一定会得到完全相同的哈希值。",[31,1094,1095,1098],{},[153,1096,1097],{},"雪崩效应","：输入数据哪怕仅仅改变了一个标点符号，输出的哈希值也会变得面目全非、毫无规律。这在密码学中非常重要，能用来保证数据未被篡改。",[14,1100,1101,1102,1105],{},"然而，传统哈希的“雪崩效应”在",[153,1103,1104],{},"相似度检索","任务中反而成为了阻碍。如果我们想通过比对哈希值来判断两篇文章是否相似，传统哈希算法完全无能为力——因为两篇高度相似但不完全相同的文章，它们的哈希值是截然不同且没有任何关联的。",[14,1107,1108,1109,1112],{},"这也恰恰引出了本文的主角——",[153,1110,1111],{},"LSH（局部敏感哈希）","。它一反常态，特意设计出了一种**“让越相似的数据，越容易产生相同的哈希值（即越容易发生碰撞）”**的过滤机制。",[192,1114],{},[10,1116,1118],{"id":1117},"算法背景lsh解决了什么痛点","算法背景：LSH解决了什么痛点？",[14,1120,1121,1122,257,1125,1127],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[153,1123,1124],{},"计算代价是否可接受",[251,1126],{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[14,1129,1130],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[28,1132,1133,1136],{},[31,1134,1135],{},"使高相似对象以较高概率落入同一桶（进入候选集）",[31,1137,1138],{},"使低相似对象以较高概率在早期被过滤",[14,1140,1141],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[208,1143,1144],{"id":1144},"常见应用领域",[372,1146,1147,1153,1159,1165],{},[31,1148,1149,1152],{},[153,1150,1151],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[31,1154,1155,1158],{},[153,1156,1157],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[31,1160,1161,1164],{},[153,1162,1163],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[31,1166,1167,1170],{},[153,1168,1169],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[192,1172],{},[10,1174,1175],{"id":1175},"示例文本集合",[14,1177,1178],{},"设文档集合：",[14,1180,1181],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[28,1183,1184,1187,1190,1193,1196],{},[31,1185,1186],{},"$d_1=\\text{“今天北京天气很好”}$",[31,1188,1189],{},"$d_2=\\text{“今天北京天气真好”}$",[31,1191,1192],{},"$d_3=\\text{“昨天上海天气很差”}$",[31,1194,1195],{},"$d_4=\\text{“今天北京天气挺好”}$",[31,1197,1198],{},"$d_5=\\text{“深度学习推荐系统”}$",[14,1200,1201],{},"直观上，$d_1$、$d_2$ 和 $d_4$ 句式高度相似（仅一字之差），而 $d_3$、$d_5$ 语义或结构上有显著差异。",[192,1203],{},[10,1205,1207],{"id":1206},"shingling文本-q-gram集合","Shingling（文本 → q-gram集合）",[14,1209,1210],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[535,1212,1213,1223],{},[538,1214,1215],{},[541,1216,1217,1220],{},[544,1218,1219],{},"文本",[544,1221,1222],{},"3-gram集合",[553,1224,1225,1233,1241,1249,1257],{},[541,1226,1227,1230],{},[558,1228,1229],{},"d1",[558,1231,1232],{},"{今天北, 天北京, 北京天, 京天气, 天气很, 气很好}",[541,1234,1235,1238],{},[558,1236,1237],{},"d2",[558,1239,1240],{},"{今天北, 天北京, 北京天, 京天气, 天气真, 气真好}",[541,1242,1243,1246],{},[558,1244,1245],{},"d3",[558,1247,1248],{},"{昨天上, 天上海, 上海天, 海天气, 天气很, 气很差}",[541,1250,1251,1254],{},[558,1252,1253],{},"d4",[558,1255,1256],{},"{今天北, 天北京, 北京天, 京天气, 天气挺, 气挺好}",[541,1258,1259,1262],{},[558,1260,1261],{},"d5",[558,1263,1264],{},"{深度学, 度学习, 学习推, 习推荐, 推荐系, 荐系统}",[14,1266,1267],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[14,1269,1270],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[1272,1273,1274],"blockquote",{},[14,1275,1276],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[192,1278],{},[10,1280,1282],{"id":1281},"minhash集合-签名向量","MinHash（集合 → 签名向量）",[14,1284,1285,1288],{},[153,1286,1287],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[208,1290,1292],{"id":1291},"_31-构造方式","3.1 构造方式",[14,1294,1295],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[14,1297,1298],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[14,1300,1301],{},"于是签名向量为：",[14,1303,1304],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[208,1306,1308],{"id":1307},"_32-为什么可行","3.2 为什么可行",[14,1310,1311],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[14,1313,1314],{},"$$\nP(m_h(A)=m_h(B)) = J(A,B)\n$$",[14,1316,1317,1320],{},[153,1318,1319],{},"简要证明","：\n哈希函数 $h$ 相当于对全集元素做了一次随机排列。考察两集合的并集 $A \\cup B$ 中的所有元素：\n要使 $m_h(A) = m_h(B)$，意味着 $A \\cup B$ 中经过哈希映射后值最小（即排在“最前面”）的那个元素，必须既属于 $A$ 也属于 $B$，也就是说必须属于交集 $A \\cap B$。\n因为哈希是完全随机的，$A \\cup B$ 中的每一个元素成为最小值的概率是完全相等的。所以这个最小元素正好属于交集 $A \\cap B$ 的概率，就是交集元素个数占并集元素个数的比例，即 $\\frac{|A \\cap B|}{|A \\cup B|} = J(A,B)$。",[14,1322,1323],{},"用 $k$ 个哈希后，可得无偏估计量：",[1325,1326,1327],"div",{"v-pre":112},"\n$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_{i=1}^{k} I[m_i(A)=m_i(B)]\n$$\n",[14,1329,1330],{},"方差为：",[14,1332,1333],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[1272,1335,1336],{},[14,1337,1338],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[208,1340,1342],{"id":1341},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[535,1344,1345,1367],{},[538,1346,1347],{},[541,1348,1349,1351,1354,1356,1358,1361,1364],{},[544,1350,1219],{},[544,1352,1353],{},"h1",[544,1355,10],{},[544,1357,208],{},[544,1359,1360],{},"h4",[544,1362,1363],{},"h5",[544,1365,1366],{},"h6",[553,1368,1369,1391,1408,1429,1445],{},[541,1370,1371,1373,1376,1379,1382,1385,1388],{},[558,1372,1229],{},[558,1374,1375],{},"12",[558,1377,1378],{},"7",[558,1380,1381],{},"5",[558,1383,1384],{},"20",[558,1386,1387],{},"11",[558,1389,1390],{},"3",[541,1392,1393,1395,1397,1399,1402,1404,1406],{},[558,1394,1237],{},[558,1396,1375],{},[558,1398,1378],{},[558,1400,1401],{},"6",[558,1403,1384],{},[558,1405,1387],{},[558,1407,1390],{},[541,1409,1410,1412,1415,1418,1421,1424,1426],{},[558,1411,1245],{},[558,1413,1414],{},"2",[558,1416,1417],{},"15",[558,1419,1420],{},"8",[558,1422,1423],{},"19",[558,1425,1378],{},[558,1427,1428],{},"4",[541,1430,1431,1433,1435,1437,1439,1441,1443],{},[558,1432,1253],{},[558,1434,1375],{},[558,1436,1378],{},[558,1438,1381],{},[558,1440,1423],{},[558,1442,1417],{},[558,1444,1420],{},[541,1446,1447,1449,1452,1455,1458,1461,1464],{},[558,1448,1261],{},[558,1450,1451],{},"30",[558,1453,1454],{},"14",[558,1456,1457],{},"22",[558,1459,1460],{},"33",[558,1462,1463],{},"28",[558,1465,1381],{},[14,1467,1468],{},"可以看出：$d_1$ 与 $d_4$ 在前三个哈希函数取值一致，而与 $d_2$ 在后三个哈希函数取值一致，这反映了它们较高的相似度。",[192,1470],{},[10,1472,1474],{"id":1473},"lsh-banding签名矩阵-候选对","LSH Banding（签名矩阵 → 候选对）",[14,1476,1477],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[208,1479,1481],{"id":1480},"_41-切分规则","4.1 切分规则",[14,1483,1484],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[14,1486,1487],{},"$$\nk=b\\cdot r\n$$",[14,1489,1490],{},"例如：$k=6,b=2,r=3$。",[28,1492,1493,1496],{},[31,1494,1495],{},"Band 1: $(h_1,h_2,h_3)$",[31,1497,1498],{},"Band 2: $(h_4,h_5,h_6)$",[208,1500,1502],{"id":1501},"_42-候选判定","4.2 候选判定",[14,1504,1505],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[535,1507,1508,1521],{},[538,1509,1510],{},[541,1511,1512,1515,1518],{},[544,1513,1514],{},"Band",[544,1516,1517],{},"桶",[544,1519,1520],{},"文档",[553,1522,1523,1534,1543,1552,1561,1571,1580,1589],{},[541,1524,1525,1528,1531],{},[558,1526,1527],{},"1",[558,1529,1530],{},"B1-1",[558,1532,1533],{},"d1, d4",[541,1535,1536,1538,1541],{},[558,1537,1527],{},[558,1539,1540],{},"B1-2",[558,1542,1237],{},[541,1544,1545,1547,1550],{},[558,1546,1527],{},[558,1548,1549],{},"B1-3",[558,1551,1245],{},[541,1553,1554,1556,1559],{},[558,1555,1527],{},[558,1557,1558],{},"B1-4",[558,1560,1261],{},[541,1562,1563,1565,1568],{},[558,1564,1414],{},[558,1566,1567],{},"B2-1",[558,1569,1570],{},"d1, d2",[541,1572,1573,1575,1578],{},[558,1574,1414],{},[558,1576,1577],{},"B2-3",[558,1579,1245],{},[541,1581,1582,1584,1587],{},[558,1583,1414],{},[558,1585,1586],{},"B2-4",[558,1588,1253],{},[541,1590,1591,1593,1596],{},[558,1592,1414],{},[558,1594,1595],{},"B2-5",[558,1597,1261],{},[14,1599,1600],{},"在这里，$d_1,d_4$ 在 Band 1 碰撞、$d_1,d_2$ 在 Band 2 碰撞，它们都会被成功召回送入下一阶段。",[208,1602,1604],{"id":1603},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[14,1606,1607],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[14,1609,1610],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[14,1612,1613],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[192,1615],{},[10,1617,1619],{"id":1618},"精确验证候选对-最终结果","精确验证（候选对 → 最终结果）",[14,1621,1622],{},"对候选集合中的文档对再计算真实 Jaccard：",[535,1624,1625,1641],{},[538,1626,1627],{},[541,1628,1629,1632,1635,1638],{},[544,1630,1631],{},"文本对",[544,1633,1634],{},"交集大小",[544,1636,1637],{},"并集大小",[544,1639,1640],{},"Jaccard",[553,1642,1643,1655],{},[541,1644,1645,1648,1650,1652],{},[558,1646,1647],{},"d1,d4",[558,1649,1428],{},[558,1651,1420],{},[558,1653,1654],{},"0.5",[541,1656,1657,1660,1662,1664],{},[558,1658,1659],{},"d1,d2",[558,1661,1428],{},[558,1663,1420],{},[558,1665,1654],{},[14,1667,1668],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[1272,1670,1671],{},[14,1672,1673],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[192,1675],{},[10,1677,1678],{"id":1678},"算法直观总结",[372,1680,1681,1687,1693,1699],{},[31,1682,1683,1686],{},[153,1684,1685],{},"Shingling","：把文本变成可比较的集合表示。",[31,1688,1689,1692],{},[153,1690,1691],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[31,1694,1695,1698],{},[153,1696,1697],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[31,1700,1701,1704],{},[153,1702,1703],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[14,1706,1707,1710],{},[153,1708,1709],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":112,"searchDepth":113,"depth":113,"links":1712},[1713,1714,1717,1718,1719,1724,1729,1730],{"id":1069,"depth":113,"text":1070},{"id":1117,"depth":113,"text":1118,"children":1715},[1716],{"id":1144,"depth":469,"text":1144},{"id":1175,"depth":113,"text":1175},{"id":1206,"depth":113,"text":1207},{"id":1281,"depth":113,"text":1282,"children":1720},[1721,1722,1723],{"id":1291,"depth":469,"text":1292},{"id":1307,"depth":469,"text":1308},{"id":1341,"depth":469,"text":1342},{"id":1473,"depth":113,"text":1474,"children":1725},[1726,1727,1728],{"id":1480,"depth":469,"text":1481},{"id":1501,"depth":469,"text":1502},{"id":1603,"depth":469,"text":1604},{"id":1618,"depth":113,"text":1619},{"id":1678,"depth":113,"text":1678},"\u002Fimg\u002Fpostcard3.jpg","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用",{},"\u002Fposts\u002Flsh-minhash-deduplication",{"title":1064,"description":1732},"posts\u002Flsh-minhash-deduplication","oG6H2fNbkQAmzn78pWFC0zQq-y8odaRz5akaYuGwnC8",{"id":4,"title":5,"body":1739,"categories":1813,"cover":122,"date":123,"description":124,"extension":125,"meta":1814,"navigation":127,"path":128,"seo":1815,"stem":130,"tags":1816,"__hash__":135},{"type":7,"value":1740,"toc":1807},[1741,1743,1745,1747,1751,1761,1763,1785,1787,1795,1797],[10,1742,12],{"id":12},[14,1744,16],{},[14,1746,19],{},[14,1748,1749],{},[23,1750],{"alt":25,"src":26},[28,1752,1753,1755,1757,1759],{},[31,1754,33],{},[31,1756,36],{},[31,1758,39],{},[31,1760,42],{},[10,1762,45],{"id":45},[28,1764,1765,1767,1769,1771,1773,1775,1777,1779,1781,1783],{},[31,1766,50],{},[31,1768,53],{},[31,1770,56],{},[31,1772,59],{},[31,1774,62],{},[31,1776,65],{},[31,1778,68],{},[31,1780,71],{},[31,1782,74],{},[