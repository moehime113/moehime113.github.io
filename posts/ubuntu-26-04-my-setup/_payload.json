[{"data":1,"prerenderedAt":1449},["ShallowReactive",2],{"post-ubuntu-26-04-my-setup":3,"all-posts":136},{"id":4,"title":5,"body":6,"categories":119,"cover":122,"date":123,"description":124,"extension":125,"meta":126,"navigation":127,"path":128,"seo":129,"stem":130,"tags":131,"__hash__":135},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":7,"value":8,"toc":111},"minimark",[9,13,17,20,27,43,46,78,82,93,97],[10,11,12],"h2",{"id":12},"我的配置清单",[14,15,16],"p",{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[14,18,19],{},"惯例先附上系统信息：",[14,21,22],{},[23,24],"img",{"alt":25,"src":26},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[28,29,30,34,37,40],"ul",{},[31,32,33],"li",{},"OS：Ubuntu 26.04 LTS",[31,35,36],{},"Kernel：Linux 7.0.0-15-generic",[31,38,39],{},"CPU：Intel Core i7-14700H",[31,41,42],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[10,44,45],{"id":45},"系统与桌面环境",[28,47,48,51,54,57,60,63,66,69,72,75],{},[31,49,50],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[31,52,53],{},"桌面协议：Wayland",[31,55,56],{},"窗口管理：Mutter",[31,58,59],{},"Shell：zsh 5.9",[31,61,62],{},"终端：Ghostty",[31,64,65],{},"输入法：Fcitx5（小鹤音形）",[31,67,68],{},"主题：Orchis-dark",[31,70,71],{},"壁纸：Variety",[31,73,74],{},"截图：Flameshot",[31,76,77],{},"VPN：v2rayN（Linux 版本）",[10,79,81],{"id":80},"工作-学习","工作 \u002F 学习",[28,83,84,87,90],{},[31,85,86],{},"办公：WPS",[31,88,89],{},"编辑器：VS Code",[31,91,92],{},"AI 工具管理：CCSwitch（ccswitch）",[10,94,96],{"id":95},"生活-游戏","生活 \u002F 游戏",[28,98,99,102,105,108],{},[31,100,101],{},"游戏：Steam",[31,103,104],{},"兼容层：Proton GE",[31,106,107],{},"浏览器：Edge",[31,109,110],{},"聊天：微信 \u002F QQ",{"title":112,"searchDepth":113,"depth":113,"links":114},"",2,[115,116,117,118],{"id":12,"depth":113,"text":12},{"id":45,"depth":113,"text":45},{"id":80,"depth":113,"text":81},{"id":95,"depth":113,"text":96},[120,121],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单","md",{},true,"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":5,"description":124},"posts\u002Fubuntu-26-04-my-setup",[132,133,134],"Ubuntu","Wayland","桌面配置","yZYlhwCbitmtIMFYkRlb5os9JMJpWZH5UyymJQNZyxc",[137,726,1370],{"id":138,"title":139,"body":140,"categories":717,"cover":718,"date":719,"description":720,"extension":125,"meta":721,"navigation":127,"path":722,"seo":723,"stem":724,"tags":717,"__hash__":725},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":141,"toc":693},[142,146,149,154,157,165,168,180,183,187,194,284,288,295,299,314,316,319,323,334,343,354,358,364,370,389,393,396,400,410,412,415,419,425,439,443,449,466,469,549,552,558,581,654,657,660,672,675,677,680,683,689],[10,143,145],{"id":144},"为什么要离开-hexo","为什么要离开 Hexo？",[14,147,148],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[150,151,153],"h3",{"id":152},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[14,155,156],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[14,158,159,160,164],{},"问题根源在于：",[161,162,163],"strong",{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[150,166,167],{"id":167},"构建速度与生态",[14,169,170,171,175,176,179],{},"文章数量上来之后，",[172,173,174],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[161,177,178],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[181,182],"hr",{},[10,184,186],{"id":185},"为什么选-nuxt","为什么选 Nuxt？",[14,188,189,190,193],{},"看过 VitePress、Astro、Next.js，最终选了 ",[161,191,192],{},"Nuxt 4 SSG","。核心考量：",[195,196,197,212],"table",{},[198,199,200],"thead",{},[201,202,203,206,209],"tr",{},[204,205],"th",{},[204,207,208],{},"Hexo",[204,210,211],{},"Nuxt 4",[213,214,215,229,242,255,268],"tbody",{},[201,216,217,223,226],{},[218,219,220],"td",{},[161,221,222],{},"构建机制",[218,224,225],{},"CLI 全量生成静态文件",[218,227,228],{},"Nitro 引擎预渲染 + 增量构建",[201,230,231,236,239],{},[218,232,233],{},[161,234,235],{},"模板\u002F组件",[218,237,238],{},"EJS\u002FPug，无组件化",[218,240,241],{},"Vue 3 组件，自动导入",[201,243,244,249,252],{},[218,245,246],{},[161,247,248],{},"内容管理",[218,250,251],{},"front-matter + markdown",[218,253,254],{},"@nuxt\u002Fcontent v3，类型安全查询",[201,256,257,262,265],{},[218,258,259],{},[161,260,261],{},"交互",[218,263,264],{},"内联 script，靠 CDN",[218,266,267],{},"完整的 Vue 响应式生态",[201,269,270,275,281],{},[218,271,272],{},[161,273,274],{},"路由",[218,276,277,280],{},[172,278,279],{},"_config.yml"," permalink 配置",[218,282,283],{},"文件系统路由，动态参数",[150,285,287],{"id":286},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[14,289,290,291,294],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[161,292,293],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[150,296,298],{"id":297},"vue-生态的开发体验","Vue 生态的开发体验",[14,300,301,302,305,306,309,310,313],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[172,303,304],{},"useAsyncData"," + ",[172,307,308],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[172,311,312],{},"\u003Cscript>"," 标签。",[181,315],{},[10,317,318],{"id":318},"迁移过程",[150,320,322],{"id":321},"内容层零改动搬过来","内容层：零改动搬过来",[14,324,325,326,329,330,333],{},"所有 markdown 文件从 Hexo 的 ",[172,327,328],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[172,331,332],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[335,336,341],"pre",{"className":337,"code":339,"language":340},[338],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[172,342,339],{"__ignoreMap":112},[14,344,345,346,349,350,353],{},"多了 ",[172,347,348],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[172,351,352],{},"tags","。内容正文一个字没改。",[150,355,357],{"id":356},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[14,359,360,361,363],{},"Hexo 的 URL 靠 ",[172,362,279],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[335,365,368],{"className":366,"code":367,"language":340},[338],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[172,369,367],{"__ignoreMap":112},[14,371,372,373,376,377,380,381,384,385,388],{},"Nuxt 路由由 ",[172,374,375],{},"pages\u002F"," 目录结构决定，",[172,378,379],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[172,382,383],{},"trailingSlash: true"," 保证 URL 一致性，",[172,386,387],{},"[...slug].vue"," 兜底 404。",[150,390,392],{"id":391},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[14,394,395],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[150,397,399],{"id":398},"部署ci-保持不变","部署：CI 保持不变",[14,401,402,403,405,406,409],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[172,404,174],{}," 替换为 ",[172,407,408],{},"npm run build","。",[181,411],{},[10,413,414],{"id":414},"架构对比",[150,416,418],{"id":417},"hexo-的架构","Hexo 的架构",[335,420,423],{"className":421,"code":422,"language":340},[338],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[172,424,422],{"__ignoreMap":112},[14,426,427,428,431,432,434,435,438],{},"Hexo 是",[161,429,430],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[172,433,279],{},"、",[172,436,437],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[150,440,442],{"id":441},"nuxt-的架构","Nuxt 的架构",[335,444,447],{"className":445,"code":446,"language":340},[338],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[172,448,446],{"__ignoreMap":112},[14,450,451,452,455,456,458,459,461,462,465],{},"Nuxt 是",[161,453,454],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[172,457,308],{}," 查询内容，",[172,460,304],{}," 管理异步数据，",[172,463,464],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[150,467,468],{"id":468},"数据流对比",[195,470,471,483],{},[198,472,473],{},[201,474,475,478,480],{},[204,476,477],{},"环节",[204,479,208],{},[204,481,482],{},"Nuxt",[213,484,485,498,511,527,538],{},[201,486,487,490,493],{},[218,488,489],{},"内容获取",[218,491,492],{},"读文件 → 模板注入变量",[218,494,495],{},[172,496,497],{},"queryCollection('posts').all()",[201,499,500,503,506],{},[218,501,502],{},"数据管理",[218,504,505],{},"无，模板即数据",[218,507,508,510],{},[172,509,304],{}," + 响应式",[201,512,513,516,521],{},[218,514,515],{},"站点配置",[218,517,518,520],{},[172,519,279],{}," + 主题 config",[218,522,523,526],{},[172,524,525],{},"useSite()"," composable",[201,528,529,532,535],{},[218,530,531],{},"主题",[218,533,534],{},"Stylus 变量 → 编译到 CSS",[218,536,537],{},"CSS 自定义属性 → 运行时切换",[201,539,540,543,546],{},[218,541,542],{},"交互状态",[218,544,545],{},"全局变量 + DOM 操作",[218,547,548],{},"Vue 响应式 + composables",[150,550,551],{"id":551},"预渲染策略",[14,553,554,555,557],{},"Hexo 每次 ",[172,556,174],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[14,559,560,561,564,565,568,569,572,573,576,577,580],{},"Nitro 的 ",[172,562,563],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[172,566,567],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[161,570,571],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[172,574,575],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[172,578,579],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[335,582,586],{"className":583,"code":584,"language":585,"meta":112,"style":112},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[172,587,588,601,616,648],{"__ignoreMap":112},[589,590,593,597],"span",{"class":591,"line":592},"line",1,[589,594,596],{"class":595},"sVyAn","prerender",[589,598,600],{"class":599},"sn6KH",": {\n",[589,602,603,606,609,613],{"class":591,"line":113},[589,604,605],{"class":595},"  crawlLinks",[589,607,608],{"class":599},": ",[589,610,612],{"class":611},"sVC51","true",[589,614,615],{"class":599},",\n",[589,617,619,622,625,629,632,635,637,640,642,645],{"class":591,"line":618},3,[589,620,621],{"class":595},"  routes",[589,623,624],{"class":599},": [",[589,626,628],{"class":627},"subq3","'\u002F'",[589,630,631],{"class":599},", ",[589,633,634],{"class":627},"'\u002Fabout'",[589,636,631],{"class":599},[589,638,639],{"class":627},"'\u002Fposts'",[589,641,631],{"class":599},[589,643,644],{"class":627},"'\u002Flinks'",[589,646,647],{"class":599},"],\n",[589,649,651],{"class":591,"line":650},4,[589,652,653],{"class":599},"}\n",[10,655,656],{"id":656},"迁移成本远低于预期",[14,658,659],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[661,662,663,666,669],"ol",{},[31,664,665],{},"搭建 Nuxt 项目骨架",[31,667,668],{},"设计 CSS token 系统",[31,670,671],{},"编写几个核心组件",[14,673,674],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[181,676],{},[10,678,679],{"id":679},"总结",[14,681,682],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[14,684,685,688],{},[161,686,687],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[690,691,692],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":112,"searchDepth":113,"depth":113,"links":694},[695,699,703,709,715,716],{"id":144,"depth":113,"text":145,"children":696},[697,698],{"id":152,"depth":618,"text":153},{"id":167,"depth":618,"text":167},{"id":185,"depth":113,"text":186,"children":700},[701,702],{"id":286,"depth":618,"text":287},{"id":297,"depth":618,"text":298},{"id":318,"depth":113,"text":318,"children":704},[705,706,707,708],{"id":321,"depth":618,"text":322},{"id":356,"depth":618,"text":357},{"id":391,"depth":618,"text":392},{"id":398,"depth":618,"text":399},{"id":414,"depth":113,"text":414,"children":710},[711,712,713,714],{"id":417,"depth":618,"text":418},{"id":441,"depth":618,"text":442},{"id":468,"depth":618,"text":468},{"id":551,"depth":618,"text":551},{"id":656,"depth":113,"text":656},{"id":679,"depth":113,"text":679},null,"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":139,"description":720},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",{"id":727,"title":728,"body":729,"categories":717,"cover":717,"date":1362,"description":1363,"extension":125,"meta":1364,"navigation":127,"path":1366,"seo":1367,"stem":1368,"tags":717,"__hash__":1369},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":7,"value":730,"toc":1343},[731,736,742,744,748,758,761,769,772,775,801,803,807,810,813,830,833,835,839,842,895,898,901,907,909,913,919,923,926,929,932,935,939,942,949,952,959,962,965,970,974,1097,1100,1102,1106,1109,1113,1116,1119,1122,1130,1134,1137,1228,1231,1235,1238,1241,1244,1246,1250,1253,1297,1300,1305,1307,1311,1337],[732,733,735],"h1",{"id":734},"lsh算法原理讲解","LSH算法原理讲解",[14,737,738,741],{},[161,739,740],{},"目标","：在海量文本中快速发现相似文档，避免 $O(n^2)$ 的全量两两比较。",[181,743],{},[10,745,747],{"id":746},"_0-算法背景lsh解决了什么痛点","0. 算法背景：LSH解决了什么痛点？",[14,749,750,751,409,754,757],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[161,752,753],{},"计算代价是否可接受",[755,756],"br",{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[14,759,760],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[28,762,763,766],{},[31,764,765],{},"使高相似对象以较高概率落入同一桶（进入候选集）",[31,767,768],{},"使低相似对象以较高概率在早期被过滤",[14,770,771],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[150,773,774],{"id":774},"常见应用领域",[661,776,777,783,789,795],{},[31,778,779,782],{},[161,780,781],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[31,784,785,788],{},[161,786,787],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[31,790,791,794],{},[161,792,793],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[31,796,797,800],{},[161,798,799],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[181,802],{},[10,804,806],{"id":805},"_1-示例文本集合","1. 示例文本集合",[14,808,809],{},"设文档集合：",[14,811,812],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[28,814,815,818,821,824,827],{},[31,816,817],{},"$d_1=\\text{“今天天气很好”}$",[31,819,820],{},"$d_2=\\text{“今天天气非常好”}$",[31,822,823],{},"$d_3=\\text{“昨天天气很差”}$",[31,825,826],{},"$d_4=\\text{“今天天气很好”}$",[31,828,829],{},"$d_5=\\text{“机器学习很有趣”}$",[14,831,832],{},"直观上，$d_1$ 与 $d_4$ 完全相同，$d_1$ 与 $d_2$ 高度相似，其余组合的相似度较低。",[181,834],{},[10,836,838],{"id":837},"_2-shingling文本-q-gram集合","2. Shingling（文本 → q-gram集合）",[14,840,841],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[195,843,844,854],{},[198,845,846],{},[201,847,848,851],{},[204,849,850],{},"文本",[204,852,853],{},"3-gram集合",[213,855,856,864,872,880,887],{},[201,857,858,861],{},[218,859,860],{},"d1",[218,862,863],{},"{今天天, 天天气, 天气很, 气很好}",[201,865,866,869],{},[218,867,868],{},"d2",[218,870,871],{},"{今天天, 天天气, 天气非, 气非常, 非常好}",[201,873,874,877],{},[218,875,876],{},"d3",[218,878,879],{},"{昨天天, 天天气, 天气很, 气很差}",[201,881,882,885],{},[218,883,884],{},"d4",[218,886,863],{},[201,888,889,892],{},[218,890,891],{},"d5",[218,893,894],{},"{机器学, 学习很, 习很有, 很有趣}",[14,896,897],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[14,899,900],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[902,903,904],"blockquote",{},[14,905,906],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[181,908],{},[10,910,912],{"id":911},"_3-minhash集合-签名向量","3. MinHash（集合 → 签名向量）",[14,914,915,918],{},[161,916,917],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[150,920,922],{"id":921},"_31-构造方式","3.1 构造方式",[14,924,925],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[14,927,928],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[14,930,931],{},"于是签名向量为：",[14,933,934],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[150,936,938],{"id":937},"_32-为什么可行","3.2 为什么可行",[14,940,941],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[14,943,944,945,948],{},"$$\n\\Pr",[589,946,947],{},"m_h(A)=m_h(B)"," = J(A,B)\n$$",[14,950,951],{},"用 $k$ 个哈希后，可得无偏估计量：",[14,953,954,955,958],{},"$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_^k \\mathbf{1}",[589,956,957],{},"m_(A)=m_(B)","\n$$",[14,960,961],{},"方差为：",[14,963,964],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[902,966,967],{},[14,968,969],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[150,971,973],{"id":972},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[195,975,976,997],{},[198,977,978],{},[201,979,980,982,984,986,988,991,994],{},[204,981,850],{},[204,983,732],{},[204,985,10],{},[204,987,150],{},[204,989,990],{},"h4",[204,992,993],{},"h5",[204,995,996],{},"h6",[213,998,999,1021,1039,1060,1076],{},[201,1000,1001,1003,1006,1009,1012,1015,1018],{},[218,1002,860],{},[218,1004,1005],{},"12",[218,1007,1008],{},"7",[218,1010,1011],{},"5",[218,1013,1014],{},"20",[218,1016,1017],{},"11",[218,1019,1020],{},"3",[201,1022,1023,1025,1027,1029,1032,1035,1037],{},[218,1024,868],{},[218,1026,1005],{},[218,1028,1008],{},[218,1030,1031],{},"6",[218,1033,1034],{},"21",[218,1036,1017],{},[218,1038,1020],{},[201,1040,1041,1043,1046,1049,1052,1055,1057],{},[218,1042,876],{},[218,1044,1045],{},"2",[218,1047,1048],{},"15",[218,1050,1051],{},"8",[218,1053,1054],{},"19",[218,1056,1008],{},[218,1058,1059],{},"4",[201,1061,1062,1064,1066,1068,1070,1072,1074],{},[218,1063,884],{},[218,1065,1005],{},[218,1067,1008],{},[218,1069,1011],{},[218,1071,1014],{},[218,1073,1017],{},[218,1075,1020],{},[201,1077,1078,1080,1083,1086,1089,1092,1095],{},[218,1079,891],{},[218,1081,1082],{},"30",[218,1084,1085],{},"14",[218,1087,1088],{},"22",[218,1090,1091],{},"33",[218,1093,1094],{},"28",[218,1096,1011],{},[14,1098,1099],{},"可以看出：$d_1$ 与 $d_4$ 完全一致，$d_1$ 与 $d_2$ 大部分行一致，符合直觉。",[181,1101],{},[10,1103,1105],{"id":1104},"_4-lsh-banding签名矩阵-候选对","4. LSH Banding（签名矩阵 → 候选对）",[14,1107,1108],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[150,1110,1112],{"id":1111},"_41-切分规则","4.1 切分规则",[14,1114,1115],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[14,1117,1118],{},"$$\nk=b\\cdot r\n$$",[14,1120,1121],{},"例如：$k=6,b=2,r=3$。",[28,1123,1124,1127],{},[31,1125,1126],{},"Band 1: $(h_1,h_2,h_3)$",[31,1128,1129],{},"Band 2: $(h_4,h_5,h_6)$",[150,1131,1133],{"id":1132},"_42-候选判定","4.2 候选判定",[14,1135,1136],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[195,1138,1139,1152],{},[198,1140,1141],{},[201,1142,1143,1146,1149],{},[204,1144,1145],{},"Band",[204,1147,1148],{},"桶",[204,1150,1151],{},"文档",[213,1153,1154,1165,1174,1183,1192,1201,1210,1219],{},[201,1155,1156,1159,1162],{},[218,1157,1158],{},"1",[218,1160,1161],{},"B1-1",[218,1163,1164],{},"d1, d4",[201,1166,1167,1169,1172],{},[218,1168,1158],{},[218,1170,1171],{},"B1-2",[218,1173,868],{},[201,1175,1176,1178,1181],{},[218,1177,1158],{},[218,1179,1180],{},"B1-3",[218,1182,876],{},[201,1184,1185,1187,1190],{},[218,1186,1158],{},[218,1188,1189],{},"B1-4",[218,1191,891],{},[201,1193,1194,1196,1199],{},[218,1195,1045],{},[218,1197,1198],{},"B2-1",[218,1200,1164],{},[201,1202,1203,1205,1208],{},[218,1204,1045],{},[218,1206,1207],{},"B2-2",[218,1209,868],{},[201,1211,1212,1214,1217],{},[218,1213,1045],{},[218,1215,1216],{},"B2-3",[218,1218,876],{},[201,1220,1221,1223,1226],{},[218,1222,1045],{},[218,1224,1225],{},"B2-4",[218,1227,891],{},[14,1229,1230],{},"因此 $d_1,d_4$ 会被稳定召回为候选。",[150,1232,1234],{"id":1233},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[14,1236,1237],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[14,1239,1240],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[14,1242,1243],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[181,1245],{},[10,1247,1249],{"id":1248},"_5-精确验证候选对-最终结果","5. 精确验证（候选对 → 最终结果）",[14,1251,1252],{},"对候选集合中的文档对再计算真实 Jaccard：",[195,1254,1255,1271],{},[198,1256,1257],{},[201,1258,1259,1262,1265,1268],{},[204,1260,1261],{},"文本对",[204,1263,1264],{},"交集大小",[204,1266,1267],{},"并集大小",[204,1269,1270],{},"Jaccard",[213,1272,1273,1285],{},[201,1274,1275,1278,1280,1282],{},[218,1276,1277],{},"d1,d4",[218,1279,1059],{},[218,1281,1059],{},[218,1283,1284],{},"1.0",[201,1286,1287,1290,1292,1294],{},[218,1288,1289],{},"d1,d2",[218,1291,1020],{},[218,1293,1011],{},[218,1295,1296],{},"0.6",[14,1298,1299],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[902,1301,1302],{},[14,1303,1304],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[181,1306],{},[10,1308,1310],{"id":1309},"_6-算法直观总结","6. 算法直观总结",[661,1312,1313,1319,1325,1331],{},[31,1314,1315,1318],{},[161,1316,1317],{},"Shingling","：把文本变成可比较的集合表示。",[31,1320,1321,1324],{},[161,1322,1323],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[31,1326,1327,1330],{},[161,1328,1329],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[31,1332,1333,1336],{},[161,1334,1335],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[14,1338,1339,1342],{},[161,1340,1341],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":112,"searchDepth":113,"depth":113,"links":1344},[1345,1348,1349,1350,1355,1360,1361],{"id":746,"depth":113,"text":747,"children":1346},[1347],{"id":774,"depth":618,"text":774},{"id":805,"depth":113,"text":806},{"id":837,"depth":113,"text":838},{"id":911,"depth":113,"text":912,"children":1351},[1352,1353,1354],{"id":921,"depth":618,"text":922},{"id":937,"depth":618,"text":938},{"id":972,"depth":618,"text":973},{"id":1104,"depth":113,"text":1105,"children":1356},[1357,1358,1359],{"id":1111,"depth":618,"text":1112},{"id":1132,"depth":618,"text":1133},{"id":1233,"depth":618,"text":1234},{"id":1248,"depth":113,"text":1249},{"id":1309,"depth":113,"text":1310},"2026-05-19","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用",{"caver":1365},"\u002Fimg\u002Fpostcard3.jpg","\u002Fposts\u002Flsh-minhash-deduplication",{"title":728,"description":1363},"posts\u002Flsh-minhash-deduplication","CPt90-O0t4_W9HZZVR7dUXrW3KsRLmOyQRQfyzd6Zb8",{"id":4,"title":5,"body":1371,"categories":1445,"cover":122,"date":123,"description":124,"extension":125,"meta":1446,"navigation":127,"path":128,"seo":1447,"stem":130,"tags":1448,"__hash__":135},{"type":7,"value":1372,"toc":1439},[1373,1375,1377,1379,1383,1393,1395,1417,1419,1427,1429],[10,1374,12],{"id":12},[14,1376,16],{},[14,1378,19],{},[14,1380,1381],{},[23,1382],{"alt":25,"src":26},[28,1384,1385,1387,1389,1391],{},[31,1386,33],{},[31,1388,36],{},[31,1390,39],{},[31,1392,42],{},[10,1394,45],{"id":45},[28,1396,1397,1399,1401,1403,1405,1407,1409,1411,1413,1415],{},[31,1398,50],{},[31,1400,53],{},[31,1402,56],{},[31,1404,59],{},[31,1406,62],{},[31,1408,65],{},[31,1410,68],{},[31,1412,71],{},[31,1414,74],{},[31,1416,77],{},[10,1418,81],{"id":80},[28,1420,1421,1423,1425],{},[31,1422,86],{},[31,1424,89],{},[31,1426,92],{},[10,1428,96],{"id":95},[28,1430,1431,1433,1435,1437],{},[31,1432,101],{},[31,1434,104],{},[31,1436,107],{},[31,1438,110],{},{"title":112,"searchDepth":113,"depth":113,"links":1440},[1441,1442,1443,1444],{"id":12,"depth":113,"text":12},{"id":45,"depth":113,"text":45},{"id":80,"depth":113,"text":81},{"id":95,"depth":113,"text":96},[120,121],{},{"title":5,"description":124},[132,133,134],1779193735202]