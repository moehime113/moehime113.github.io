[{"data":1,"prerenderedAt":1949},["ShallowReactive",2],{"post-bpe-tokenization-algorithm":3,"all-posts":356},{"id":4,"title":5,"body":6,"categories":345,"cover":346,"date":347,"description":348,"extension":349,"meta":350,"navigation":351,"path":352,"seo":353,"stem":354,"tags":345,"__hash__":355},"posts\u002Fposts\u002Fbpe-tokenization-algorithm.md","BPE 分词算法原理讲解：大模型背后的词表构建基石",{"type":7,"value":8,"toc":334},"minimark",[9,14,18,39,53,60,63,67,73,76,81,88,116,129,165,184,219,222,224,227,230,236,242,277,291,293,297,300,306,317,320],[10,11,13],"h2",{"id":12},"词表危机llm-如何认识世界","词表危机：LLM 如何认识世界？",[15,16,17],"p",{},"在把人类语言喂给 Transformer 等深度学习模型之前，我们必须先将其切分成离散的“词元”（Token）。这个切分过程往往面临两难：",[15,19,20,21,25,26,30,31,34,35,38],{},"如果",[22,23,24],"strong",{},"按词切分（Word-level）","，比如把 ",[27,28,29],"code",{},"machine learning"," 变成 ",[27,32,33],{},"[machine, learning]","，随着语料丰富，词汇表会膨胀到天文数字大小。而且在遇到网络造词、罕见拼写变形时，模型只能用 ",[27,36,37],{},"\u003CUNK>"," (未知) 符号糊弄过去，丢失极大的信息。",[15,40,41,42,45,46,49,50,52],{},"如果退而求其次",[22,43,44],{},"按字符切分（Character-level）","，比如拆成 ",[27,47,48],{},"[m, a, c, h, i, n, e, ...]","，虽然词表变小了且没有 ",[27,51,37],{}," 问题，但每个句子的序列长度会暴增。这直接会导致 Transformer 昂贵的注意力机制算力爆炸，且单个字母也很难承载复杂的语义。",[15,54,55,56,59],{},"那么，有没有一种两全其美的办法，既能把常见词当成整体处理，又能把生僻词拆成合理的词根？",[22,57,58],{},"BPE（字节对编码）"," 应运而生。",[61,62],"hr",{},[10,64,66],{"id":65},"bpe-是如何炼成的","BPE 是如何炼成的？",[15,68,69,70],{},"BPE（Byte Pair Encoding）原本是用于数据压缩的古老算法。其核心思路非常纯粹：",[22,71,72],{},"将文本中最高频出现的相邻符号对，合并成一个新的大符号。",[15,74,75],{},"通过在语料库上持续进行“频率统计 $\\to$ 贪心合并”，模型可以自动学出一套包含不同粒度的子词（Subword）词表。",[77,78,80],"h3",{"id":79},"模拟训练构造一个迷你词表","模拟训练：构造一个迷你词表",[15,82,83,84,87],{},"假设我们手头只有以下 4 个单词及其词频，为了清楚边界，我们给每个词结尾加一个特殊标记 ",[27,85,86],{},"\u003C\u002Fw>","：",[89,90,91,98,104,110],"ul",{},[92,93,94,97],"li",{},[27,95,96],{},"low\u003C\u002Fw>"," （出现 5 次）",[92,99,100,103],{},[27,101,102],{},"lower\u003C\u002Fw>"," （出现 2 次）",[92,105,106,109],{},[27,107,108],{},"newest\u003C\u002Fw>"," （出现 6 次）",[92,111,112,115],{},[27,113,114],{},"widest\u003C\u002Fw>"," （出现 3 次）",[15,117,118,121,124,125,128],{},[22,119,120],{},"Step 1：拆成原子字符",[122,123],"br",{},"\n一开始，我们把所有词打碎，此时的基础词表只有拆开的单字符：",[27,126,127],{},"l, o, w, e, r, n, s, t, i, d, \u003C\u002Fw>","。",[15,130,131,134,136,137,140,141,144,145,148,149,152,153,156,157,160,161,164],{},[22,132,133],{},"Step 2：寻找最高频组合",[122,135],{},"\n扫描这批打碎的语料，统计相邻两两字符的出现频率。\n我们注意到 ",[27,138,139],{},"(e, s)"," 相邻的频率非常高：在 ",[27,142,143],{},"newest"," 中出现了 6 次，在 ",[27,146,147],{},"widest"," 中出现了 3 次，总计 ",[22,150,151],{},"9次","。\n由于它是最高频对，我们将 ",[27,154,155],{},"e"," 和 ",[27,158,159],{},"s"," 合并为新词元 ",[27,162,163],{},"es","，并将其郑重写入我们的词汇表中。",[15,166,167,170,172,173,176,177,180,181,128],{},[22,168,169],{},"Step 3：不断迭代",[122,171],{},"\n此时数据变成了 ",[27,174,175],{},"n e w es t \u003C\u002Fw>"," 等。我们继续扫描，发现 ",[27,178,179],{},"(es, t)"," 又紧挨着出现了 9 次。\n继续合并：我们得到新词元 ",[27,182,183],{},"est",[15,185,186,187,190,191,194,195,198,199,156,202,205,206,209,210,156,212,215,216,128],{},"之后 ",[27,188,189],{},"(est, \u003C\u002Fw>)"," 会被合并为 ",[27,192,193],{},"est\u003C\u002Fw>","，因为英文里 ",[27,196,197],{},"-est"," 作为后缀经常出现在词尾。再往后，",[27,200,201],{},"l",[27,203,204],{},"o"," 会合并为 ",[27,207,208],{},"lo","，接着 ",[27,211,208],{},[27,213,214],{},"w"," 合并为 ",[27,217,218],{},"low",[15,220,221],{},"只要我们将这个循环跑下去，设定一个目标词表大小（比如 32,000 或 64,000），算法就会在拼满后自动停止。最终生成的词汇库里，既有基础的单字符，也会包含大量高频的前缀、后缀和常用单词。",[61,223],{},[10,225,226],{"id":226},"推理阶段的切词艺术",[15,228,229],{},"词表炼成之后，对于任意一段全新的用户输入，BPE 是如何进行拆解的呢？",[15,231,232,233],{},"规则其实是死板而严格的：",[22,234,235],{},"绝对服从训练时生成的合并记录，依次尝试将字符组合起来。",[15,237,238,239,128],{},"举个例子，用户输入了一个模型从未在训练语料里见过的生造词 ",[27,240,241],{},"lowest",[243,244,245,251,265],"ol",{},[92,246,247,248],{},"BPE 先把它切得粉碎：",[27,249,250],{},"l o w e s t \u003C\u002Fw>",[92,252,253,254,256,257,259,260,256,262,264],{},"根据训练时学到的优先级，首先套用 ",[27,255,139],{}," $\\to$ ",[27,258,163],{}," 的规则，接着套用 ",[27,261,179],{},[27,263,183],{}," 的规则。",[92,266,267,268,156,271,274,275,128],{},"前半部分套用 ",[27,269,270],{},"(l, o)",[27,272,273],{},"(lo, w)"," 的规则，得到 ",[27,276,218],{},[15,278,279,280,282,283,156,285,287,288,290],{},"奇迹发生了——新造词 ",[27,281,241],{}," 被切成了 ",[27,284,218],{},[27,286,183],{}," 两个 Subword。模型虽然没背过这个词，但顺理成章地理解了这是“低”的“最高级”，不仅完全避免了抛出 ",[27,289,37],{}," 的尴尬，还精准洞察了它的词根逻辑。",[61,292],{},[10,294,296],{"id":295},"进化版bbpebyte-level-bpe","进化版：BBPE（Byte-Level BPE）",[15,298,299],{},"传统的 BPE 一般建立在 Unicode 字符上。然而，世界上的语言、符号极度繁杂，各种稀奇古怪的 emoji 层出不穷，光是把单字符穷举出来就已经是一个庞大的基座了。",[15,301,302,303],{},"后来，OpenAI 在设计 GPT-2 时另辟蹊径：",[22,304,305],{},"任何文本，在计算机底层不全是由 UTF-8 编码的字节（Byte）拼接而成的吗？",[15,307,308,309,312,313,316],{},"既然 1 个字节只有 256 种可能的取值，那就直接把这 ",[22,310,311],{},"256 个基础字节","作为最底层的原子字符！这就诞生了更加通用的 ",[22,314,315],{},"BBPE","（Byte-Level BPE）。",[15,318,319],{},"在这种架构下：",[89,321,322,328],{},[92,323,324,327],{},[22,325,326],{},"永远告别 OOV（未登录词）","：哪怕遇到一段乱码或者罕见的外星文，最后也一定兜底退化成这 256 种字节基础单元的拼接。",[92,329,330,333],{},[22,331,332],{},"词表空间极大释放","：把原本因为处理各国冷门文字而浪费的槽位省出来，让词表更加紧凑纯粹。现代绝大多数万亿参数的巨兽模型，都在沿用这项革命性的改进设计。",{"title":335,"searchDepth":336,"depth":336,"links":337},"",2,[338,339,343,344],{"id":12,"depth":336,"text":13},{"id":65,"depth":336,"text":66,"children":340},[341],{"id":79,"depth":342,"text":80},3,{"id":226,"depth":336,"text":226},{"id":295,"depth":336,"text":296},null,"\u002Fimg\u002Fpostcard4.jpg","2026-05-19","深入 Byte Pair Encoding (BPE) 的工作流程，理解从字符到子词的合并机制，探讨它为何成为现代 LLM 的标配","md",{},true,"\u002Fposts\u002Fbpe-tokenization-algorithm",{"title":5,"description":348},"posts\u002Fbpe-tokenization-algorithm","9zCuC2wb6rMfJiMOWGrAIjJ9BmpdIxbHF1vYD1t29oM",[357,568,1149,1825],{"id":4,"title":5,"body":358,"categories":345,"cover":346,"date":347,"description":348,"extension":349,"meta":566,"navigation":351,"path":352,"seo":567,"stem":354,"tags":345,"__hash__":355},{"type":7,"value":359,"toc":558},[360,362,364,374,382,386,388,390,394,396,398,402,420,428,448,460,480,482,484,486,488,492,496,520,530,532,534,536,540,546,548],[10,361,13],{"id":12},[15,363,17],{},[15,365,20,366,25,368,30,370,34,372,38],{},[22,367,24],{},[27,369,29],{},[27,371,33],{},[27,373,37],{},[15,375,41,376,45,378,49,380,52],{},[22,377,44],{},[27,379,48],{},[27,381,37],{},[15,383,55,384,59],{},[22,385,58],{},[61,387],{},[10,389,66],{"id":65},[15,391,69,392],{},[22,393,72],{},[15,395,75],{},[77,397,80],{"id":79},[15,399,83,400,87],{},[27,401,86],{},[89,403,404,408,412,416],{},[92,405,406,97],{},[27,407,96],{},[92,409,410,103],{},[27,411,102],{},[92,413,414,109],{},[27,415,108],{},[92,417,418,115],{},[27,419,114],{},[15,421,422,424,124,426,128],{},[22,423,120],{},[122,425],{},[27,427,127],{},[15,429,430,432,136,434,140,436,144,438,148,440,152,442,156,444,160,446,164],{},[22,431,133],{},[122,433],{},[27,435,139],{},[27,437,143],{},[27,439,147],{},[22,441,151],{},[27,443,155],{},[27,445,159],{},[27,447,163],{},[15,449,450,452,172,454,176,456,180,458,128],{},[22,451,169],{},[122,453],{},[27,455,175],{},[27,457,179],{},[27,459,183],{},[15,461,186,462,190,464,194,466,198,468,156,470,205,472,209,474,156,476,215,478,128],{},[27,463,189],{},[27,465,193],{},[27,467,197],{},[27,469,201],{},[27,471,204],{},[27,473,208],{},[27,475,208],{},[27,477,214],{},[27,479,218],{},[15,481,221],{},[61,483],{},[10,485,226],{"id":226},[15,487,229],{},[15,489,232,490],{},[22,491,235],{},[15,493,238,494,128],{},[27,495,241],{},[243,497,498,502,512],{},[92,499,247,500],{},[27,501,250],{},[92,503,253,504,256,506,259,508,256,510,264],{},[27,505,139],{},[27,507,163],{},[27,509,179],{},[27,511,183],{},[92,513,267,514,156,516,274,518,128],{},[27,515,270],{},[27,517,273],{},[27,519,218],{},[15,521,279,522,282,524,156,526,287,528,290],{},[27,523,241],{},[27,525,218],{},[27,527,183],{},[27,529,37],{},[61,531],{},[10,533,296],{"id":295},[15,535,299],{},[15,537,302,538],{},[22,539,305],{},[15,541,308,542,312,544,316],{},[22,543,311],{},[22,545,315],{},[15,547,319],{},[89,549,550,554],{},[92,551,552,327],{},[22,553,326],{},[92,555,556,333],{},[22,557,332],{},{"title":335,"searchDepth":336,"depth":336,"links":559},[560,561,564,565],{"id":12,"depth":336,"text":13},{"id":65,"depth":336,"text":66,"children":562},[563],{"id":79,"depth":342,"text":80},{"id":226,"depth":336,"text":226},{"id":295,"depth":336,"text":296},{},{"title":5,"description":348},{"id":569,"title":570,"body":571,"categories":345,"cover":1141,"date":1142,"description":1143,"extension":349,"meta":1144,"navigation":351,"path":1145,"seo":1146,"stem":1147,"tags":345,"__hash__":1148},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":572,"toc":1117},[573,577,580,584,587,594,597,608,610,614,621,711,715,722,726,741,743,746,750,761,770,781,785,791,797,816,820,823,827,836,838,841,845,851,865,869,875,892,895,975,978,984,1007,1079,1082,1085,1096,1099,1101,1104,1107,1113],[10,574,576],{"id":575},"为什么要离开-hexo","为什么要离开 Hexo？",[15,578,579],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[77,581,583],{"id":582},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,585,586],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,588,589,590,593],{},"问题根源在于：",[22,591,592],{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[77,595,596],{"id":596},"构建速度与生态",[15,598,599,600,603,604,607],{},"文章数量上来之后，",[27,601,602],{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[22,605,606],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[61,609],{},[10,611,613],{"id":612},"为什么选-nuxt","为什么选 Nuxt？",[15,615,616,617,620],{},"看过 VitePress、Astro、Next.js，最终选了 ",[22,618,619],{},"Nuxt 4 SSG","。核心考量：",[622,623,624,639],"table",{},[625,626,627],"thead",{},[628,629,630,633,636],"tr",{},[631,632],"th",{},[631,634,635],{},"Hexo",[631,637,638],{},"Nuxt 4",[640,641,642,656,669,682,695],"tbody",{},[628,643,644,650,653],{},[645,646,647],"td",{},[22,648,649],{},"构建机制",[645,651,652],{},"CLI 全量生成静态文件",[645,654,655],{},"Nitro 引擎预渲染 + 增量构建",[628,657,658,663,666],{},[645,659,660],{},[22,661,662],{},"模板\u002F组件",[645,664,665],{},"EJS\u002FPug，无组件化",[645,667,668],{},"Vue 3 组件，自动导入",[628,670,671,676,679],{},[645,672,673],{},[22,674,675],{},"内容管理",[645,677,678],{},"front-matter + markdown",[645,680,681],{},"@nuxt\u002Fcontent v3，类型安全查询",[628,683,684,689,692],{},[645,685,686],{},[22,687,688],{},"交互",[645,690,691],{},"内联 script，靠 CDN",[645,693,694],{},"完整的 Vue 响应式生态",[628,696,697,702,708],{},[645,698,699],{},[22,700,701],{},"路由",[645,703,704,707],{},[27,705,706],{},"_config.yml"," permalink 配置",[645,709,710],{},"文件系统路由，动态参数",[77,712,714],{"id":713},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,716,717,718,721],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[22,719,720],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[77,723,725],{"id":724},"vue-生态的开发体验","Vue 生态的开发体验",[15,727,728,729,732,733,736,737,740],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[27,730,731],{},"useAsyncData"," + ",[27,734,735],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[27,738,739],{},"\u003Cscript>"," 标签。",[61,742],{},[10,744,745],{"id":745},"迁移过程",[77,747,749],{"id":748},"内容层零改动搬过来","内容层：零改动搬过来",[15,751,752,753,756,757,760],{},"所有 markdown 文件从 Hexo 的 ",[27,754,755],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[27,758,759],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[762,763,768],"pre",{"className":764,"code":766,"language":767},[765],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[27,769,766],{"__ignoreMap":335},[15,771,772,773,776,777,780],{},"多了 ",[27,774,775],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[27,778,779],{},"tags","。内容正文一个字没改。",[77,782,784],{"id":783},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,786,787,788,790],{},"Hexo 的 URL 靠 ",[27,789,706],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[762,792,795],{"className":793,"code":794,"language":767},[765],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[27,796,794],{"__ignoreMap":335},[15,798,799,800,803,804,807,808,811,812,815],{},"Nuxt 路由由 ",[27,801,802],{},"pages\u002F"," 目录结构决定，",[27,805,806],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[27,809,810],{},"trailingSlash: true"," 保证 URL 一致性，",[27,813,814],{},"[...slug].vue"," 兜底 404。",[77,817,819],{"id":818},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,821,822],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[77,824,826],{"id":825},"部署ci-保持不变","部署：CI 保持不变",[15,828,829,830,832,833,128],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[27,831,602],{}," 替换为 ",[27,834,835],{},"npm run build",[61,837],{},[10,839,840],{"id":840},"架构对比",[77,842,844],{"id":843},"hexo-的架构","Hexo 的架构",[762,846,849],{"className":847,"code":848,"language":767},[765],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[27,850,848],{"__ignoreMap":335},[15,852,853,854,857,858,860,861,864],{},"Hexo 是",[22,855,856],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[27,859,706],{},"、",[27,862,863],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[77,866,868],{"id":867},"nuxt-的架构","Nuxt 的架构",[762,870,873],{"className":871,"code":872,"language":767},[765],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[27,874,872],{"__ignoreMap":335},[15,876,877,878,881,882,884,885,887,888,891],{},"Nuxt 是",[22,879,880],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[27,883,735],{}," 查询内容，",[27,886,731],{}," 管理异步数据，",[27,889,890],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[77,893,894],{"id":894},"数据流对比",[622,896,897,909],{},[625,898,899],{},[628,900,901,904,906],{},[631,902,903],{},"环节",[631,905,635],{},[631,907,908],{},"Nuxt",[640,910,911,924,937,953,964],{},[628,912,913,916,919],{},[645,914,915],{},"内容获取",[645,917,918],{},"读文件 → 模板注入变量",[645,920,921],{},[27,922,923],{},"queryCollection('posts').all()",[628,925,926,929,932],{},[645,927,928],{},"数据管理",[645,930,931],{},"无，模板即数据",[645,933,934,936],{},[27,935,731],{}," + 响应式",[628,938,939,942,947],{},[645,940,941],{},"站点配置",[645,943,944,946],{},[27,945,706],{}," + 主题 config",[645,948,949,952],{},[27,950,951],{},"useSite()"," composable",[628,954,955,958,961],{},[645,956,957],{},"主题",[645,959,960],{},"Stylus 变量 → 编译到 CSS",[645,962,963],{},"CSS 自定义属性 → 运行时切换",[628,965,966,969,972],{},[645,967,968],{},"交互状态",[645,970,971],{},"全局变量 + DOM 操作",[645,973,974],{},"Vue 响应式 + composables",[77,976,977],{"id":977},"预渲染策略",[15,979,980,981,983],{},"Hexo 每次 ",[27,982,602],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,985,986,987,990,991,994,995,998,999,1002,1003,1006],{},"Nitro 的 ",[27,988,989],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[27,992,993],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[22,996,997],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[27,1000,1001],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[27,1004,1005],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[762,1008,1012],{"className":1009,"code":1010,"language":1011,"meta":335,"style":335},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[27,1013,1014,1027,1042,1073],{"__ignoreMap":335},[1015,1016,1019,1023],"span",{"class":1017,"line":1018},"line",1,[1015,1020,1022],{"class":1021},"sVyAn","prerender",[1015,1024,1026],{"class":1025},"sn6KH",": {\n",[1015,1028,1029,1032,1035,1039],{"class":1017,"line":336},[1015,1030,1031],{"class":1021},"  crawlLinks",[1015,1033,1034],{"class":1025},": ",[1015,1036,1038],{"class":1037},"sVC51","true",[1015,1040,1041],{"class":1025},",\n",[1015,1043,1044,1047,1050,1054,1057,1060,1062,1065,1067,1070],{"class":1017,"line":342},[1015,1045,1046],{"class":1021},"  routes",[1015,1048,1049],{"class":1025},": [",[1015,1051,1053],{"class":1052},"subq3","'\u002F'",[1015,1055,1056],{"class":1025},", ",[1015,1058,1059],{"class":1052},"'\u002Fabout'",[1015,1061,1056],{"class":1025},[1015,1063,1064],{"class":1052},"'\u002Fposts'",[1015,1066,1056],{"class":1025},[1015,1068,1069],{"class":1052},"'\u002Flinks'",[1015,1071,1072],{"class":1025},"],\n",[1015,1074,1076],{"class":1017,"line":1075},4,[1015,1077,1078],{"class":1025},"}\n",[10,1080,1081],{"id":1081},"迁移成本远低于预期",[15,1083,1084],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[243,1086,1087,1090,1093],{},[92,1088,1089],{},"搭建 Nuxt 项目骨架",[92,1091,1092],{},"设计 CSS token 系统",[92,1094,1095],{},"编写几个核心组件",[15,1097,1098],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[61,1100],{},[10,1102,1103],{"id":1103},"总结",[15,1105,1106],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,1108,1109,1112],{},[22,1110,1111],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[1114,1115,1116],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":335,"searchDepth":336,"depth":336,"links":1118},[1119,1123,1127,1133,1139,1140],{"id":575,"depth":336,"text":576,"children":1120},[1121,1122],{"id":582,"depth":342,"text":583},{"id":596,"depth":342,"text":596},{"id":612,"depth":336,"text":613,"children":1124},[1125,1126],{"id":713,"depth":342,"text":714},{"id":724,"depth":342,"text":725},{"id":745,"depth":336,"text":745,"children":1128},[1129,1130,1131,1132],{"id":748,"depth":342,"text":749},{"id":783,"depth":342,"text":784},{"id":818,"depth":342,"text":819},{"id":825,"depth":342,"text":826},{"id":840,"depth":336,"text":840,"children":1134},[1135,1136,1137,1138],{"id":843,"depth":342,"text":844},{"id":867,"depth":342,"text":868},{"id":894,"depth":342,"text":894},{"id":977,"depth":342,"text":977},{"id":1081,"depth":336,"text":1081},{"id":1103,"depth":336,"text":1103},"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":570,"description":1143},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",{"id":1150,"title":1151,"body":1152,"categories":345,"cover":1818,"date":347,"description":1819,"extension":349,"meta":1820,"navigation":351,"path":1821,"seo":1822,"stem":1823,"tags":345,"__hash__":1824},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":7,"value":1153,"toc":1798},[1154,1158,1164,1167,1172,1186,1193,1200,1202,1206,1215,1218,1226,1229,1232,1258,1260,1263,1266,1269,1286,1289,1291,1295,1298,1352,1355,1358,1364,1366,1370,1376,1380,1383,1386,1389,1392,1396,1399,1402,1408,1411,1415,1418,1421,1426,1430,1553,1556,1558,1562,1565,1569,1572,1575,1578,1586,1590,1593,1685,1688,1692,1695,1698,1701,1703,1707,1710,1753,1756,1761,1763,1766,1792],[10,1155,1157],{"id":1156},"前置知识什么是哈希hash算法","前置知识：什么是哈希（Hash）算法？",[15,1159,1160,1161,128],{},"在深入 LSH 之前，我们需要先理解基础的",[22,1162,1163],{},"哈希算法",[15,1165,1166],{},"简单来说，哈希函数（Hash Function）就像是一个“数字指纹生成器”。它接收任意长度的数据（如一段文本、一篇文档），并将其映射为一个固定长度的较短字符串或数值（即哈希值或签名）。",[15,1168,1169],{},[22,1170,1171],{},"传统哈希算法（如 MD5、SHA-256）的核心特征是：",[243,1173,1174,1180],{},[92,1175,1176,1179],{},[22,1177,1178],{},"唯一性与确定性","：绝对相同的输入，一定会得到完全相同的哈希值。",[92,1181,1182,1185],{},[22,1183,1184],{},"雪崩效应","：输入数据哪怕仅仅改变了一个标点符号，输出的哈希值也会变得面目全非、毫无规律。这在密码学中非常重要，能用来保证数据未被篡改。",[15,1187,1188,1189,1192],{},"然而，传统哈希的“雪崩效应”在",[22,1190,1191],{},"相似度检索","任务中反而成为了阻碍。如果我们想通过比对哈希值来判断两篇文章是否相似，传统哈希算法完全无能为力——因为两篇高度相似但不完全相同的文章，它们的哈希值是截然不同且没有任何关联的。",[15,1194,1195,1196,1199],{},"这也恰恰引出了本文的主角——",[22,1197,1198],{},"LSH（局部敏感哈希）","。它一反常态，特意设计出了一种**“让越相似的数据，越容易产生相同的哈希值（即越容易发生碰撞）”**的过滤机制。",[61,1201],{},[10,1203,1205],{"id":1204},"算法背景lsh解决了什么痛点","算法背景：LSH解决了什么痛点？",[15,1207,1208,1209,128,1212,1214],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[22,1210,1211],{},"计算代价是否可接受",[122,1213],{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[15,1216,1217],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[89,1219,1220,1223],{},[92,1221,1222],{},"使高相似对象以较高概率落入同一桶（进入候选集）",[92,1224,1225],{},"使低相似对象以较高概率在早期被过滤",[15,1227,1228],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[77,1230,1231],{"id":1231},"常见应用领域",[243,1233,1234,1240,1246,1252],{},[92,1235,1236,1239],{},[22,1237,1238],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[92,1241,1242,1245],{},[22,1243,1244],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[92,1247,1248,1251],{},[22,1249,1250],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[92,1253,1254,1257],{},[22,1255,1256],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[61,1259],{},[10,1261,1262],{"id":1262},"示例文本集合",[15,1264,1265],{},"设文档集合：",[15,1267,1268],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[89,1270,1271,1274,1277,1280,1283],{},[92,1272,1273],{},"$d_1=\\text{“今天北京天气很好”}$",[92,1275,1276],{},"$d_2=\\text{“今天北京天气真好”}$",[92,1278,1279],{},"$d_3=\\text{“昨天上海天气很差”}$",[92,1281,1282],{},"$d_4=\\text{“今天北京天气挺好”}$",[92,1284,1285],{},"$d_5=\\text{“深度学习推荐系统”}$",[15,1287,1288],{},"直观上，$d_1$、$d_2$ 和 $d_4$ 句式高度相似（仅一字之差），而 $d_3$、$d_5$ 语义或结构上有显著差异。",[61,1290],{},[10,1292,1294],{"id":1293},"shingling文本-q-gram集合","Shingling（文本 → q-gram集合）",[15,1296,1297],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[622,1299,1300,1310],{},[625,1301,1302],{},[628,1303,1304,1307],{},[631,1305,1306],{},"文本",[631,1308,1309],{},"3-gram集合",[640,1311,1312,1320,1328,1336,1344],{},[628,1313,1314,1317],{},[645,1315,1316],{},"d1",[645,1318,1319],{},"{今天北, 天北京, 北京天, 京天气, 天气很, 气很好}",[628,1321,1322,1325],{},[645,1323,1324],{},"d2",[645,1326,1327],{},"{今天北, 天北京, 北京天, 京天气, 天气真, 气真好}",[628,1329,1330,1333],{},[645,1331,1332],{},"d3",[645,1334,1335],{},"{昨天上, 天上海, 上海天, 海天气, 天气很, 气很差}",[628,1337,1338,1341],{},[645,1339,1340],{},"d4",[645,1342,1343],{},"{今天北, 天北京, 北京天, 京天气, 天气挺, 气挺好}",[628,1345,1346,1349],{},[645,1347,1348],{},"d5",[645,1350,1351],{},"{深度学, 度学习, 学习推, 习推荐, 推荐系, 荐系统}",[15,1353,1354],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[15,1356,1357],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[1359,1360,1361],"blockquote",{},[15,1362,1363],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[61,1365],{},[10,1367,1369],{"id":1368},"minhash集合-签名向量","MinHash（集合 → 签名向量）",[15,1371,1372,1375],{},[22,1373,1374],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[77,1377,1379],{"id":1378},"_31-构造方式","3.1 构造方式",[15,1381,1382],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[15,1384,1385],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[15,1387,1388],{},"于是签名向量为：",[15,1390,1391],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[77,1393,1395],{"id":1394},"_32-为什么可行","3.2 为什么可行",[15,1397,1398],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[15,1400,1401],{},"$$\nP(m_h(A)=m_h(B)) = J(A,B)\n$$",[15,1403,1404,1407],{},[22,1405,1406],{},"简要证明","：\n哈希函数 $h$ 相当于对全集元素做了一次随机排列。考察两集合的并集 $A \\cup B$ 中的所有元素：\n要使 $m_h(A) = m_h(B)$，意味着 $A \\cup B$ 中经过哈希映射后值最小（即排在“最前面”）的那个元素，必须既属于 $A$ 也属于 $B$，也就是说必须属于交集 $A \\cap B$。\n因为哈希是完全随机的，$A \\cup B$ 中的每一个元素成为最小值的概率是完全相等的。所以这个最小元素正好属于交集 $A \\cap B$ 的概率，就是交集元素个数占并集元素个数的比例，即 $\\frac{|A \\cap B|}{|A \\cup B|} = J(A,B)$。",[15,1409,1410],{},"用 $k$ 个哈希后，可得无偏估计量：",[1412,1413,1414],"div",{"v-pre":335},"\n$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_{i=1}^{k} I[m_i(A)=m_i(B)]\n$$\n",[15,1416,1417],{},"方差为：",[15,1419,1420],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[1359,1422,1423],{},[15,1424,1425],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[77,1427,1429],{"id":1428},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[622,1431,1432,1454],{},[625,1433,1434],{},[628,1435,1436,1438,1441,1443,1445,1448,1451],{},[631,1437,1306],{},[631,1439,1440],{},"h1",[631,1442,10],{},[631,1444,77],{},[631,1446,1447],{},"h4",[631,1449,1450],{},"h5",[631,1452,1453],{},"h6",[640,1455,1456,1478,1495,1516,1532],{},[628,1457,1458,1460,1463,1466,1469,1472,1475],{},[645,1459,1316],{},[645,1461,1462],{},"12",[645,1464,1465],{},"7",[645,1467,1468],{},"5",[645,1470,1471],{},"20",[645,1473,1474],{},"11",[645,1476,1477],{},"3",[628,1479,1480,1482,1484,1486,1489,1491,1493],{},[645,1481,1324],{},[645,1483,1462],{},[645,1485,1465],{},[645,1487,1488],{},"6",[645,1490,1471],{},[645,1492,1474],{},[645,1494,1477],{},[628,1496,1497,1499,1502,1505,1508,1511,1513],{},[645,1498,1332],{},[645,1500,1501],{},"2",[645,1503,1504],{},"15",[645,1506,1507],{},"8",[645,1509,1510],{},"19",[645,1512,1465],{},[645,1514,1515],{},"4",[628,1517,1518,1520,1522,1524,1526,1528,1530],{},[645,1519,1340],{},[645,1521,1462],{},[645,1523,1465],{},[645,1525,1468],{},[645,1527,1510],{},[645,1529,1504],{},[645,1531,1507],{},[628,1533,1534,1536,1539,1542,1545,1548,1551],{},[645,1535,1348],{},[645,1537,1538],{},"30",[645,1540,1541],{},"14",[645,1543,1544],{},"22",[645,1546,1547],{},"33",[645,1549,1550],{},"28",[645,1552,1468],{},[15,1554,1555],{},"可以看出：$d_1$ 与 $d_4$ 在前三个哈希函数取值一致，而与 $d_2$ 在后三个哈希函数取值一致，这反映了它们较高的相似度。",[61,1557],{},[10,1559,1561],{"id":1560},"lsh-banding签名矩阵-候选对","LSH Banding（签名矩阵 → 候选对）",[15,1563,1564],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[77,1566,1568],{"id":1567},"_41-切分规则","4.1 切分规则",[15,1570,1571],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[15,1573,1574],{},"$$\nk=b\\cdot r\n$$",[15,1576,1577],{},"例如：$k=6,b=2,r=3$。",[89,1579,1580,1583],{},[92,1581,1582],{},"Band 1: $(h_1,h_2,h_3)$",[92,1584,1585],{},"Band 2: $(h_4,h_5,h_6)$",[77,1587,1589],{"id":1588},"_42-候选判定","4.2 候选判定",[15,1591,1592],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[622,1594,1595,1608],{},[625,1596,1597],{},[628,1598,1599,1602,1605],{},[631,1600,1601],{},"Band",[631,1603,1604],{},"桶",[631,1606,1607],{},"文档",[640,1609,1610,1621,1630,1639,1648,1658,1667,1676],{},[628,1611,1612,1615,1618],{},[645,1613,1614],{},"1",[645,1616,1617],{},"B1-1",[645,1619,1620],{},"d1, d4",[628,1622,1623,1625,1628],{},[645,1624,1614],{},[645,1626,1627],{},"B1-2",[645,1629,1324],{},[628,1631,1632,1634,1637],{},[645,1633,1614],{},[645,1635,1636],{},"B1-3",[645,1638,1332],{},[628,1640,1641,1643,1646],{},[645,1642,1614],{},[645,1644,1645],{},"B1-4",[645,1647,1348],{},[628,1649,1650,1652,1655],{},[645,1651,1501],{},[645,1653,1654],{},"B2-1",[645,1656,1657],{},"d1, d2",[628,1659,1660,1662,1665],{},[645,1661,1501],{},[645,1663,1664],{},"B2-3",[645,1666,1332],{},[628,1668,1669,1671,1674],{},[645,1670,1501],{},[645,1672,1673],{},"B2-4",[645,1675,1340],{},[628,1677,1678,1680,1683],{},[645,1679,1501],{},[645,1681,1682],{},"B2-5",[645,1684,1348],{},[15,1686,1687],{},"在这里，$d_1,d_4$ 在 Band 1 碰撞、$d_1,d_2$ 在 Band 2 碰撞，它们都会被成功召回送入下一阶段。",[77,1689,1691],{"id":1690},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[15,1693,1694],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[15,1696,1697],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[15,1699,1700],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[61,1702],{},[10,1704,1706],{"id":1705},"精确验证候选对-最终结果","精确验证（候选对 → 最终结果）",[15,1708,1709],{},"对候选集合中的文档对再计算真实 Jaccard：",[622,1711,1712,1728],{},[625,1713,1714],{},[628,1715,1716,1719,1722,1725],{},[631,1717,1718],{},"文本对",[631,1720,1721],{},"交集大小",[631,1723,1724],{},"并集大小",[631,1726,1727],{},"Jaccard",[640,1729,1730,1742],{},[628,1731,1732,1735,1737,1739],{},[645,1733,1734],{},"d1,d4",[645,1736,1515],{},[645,1738,1507],{},[645,1740,1741],{},"0.5",[628,1743,1744,1747,1749,1751],{},[645,1745,1746],{},"d1,d2",[645,1748,1515],{},[645,1750,1507],{},[645,1752,1741],{},[15,1754,1755],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[1359,1757,1758],{},[15,1759,1760],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[61,1762],{},[10,1764,1765],{"id":1765},"算法直观总结",[243,1767,1768,1774,1780,1786],{},[92,1769,1770,1773],{},[22,1771,1772],{},"Shingling","：把文本变成可比较的集合表示。",[92,1775,1776,1779],{},[22,1777,1778],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[92,1781,1782,1785],{},[22,1783,1784],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[92,1787,1788,1791],{},[22,1789,1790],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[15,1793,1794,1797],{},[22,1795,1796],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":335,"searchDepth":336,"depth":336,"links":1799},[1800,1801,1804,1805,1806,1811,1816,1817],{"id":1156,"depth":336,"text":1157},{"id":1204,"depth":336,"text":1205,"children":1802},[1803],{"id":1231,"depth":342,"text":1231},{"id":1262,"depth":336,"text":1262},{"id":1293,"depth":336,"text":1294},{"id":1368,"depth":336,"text":1369,"children":1807},[1808,1809,1810],{"id":1378,"depth":342,"text":1379},{"id":1394,"depth":342,"text":1395},{"id":1428,"depth":342,"text":1429},{"id":1560,"depth":336,"text":1561,"children":1812},[1813,1814,1815],{"id":1567,"depth":342,"text":1568},{"id":1588,"depth":342,"text":1589},{"id":1690,"depth":342,"text":1691},{"id":1705,"depth":336,"text":1706},{"id":1765,"depth":336,"text":1765},"\u002Fimg\u002Fpostcard3.jpg","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用",{},"\u002Fposts\u002Flsh-minhash-deduplication",{"title":1151,"description":1819},"posts\u002Flsh-minhash-deduplication","oG6H2fNbkQAmzn78pWFC0zQq-y8odaRz5akaYuGwnC8",{"id":1826,"title":1827,"body":1828,"categories":1934,"cover":1937,"date":1938,"description":1939,"extension":349,"meta":1940,"navigation":351,"path":1941,"seo":1942,"stem":1943,"tags":1944,"__hash__":1948},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":7,"value":1829,"toc":1928},[1830,1833,1836,1839,1846,1860,1863,1895,1899,1910,1914],[10,1831,1832],{"id":1832},"我的配置清单",[15,1834,1835],{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[15,1837,1838],{},"惯例先附上系统信息：",[15,1840,1841],{},[1842,1843],"img",{"alt":1844,"src":1845},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[89,1847,1848,1851,1854,1857],{},[92,1849,1850],{},"OS：Ubuntu 26.04 LTS",[92,1852,1853],{},"Kernel：Linux 7.0.0-15-generic",[92,1855,1856],{},"CPU：Intel Core i7-14700H",[92,1858,1859],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[10,1861,1862],{"id":1862},"系统与桌面环境",[89,1864,1865,1868,1871,1874,1877,1880,1883,1886,1889,1892],{},[92,1866,1867],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[92,1869,1870],{},"桌面协议：Wayland",[92,1872,1873],{},"窗口管理：Mutter",[92,1875,1876],{},"Shell：zsh 5.9",[92,1878,1879],{},"终端：Ghostty",[92,1881,1882],{},"输入法：Fcitx5（小鹤音形）",[92,1884,1885],{},"主题：Orchis-dark",[92,1887,1888],{},"壁纸：Variety",[92,1890,1891],{},"截图：Flameshot",[92,1893,1894],{},"VPN：v2rayN（Linux 版本）",[10,1896,1898],{"id":1897},"工作-学习","工作 \u002F 学习",[89,1900,1901,1904,1907],{},[92,1902,1903],{},"办公：WPS",[92,1905,1906],{},"编辑器：VS Code",[92,1908,1909],{},"AI 工具管理：CCSwitch（ccswitch）",[10,1911,1913],{"id":1912},"生活-游戏","生活 \u002F 游戏",[89,1915,1916,1919,1922,1925],{},[92,1917,1918],{},"游戏：Steam",[92,1920,1921],{},"兼容层：Proton GE",[92,1923,1924],{},"浏览器：Edge",[92,1926,1927],{},"聊天：微信 \u002F QQ",{"title":335,"searchDepth":336,"depth":336,"links":1929},[1930,1931,1932,1933],{"id":1832,"depth":336,"text":1832},{"id":1862,"depth":336,"text":1862},{"id":1897,"depth":336,"text":1898},{"id":1912,"depth":336,"text":1913},[1935,1936],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单",{},"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":1827,"description":1939},"posts\u002Fubuntu-26-04-my-setup",[1945,1946,1947],"Ubuntu","Wayland","桌面配置","yZYl