4},[181],[15,182,183],{},"这是一篇关于生活随笔的测试文章。",{"title":115,"searchDepth":116,"depth":116,"links":185},[],"生活随笔与日常感悟，记录平常但值得回味的小事",{"date":188,"categories":189,"swiper_index":191},"2026-04-16 10:2:00",[190],"生活分享",3,"\u002Fposts\u002Ftest-2",{"title":178,"description":186},"posts\u002Ftest-2","3JR7ro8fISwftKU5-gAhb_3KFK5CINSs2hospqJu2hs",{"id":197,"title":198,"body":199,"description":206,"extension":124,"meta":207,"navigation":131,"path":211,"seo":212,"stem":213,"__hash__":214},"posts\u002Fposts\u002Ftest-1.md","测试文章 - 技术教程",{"type":8,"value":200,"toc":204},[201],[15,202,203],{},"这是一篇关于技术教程的测试文章。",{"title":115,"searchDepth":116,"depth":116,"links":205},[],"技术教程实践记录，整理常用技巧与问题处理方法",{"date":208,"categories":209,"swiper_index":116},"2026-04-16 10:1:00",[210],"嵌入式","\u002Fposts\u002Ftest-1",{"title":198,"description":206},"posts\u002Ftest-1","KGjLTIqtq3sFUjnbb22_Dt8u-XVt7cr6MFYWyN_vK6E",{"id":216,"title":217,"body":218,"description":659,"extension":124,"meta":660,"navigation":131,"path":663,"seo":664,"stem":665,"__hash__":666},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":8,"value":219,"toc":641},[220,224,236,239,242,246,249,254,257,273,277,280,348,354,368,391,393,397,400,404,415,441,445,456,458,462,465,469,511,515,540,544,566,570,591,622,624,628,631,634,637],[35,221,223],{"id":222},"初衷为什么想做一个博客","🌟 初衷：为什么想做一个博客？",[15,225,226,227,231,232,235],{},"一直想有块完全属于自己的“互联网自留地”，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：",[228,229,230],"strong",{},"Hexo"," + ",[228,233,234],{},"Butterfly"," 主题。",[15,237,238],{},"下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。",[240,241],"hr",{},[35,243,245],{"id":244},"️-折腾第一步让博客先跑起来","🛠️ 折腾第一步：让博客先跑起来",[15,247,248],{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[250,251,253],"h3",{"id":252},"_1-搞定基础环境","1. 搞定基础环境",[15,255,256],{},"备好两样工具：",[258,259,260,267],"ul",{},[261,262,263,266],"li",{},[228,264,265],{},"Git & GitHub","：做版本控制和网页托管。",[261,268,269,272],{},[228,270,271],{},"Node.js","：Hexo 的运行基础，官网下个稳定版装上就行。",[250,274,276],{"id":275},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[15,278,279],{},"打开终端，敲几行命令搭好骨架：",[281,282,286],"pre",{"className":283,"code":284,"language":285,"meta":115,"style":115},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash",[95,287,288,297,314,333],{"__ignoreMap":115},[289,290,293],"span",{"class":291,"line":292},"line",1,[289,294,296],{"class":295},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[289,298,299,303,307,311],{"class":291,"line":116},[289,300,302],{"class":301},"sVbv2","npm",[289,304,306],{"class":305},"subq3"," install",[289,308,310],{"class":309},"sVC51"," -g",[289,312,313],{"class":305}," hexo-cli\n",[289,315,316,319,322,326,330],{"class":291,"line":191},[289,317,318],{"class":301},"mkdir",[289,320,321],{"class":305}," your_blog",[289,323,325],{"class":324},"sn6KH"," && ",[289,327,329],{"class":328},"sjrmR","cd",[289,331,332],{"class":305}," your_blog\n",[289,334,335,338,341,343,345],{"class":291,"line":171},[289,336,337],{"class":301},"hexo",[289,339,340],{"class":305}," init",[289,342,325],{"class":324},[289,344,302],{"class":301},[289,346,347],{"class":305}," install\n",[15,349,350,351,353],{},"接着装上 ",[228,352,234],{}," 主题：",[281,355,357],{"className":283,"code":356,"language":285,"meta":115,"style":115},"npm install hexo-theme-butterfly\n",[95,358,359],{"__ignoreMap":115},[289,360,361,363,365],{"class":291,"line":292},[289,362,302],{"class":301},[289,364,306],{"class":305},[289,366,367],{"class":305}," hexo-theme-butterfly\n",[15,369,370,371,374,375,378,379,382,383,386,387,390],{},"修改根目录 ",[95,372,373],{},"_config.yml","，把 ",[95,376,377],{},"theme"," 设为 ",[95,380,381],{},"butterfly","。终端跑一句 ",[95,384,385],{},"hexo s","，打开 ",[95,388,389],{},"http:\u002F\u002Flocalhost:4000","——看到雏形加载出来的那一刻，还是挺有成就感的！",[240,392],{},[35,394,396],{"id":395},"部署上线让世界看到你的博客","🚀 部署上线：让世界看到你的博客",[15,398,399],{},"本地自嗨不够，得把它挂到网上。",[250,401,403],{"id":402},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[15,405,406,407,410,411,414],{},"装好 Git 部署插件 ",[95,408,409],{},"hexo-deployer-git","，在配置文件填上 GitHub 仓库地址和分支（推荐 ",[95,412,413],{},"main","）。然后执行经典的“三连”命令推送到云端：",[281,416,418],{"className":283,"code":417,"language":285,"meta":115,"style":115},"hexo clean && hexo g && hexo d \n",[95,419,420],{"__ignoreMap":115},[289,421,422,424,427,429,431,434,436,438],{"class":291,"line":292},[289,423,337],{"class":301},[289,425,426],{"class":305}," clean",[289,428,325],{"class":324},[289,430,337],{"class":301},[289,432,433],{"class":305}," g",[289,435,325],{"class":324},[289,437,337],{"class":301},[289,439,440],{"class":305}," d\n",[250,442,444],{"id":443},"_2-进阶玩法vercel-与评论系统部署","2. 进阶玩法：Vercel 与评论系统部署",[15,446,447,448,451,452,455],{},"如果想要国内访问更快，强烈推荐用 ",[228,449,450],{},"Vercel"," 托管静态页面。\n另外，我后来还折腾了 ",[228,453,454],{},"Twikoo"," 评论系统，同样用 Vercel 部署云函数。免费好用，不用操心服务器，完美契合静态博客。",[240,457],{},[35,459,461],{"id":460},"魔改与避坑指南那些折磨过我的-bug","🔨 魔改与避坑指南：那些折磨过我的 Bug",[15,463,464],{},"跟着教程走一帆风顺，自己动手加特效（比如轮播图、Aplayer 音乐）时，玄学问题就来了。盘点几个大坑：",[250,466,468],{"id":467},"坑一静态资源加载失败cdn-之痛","❌ 坑一：静态资源加载失败（CDN 之痛）",[15,470,471,474,475,478,479,482,483,486,487,490,491,494,495,498,499,504,505,510],{},[228,472,473],{},"现象","：本地跑得好好的，一部署线上控制台就一片红 ",[95,476,477],{},"ERR_ABORTED","，排版错乱、图标变方块。\n",[228,480,481],{},"原因","：老教程推荐的国内\u002F小众 CDN（如 ",[95,484,485],{},"tianli0.top","、",[95,488,489],{},"bootcdn","）很多已停运，或在 GitHub\u002FVercel 环境被拦截。\n",[228,492,493],{},"✅ 解决","：果断弃用！在 ",[95,496,497],{},"_config.butterfly.yml"," 里，把第三方资源统统换成国际大厂 CDN，比如 ",[228,500,501],{},[95,502,503],{},"unpkg.com","（最稳妥）或 ",[228,506,507],{},[95,508,509],{},"cdn.jsdelivr.net\u002Fnpm\u002F","。",[250,512,514],{"id":513},"坑二github-actions-自动部署页面不更新","❌ 坑二：GitHub Actions 自动部署页面不更新",[15,516,517,519,520,522,523,525,526,529,530,532,533,536,537,539],{},[228,518,473],{},"：Workflow 自动构建并推送到 ",[95,521,413],{}," 分支显示成功，但网页死活不更新。\n",[228,524,481],{},"：GitHub Pages 默认可能还在傻傻读取旧的 ",[95,527,528],{},"gh-pages"," 分支。\n",[228,531,493],{},"：去 GitHub 仓库的 ",[228,534,535],{},"Settings -> Pages","，把部署分支手动改为 ",[95,538,413],{},"，保存稍等片刻即可。",[250,541,543],{"id":542},"坑三vercel-部署重复构建报错","❌ 坑三：Vercel 部署重复构建报错",[15,545,546,548,549,551,552,554,555,557,558,561,562,565],{},[228,547,473],{},"：把跑过 Actions 的 ",[95,550,413],{}," 分支导入 Vercel，构建卡住甚至报错。\n",[228,553,481],{},"：Actions 已生成纯静态文件，但 Vercel 发现是 Hexo 项目，又自作多情帮你跑了一遍构建命令。\n",[228,556,493],{},"：在 Vercel 项目设置里找到 ",[228,559,560],{},"Build Command","，打开 Override 并",[228,563,564],{},"留空","。让 Vercel 把它当纯静态站点直接部署，清爽快速。",[250,567,569],{"id":568},"坑四本地预览和线上效果不一致最恶心的玄学","❌ 坑四：本地预览和线上效果不一致（最恶心的玄学）",[15,571,572,574,575,577,578,580,581,584,585,588,589,574],{},[228,573,473],{},"：",[95,576,385],{}," 本地看一切完美，推送到线上后，发现样式没变、自定义的特效出不来，甚至页面错乱。\n",[228,579,481],{},"：这通常和 ",[228,582,583],{},"缓存（浏览器\u002FCDN\u002FPWA 服务端缓存）"," 或 ",[228,586,587],{},"PJAX 异步加载"," 有关。本地是即时响应的，而线上部署后，浏览器或 JS 服务端（Service Worker）会强缓存旧文件。另外，如果加了自定义 JS 特效，由于 Butterfly 开启了 PJAX 无刷新跳转，换页时 JS 可能不会重新执行。\n",[228,590,493],{},[592,593,594,612],"ol",{},[261,595,596,599,600,603,604,607,608,611],{},[228,597,598],{},"清缓存","：遇事不决先 ",[95,601,602],{},"hexo clean","，线上调试务必用浏览器的 ",[228,605,606],{},"无痕模式"," 或强刷（",[95,609,610],{},"Ctrl + F5","）。如果开了 PWA，记得去控制台清理 Service Worker。",[261,613,614,617,618,621],{},[228,615,616],{},"PJAX 适配","：如果是自定义 JS 特效失效，要把 JS 代码包在 PJAX 重载事件里（如 ",[95,619,620],{},"document.addEventListener('pjax:complete', function() {...})","），确保每次切页都能重新触发。",[240,623],{},[35,625,627],{"id":626},"最终成果与碎碎念","💡 最终成果与碎碎念",[15,629,630],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[15,632,633],{},"建站最大的门槛其实是**“开始动手”**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[15,635,636],{},"折腾不息，共勉！",[638,639,640],"style",{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html co