[{"data":1,"prerenderedAt":2243},["ShallowReactive",2],{"post-lsh-minhash-deduplication":3,"all-posts":703},{"id":4,"title":5,"body":6,"categories":692,"cover":693,"date":694,"description":695,"extension":696,"meta":697,"navigation":698,"path":699,"seo":700,"stem":701,"tags":692,"__hash__":702},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":7,"value":8,"toc":670},"minimark",[9,14,23,26,31,47,54,61,64,68,78,81,90,93,97,123,125,128,131,134,151,154,156,160,163,223,226,229,235,237,241,247,251,254,257,260,263,267,270,273,279,282,287,290,293,298,302,425,428,430,434,437,441,444,447,450,458,462,465,557,560,564,567,570,573,575,579,582,625,628,633,635,638,664],[10,11,13],"h2",{"id":12},"前置知识什么是哈希hash算法","前置知识：什么是哈希（Hash）算法？",[15,16,17,18,22],"p",{},"在深入 LSH 之前，我们需要先理解基础的",[19,20,21],"strong",{},"哈希算法","。",[15,24,25],{},"简单来说，哈希函数（Hash Function）就像是一个“数字指纹生成器”。它接收任意长度的数据（如一段文本、一篇文档），并将其映射为一个固定长度的较短字符串或数值（即哈希值或签名）。",[15,27,28],{},[19,29,30],{},"传统哈希算法（如 MD5、SHA-256）的核心特征是：",[32,33,34,41],"ol",{},[35,36,37,40],"li",{},[19,38,39],{},"唯一性与确定性","：绝对相同的输入，一定会得到完全相同的哈希值。",[35,42,43,46],{},[19,44,45],{},"雪崩效应","：输入数据哪怕仅仅改变了一个标点符号，输出的哈希值也会变得面目全非、毫无规律。这在密码学中非常重要，能用来保证数据未被篡改。",[15,48,49,50,53],{},"然而，传统哈希的“雪崩效应”在",[19,51,52],{},"相似度检索","任务中反而成为了阻碍。如果我们想通过比对哈希值来判断两篇文章是否相似，传统哈希算法完全无能为力——因为两篇高度相似但不完全相同的文章，它们的哈希值是截然不同且没有任何关联的。",[15,55,56,57,60],{},"这也恰恰引出了本文的主角——",[19,58,59],{},"LSH（局部敏感哈希）","。它一反常态，特意设计出了一种**“让越相似的数据，越容易产生相同的哈希值（即越容易发生碰撞）”**的过滤机制。",[62,63],"hr",{},[10,65,67],{"id":66},"算法背景lsh解决了什么痛点","算法背景：LSH解决了什么痛点？",[15,69,70,71,22,74,77],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[19,72,73],{},"计算代价是否可接受",[75,76],"br",{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[15,79,80],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[82,83,84,87],"ul",{},[35,85,86],{},"使高相似对象以较高概率落入同一桶（进入候选集）",[35,88,89],{},"使低相似对象以较高概率在早期被过滤",[15,91,92],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[94,95,96],"h3",{"id":96},"常见应用领域",[32,98,99,105,111,117],{},[35,100,101,104],{},[19,102,103],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[35,106,107,110],{},[19,108,109],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[35,112,113,116],{},[19,114,115],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[35,118,119,122],{},[19,120,121],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[62,124],{},[10,126,127],{"id":127},"示例文本集合",[15,129,130],{},"设文档集合：",[15,132,133],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[82,135,136,139,142,145,148],{},[35,137,138],{},"$d_1=\\text{“今天北京天气很好”}$",[35,140,141],{},"$d_2=\\text{“今天北京天气真好”}$",[35,143,144],{},"$d_3=\\text{“昨天上海天气很差”}$",[35,146,147],{},"$d_4=\\text{“今天北京天气挺好”}$",[35,149,150],{},"$d_5=\\text{“深度学习推荐系统”}$",[15,152,153],{},"直观上，$d_1$、$d_2$ 和 $d_4$ 句式高度相似（仅一字之差），而 $d_3$、$d_5$ 语义或结构上有显著差异。",[62,155],{},[10,157,159],{"id":158},"shingling文本-q-gram集合","Shingling（文本 → q-gram集合）",[15,161,162],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[164,165,166,179],"table",{},[167,168,169],"thead",{},[170,171,172,176],"tr",{},[173,174,175],"th",{},"文本",[173,177,178],{},"3-gram集合",[180,181,182,191,199,207,215],"tbody",{},[170,183,184,188],{},[185,186,187],"td",{},"d1",[185,189,190],{},"{今天北, 天北京, 北京天, 京天气, 天气很, 气很好}",[170,192,193,196],{},[185,194,195],{},"d2",[185,197,198],{},"{今天北, 天北京, 北京天, 京天气, 天气真, 气真好}",[170,200,201,204],{},[185,202,203],{},"d3",[185,205,206],{},"{昨天上, 天上海, 上海天, 海天气, 天气很, 气很差}",[170,208,209,212],{},[185,210,211],{},"d4",[185,213,214],{},"{今天北, 天北京, 北京天, 京天气, 天气挺, 气挺好}",[170,216,217,220],{},[185,218,219],{},"d5",[185,221,222],{},"{深度学, 度学习, 学习推, 习推荐, 推荐系, 荐系统}",[15,224,225],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[15,227,228],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[230,231,232],"blockquote",{},[15,233,234],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[62,236],{},[10,238,240],{"id":239},"minhash集合-签名向量","MinHash（集合 → 签名向量）",[15,242,243,246],{},[19,244,245],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[94,248,250],{"id":249},"_31-构造方式","3.1 构造方式",[15,252,253],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[15,255,256],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[15,258,259],{},"于是签名向量为：",[15,261,262],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[94,264,266],{"id":265},"_32-为什么可行","3.2 为什么可行",[15,268,269],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[15,271,272],{},"$$\nP(m_h(A)=m_h(B)) = J(A,B)\n$$",[15,274,275,278],{},[19,276,277],{},"简要证明","：\n哈希函数 $h$ 相当于对全集元素做了一次随机排列。考察两集合的并集 $A \\cup B$ 中的所有元素：\n要使 $m_h(A) = m_h(B)$，意味着 $A \\cup B$ 中经过哈希映射后值最小（即排在“最前面”）的那个元素，必须既属于 $A$ 也属于 $B$，也就是说必须属于交集 $A \\cap B$。\n因为哈希是完全随机的，$A \\cup B$ 中的每一个元素成为最小值的概率是完全相等的。所以这个最小元素正好属于交集 $A \\cap B$ 的概率，就是交集元素个数占并集元素个数的比例，即 $\\frac{|A \\cap B|}{|A \\cup B|} = J(A,B)$。",[15,280,281],{},"用 $k$ 个哈希后，可得无偏估计量：",[283,284,286],"div",{"v-pre":285},"","\n$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_{i=1}^{k} I[m_i(A)=m_i(B)]\n$$\n",[15,288,289],{},"方差为：",[15,291,292],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[230,294,295],{},[15,296,297],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[94,299,301],{"id":300},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[164,303,304,326],{},[167,305,306],{},[170,307,308,310,313,315,317,320,323],{},[173,309,175],{},[173,311,312],{},"h1",[173,314,10],{},[173,316,94],{},[173,318,319],{},"h4",[173,321,322],{},"h5",[173,324,325],{},"h6",[180,327,328,350,367,388,404],{},[170,329,330,332,335,338,341,344,347],{},[185,331,187],{},[185,333,334],{},"12",[185,336,337],{},"7",[185,339,340],{},"5",[185,342,343],{},"20",[185,345,346],{},"11",[185,348,349],{},"3",[170,351,352,354,356,358,361,363,365],{},[185,353,195],{},[185,355,334],{},[185,357,337],{},[185,359,360],{},"6",[185,362,343],{},[185,364,346],{},[185,366,349],{},[170,368,369,371,374,377,380,383,385],{},[185,370,203],{},[185,372,373],{},"2",[185,375,376],{},"15",[185,378,379],{},"8",[185,381,382],{},"19",[185,384,337],{},[185,386,387],{},"4",[170,389,390,392,394,396,398,400,402],{},[185,391,211],{},[185,393,334],{},[185,395,337],{},[185,397,340],{},[185,399,382],{},[185,401,376],{},[185,403,379],{},[170,405,406,408,411,414,417,420,423],{},[185,407,219],{},[185,409,410],{},"30",[185,412,413],{},"14",[185,415,416],{},"22",[185,418,419],{},"33",[185,421,422],{},"28",[185,424,340],{},[15,426,427],{},"可以看出：$d_1$ 与 $d_4$ 在前三个哈希函数取值一致，而与 $d_2$ 在后三个哈希函数取值一致，这反映了它们较高的相似度。",[62,429],{},[10,431,433],{"id":432},"lsh-banding签名矩阵-候选对","LSH Banding（签名矩阵 → 候选对）",[15,435,436],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[94,438,440],{"id":439},"_41-切分规则","4.1 切分规则",[15,442,443],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[15,445,446],{},"$$\nk=b\\cdot r\n$$",[15,448,449],{},"例如：$k=6,b=2,r=3$。",[82,451,452,455],{},[35,453,454],{},"Band 1: $(h_1,h_2,h_3)$",[35,456,457],{},"Band 2: $(h_4,h_5,h_6)$",[94,459,461],{"id":460},"_42-候选判定","4.2 候选判定",[15,463,464],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[164,466,467,480],{},[167,468,469],{},[170,470,471,474,477],{},[173,472,473],{},"Band",[173,475,476],{},"桶",[173,478,479],{},"文档",[180,481,482,493,502,511,520,530,539,548],{},[170,483,484,487,490],{},[185,485,486],{},"1",[185,488,489],{},"B1-1",[185,491,492],{},"d1, d4",[170,494,495,497,500],{},[185,496,486],{},[185,498,499],{},"B1-2",[185,501,195],{},[170,503,504,506,509],{},[185,505,486],{},[185,507,508],{},"B1-3",[185,510,203],{},[170,512,513,515,518],{},[185,514,486],{},[185,516,517],{},"B1-4",[185,519,219],{},[170,521,522,524,527],{},[185,523,373],{},[185,525,526],{},"B2-1",[185,528,529],{},"d1, d2",[170,531,532,534,537],{},[185,533,373],{},[185,535,536],{},"B2-3",[185,538,203],{},[170,540,541,543,546],{},[185,542,373],{},[185,544,545],{},"B2-4",[185,547,211],{},[170,549,550,552,555],{},[185,551,373],{},[185,553,554],{},"B2-5",[185,556,219],{},[15,558,559],{},"在这里，$d_1,d_4$ 在 Band 1 碰撞、$d_1,d_2$ 在 Band 2 碰撞，它们都会被成功召回送入下一阶段。",[94,561,563],{"id":562},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[15,565,566],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[15,568,569],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[15,571,572],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[62,574],{},[10,576,578],{"id":577},"精确验证候选对-最终结果","精确验证（候选对 → 最终结果）",[15,580,581],{},"对候选集合中的文档对再计算真实 Jaccard：",[164,583,584,600],{},[167,585,586],{},[170,587,588,591,594,597],{},[173,589,590],{},"文本对",[173,592,593],{},"交集大小",[173,595,596],{},"并集大小",[173,598,599],{},"Jaccard",[180,601,602,614],{},[170,603,604,607,609,611],{},[185,605,606],{},"d1,d4",[185,608,387],{},[185,610,379],{},[185,612,613],{},"0.5",[170,615,616,619,621,623],{},[185,617,618],{},"d1,d2",[185,620,387],{},[185,622,379],{},[185,624,613],{},[15,626,627],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[230,629,630],{},[15,631,632],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[62,634],{},[10,636,637],{"id":637},"算法直观总结",[32,639,640,646,652,658],{},[35,641,642,645],{},[19,643,644],{},"Shingling","：把文本变成可比较的集合表示。",[35,647,648,651],{},[19,649,650],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[35,653,654,657],{},[19,655,656],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[35,659,660,663],{},[19,661,662],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[15,665,666,669],{},[19,667,668],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":285,"searchDepth":671,"depth":671,"links":672},2,[673,674,678,679,680,685,690,691],{"id":12,"depth":671,"text":13},{"id":66,"depth":671,"text":67,"children":675},[676],{"id":96,"depth":677,"text":96},3,{"id":127,"depth":671,"text":127},{"id":158,"depth":671,"text":159},{"id":239,"depth":671,"text":240,"children":681},[682,683,684],{"id":249,"depth":677,"text":250},{"id":265,"depth":677,"text":266},{"id":300,"depth":677,"text":301},{"id":432,"depth":671,"text":433,"children":686},[687,688,689],{"id":439,"depth":677,"text":440},{"id":460,"depth":677,"text":461},{"id":562,"depth":677,"text":563},{"id":577,"depth":671,"text":578},{"id":637,"depth":671,"text":637},null,"\u002Fimg\u002Fpostcard3.jpg","2026-05-19","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用","md",{},true,"\u002Fposts\u002Flsh-minhash-deduplication",{"title":5,"description":695},"posts\u002Flsh-minhash-deduplication","oG6H2fNbkQAmzn78pWFC0zQq-y8odaRz5akaYuGwnC8",[704,1039,1614,2119],{"id":705,"title":706,"body":707,"categories":692,"cover":1032,"date":694,"description":1033,"extension":696,"meta":1034,"navigation":698,"path":1035,"seo":1036,"stem":1037,"tags":692,"__hash__":1038},"posts\u002Fposts\u002Fbpe-tokenization-algorithm.md","BPE 分词算法原理讲解：大模型背后的词表构建基石",{"type":7,"value":708,"toc":1024},[709,713,716,736,750,757,759,763,769,772,776,783,809,820,856,875,910,913,915,918,921,927,933,967,981,983,987,990,996,1007,1010],[10,710,712],{"id":711},"词表危机llm-如何认识世界","词表危机：LLM 如何认识世界？",[15,714,715],{},"在把人类语言喂给 Transformer 等深度学习模型之前，我们必须先将其切分成离散的“词元”（Token）。这个切分过程往往面临两难：",[15,717,718,719,722,723,727,728,731,732,735],{},"如果",[19,720,721],{},"按词切分（Word-level）","，比如把 ",[724,725,726],"code",{},"machine learning"," 变成 ",[724,729,730],{},"[machine, learning]","，随着语料丰富，词汇表会膨胀到天文数字大小。而且在遇到网络造词、罕见拼写变形时，模型只能用 ",[724,733,734],{},"\u003CUNK>"," (未知) 符号糊弄过去，丢失极大的信息。",[15,737,738,739,742,743,746,747,749],{},"如果退而求其次",[19,740,741],{},"按字符切分（Character-level）","，比如拆成 ",[724,744,745],{},"[m, a, c, h, i, n, e, ...]","，虽然词表变小了且没有 ",[724,748,734],{}," 问题，但每个句子的序列长度会暴增。这直接会导致 Transformer 昂贵的注意力机制算力爆炸，且单个字母也很难承载复杂的语义。",[15,751,752,753,756],{},"那么，有没有一种两全其美的办法，既能把常见词当成整体处理，又能把生僻词拆成合理的词根？",[19,754,755],{},"BPE（字节对编码）"," 应运而生。",[62,758],{},[10,760,762],{"id":761},"bpe-是如何炼成的","BPE 是如何炼成的？",[15,764,765,766],{},"BPE（Byte Pair Encoding）原本是用于数据压缩的古老算法。其核心思路非常纯粹：",[19,767,768],{},"将文本中最高频出现的相邻符号对，合并成一个新的大符号。",[15,770,771],{},"通过在语料库上持续进行“频率统计 $\\to$ 贪心合并”，模型可以自动学出一套包含不同粒度的子词（Subword）词表。",[94,773,775],{"id":774},"模拟训练构造一个迷你词表","模拟训练：构造一个迷你词表",[15,777,778,779,782],{},"假设我们手头只有以下 4 个单词及其词频，为了清楚边界，我们给每个词结尾加一个特殊标记 ",[724,780,781],{},"\u003C\u002Fw>","：",[82,784,785,791,797,803],{},[35,786,787,790],{},[724,788,789],{},"low\u003C\u002Fw>"," （出现 5 次）",[35,792,793,796],{},[724,794,795],{},"lower\u003C\u002Fw>"," （出现 2 次）",[35,798,799,802],{},[724,800,801],{},"newest\u003C\u002Fw>"," （出现 6 次）",[35,804,805,808],{},[724,806,807],{},"widest\u003C\u002Fw>"," （出现 3 次）",[15,810,811,814,816,817,22],{},[19,812,813],{},"Step 1：拆成原子字符",[75,815],{},"\n一开始，我们把所有词打碎，此时的基础词表只有拆开的单字符：",[724,818,819],{},"l, o, w, e, r, n, s, t, i, d, \u003C\u002Fw>",[15,821,822,825,827,828,831,832,835,836,839,840,843,844,847,848,851,852,855],{},[19,823,824],{},"Step 2：寻找最高频组合",[75,826],{},"\n扫描这批打碎的语料，统计相邻两两字符的出现频率。\n我们注意到 ",[724,829,830],{},"(e, s)"," 相邻的频率非常高：在 ",[724,833,834],{},"newest"," 中出现了 6 次，在 ",[724,837,838],{},"widest"," 中出现了 3 次，总计 ",[19,841,842],{},"9次","。\n由于它是最高频对，我们将 ",[724,845,846],{},"e"," 和 ",[724,849,850],{},"s"," 合并为新词元 ",[724,853,854],{},"es","，并将其郑重写入我们的词汇表中。",[15,857,858,861,863,864,867,868,871,872,22],{},[19,859,860],{},"Step 3：不断迭代",[75,862],{},"\n此时数据变成了 ",[724,865,866],{},"n e w es t \u003C\u002Fw>"," 等。我们继续扫描，发现 ",[724,869,870],{},"(es, t)"," 又紧挨着出现了 9 次。\n继续合并：我们得到新词元 ",[724,873,874],{},"est",[15,876,877,878,881,882,885,886,889,890,847,893,896,897,900,901,847,903,906,907,22],{},"之后 ",[724,879,880],{},"(est, \u003C\u002Fw>)"," 会被合并为 ",[724,883,884],{},"est\u003C\u002Fw>","，因为英文里 ",[724,887,888],{},"-est"," 作为后缀经常出现在词尾。再往后，",[724,891,892],{},"l",[724,894,895],{},"o"," 会合并为 ",[724,898,899],{},"lo","，接着 ",[724,902,899],{},[724,904,905],{},"w"," 合并为 ",[724,908,909],{},"low",[15,911,912],{},"只要我们将这个循环跑下去，设定一个目标词表大小（比如 32,000 或 64,000），算法就会在拼满后自动停止。最终生成的词汇库里，既有基础的单字符，也会包含大量高频的前缀、后缀和常用单词。",[62,914],{},[10,916,917],{"id":917},"推理阶段的切词艺术",[15,919,920],{},"词表炼成之后，对于任意一段全新的用户输入，BPE 是如何进行拆解的呢？",[15,922,923,924],{},"规则其实是死板而严格的：",[19,925,926],{},"绝对服从训练时生成的合并记录，依次尝试将字符组合起来。",[15,928,929,930,22],{},"举个例子，用户输入了一个模型从未在训练语料里见过的生造词 ",[724,931,932],{},"lowest",[32,934,935,941,955],{},[35,936,937,938],{},"BPE 先把它切得粉碎：",[724,939,940],{},"l o w e s t \u003C\u002Fw>",[35,942,943,944,946,947,949,950,946,952,954],{},"根据训练时学到的优先级，首先套用 ",[724,945,830],{}," $\\to$ ",[724,948,854],{}," 的规则，接着套用 ",[724,951,870],{},[724,953,874],{}," 的规则。",[35,956,957,958,847,961,964,965,22],{},"前半部分套用 ",[724,959,960],{},"(l, o)",[724,962,963],{},"(lo, w)"," 的规则，得到 ",[724,966,909],{},[15,968,969,970,972,973,847,975,977,978,980],{},"奇迹发生了——新造词 ",[724,971,932],{}," 被切成了 ",[724,974,909],{},[724,976,874],{}," 两个 Subword。模型虽然没背过这个词，但顺理成章地理解了这是“低”的“最高级”，不仅完全避免了抛出 ",[724,979,734],{}," 的尴尬，还精准洞察了它的词根逻辑。",[62,982],{},[10,984,986],{"id":985},"进化版bbpebyte-level-bpe","进化版：BBPE（Byte-Level BPE）",[15,988,989],{},"传统的 BPE 一般建立在 Unicode 字符上。然而，世界上的语言、符号极度繁杂，各种稀奇古怪的 emoji 层出不穷，光是把单字符穷举出来就已经是一个庞大的基座了。",[15,991,992,993],{},"后来，OpenAI 在设计 GPT-2 时另辟蹊径：",[19,994,995],{},"任何文本，在计算机底层不全是由 UTF-8 编码的字节（Byte）拼接而成的吗？",[15,997,998,999,1002,1003,1006],{},"既然 1 个字节只有 256 种可能的取值，那就直接把这 ",[19,1000,1001],{},"256 个基础字节","作为最底层的原子字符！这就诞生了更加通用的 ",[19,1004,1005],{},"BBPE","（Byte-Level BPE）。",[15,1008,1009],{},"在这种架构下：",[82,1011,1012,1018],{},[35,1013,1014,1017],{},[19,1015,1016],{},"永远告别 OOV（未登录词）","：哪怕遇到一段乱码或者罕见的外星文，最后也一定兜底退化成这 256 种字节基础单元的拼接。",[35,1019,1020,1023],{},[19,1021,1022],{},"词表空间极大释放","：把原本因为处理各国冷门文字而浪费的槽位省出来，让词表更加紧凑纯粹。现代绝大多数万亿参数的巨兽模型，都在沿用这项革命性的改进设计。",{"title":285,"searchDepth":671,"depth":671,"links":1025},[1026,1027,1030,1031],{"id":711,"depth":671,"text":712},{"id":761,"depth":671,"text":762,"children":1028},[1029],{"id":774,"depth":677,"text":775},{"id":917,"depth":671,"text":917},{"id":985,"depth":671,"text":986},"\u002Fimg\u002Fpostcard4.jpg","深入 Byte Pair Encoding (BPE) 的工作流程，理解从字符到子词的合并机制，探讨它为何成为现代 LLM 的标配",{},"\u002Fposts\u002Fbpe-tokenization-algorithm",{"title":706,"description":1033},"posts\u002Fbpe-tokenization-algorithm","9zCuC2wb6rMfJiMOWGrAIjJ9BmpdIxbHF1vYD1t29oM",{"id":1040,"title":1041,"body":1042,"categories":692,"cover":1606,"date":1607,"description":1608,"extension":696,"meta":1609,"navigation":698,"path":1610,"seo":1611,"stem":1612,"tags":692,"__hash__":1613},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":1043,"toc":1582},[1044,1048,1051,1055,1058,1065,1068,1079,1081,1085,1092,1176,1180,1187,1191,1206,1208,1211,1215,1226,1235,1246,1250,1256,1262,1281,1285,1288,1292,1301,1303,1306,1310,1316,1330,1334,1340,1357,1360,1440,1443,1449,1472,1544,1547,1550,1561,1564,1566,1569,1572,1578],[10,1045,1047],{"id":1046},"为什么要离开-hexo","为什么要离开 Hexo？",[15,1049,1050],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[94,1052,1054],{"id":1053},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,1056,1057],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,1059,1060,1061,1064],{},"问题根源在于：",[19,1062,1063],{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[94,1066,1067],{"id":1067},"构建速度与生态",[15,1069,1070,1071,1074,1075,1078],{},"文章数量上来之后，",[724,1072,1073],{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[19,1076,1077],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[62,1080],{},[10,1082,1084],{"id":1083},"为什么选-nuxt","为什么选 Nuxt？",[15,1086,1087,1088,1091],{},"看过 VitePress、Astro、Next.js，最终选了 ",[19,1089,1090],{},"Nuxt 4 SSG","。核心考量：",[164,1093,1094,1106],{},[167,1095,1096],{},[170,1097,1098,1100,1103],{},[173,1099],{},[173,1101,1102],{},"Hexo",[173,1104,1105],{},"Nuxt 4",[180,1107,1108,1121,1134,1147,1160],{},[170,1109,1110,1115,1118],{},[185,1111,1112],{},[19,1113,1114],{},"构建机制",[185,1116,1117],{},"CLI 全量生成静态文件",[185,1119,1120],{},"Nitro 引擎预渲染 + 增量构建",[170,1122,1123,1128,1131],{},[185,1124,1125],{},[19,1126,1127],{},"模板\u002F组件",[185,1129,1130],{},"EJS\u002FPug，无组件化",[185,1132,1133],{},"Vue 3 组件，自动导入",[170,1135,1136,1141,1144],{},[185,1137,1138],{},[19,1139,1140],{},"内容管理",[185,1142,1143],{},"front-matter + markdown",[185,1145,1146],{},"@nuxt\u002Fcontent v3，类型安全查询",[170,1148,1149,1154,1157],{},[185,1150,1151],{},[19,1152,1153],{},"交互",[185,1155,1156],{},"内联 script，靠 CDN",[185,1158,1159],{},"完整的 Vue 响应式生态",[170,1161,1162,1167,1173],{},[185,1163,1164],{},[19,1165,1166],{},"路由",[185,1168,1169,1172],{},[724,1170,1171],{},"_config.yml"," permalink 配置",[185,1174,1175],{},"文件系统路由，动态参数",[94,1177,1179],{"id":1178},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,1181,1182,1183,1186],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[19,1184,1185],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[94,1188,1190],{"id":1189},"vue-生态的开发体验","Vue 生态的开发体验",[15,1192,1193,1194,1197,1198,1201,1202,1205],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[724,1195,1196],{},"useAsyncData"," + ",[724,1199,1200],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[724,1203,1204],{},"\u003Cscript>"," 标签。",[62,1207],{},[10,1209,1210],{"id":1210},"迁移过程",[94,1212,1214],{"id":1213},"内容层零改动搬过来","内容层：零改动搬过来",[15,1216,1217,1218,1221,1222,1225],{},"所有 markdown 文件从 Hexo 的 ",[724,1219,1220],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[724,1223,1224],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[1227,1228,1233],"pre",{"className":1229,"code":1231,"language":1232},[1230],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[724,1234,1231],{"__ignoreMap":285},[15,1236,1237,1238,1241,1242,1245],{},"多了 ",[724,1239,1240],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[724,1243,1244],{},"tags","。内容正文一个字没改。",[94,1247,1249],{"id":1248},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,1251,1252,1253,1255],{},"Hexo 的 URL 靠 ",[724,1254,1171],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[1227,1257,1260],{"className":1258,"code":1259,"language":1232},[1230],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[724,1261,1259],{"__ignoreMap":285},[15,1263,1264,1265,1268,1269,1272,1273,1276,1277,1280],{},"Nuxt 路由由 ",[724,1266,1267],{},"pages\u002F"," 目录结构决定，",[724,1270,1271],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[724,1274,1275],{},"trailingSlash: true"," 保证 URL 一致性，",[724,1278,1279],{},"[...slug].vue"," 兜底 404。",[94,1282,1284],{"id":1283},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,1286,1287],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[94,1289,1291],{"id":1290},"部署ci-保持不变","部署：CI 保持不变",[15,1293,1294,1295,1297,1298,22],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[724,1296,1073],{}," 替换为 ",[724,1299,1300],{},"npm run build",[62,1302],{},[10,1304,1305],{"id":1305},"架构对比",[94,1307,1309],{"id":1308},"hexo-的架构","Hexo 的架构",[1227,1311,1314],{"className":1312,"code":1313,"language":1232},[1230],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[724,1315,1313],{"__ignoreMap":285},[15,1317,1318,1319,1322,1323,1325,1326,1329],{},"Hexo 是",[19,1320,1321],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[724,1324,1171],{},"、",[724,1327,1328],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[94,1331,1333],{"id":1332},"nuxt-的架构","Nuxt 的架构",[1227,1335,1338],{"className":1336,"code":1337,"language":1232},[1230],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[724,1339,1337],{"__ignoreMap":285},[15,1341,1342,1343,1346,1347,1349,1350,1352,1353,1356],{},"Nuxt 是",[19,1344,1345],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[724,1348,1200],{}," 查询内容，",[724,1351,1196],{}," 管理异步数据，",[724,1354,1355],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[94,1358,1359],{"id":1359},"数据流对比",[164,1361,1362,1374],{},[167,1363,1364],{},[170,1365,1366,1369,1371],{},[173,1367,1368],{},"环节",[173,1370,1102],{},[173,1372,1373],{},"Nuxt",[180,1375,1376,1389,1402,1418,1429],{},[170,1377,1378,1381,1384],{},[185,1379,1380],{},"内容获取",[185,1382,1383],{},"读文件 → 模板注入变量",[185,1385,1386],{},[724,1387,1388],{},"queryCollection('posts').all()",[170,1390,1391,1394,1397],{},[185,1392,1393],{},"数据管理",[185,1395,1396],{},"无，模板即数据",[185,1398,1399,1401],{},[724,1400,1196],{}," + 响应式",[170,1403,1404,1407,1412],{},[185,1405,1406],{},"站点配置",[185,1408,1409,1411],{},[724,1410,1171],{}," + 主题 config",[185,1413,1414,1417],{},[724,1415,1416],{},"useSite()"," composable",[170,1419,1420,1423,1426],{},[185,1421,1422],{},"主题",[185,1424,1425],{},"Stylus 变量 → 编译到 CSS",[185,1427,1428],{},"CSS 自定义属性 → 运行时切换",[170,1430,1431,1434,1437],{},[185,1432,1433],{},"交互状态",[185,1435,1436],{},"全局变量 + DOM 操作",[185,1438,1439],{},"Vue 响应式 + composables",[94,1441,1442],{"id":1442},"预渲染策略",[15,1444,1445,1446,1448],{},"Hexo 每次 ",[724,1447,1073],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,1450,1451,1452,1455,1456,1459,1460,1463,1464,1467,1468,1471],{},"Nitro 的 ",[724,1453,1454],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[724,1457,1458],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[19,1461,1462],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[724,1465,1466],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[724,1469,1470],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[1227,1473,1477],{"className":1474,"code":1475,"language":1476,"meta":285,"style":285},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[724,1478,1479,1492,1507,1538],{"__ignoreMap":285},[1480,1481,1484,1488],"span",{"class":1482,"line":1483},"line",1,[1480,1485,1487],{"class":1486},"sVyAn","prerender",[1480,1489,1491],{"class":1490},"sn6KH",": {\n",[1480,1493,1494,1497,1500,1504],{"class":1482,"line":671},[1480,1495,1496],{"class":1486},"  crawlLinks",[1480,1498,1499],{"class":1490},": ",[1480,1501,1503],{"class":1502},"sVC51","true",[1480,1505,1506],{"class":1490},",\n",[1480,1508,1509,1512,1515,1519,1522,1525,1527,1530,1532,1535],{"class":1482,"line":677},[1480,1510,1511],{"class":1486},"  routes",[1480,1513,1514],{"class":1490},": [",[1480,1516,1518],{"class":1517},"subq3","'\u002F'",[1480,1520,1521],{"class":1490},", ",[1480,1523,1524],{"class":1517},"'\u002Fabout'",[1480,1526,1521],{"class":1490},[1480,1528,1529],{"class":1517},"'\u002Fposts'",[1480,1531,1521],{"class":1490},[1480,1533,1534],{"class":1517},"'\u002Flinks'",[1480,1536,1537],{"class":1490},"],\n",[1480,1539,1541],{"class":1482,"line":1540},4,[1480,1542,1543],{"class":1490},"}\n",[10,1545,1546],{"id":1546},"迁移成本远低于预期",[15,1548,1549],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[32,1551,1552,1555,1558],{},[35,1553,1554],{},"搭建 Nuxt 项目骨架",[35,1556,1557],{},"设计 CSS token 系统",[35,1559,1560],{},"编写几个核心组件",[15,1562,1563],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[62,1565],{},[10,1567,1568],{"id":1568},"总结",[15,1570,1571],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,1573,1574,1577],{},[19,1575,1576],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[1579,1580,1581],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":285,"searchDepth":671,"depth":671,"links":1583},[1584,1588,1592,1598,1604,1605],{"id":1046,"depth":671,"text":10