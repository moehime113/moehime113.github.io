[{"data":1,"prerenderedAt":1850},["ShallowReactive",2],{"post-lsh-minhash-deduplication":3,"all-posts":670},{"id":4,"title":5,"body":6,"categories":659,"cover":659,"date":660,"description":661,"extension":662,"meta":663,"navigation":665,"path":666,"seo":667,"stem":668,"tags":659,"__hash__":669},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":7,"value":8,"toc":637},"minimark",[9,14,22,25,30,41,44,54,57,61,88,90,94,97,100,117,120,122,126,129,188,191,194,200,202,206,212,216,219,222,225,228,232,235,243,246,253,256,259,264,268,391,394,396,400,403,407,410,413,416,424,428,431,522,525,529,532,535,538,540,544,547,591,594,599,601,605,631],[10,11,13],"h1",{"id":12},"lsh算法原理讲解","LSH算法原理讲解",[15,16,17,21],"p",{},[18,19,20],"strong",{},"目标","：在海量文本中快速发现相似文档，避免 $O(n^2)$ 的全量两两比较。",[23,24],"hr",{},[26,27,29],"h2",{"id":28},"_0-算法背景lsh解决了什么痛点","0. 算法背景：LSH解决了什么痛点？",[15,31,32,33,36,37,40],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[18,34,35],{},"计算代价是否可接受","。",[38,39],"br",{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[15,42,43],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[45,46,47,51],"ul",{},[48,49,50],"li",{},"使高相似对象以较高概率落入同一桶（进入候选集）",[48,52,53],{},"使低相似对象以较高概率在早期被过滤",[15,55,56],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[58,59,60],"h3",{"id":60},"常见应用领域",[62,63,64,70,76,82],"ol",{},[48,65,66,69],{},[18,67,68],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[48,71,72,75],{},[18,73,74],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[48,77,78,81],{},[18,79,80],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[48,83,84,87],{},[18,85,86],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[23,89],{},[26,91,93],{"id":92},"_1-示例文本集合","1. 示例文本集合",[15,95,96],{},"设文档集合：",[15,98,99],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[45,101,102,105,108,111,114],{},[48,103,104],{},"$d_1=\\text{“今天天气很好”}$",[48,106,107],{},"$d_2=\\text{“今天天气非常好”}$",[48,109,110],{},"$d_3=\\text{“昨天天气很差”}$",[48,112,113],{},"$d_4=\\text{“今天天气很好”}$",[48,115,116],{},"$d_5=\\text{“机器学习很有趣”}$",[15,118,119],{},"直观上，$d_1$ 与 $d_4$ 完全相同，$d_1$ 与 $d_2$ 高度相似，其余组合的相似度较低。",[23,121],{},[26,123,125],{"id":124},"_2-shingling文本-q-gram集合","2. Shingling（文本 → q-gram集合）",[15,127,128],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[130,131,132,145],"table",{},[133,134,135],"thead",{},[136,137,138,142],"tr",{},[139,140,141],"th",{},"文本",[139,143,144],{},"3-gram集合",[146,147,148,157,165,173,180],"tbody",{},[136,149,150,154],{},[151,152,153],"td",{},"d1",[151,155,156],{},"{今天天, 天天气, 天气很, 气很好}",[136,158,159,162],{},[151,160,161],{},"d2",[151,163,164],{},"{今天天, 天天气, 天气非, 气非常, 非常好}",[136,166,167,170],{},[151,168,169],{},"d3",[151,171,172],{},"{昨天天, 天天气, 天气很, 气很差}",[136,174,175,178],{},[151,176,177],{},"d4",[151,179,156],{},[136,181,182,185],{},[151,183,184],{},"d5",[151,186,187],{},"{机器学, 学习很, 习很有, 很有趣}",[15,189,190],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[15,192,193],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[195,196,197],"blockquote",{},[15,198,199],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[23,201],{},[26,203,205],{"id":204},"_3-minhash集合-签名向量","3. MinHash（集合 → 签名向量）",[15,207,208,211],{},[18,209,210],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[58,213,215],{"id":214},"_31-构造方式","3.1 构造方式",[15,217,218],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[15,220,221],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[15,223,224],{},"于是签名向量为：",[15,226,227],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[58,229,231],{"id":230},"_32-为什么可行","3.2 为什么可行",[15,233,234],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[15,236,237,238,242],{},"$$\n\\Pr",[239,240,241],"span",{},"m_h(A)=m_h(B)"," = J(A,B)\n$$",[15,244,245],{},"用 $k$ 个哈希后，可得无偏估计量：",[15,247,248,249,252],{},"$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_^k \\mathbf{1}",[239,250,251],{},"m_(A)=m_(B)","\n$$",[15,254,255],{},"方差为：",[15,257,258],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[195,260,261],{},[15,262,263],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[58,265,267],{"id":266},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[130,269,270,291],{},[133,271,272],{},[136,273,274,276,278,280,282,285,288],{},[139,275,141],{},[139,277,10],{},[139,279,26],{},[139,281,58],{},[139,283,284],{},"h4",[139,286,287],{},"h5",[139,289,290],{},"h6",[146,292,293,315,333,354,370],{},[136,294,295,297,300,303,306,309,312],{},[151,296,153],{},[151,298,299],{},"12",[151,301,302],{},"7",[151,304,305],{},"5",[151,307,308],{},"20",[151,310,311],{},"11",[151,313,314],{},"3",[136,316,317,319,321,323,326,329,331],{},[151,318,161],{},[151,320,299],{},[151,322,302],{},[151,324,325],{},"6",[151,327,328],{},"21",[151,330,311],{},[151,332,314],{},[136,334,335,337,340,343,346,349,351],{},[151,336,169],{},[151,338,339],{},"2",[151,341,342],{},"15",[151,344,345],{},"8",[151,347,348],{},"19",[151,350,302],{},[151,352,353],{},"4",[136,355,356,358,360,362,364,366,368],{},[151,357,177],{},[151,359,299],{},[151,361,302],{},[151,363,305],{},[151,365,308],{},[151,367,311],{},[151,369,314],{},[136,371,372,374,377,380,383,386,389],{},[151,373,184],{},[151,375,376],{},"30",[151,378,379],{},"14",[151,381,382],{},"22",[151,384,385],{},"33",[151,387,388],{},"28",[151,390,305],{},[15,392,393],{},"可以看出：$d_1$ 与 $d_4$ 完全一致，$d_1$ 与 $d_2$ 大部分行一致，符合直觉。",[23,395],{},[26,397,399],{"id":398},"_4-lsh-banding签名矩阵-候选对","4. LSH Banding（签名矩阵 → 候选对）",[15,401,402],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[58,404,406],{"id":405},"_41-切分规则","4.1 切分规则",[15,408,409],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[15,411,412],{},"$$\nk=b\\cdot r\n$$",[15,414,415],{},"例如：$k=6,b=2,r=3$。",[45,417,418,421],{},[48,419,420],{},"Band 1: $(h_1,h_2,h_3)$",[48,422,423],{},"Band 2: $(h_4,h_5,h_6)$",[58,425,427],{"id":426},"_42-候选判定","4.2 候选判定",[15,429,430],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[130,432,433,446],{},[133,434,435],{},[136,436,437,440,443],{},[139,438,439],{},"Band",[139,441,442],{},"桶",[139,444,445],{},"文档",[146,447,448,459,468,477,486,495,504,513],{},[136,449,450,453,456],{},[151,451,452],{},"1",[151,454,455],{},"B1-1",[151,457,458],{},"d1, d4",[136,460,461,463,466],{},[151,462,452],{},[151,464,465],{},"B1-2",[151,467,161],{},[136,469,470,472,475],{},[151,471,452],{},[151,473,474],{},"B1-3",[151,476,169],{},[136,478,479,481,484],{},[151,480,452],{},[151,482,483],{},"B1-4",[151,485,184],{},[136,487,488,490,493],{},[151,489,339],{},[151,491,492],{},"B2-1",[151,494,458],{},[136,496,497,499,502],{},[151,498,339],{},[151,500,501],{},"B2-2",[151,503,161],{},[136,505,506,508,511],{},[151,507,339],{},[151,509,510],{},"B2-3",[151,512,169],{},[136,514,515,517,520],{},[151,516,339],{},[151,518,519],{},"B2-4",[151,521,184],{},[15,523,524],{},"因此 $d_1,d_4$ 会被稳定召回为候选。",[58,526,528],{"id":527},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[15,530,531],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[15,533,534],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[15,536,537],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[23,539],{},[26,541,543],{"id":542},"_5-精确验证候选对-最终结果","5. 精确验证（候选对 → 最终结果）",[15,545,546],{},"对候选集合中的文档对再计算真实 Jaccard：",[130,548,549,565],{},[133,550,551],{},[136,552,553,556,559,562],{},[139,554,555],{},"文本对",[139,557,558],{},"交集大小",[139,560,561],{},"并集大小",[139,563,564],{},"Jaccard",[146,566,567,579],{},[136,568,569,572,574,576],{},[151,570,571],{},"d1,d4",[151,573,353],{},[151,575,353],{},[151,577,578],{},"1.0",[136,580,581,584,586,588],{},[151,582,583],{},"d1,d2",[151,585,314],{},[151,587,305],{},[151,589,590],{},"0.6",[15,592,593],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[195,595,596],{},[15,597,598],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[23,600],{},[26,602,604],{"id":603},"_6-算法直观总结","6. 算法直观总结",[62,606,607,613,619,625],{},[48,608,609,612],{},[18,610,611],{},"Shingling","：把文本变成可比较的集合表示。",[48,614,615,618],{},[18,616,617],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[48,620,621,624],{},[18,622,623],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[48,626,627,630],{},[18,628,629],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[15,632,633,636],{},[18,634,635],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":638,"searchDepth":639,"depth":639,"links":640},"",2,[641,645,646,647,652,657,658],{"id":28,"depth":639,"text":29,"children":642},[643],{"id":60,"depth":644,"text":60},3,{"id":92,"depth":639,"text":93},{"id":124,"depth":639,"text":125},{"id":204,"depth":639,"text":205,"children":648},[649,650,651],{"id":214,"depth":644,"text":215},{"id":230,"depth":644,"text":231},{"id":266,"depth":644,"text":267},{"id":398,"depth":639,"text":399,"children":653},[654,655,656],{"id":405,"depth":644,"text":406},{"id":426,"depth":644,"text":427},{"id":527,"depth":644,"text":528},{"id":542,"depth":639,"text":543},{"id":603,"depth":639,"text":604},null,"2026-05-19","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用","md",{"caver":664},"\u002Fimg\u002Fpostcard3.jpg",true,"\u002Fposts\u002Flsh-minhash-deduplication",{"title":5,"description":661},"posts\u002Flsh-minhash-deduplication","CPt90-O0t4_W9HZZVR7dUXrW3KsRLmOyQRQfyzd6Zb8",[671,1246,1726],{"id":672,"title":673,"body":674,"categories":659,"cover":1238,"date":1239,"description":1240,"extension":662,"meta":1241,"navigation":665,"path":1242,"seo":1243,"stem":1244,"tags":659,"__hash__":1245},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":675,"toc":1214},[676,680,683,687,690,697,700,712,714,718,725,809,813,820,824,839,841,844,848,859,868,879,883,889,895,914,918,921,925,934,936,939,943,949,963,967,973,990,993,1073,1076,1082,1105,1176,1179,1182,1193,1196,1198,1201,1204,1210],[26,677,679],{"id":678},"为什么要离开-hexo","为什么要离开 Hexo？",[15,681,682],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[58,684,686],{"id":685},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,688,689],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,691,692,693,696],{},"问题根源在于：",[18,694,695],{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[58,698,699],{"id":699},"构建速度与生态",[15,701,702,703,707,708,711],{},"文章数量上来之后，",[704,705,706],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[18,709,710],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[23,713],{},[26,715,717],{"id":716},"为什么选-nuxt","为什么选 Nuxt？",[15,719,720,721,724],{},"看过 VitePress、Astro、Next.js，最终选了 ",[18,722,723],{},"Nuxt 4 SSG","。核心考量：",[130,726,727,739],{},[133,728,729],{},[136,730,731,733,736],{},[139,732],{},[139,734,735],{},"Hexo",[139,737,738],{},"Nuxt 4",[146,740,741,754,767,780,793],{},[136,742,743,748,751],{},[151,744,745],{},[18,746,747],{},"构建机制",[151,749,750],{},"CLI 全量生成静态文件",[151,752,753],{},"Nitro 引擎预渲染 + 增量构建",[136,755,756,761,764],{},[151,757,758],{},[18,759,760],{},"模板\u002F组件",[151,762,763],{},"EJS\u002FPug，无组件化",[151,765,766],{},"Vue 3 组件，自动导入",[136,768,769,774,777],{},[151,770,771],{},[18,772,773],{},"内容管理",[151,775,776],{},"front-matter + markdown",[151,778,779],{},"@nuxt\u002Fcontent v3，类型安全查询",[136,781,782,787,790],{},[151,783,784],{},[18,785,786],{},"交互",[151,788,789],{},"内联 script，靠 CDN",[151,791,792],{},"完整的 Vue 响应式生态",[136,794,795,800,806],{},[151,796,797],{},[18,798,799],{},"路由",[151,801,802,805],{},[704,803,804],{},"_config.yml"," permalink 配置",[151,807,808],{},"文件系统路由，动态参数",[58,810,812],{"id":811},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,814,815,816,819],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[18,817,818],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[58,821,823],{"id":822},"vue-生态的开发体验","Vue 生态的开发体验",[15,825,826,827,830,831,834,835,838],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[704,828,829],{},"useAsyncData"," + ",[704,832,833],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[704,836,837],{},"\u003Cscript>"," 标签。",[23,840],{},[26,842,843],{"id":843},"迁移过程",[58,845,847],{"id":846},"内容层零改动搬过来","内容层：零改动搬过来",[15,849,850,851,854,855,858],{},"所有 markdown 文件从 Hexo 的 ",[704,852,853],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[704,856,857],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[860,861,866],"pre",{"className":862,"code":864,"language":865},[863],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[704,867,864],{"__ignoreMap":638},[15,869,870,871,874,875,878],{},"多了 ",[704,872,873],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[704,876,877],{},"tags","。内容正文一个字没改。",[58,880,882],{"id":881},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,884,885,886,888],{},"Hexo 的 URL 靠 ",[704,887,804],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[860,890,893],{"className":891,"code":892,"language":865},[863],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[704,894,892],{"__ignoreMap":638},[15,896,897,898,901,902,905,906,909,910,913],{},"Nuxt 路由由 ",[704,899,900],{},"pages\u002F"," 目录结构决定，",[704,903,904],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[704,907,908],{},"trailingSlash: true"," 保证 URL 一致性，",[704,911,912],{},"[...slug].vue"," 兜底 404。",[58,915,917],{"id":916},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,919,920],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[58,922,924],{"id":923},"部署ci-保持不变","部署：CI 保持不变",[15,926,927,928,930,931,36],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[704,929,706],{}," 替换为 ",[704,932,933],{},"npm run build",[23,935],{},[26,937,938],{"id":938},"架构对比",[58,940,942],{"id":941},"hexo-的架构","Hexo 的架构",[860,944,947],{"className":945,"code":946,"language":865},[863],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[704,948,946],{"__ignoreMap":638},[15,950,951,952,955,956,958,959,962],{},"Hexo 是",[18,953,954],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[704,957,804],{},"、",[704,960,961],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[58,964,966],{"id":965},"nuxt-的架构","Nuxt 的架构",[860,968,971],{"className":969,"code":970,"language":865},[863],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[704,972,970],{"__ignoreMap":638},[15,974,975,976,979,980,982,983,985,986,989],{},"Nuxt 是",[18,977,978],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[704,981,833],{}," 查询内容，",[704,984,829],{}," 管理异步数据，",[704,987,988],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[58,991,992],{"id":992},"数据流对比",[130,994,995,1007],{},[133,996,997],{},[136,998,999,1002,1004],{},[139,1000,1001],{},"环节",[139,1003,735],{},[139,1005,1006],{},"Nuxt",[146,1008,1009,1022,1035,1051,1062],{},[136,1010,1011,1014,1017],{},[151,1012,1013],{},"内容获取",[151,1015,1016],{},"读文件 → 模板注入变量",[151,1018,1019],{},[704,1020,1021],{},"queryCollection('posts').all()",[136,1023,1024,1027,1030],{},[151,1025,1026],{},"数据管理",[151,1028,1029],{},"无，模板即数据",[151,1031,1032,1034],{},[704,1033,829],{}," + 响应式",[136,1036,1037,1040,1045],{},[151,1038,1039],{},"站点配置",[151,1041,1042,1044],{},[704,1043,804],{}," + 主题 config",[151,1046,1047,1050],{},[704,1048,1049],{},"useSite()"," composable",[136,1052,1053,1056,1059],{},[151,1054,1055],{},"主题",[151,1057,1058],{},"Stylus 变量 → 编译到 CSS",[151,1060,1061],{},"CSS 自定义属性 → 运行时切换",[136,1063,1064,1067,1070],{},[151,1065,1066],{},"交互状态",[151,1068,1069],{},"全局变量 + DOM 操作",[151,1071,1072],{},"Vue 响应式 + composables",[58,1074,1075],{"id":1075},"预渲染策略",[15,1077,1078,1079,1081],{},"Hexo 每次 ",[704,1080,706],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,1083,1084,1085,1088,1089,1092,1093,1096,1097,1100,1101,1104],{},"Nitro 的 ",[704,1086,1087],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[704,1090,1091],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[18,1094,1095],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[704,1098,1099],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[704,1102,1103],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[860,1106,1110],{"className":1107,"code":1108,"language":1109,"meta":638,"style":638},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[704,1111,1112,1124,1139,1170],{"__ignoreMap":638},[239,1113,1116,1120],{"class":1114,"line":1115},"line",1,[239,1117,1119],{"class":1118},"sVyAn","prerender",[239,1121,1123],{"class":1122},"sn6KH",": {\n",[239,1125,1126,1129,1132,1136],{"class":1114,"line":639},[239,1127,1128],{"class":1118},"  crawlLinks",[239,1130,1131],{"class":1122},": ",[239,1133,1135],{"class":1134},"sVC51","true",[239,1137,1138],{"class":1122},",\n",[239,1140,1141,1144,1147,1151,1154,1157,1159,1162,1164,1167],{"class":1114,"line":644},[239,1142,1143],{"class":1118},"  routes",[239,1145,1146],{"class":1122},": [",[239,1148,1150],{"class":1149},"subq3","'\u002F'",[239,1152,1153],{"class":1122},", ",[239,1155,1156],{"class":1149},"'\u002Fabout'",[239,1158,1153],{"class":1122},[239,1160,1161],{"class":1149},"'\u002Fposts'",[239,1163,1153],{"class":1122},[239,1165,1166],{"class":1149},"'\u002Flinks'",[239,1168,1169],{"class":1122},"],\n",[239,1171,1173],{"class":1114,"line":1172},4,[239,1174,1175],{"class":1122},"}\n",[26,1177,1178],{"id":1178},"迁移成本远低于预期",[15,1180,1181],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[62,1183,1184,1187,1190],{},[48,1185,1186],{},"搭建 Nuxt 项目骨架",[48,1188,1189],{},"设计 CSS token 系统",[48,1191,1192],{},"编写几个核心组件",[15,1194,1195],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[23,1197],{},[26,1199,1200],{"id":1200},"总结",[15,1202,1203],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,1205,1206,1209],{},[18,1207,1208],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[1211,1212,1213],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":638,"searchDepth":639,"depth":639,"links":1215},[1216,1220,1224,1230,1236,1237],{"id":678,"depth":639,"text":679,"children":1217},[1218,1219],{"id":685,"depth":644,"text":686},{"id":699,"depth":644,"text":699},{"id":716,"depth":639,"text":717,"children":1221},[1222,1223],{"id":811,"depth":644,"text":812},{"id":822,"depth":644,"text":823},{"id":843,"depth":639,"text":843,"children":1225},[1226,1227,1228,1229],{"id":846,"depth":644,"text":847},{"id":881,"depth":644,"text":882},{"id":916,"depth":644,"text":917},{"id":923,"depth":644,"text":924},{"id":938,"depth":639,"text":938,"children":1231},[1232,1233,1234,1235],{"id":941,"depth":644,"text":942},{"id":965,"depth":644,"text":966},{"id":992,"depth":644,"text":992},{"id":1075,"depth":644,"text":1075},{"id":1178,"depth":639,"text":1178},{"id":1200,"depth":639,"text":1200},"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":673,"description":1240},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-