7],{},[30,1220,441],{},[41,1222,445],{},[41,1224,449],{},[204,1226,1227],{"className":453,"code":454,"language":455,"meta":212,"style":212},[41,1228,1229,1235,1245,1267],{"__ignoreMap":212},[459,1230,1231,1233],{"class":461,"line":462},[459,1232,466],{"class":465},[459,1234,470],{"class":469},[459,1236,1237,1239,1241,1243],{"class":461,"line":473},[459,1238,476],{"class":465},[459,1240,479],{"class":469},[459,1242,483],{"class":482},[459,1244,486],{"class":469},[459,1246,1247,1249,1251,1253,1255,1257,1259,1261,1263,1265],{"class":461,"line":489},[459,1248,492],{"class":465},[459,1250,495],{"class":469},[459,1252,499],{"class":498},[459,1254,502],{"class":469},[459,1256,505],{"class":498},[459,1258,502],{"class":469},[459,1260,510],{"class":498},[459,1262,502],{"class":469},[459,1264,515],{"class":498},[459,1266,518],{"class":469},[459,1268,1269],{"class":461,"line":521},[459,1270,524],{"class":469},[10,1272,527],{"id":527},[15,1274,530],{},[532,1276,1277,1279,1281],{},[535,1278,537],{},[535,1280,540],{},[535,1282,543],{},[15,1284,546],{},[50,1286],{},[10,1288,551],{"id":551},[15,1290,554],{},[15,1292,1293,560],{},[30,1294,559],{},[562,1296,564],{},{"title":212,"searchDepth":473,"depth":473,"links":1298},[1299,1303,1307,1313,1319,1320],{"id":12,"depth":473,"text":13,"children":1300},[1301,1302],{"id":21,"depth":489,"text":22},{"id":36,"depth":489,"text":36},{"id":54,"depth":473,"text":55,"children":1304},[1305,1306],{"id":155,"depth":489,"text":156},{"id":166,"depth":489,"text":167},{"id":187,"depth":473,"text":187,"children":1308},[1309,1310,1311,1312],{"id":190,"depth":489,"text":191},{"id":226,"depth":489,"text":227},{"id":261,"depth":489,"text":262},{"id":268,"depth":489,"text":269},{"id":284,"depth":473,"text":284,"children":1314},[1315,1316,1317,1318],{"id":287,"depth":489,"text":288},{"id":311,"depth":489,"text":312},{"id":338,"depth":489,"text":338},{"id":421,"depth":489,"text":421},{"id":527,"depth":473,"text":527},{"id":551,"depth":473,"text":551},{},{"title":5,"description":592},{"id":1324,"title":1325,"body":1326,"categories":589,"cover":1992,"date":931,"description":1993,"extension":593,"meta":1994,"navigation":595,"path":1995,"seo":1996,"stem":1997,"tags":589,"__hash__":1998},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":7,"value":1327,"toc":1972},[1328,1332,1338,1341,1346,1360,1367,1374,1376,1380,1389,1392,1400,1403,1406,1432,1434,1437,1440,1443,1460,1463,1465,1469,1472,1526,1529,1532,1538,1540,1544,1550,1554,1557,1560,1563,1566,1570,1573,1576,1582,1585,1589,1592,1595,1600,1604,1727,1730,1732,1736,1739,1743,1746,1749,1752,1760,1764,1767,1859,1862,1866,1869,1872,1875,1877,1881,1884,1927,1930,1935,1937,1940,1966],[10,1329,1331],{"id":1330},"前置知识什么是哈希hash算法","前置知识：什么是哈希（Hash）算法？",[15,1333,1334,1335,279],{},"在深入 LSH 之前，我们需要先理解基础的",[30,1336,1337],{},"哈希算法",[15,1339,1340],{},"简单来说，哈希函数（Hash Function）就像是一个“数字指纹生成器”。它接收任意长度的数据（如一段文本、一篇文档），并将其映射为一个固定长度的较短字符串或数值（即哈希值或签名）。",[15,1342,1343],{},[30,1344,1345],{},"传统哈希算法（如 MD5、SHA-256）的核心特征是：",[532,1347,1348,1354],{},[535,1349,1350,1353],{},[30,1351,1352],{},"唯一性与确定性","：绝对相同的输入，一定会得到完全相同的哈希值。",[535,1355,1356,1359],{},[30,1357,1358],{},"雪崩效应","：输入数据哪怕仅仅改变了一个标点符号，输出的哈希值也会变得面目全非、毫无规律。这在密码学中非常重要，能用来保证数据未被篡改。",[15,1361,1362,1363,1366],{},"然而，传统哈希的“雪崩效应”在",[30,1364,1365],{},"相似度检索","任务中反而成为了阻碍。如果我们想通过比对哈希值来判断两篇文章是否相似，传统哈希算法完全无能为力——因为两篇高度相似但不完全相同的文章，它们的哈希值是截然不同且没有任何关联的。",[15,1368,1369,1370,1373],{},"这也恰恰引出了本文的主角——",[30,1371,1372],{},"LSH（局部敏感哈希）","。它一反常态，特意设计出了一种**“让越相似的数据，越容易产生相同的哈希值（即越容易发生碰撞）”**的过滤机制。",[50,1375],{},[10,1377,1379],{"id":1378},"算法背景lsh解决了什么痛点","算法背景：LSH解决了什么痛点？",[15,1381,1382,1383,279,1386,1388],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[30,1384,1385],{},"计算代价是否可接受",[712,1387],{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[15,1390,1391],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[680,1393,1394,1397],{},[535,1395,1396],{},"使高相似对象以较高概率落入同一桶（进入候选集）",[535,1398,1399],{},"使低相似对象以较高概率在早期被过滤",[15,1401,1402],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[19,1404,1405],{"id":1405},"常见应用领域",[532,1407,1408,1414,1420,1426],{},[535,1409,1410,1413],{},[30,1411,1412],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[535,1415,1416,1419],{},[30,1417,1418],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[535,1421,1422,1425],{},[30,1423,1424],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[535,1427,1428,1431],{},[30,1429,1430],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[50,1433],{},[10,1435,1436],{"id":1436},"示例文本集合",[15,1438,1439],{},"设文档集合：",[15,1441,1442],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[680,1444,1445,1448,1451,1454,1457],{},[535,1446,1447],{},"$d_1=\\text{“今天北京天气很好”}$",[535,1449,1450],{},"$d_2=\\text{“今天北京天气真好”}$",[535,1452,1453],{},"$d_3=\\text{“昨天上海天气很差”}$",[535,1455,1456],{},"$d_4=\\text{“今天北京天气挺好”}$",[535,1458,1459],{},"$d_5=\\text{“深度学习推荐系统”}$",[15,1461,1462],{},"直观上，$d_1$、$d_2$ 和 $d_4$ 句式高度相似（仅一字之差），而 $d_3$、$d_5$ 语义或结构上有显著差异。",[50,1464],{},[10,1466,1468],{"id":1467},"shingling文本-q-gram集合","Shingling（文本 → q-gram集合）",[15,1470,1471],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[64,1473,1474,1484],{},[67,1475,1476],{},[70,1477,1478,1481],{},[73,1479,1480],{},"文本",[73,1482,1483],{},"3-gram集合",[82,1485,1486,1494,1502,1510,1518],{},[70,1487,1488,1491],{},[87,1489,1490],{},"d1",[87,1492,1493],{},"{今天北, 天北京, 北京天, 京天气, 天气很, 气很好}",[70,1495,1496,1499],{},[87,1497,1498],{},"d2",[87,1500,1501],{},"{今天北, 天北京, 北京天, 京天气, 天气真, 气真好}",[70,1503,1504,1507],{},[87,1505,1506],{},"d3",[87,1508,1509],{},"{昨天上, 天上海, 上海天, 海天气, 天气很, 气很差}",[70,1511,1512,1515],{},[87,1513,1514],{},"d4",[87,1516,1517],{},"{今天北, 天北京, 北京天, 京天气, 天气挺, 气挺好}",[70,1519,1520,1523],{},[87,1521,1522],{},"d5",[87,1524,1525],{},"{深度学, 度学习, 学习推, 习推荐, 推荐系, 荐系统}",[15,1527,1528],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[15,1530,1531],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[1533,1534,1535],"blockquote",{},[15,1536,1537],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[50,1539],{},[10,1541,1543],{"id":1542},"minhash集合-签名向量","MinHash（集合 → 签名向量）",[15,1545,1546,1549],{},[30,1547,1548],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[19,1551,1553],{"id":1552},"_31-构造方式","3.1 构造方式",[15,1555,1556],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[15,1558,1559],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[15,1561,1562],{},"于是签名向量为：",[15,1564,1565],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[19,1567,1569],{"id":1568},"_32-为什么可行","3.2 为什么可行",[15,1571,1572],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[15,1574,1575],{},"$$\nP(m_h(A)=m_h(B)) = J(A,B)\n$$",[15,1577,1578,1581],{},[30,1579,1580],{},"简要证明","：\n哈希函数 $h$ 相当于对全集元素做了一次随机排列。考察两集合的并集 $A \\cup B$ 中的所有元素：\n要使 $m_h(A) = m_h(B)$，意味着 $A \\cup B$ 中经过哈希映射后值最小（即排在“最前面”）的那个元素，必须既属于 $A$ 也属于 $B$，也就是说必须属于交集 $A \\cap B$。\n因为哈希是完全随机的，$A \\cup B$ 中的每一个元素成为最小值的概率是完全相等的。所以这个最小元素正好属于交集 $A \\cap B$ 的概率，就是交集元素个数占并集元素个数的比例，即 $\\frac{|A \\cap B|}{|A \\cup B|} = J(A,B)$。",[15,1583,1584],{},"用 $k$ 个哈希后，可得无偏估计量：",[1586,1587,1588],"div",{"v-pre":212},"\n$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_{i=1}^{k} I[m_i(A)=m_i(B)]\n$$\n",[15,1590,1591],{},"方差为：",[15,1593,1594],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[1533,1596,1597],{},[15,1598,1599],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[19,1601,1603],{"id":1602},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[64,1605,1606,1628],{},[67,1607,1608],{},[70,1609,1610,1612,1615,1617,1619,1622,1625],{},[73,1611,1480],{},[73,1613,1614],{},"h1",[73,1616,10],{},[73,1618,19],{},[73,1620,1621],{},"h4",[73,1623,1624],{},"h5",[73,1626,1627],{},"h6",[82,1629,1630,1652,1669,1690,1706],{},[70,1631,1632,1634,1637,1640,1643,1646,1649],{},[87,1633,1490],{},[87,1635,1636],{},"12",[87,1638,1639],{},"7",[87,1641,1642],{},"5",[87,1644,1645],{},"20",[87,1647,1648],{},"11",[87,1650,1651],{},"3",[70,1653,1654,1656,1658,1660,1663,1665,1667],{},[87,1655,1498],{},[87,1657,1636],{},[87,1659,1639],{},[87,1661,1662],{},"6",[87,1664,1645],{},[87,1666,1648],{},[87,1668,1651],{},[70,1670,1671,1673,1676,1679,1682,1685,1687],{},[87,1672,1506],{},[87,1674,1675],{},"2",[87,1677,1678],{},"15",[87,1680,1681],{},"8",[87,1683,1684],{},"19",[87,1686,1639],{},[87,1688,1689],{},"4",[70,1691,1692,1694,1696,1698,1700,1702,1704],{},[87,1693,1514],{},[87,1695,1636],{},[87,1697,1639],{},[87,1699,1642],{},[87,1701,1684],{},[87,1703,1678],{},[87,1705,1681],{},[70,1707,1708,1710,1713,1716,1719,1722,1725],{},[87,1709,1522],{},[87,1711,1712],{},"30",[87,1714,1715],{},"14",[87,1717,1718],{},"22",[87,1720,1721],{},"33",[87,1723,1724],{},"28",[87,1726,1642],{},[15,1728,1729],{},"可以看出：$d_1$ 与 $d_4$ 在前三个哈希函数取值一致，而与 $d_2$ 在后三个哈希函数取值一致，这反映了它们较高的相似度。",[50,1731],{},[10,1733,1735],{"id":1734},"lsh-banding签名矩阵-候选对","LSH Banding（签名矩阵 → 候选对）",[15,1737,1738],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[19,1740,1742],{"id":1741},"_41-切分规则","4.1 切分规则",[15,1744,1745],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[15,1747,1748],{},"$$\nk=b\\cdot r\n$$",[15,1750,1751],{},"例如：$k=6,b=2,r=3$。",[680,1753,1754,1757],{},[535,1755,1756],{},"Band 1: $(h_1,h_2,h_3)$",[535,1758,1759],{},"Band 2: $(h_4,h_5,h_6)$",[19,1761,1763],{"id":1762},"_42-候选判定","4.2 候选判定",[15,1765,1766],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[64,1768,1769,1782],{},[67,1770,1771],{},[70,1772,1773,1776,1779],{},[73,1774,1775],{},"Band",[73,1777,1778],{},"桶",[73,1780,1781],{},"文档",[82,1783,1784,1795,1804,1813,1822,1832,1841,1850],{},[70,1785,1786,1789,1792],{},[87,1787,1788],{},"1",[87,1790,1791],{},"B1-1",[87,1793,1794],{},"d1, d4",[70,1796,1797,1799,1802],{},[87,1798,1788],{},[87,1800,1801],{},"B1-2",[87,1803,1498],{},[70,1805,1806,1808,1811],{},[87,1807,1788],{},[87,1809,1810],{},"B1-3",[87,1812,1506],{},[70,1814,1815,1817,1820],{},[87,1816,1788],{},[87,1818,1819],{},"B1-4",[87,1821,1522],{},[70,1823,1824,1826,1829],{},[87,1825,1675],{},[87,1827,1828],{},"B2-1",[87,1830,1831],{},"d1, d2",[70,1833,1834,1836,1839],{},[87,1835,1675],{},[87,1837,1838],{},"B2-3",[87,1840,1506],{},[70,1842,1843,1845,1848],{},[87,1844,1675],{},[87,1846,1847],{},"B2-4",[87,1849,1514],{},[70,1851,1852,1854,1857],{},[87,1853,1675],{},[87,1855,1856],{},"B2-5",[87,1858,1522],{},[15,1860,1861],{},"在这里，$d_1,d_4$ 在 Band 1 碰撞、$d_1,d_2$ 在 Band 2 碰撞，它们都会被成功召回送入下一阶段。",[19,1863,1865],{"id":1864},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[15,1867,1868],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[15,1870,1871],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[15,1873,1874],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[50,1876],{},[10,1878,1880],{"id":1879},"精确验证候选对-最终结果","精确验证（候选对 → 最终结果）",[15,1882,1883],{},"对候选集合中的文档对再计算真实 Jaccard：",[64,1885,1886,1902],{},[67,1887,1888],{},[70,1889,1890,1893,1896,1899],{},[73,1891,1892],{},"文本对",[73,1894,1895],{},"交集大小",[73,1897,1898],{},"并集大小",[73,1900,1901],{},"Jaccard",[82,1903,1904,1916],{},[70,1905,1906,1909,1911,1913],{},[87,1907,1908],{},"d1,d4",[87,1910,1689],{},[87,1912,1681],{},[87,1914,1915],{},"0.5",[70,1917,1918,1921,1923,1925],{},[87,1919,1920],{},"d1,d2",[87,1922,1689],{},[87,1924,1681],{},[87,1926,1915],{},[15,1928,1929],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[1533,1931,1932],{},[15,1933,1934],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[50,1936],{},[10,1938,1939],{"id":1939},"算法直观总结",[532,1941,1942,1948,1954,1960],{},[535,1943,1944,1947],{},[30,1945,1946],{},"Shingling","：把文本变成可比较的集合表示。",[535,1949,1950,1953],{},[30,1951,1952],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[535,1955,1956,1959],{},[30,1957,1958],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[535,1961,1962,1965],{},[30,1963,1964],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[15,1967,1968,1971],{},[30,1969,1970],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":212,"searchDepth":473,"depth":473,"links":1973},[1974,1975,1978,1979,1980,1985,1990,1991],{"id":1330,"depth":473,"text":1331},{"id":1378,"depth":473,"text":1379,"children":1976},[1977],{"id":1405,"depth":489,"text":1405},{"id":1436,"depth":473,"text":1436},{"id":1467,"depth":473,"text":1468},{"id":1542,"depth":473,"text":1543,"children":1981},[1982,1983,1984],{"id":1552,"depth":489,"text":1553},{"id":1568,"depth":489,"text":1569},{"id":1602,"depth":489,"text":1603},{"id":1734,"depth":473,"text":1735,"children":1986},[1987,1988,1989],{"id":1741,"depth":489,"text":1742},{"id":1762,"depth":489,"text":1763},{"id":1864,"depth":489,"text":1865},{"id":1879,"depth":473,"text":1880},{"id":1939,"depth":473,"text":1939},"\u002Fimg\u002Fpostcard3.jpg","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用",{},"\u002Fposts\u002Flsh-minhash-deduplication",{"title":1325,"description":1993},"posts\u002Flsh-minhash-deduplication","oG6H2fNbkQAmzn78pWFC0zQq-y8odaRz5akaYuGwnC8",{"id":2000,"title":2001,"body":2002,"categories":2108,"cover":2111,"date":2112,"description":2113,"extension":593,"meta":2114,"navigation":595,"path":2115,"seo":2116,"stem":2117,"tags":2118,"__hash__":2122},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":7,"value":2003,"toc":2102},[2004,2007,2010,2013,2020,2034,2037,2069,2073,2084,2088],[10,2005,2006],{"id":2006},"我的配置清单",[15,2008,2009],{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[15,2011,2012],{},"惯例先附上系统信息：",[15,2014,2015],{},[2016,2017],"img",{"alt":2018,"src":2019},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[680,2021,2022,2025,2028,2031],{},[535,2023,2024],{},"OS：Ubuntu 26.04 LTS",[535,2026,2027],{},"Kernel：Linux 7.0.0-15-generic",[535,2029,2030],{},"CPU：Intel Core i7-14700H",[535,2032,2033],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[10,2035,2036],{"id":2036},"系统与桌面环境",[680,2038,2039,2042,2045,2048,2051,2054,2057,2060,2063,2066],{},[535,2040,2041],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[535,2043,2044],{},"桌面协议：Wayland",[535,2046,2047],{},"窗口管理：Mutter",[535,2049,2050],{},"Shell：zsh 5.9",[535,2052,2053],{},"终端：Ghostty",[535,2055,2056],{},"输入法：Fcitx5（小鹤音形）",[535,2058,2059],{},"主题：Orchis-dark",[535,2061,2062],{},"壁纸：Variety",[535,2064,2065],{},"截图：Flameshot",[535,2067,2068],{},"VPN：v2rayN（Linux 版本）",[10,2070,2072],{"id":2071},"工作-学习","工作 \u002F 学习",[680,2074,2075,2078,2081],{},[535,2076,2077],{},"办公：WPS",[535,2079,2080],{},"编辑器：VS Code",[535,2082,2083],{},"AI 工具管理：CCSwitch（ccswitch）",[10,2085,2087],{"id":2086},"生活-游戏","生活 \u002F 游戏",[680,2089,2090,2093,2096,2099],{},[535,2091,2092],{},"游戏：Steam",[535,2094,2095],{},"兼容层：Proton GE",[535,2097,2098],{},"浏览器：Edge",[535,2100,2101],{},"聊天：微信 \u002F QQ",{"title":212,"searchDepth":473,"depth":473,"links":2103},[2104,2105,2106,2107],{"id":2006,"depth":473,"text":2006},{"id":2036,"depth":473,"text":2036},{"id":2071,"depth":473,"text":2072},{"id":2086,"depth":473,"text":2087},[2109,2110],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单",{},"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":2001,"description":2113},"posts\u002Fubuntu-26-04-my-setup",[2119,2120,2121],"Ubuntu","Wayland","桌面配置","yZYlhwCbitmtIMFYkRlb5os9JMJpWZH5UyymJQNZyxc",1779202436425]