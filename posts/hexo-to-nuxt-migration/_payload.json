,[87,851,852,396],{},[41,853,395],{},[70,855,856,858,860],{},[87,857,401],{},[87,859,404],{},[87,861,407],{},[70,863,864,866,868],{},[87,865,412],{},[87,867,415],{},[87,869,418],{},[19,871,421],{"id":421},[15,873,424,874,427],{},[41,875,43],{},[15,877,430,878,434,880,438,882,442,884,446,886,450],{},[41,879,433],{},[41,881,437],{},[30,883,441],{},[41,885,445],{},[41,887,449],{},[204,889,890],{"className":453,"code":454,"language":455,"meta":212,"style":212},[41,891,892,898,908,930],{"__ignoreMap":212},[459,893,894,896],{"class":461,"line":462},[459,895,466],{"class":465},[459,897,470],{"class":469},[459,899,900,902,904,906],{"class":461,"line":473},[459,901,476],{"class":465},[459,903,479],{"class":469},[459,905,483],{"class":482},[459,907,486],{"class":469},[459,909,910,912,914,916,918,920,922,924,926,928],{"class":461,"line":489},[459,911,492],{"class":465},[459,913,495],{"class":469},[459,915,499],{"class":498},[459,917,502],{"class":469},[459,919,505],{"class":498},[459,921,502],{"class":469},[459,923,510],{"class":498},[459,925,502],{"class":469},[459,927,515],{"class":498},[459,929,518],{"class":469},[459,931,932],{"class":461,"line":521},[459,933,524],{"class":469},[10,935,527],{"id":527},[15,937,530],{},[532,939,940,942,944],{},[535,941,537],{},[535,943,540],{},[535,945,543],{},[15,947,546],{},[50,949],{},[10,951,551],{"id":551},[15,953,554],{},[15,955,956,560],{},[30,957,559],{},[562,959,564],{},{"title":212,"searchDepth":473,"depth":473,"links":961},[962,966,970,976,982,983],{"id":12,"depth":473,"text":13,"children":963},[964,965],{"id":21,"depth":489,"text":22},{"id":36,"depth":489,"text":36},{"id":54,"depth":473,"text":55,"children":967},[968,969],{"id":155,"depth":489,"text":156},{"id":166,"depth":489,"text":167},{"id":187,"depth":473,"text":187,"children":971},[972,973,974,975],{"id":190,"depth":489,"text":191},{"id":226,"depth":489,"text":227},{"id":261,"depth":489,"text":262},{"id":268,"depth":489,"text":269},{"id":284,"depth":473,"text":284,"children":977},[978,979,980,981],{"id":287,"depth":489,"text":288},{"id":311,"depth":489,"text":312},{"id":338,"depth":489,"text":338},{"id":421,"depth":489,"text":421},{"id":527,"depth":473,"text":527},{"id":551,"depth":473,"text":551},{},{"title":5,"description":592},{"id":987,"title":988,"body":989,"categories":589,"cover":589,"date":1623,"description":1624,"extension":593,"meta":1625,"navigation":595,"path":1627,"seo":1628,"stem":1629,"tags":589,"__hash__":1630},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":7,"value":990,"toc":1604},[991,996,1002,1004,1008,1018,1021,1030,1033,1036,1062,1064,1068,1071,1074,1091,1094,1096,1100,1103,1156,1159,1162,1168,1170,1174,1180,1184,1187,1190,1193,1196,1200,1203,1210,1213,1220,1223,1226,1231,1235,1358,1361,1363,1367,1370,1374,1377,1380,1383,1391,1395,1398,1489,1492,1496,1499,1502,1505,1507,1511,1514,1558,1561,1566,1568,1572,1598],[992,993,995],"h1",{"id":994},"lsh算法原理讲解","LSH算法原理讲解",[15,997,998,1001],{},[30,999,1000],{},"目标","：在海量文本中快速发现相似文档，避免 $O(n^2)$ 的全量两两比较。",[50,1003],{},[10,1005,1007],{"id":1006},"_0-算法背景lsh解决了什么痛点","0. 算法背景：LSH解决了什么痛点？",[15,1009,1010,1011,279,1014,1017],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[30,1012,1013],{},"计算代价是否可接受",[1015,1016],"br",{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[15,1019,1020],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[1022,1023,1024,1027],"ul",{},[535,1025,1026],{},"使高相似对象以较高概率落入同一桶（进入候选集）",[535,1028,1029],{},"使低相似对象以较高概率在早期被过滤",[15,1031,1032],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[19,1034,1035],{"id":1035},"常见应用领域",[532,1037,1038,1044,1050,1056],{},[535,1039,1040,1043],{},[30,1041,1042],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[535,1045,1046,1049],{},[30,1047,1048],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[535,1051,1052,1055],{},[30,1053,1054],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[535,1057,1058,1061],{},[30,1059,1060],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[50,1063],{},[10,1065,1067],{"id":1066},"_1-示例文本集合","1. 示例文本集合",[15,1069,1070],{},"设文档集合：",[15,1072,1073],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[1022,1075,1076,1079,1082,1085,1088],{},[535,1077,1078],{},"$d_1=\\text{“今天天气很好”}$",[535,1080,1081],{},"$d_2=\\text{“今天天气非常好”}$",[535,1083,1084],{},"$d_3=\\text{“昨天天气很差”}$",[535,1086,1087],{},"$d_4=\\text{“今天天气很好”}$",[535,1089,1090],{},"$d_5=\\text{“机器学习很有趣”}$",[15,1092,1093],{},"直观上，$d_1$ 与 $d_4$ 完全相同，$d_1$ 与 $d_2$ 高度相似，其余组合的相似度较低。",[50,1095],{},[10,1097,1099],{"id":1098},"_2-shingling文本-q-gram集合","2. Shingling（文本 → q-gram集合）",[15,1101,1102],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[64,1104,1105,1115],{},[67,1106,1107],{},[70,1108,1109,1112],{},[73,1110,1111],{},"文本",[73,1113,1114],{},"3-gram集合",[82,1116,1117,1125,1133,1141,1148],{},[70,1118,1119,1122],{},[87,1120,1121],{},"d1",[87,1123,1124],{},"{今天天, 天天气, 天气很, 气很好}",[70,1126,1127,1130],{},[87,1128,1129],{},"d2",[87,1131,1132],{},"{今天天, 天天气, 天气非, 气非常, 非常好}",[70,1134,1135,1138],{},[87,1136,1137],{},"d3",[87,1139,1140],{},"{昨天天, 天天气, 天气很, 气很差}",[70,1142,1143,1146],{},[87,1144,1145],{},"d4",[87,1147,1124],{},[70,1149,1150,1153],{},[87,1151,1152],{},"d5",[87,1154,1155],{},"{机器学, 学习很, 习很有, 很有趣}",[15,1157,1158],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[15,1160,1161],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[1163,1164,1165],"blockquote",{},[15,1166,1167],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[50,1169],{},[10,1171,1173],{"id":1172},"_3-minhash集合-签名向量","3. MinHash（集合 → 签名向量）",[15,1175,1176,1179],{},[30,1177,1178],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[19,1181,1183],{"id":1182},"_31-构造方式","3.1 构造方式",[15,1185,1186],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[15,1188,1189],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[15,1191,1192],{},"于是签名向量为：",[15,1194,1195],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[19,1197,1199],{"id":1198},"_32-为什么可行","3.2 为什么可行",[15,1201,1202],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[15,1204,1205,1206,1209],{},"$$\n\\Pr",[459,1207,1208],{},"m_h(A)=m_h(B)"," = J(A,B)\n$$",[15,1211,1212],{},"用 $k$ 个哈希后，可得无偏估计量：",[15,1214,1215,1216,1219],{},"$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_^k \\mathbf{1}",[459,1217,1218],{},"m_(A)=m_(B)","\n$$",[15,1221,1222],{},"方差为：",[15,1224,1225],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[1163,1227,1228],{},[15,1229,1230],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[19,1232,1234],{"id":1233},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[64,1236,1237,1258],{},[67,1238,1239],{},[70,1240,1241,1243,1245,1247,1249,1252,1255],{},[73,1242,1111],{},[73,1244,992],{},[73,1246,10],{},[73,1248,19],{},[73,1250,1251],{},"h4",[73,1253,1254],{},"h5",[73,1256,1257],{},"h6",[82,1259,1260,1282,1300,1321,1337],{},[70,1261,1262,1264,1267,1270,1273,1276,1279],{},[87,1263,1121],{},[87,1265,1266],{},"12",[87,1268,1269],{},"7",[87,1271,1272],{},"5",[87,1274,1275],{},"20",[87,1277,1278],{},"11",[87,1280,1281],{},"3",[70,1283,1284,1286,1288,1290,1293,1296,1298],{},[87,1285,1129],{},[87,1287,1266],{},[87,1289,1269],{},[87,1291,1292],{},"6",[87,1294,1295],{},"21",[87,1297,1278],{},[87,1299,1281],{},[70,1301,1302,1304,1307,1310,1313,1316,1318],{},[87,1303,1137],{},[87,1305,1306],{},"2",[87,1308,1309],{},"15",[87,1311,1312],{},"8",[87,1314,1315],{},"19",[87,1317,1269],{},[87,1319,1320],{},"4",[70,1322,1323,1325,1327,1329,1331,1333,1335],{},[87,1324,1145],{},[87,1326,1266],{},[87,1328,1269],{},[87,1330,1272],{},[87,1332,1275],{},[87,1334,1278],{},[87,1336,1281],{},[70,1338,1339,1341,1344,1347,1350,1353,1356],{},[87,1340,1152],{},[87,1342,1343],{},"30",[87,1345,1346],{},"14",[87,1348,1349],{},"22",[87,1351,1352],{},"33",[87,1354,1355],{},"28",[87,1357,1272],{},[15,1359,1360],{},"可以看出：$d_1$ 与 $d_4$ 完全一致，$d_1$ 与 $d_2$ 大部分行一致，符合直觉。",[50,1362],{},[10,1364,1366],{"id":1365},"_4-lsh-banding签名矩阵-候选对","4. LSH Banding（签名矩阵 → 候选对）",[15,1368,1369],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[19,1371,1373],{"id":1372},"_41-切分规则","4.1 切分规则",[15,1375,1376],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[15,1378,1379],{},"$$\nk=b\\cdot r\n$$",[15,1381,1382],{},"例如：$k=6,b=2,r=3$。",[1022,1384,1385,1388],{},[535,1386,1387],{},"Band 1: $(h_1,h_2,h_3)$",[535,1389,1390],{},"Band 2: $(h_4,h_5,h_6)$",[19,1392,1394],{"id":1393},"_42-候选判定","4.2 候选判定",[15,1396,1397],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[64,1399,1400,1413],{},[67,1401,1402],{},[70,1403,1404,1407,1410],{},[73,1405,1406],{},"Band",[73,1408,1409],{},"桶",[73,1411,1412],{},"文档",[82,1414,1415,1426,1435,1444,1453,1462,1471,1480],{},[70,1416,1417,1420,1423],{},[87,1418,1419],{},"1",[87,1421,1422],{},"B1-1",[87,1424,1425],{},"d1, d4",[70,1427,1428,1430,1433],{},[87,1429,1419],{},[87,1431,1432],{},"B1-2",[87,1434,1129],{},[70,1436,1437,1439,1442],{},[87,1438,1419],{},[87,1440,1441],{},"B1-3",[87,1443,1137],{},[70,1445,1446,1448,1451],{},[87,1447,1419],{},[87,1449,1450],{},"B1-4",[87,1452,1152],{},[70,1454,1455,1457,1460],{},[87,1456,1306],{},[87,1458,1459],{},"B2-1",[87,1461,1425],{},[70,1463,1464,1466,1469],{},[87,1465,1306],{},[87,1467,1468],{},"B2-2",[87,1470,1129],{},[70,1472,1473,1475,1478],{},[87,1474,1306],{},[87,1476,1477],{},"B2-3",[87,1479,1137],{},[70,1481,1482,1484,1487],{},[87,1483,1306],{},[87,1485,1486],{},"B2-4",[87,1488,1152],{},[15,1490,1491],{},"因此 $d_1,d_4$ 会被稳定召回为候选。",[19,1493,1495],{"id":1494},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[15,1497,1498],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[15,1500,1501],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[15,1503,1504],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[50,1506],{},[10,1508,1510],{"id":1509},"_5-精确验证候选对-最终结果","5. 精确验证（候选对 → 最终结果）",[15,1512,1513],{},"对候选集合中的文档对再计算真实 Jaccard：",[64,1515,1516,1532],{},[67,1517,1518],{},[70,1519,1520,1523,1526,1529],{},[73,1521,1522],{},"文本对",[73,1524,1525],{},"交集大小",[73,1527,1528],{},"并集大小",[73,1530,1531],{},"Jaccard",[82,1533,1534,1546],{},[70,1535,1536,1539,1541,1543],{},[87,1537,1538],{},"d1,d4",[87,1540,1320],{},[87,1542,1320],{},[87,1544,1545],{},"1.0",[70,1547,1548,1551,1553,1555],{},[87,1549,1550],{},"d1,d2",[87,1552,1281],{},[87,1554,1272],{},[87,1556,1557],{},"0.6",[15,1559,1560],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[1163,1562,1563],{},[15,1564,1565],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[50,1567],{},[10,1569,1571],{"id":1570},"_6-算法直观总结","6. 算法直观总结",[532,1573,1574,1580,1586,1592],{},[535,1575,1576,1579],{},[30,1577,1578],{},"Shingling","：把文本变成可比较的集合表示。",[535,1581,1582,1585],{},[30,1583,1584],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[535,1587,1588,1591],{},[30,1589,1590],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[535,1593,1594,1597],{},[30,1595,1596],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[15,1599,1600,1603],{},[30,1601,1602],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":212,"searchDepth":473,"depth":473,"links":1605},[1606,1609,1610,1611,1616,1621,1622],{"id":1006,"depth":473,"text":1007,"children":1607},[1608],{"id":1035,"depth":489,"text":1035},{"id":1066,"depth":473,"text":1067},{"id":1098,"depth":473,"text":1099},{"id":1172,"depth":473,"text":1173,"children":1612},[1613,1614,1615],{"id":1182,"depth":489,"text":1183},{"id":1198,"depth":489,"text":1199},{"id":1233,"depth":489,"text":1234},{"id":1365,"depth":473,"text":1366,"children":1617},[1618,1619,1620],{"id":1372,"depth":489,"text":1373},{"id":1393,"depth":489,"text":1394},{"id":1494,"depth":489,"text":1495},{"id":1509,"depth":473,"text":1510},{"id":1570,"depth":473,"text":1571},"2026-05-19","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用",{"caver":1626},"\u002Fimg\u002Fpostcard3.jpg","\u002Fposts\u002Flsh-minhash-deduplication",{"title":988,"description":1624},"posts\u002Flsh-minhash-deduplication","CPt90-O0t4_W9HZZVR7dUXrW3KsRLmOyQRQfyzd6Zb8",{"id":1632,"title":1633,"body":1634,"categories":1740,"cover":1743,"date":1744,"description":1745,"extension":593,"meta":1746,"navigation":595,"path":1747,"seo":1748,"stem":1749,"tags":1750,"__hash__":1754},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":7,"value":1635,"toc":1734},[1636,1639,1642,1645,1652,1666,1669,1701,1705,1716,1720],[10,1637,1638],{"id":1638},"我的配置清单",[15,1640,1641],{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[15,1643,1644],{},"惯例先附上系统信息：",[15,1646,1647],{},[1648,1649],"img",{"alt":1650,"src":1651},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[1022,1653,1654,1657,1660,1663],{},[535,1655,1656],{},"OS：Ubuntu 26.04 LTS",[535,1658,1659],{},"Kernel：Linux 7.0.0-15-generic",[535,1661,1662],{},"CPU：Intel Core i7-14700H",[535,1664,1665],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[10,1667,1668],{"id":1668},"系统与桌面环境",[1022,1670,1671,1674,1677,1680,1683,1686,1689,1692,1695,1698],{},[535,1672,1673],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[535,1675,1676],{},"桌面协议：Wayland",[535,1678,1679],{},"窗口管理：Mutter",[535,1681,1682],{},"Shell：zsh 5.9",[535,1684,1685],{},"终端：Ghostty",[535,1687,1688],{},"输入法：Fcitx5（小鹤音形）",[535,1690,1691],{},"主题：Orchis-dark",[535,1693,1694],{},"壁纸：Variety",[535,1696,1697],{},"截图：Flameshot",[535,1699,1700],{},"VPN：v2rayN（Linux 版本）",[10,1702,1704],{"id":1703},"工作-学习","工作 \u002F 学习",[1022,1706,1707,1710,1713],{},[535,1708,1709],{},"办公：WPS",[535,1711,1712],{},"编辑器：VS Code",[535,1714,1715],{},"AI 工具管理：CCSwitch（ccswitch）",[10,1717,1719],{"id":1718},"生活-游戏","生活 \u002F 游戏",[1022,1721,1722,1725,1728,1731],{},[535,1723,1724],{},"游戏：Steam",[535,1726,1727],{},"兼容层：Proton GE",[535,1729,1730],{},"浏览器：Edge",[535,1732,1733],{},"聊天：微信 \u002F QQ",{"title":212,"searchDepth":473,"depth":473,"links":1735},[1736,1737,1738,1739],{"id":1638,"depth":473,"text":1638},{"id":1668,"depth":473,"text":1668},{"id":1703,"depth":473,"text":1704},{"id":1718,"depth":473,"text":1719},[1741,1742],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单",{},"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":1633,"description":1745},"posts\u002Fubuntu-26-04-my-setup",[1751,1752,1753],"Ubuntu","Wayland","桌面配置","yZYlhwCbitmtIMFYkRlb5os9JMJpWZH5UyymJQNZyxc",1779193735210]