[{"data":1,"prerenderedAt":1111},["ShallowReactive",2],{"post-hexo-to-nuxt-migration":3,"all-posts":600},{"id":4,"title":5,"body":6,"categories":589,"cover":590,"date":591,"description":592,"extension":593,"meta":594,"navigation":595,"path":596,"seo":597,"stem":598,"tags":589,"__hash__":599},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":8,"toc":565},"minimark",[9,14,18,23,26,34,37,49,52,56,63,153,157,164,168,183,185,188,192,203,213,224,228,234,240,259,263,266,270,280,282,285,289,295,309,313,319,336,339,419,422,428,451,525,528,531,544,547,549,552,555,561],[10,11,13],"h2",{"id":12},"为什么要离开-hexo","为什么要离开 Hexo？",[15,16,17],"p",{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[19,20,22],"h3",{"id":21},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,24,25],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,27,28,29,33],{},"问题根源在于：",[30,31,32],"strong",{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[19,35,36],{"id":36},"构建速度与生态",[15,38,39,40,44,45,48],{},"文章数量上来之后，",[41,42,43],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[30,46,47],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[50,51],"hr",{},[10,53,55],{"id":54},"为什么选-nuxt","为什么选 Nuxt？",[15,57,58,59,62],{},"看过 VitePress、Astro、Next.js，最终选了 ",[30,60,61],{},"Nuxt 4 SSG","。核心考量：",[64,65,66,81],"table",{},[67,68,69],"thead",{},[70,71,72,75,78],"tr",{},[73,74],"th",{},[73,76,77],{},"Hexo",[73,79,80],{},"Nuxt 4",[82,83,84,98,111,124,137],"tbody",{},[70,85,86,92,95],{},[87,88,89],"td",{},[30,90,91],{},"构建机制",[87,93,94],{},"CLI 全量生成静态文件",[87,96,97],{},"Nitro 引擎预渲染 + 增量构建",[70,99,100,105,108],{},[87,101,102],{},[30,103,104],{},"模板\u002F组件",[87,106,107],{},"EJS\u002FPug，无组件化",[87,109,110],{},"Vue 3 组件，自动导入",[70,112,113,118,121],{},[87,114,115],{},[30,116,117],{},"内容管理",[87,119,120],{},"front-matter + markdown",[87,122,123],{},"@nuxt\u002Fcontent v3，类型安全查询",[70,125,126,131,134],{},[87,127,128],{},[30,129,130],{},"交互",[87,132,133],{},"内联 script，靠 CDN",[87,135,136],{},"完整的 Vue 响应式生态",[70,138,139,144,150],{},[87,140,141],{},[30,142,143],{},"路由",[87,145,146,149],{},[41,147,148],{},"_config.yml"," permalink 配置",[87,151,152],{},"文件系统路由，动态参数",[19,154,156],{"id":155},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,158,159,160,163],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[30,161,162],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[19,165,167],{"id":166},"vue-生态的开发体验","Vue 生态的开发体验",[15,169,170,171,174,175,178,179,182],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[41,172,173],{},"useAsyncData"," + ",[41,176,177],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[41,180,181],{},"\u003Cscript>"," 标签。",[50,184],{},[10,186,187],{"id":187},"迁移过程",[19,189,191],{"id":190},"内容层零改动搬过来","内容层：零改动搬过来",[15,193,194,195,198,199,202],{},"所有 markdown 文件从 Hexo 的 ",[41,196,197],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[41,200,201],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[204,205,210],"pre",{"className":206,"code":208,"language":209},[207],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[41,211,208],{"__ignoreMap":212},"",[15,214,215,216,219,220,223],{},"多了 ",[41,217,218],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[41,221,222],{},"tags","。内容正文一个字没改。",[19,225,227],{"id":226},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,229,230,231,233],{},"Hexo 的 URL 靠 ",[41,232,148],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[204,235,238],{"className":236,"code":237,"language":209},[207],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[41,239,237],{"__ignoreMap":212},[15,241,242,243,246,247,250,251,254,255,258],{},"Nuxt 路由由 ",[41,244,245],{},"pages\u002F"," 目录结构决定，",[41,248,249],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[41,252,253],{},"trailingSlash: true"," 保证 URL 一致性，",[41,256,257],{},"[...slug].vue"," 兜底 404。",[19,260,262],{"id":261},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,264,265],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[19,267,269],{"id":268},"部署ci-保持不变","部署：CI 保持不变",[15,271,272,273,275,276,279],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[41,274,43],{}," 替换为 ",[41,277,278],{},"npm run build","。",[50,281],{},[10,283,284],{"id":284},"架构对比",[19,286,288],{"id":287},"hexo-的架构","Hexo 的架构",[204,290,293],{"className":291,"code":292,"language":209},[207],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[41,294,292],{"__ignoreMap":212},[15,296,297,298,301,302,304,305,308],{},"Hexo 是",[30,299,300],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[41,303,148],{},"、",[41,306,307],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[19,310,312],{"id":311},"nuxt-的架构","Nuxt 的架构",[204,314,317],{"className":315,"code":316,"language":209},[207],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[41,318,316],{"__ignoreMap":212},[15,320,321,322,325,326,328,329,331,332,335],{},"Nuxt 是",[30,323,324],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[41,327,177],{}," 查询内容，",[41,330,173],{}," 管理异步数据，",[41,333,334],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[19,337,338],{"id":338},"数据流对比",[64,340,341,353],{},[67,342,343],{},[70,344,345,348,350],{},[73,346,347],{},"环节",[73,349,77],{},[73,351,352],{},"Nuxt",[82,354,355,368,381,397,408],{},[70,356,357,360,363],{},[87,358,359],{},"内容获取",[87,361,362],{},"读文件 → 模板注入变量",[87,364,365],{},[41,366,367],{},"queryCollection('posts').all()",[70,369,370,373,376],{},[87,371,372],{},"数据管理",[87,374,375],{},"无，模板即数据",[87,377,378,380],{},[41,379,173],{}," + 响应式",[70,382,383,386,391],{},[87,384,385],{},"站点配置",[87,387,388,390],{},[41,389,148],{}," + 主题 config",[87,392,393,396],{},[41,394,395],{},"useSite()"," composable",[70,398,399,402,405],{},[87,400,401],{},"主题",[87,403,404],{},"Stylus 变量 → 编译到 CSS",[87,406,407],{},"CSS 自定义属性 → 运行时切换",[70,409,410,413,416],{},[87,411,412],{},"交互状态",[87,414,415],{},"全局变量 + DOM 操作",[87,417,418],{},"Vue 响应式 + composables",[19,420,421],{"id":421},"预渲染策略",[15,423,424,425,427],{},"Hexo 每次 ",[41,426,43],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,429,430,431,434,435,438,439,442,443,446,447,450],{},"Nitro 的 ",[41,432,433],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[41,436,437],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[30,440,441],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[41,444,445],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[41,448,449],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[204,452,456],{"className":453,"code":454,"language":455,"meta":212,"style":212},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[41,457,458,471,487,519],{"__ignoreMap":212},[459,460,463,467],"span",{"class":461,"line":462},"line",1,[459,464,466],{"class":465},"sVyAn","prerender",[459,468,470],{"class":469},"sn6KH",": {\n",[459,472,474,477,480,484],{"class":461,"line":473},2,[459,475,476],{"class":465},"  crawlLinks",[459,478,479],{"class":469},": ",[459,481,483],{"class":482},"sVC51","true",[459,485,486],{"class":469},",\n",[459,488,490,493,496,500,503,506,508,511,513,516],{"class":461,"line":489},3,[459,491,492],{"class":465},"  routes",[459,494,495],{"class":469},": [",[459,497,499],{"class":498},"subq3","'\u002F'",[459,501,502],{"class":469},", ",[459,504,505],{"class":498},"'\u002Fabout'",[459,507,502],{"class":469},[459,509,510],{"class":498},"'\u002Fposts'",[459,512,502],{"class":469},[459,514,515],{"class":498},"'\u002Flinks'",[459,517,518],{"class":469},"],\n",[459,520,522],{"class":461,"line":521},4,[459,523,524],{"class":469},"}\n",[10,526,527],{"id":527},"迁移成本远低于预期",[15,529,530],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[532,533,534,538,541],"ol",{},[535,536,537],"li",{},"搭建 Nuxt 项目骨架",[535,539,540],{},"设计 CSS token 系统",[535,542,543],{},"编写几个核心组件",[15,545,546],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[50,548],{},[10,550,551],{"id":551},"总结",[15,553,554],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,556,557,560],{},[30,558,559],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[562,563,564],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":212,"searchDepth":473,"depth":473,"links":566},[567,571,575,581,587,588],{"id":12,"depth":473,"text":13,"children":568