[{"data":1,"prerenderedAt":2123},["ShallowReactive",2],{"post-hexo-to-nuxt-migration":3,"all-posts":600},{"id":4,"title":5,"body":6,"categories":589,"cover":590,"date":591,"description":592,"extension":593,"meta":594,"navigation":595,"path":596,"seo":597,"stem":598,"tags":589,"__hash__":599},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":8,"toc":565},"minimark",[9,14,18,23,26,34,37,49,52,56,63,153,157,164,168,183,185,188,192,203,213,224,228,234,240,259,263,266,270,280,282,285,289,295,309,313,319,336,339,419,422,428,451,525,528,531,544,547,549,552,555,561],[10,11,13],"h2",{"id":12},"为什么要离开-hexo","为什么要离开 Hexo？",[15,16,17],"p",{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[19,20,22],"h3",{"id":21},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,24,25],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,27,28,29,33],{},"问题根源在于：",[30,31,32],"strong",{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[19,35,36],{"id":36},"构建速度与生态",[15,38,39,40,44,45,48],{},"文章数量上来之后，",[41,42,43],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[30,46,47],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[50,51],"hr",{},[10,53,55],{"id":54},"为什么选-nuxt","为什么选 Nuxt？",[15,57,58,59,62],{},"看过 VitePress、Astro、Next.js，最终选了 ",[30,60,61],{},"Nuxt 4 SSG","。核心考量：",[64,65,66,81],"table",{},[67,68,69],"thead",{},[70,71,72,75,78],"tr",{},[73,74],"th",{},[73,76,77],{},"Hexo",[73,79,80],{},"Nuxt 4",[82,83,84,98,111,124,137],"tbody",{},[70,85,86,92,95],{},[87,88,89],"td",{},[30,90,91],{},"构建机制",[87,93,94],{},"CLI 全量生成静态文件",[87,96,97],{},"Nitro 引擎预渲染 + 增量构建",[70,99,100,105,108],{},[87,101,102],{},[30,103,104],{},"模板\u002F组件",[87,106,107],{},"EJS\u002FPug，无组件化",[87,109,110],{},"Vue 3 组件，自动导入",[70,112,113,118,121],{},[87,114,115],{},[30,116,117],{},"内容管理",[87,119,120],{},"front-matter + markdown",[87,122,123],{},"@nuxt\u002Fcontent v3，类型安全查询",[70,125,126,131,134],{},[87,127,128],{},[30,129,130],{},"交互",[87,132,133],{},"内联 script，靠 CDN",[87,135,136],{},"完整的 Vue 响应式生态",[70,138,139,144,150],{},[87,140,141],{},[30,142,143],{},"路由",[87,145,146,149],{},[41,147,148],{},"_config.yml"," permalink 配置",[87,151,152],{},"文件系统路由，动态参数",[19,154,156],{"id":155},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,158,159,160,163],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[30,161,162],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[19,165,167],{"id":166},"vue-生态的开发体验","Vue 生态的开发体验",[15,169,170,171,174,175,178,179,182],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[41,172,173],{},"useAsyncData"," + ",[41,176,177],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[41,180,181],{},"\u003Cscript>"," 标签。",[50,184],{},[10,186,187],{"id":187},"迁移过程",[19,189,191],{"id":190},"内容层零改动搬过来","内容层：零改动搬过来",[15,193,194,195,198,199,202],{},"所有 markdown 文件从 Hexo 的 ",[41,196,197],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[41,200,201],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[204,205,210],"pre",{"className":206,"code":208,"language":209},[207],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[41,211,208],{"__ignoreMap":212},"",[15,214,215,216,219,220,223],{},"多了 ",[41,217,218],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[41,221,222],{},"tags","。内容正文一个字没改。",[19,225,227],{"id":226},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,229,230,231,233],{},"Hexo 的 URL 靠 ",[41,232,148],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[204,235,238],{"className":236,"code":237,"language":209},[207],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[41,239,237],{"__ignoreMap":212},[15,241,242,243,246,247,250,251,254,255,258],{},"Nuxt 路由由 ",[41,244,245],{},"pages\u002F"," 目录结构决定，",[41,248,249],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[41,252,253],{},"trailingSlash: true"," 保证 URL 一致性，",[41,256,257],{},"[...slug].vue"," 兜底 404。",[19,260,262],{"id":261},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,264,265],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[19,267,269],{"id":268},"部署ci-保持不变","部署：CI 保持不变",[15,271,272,273,275,276,279],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[41,274,43],{}," 替换为 ",[41,277,278],{},"npm run build","。",[50,281],{},[10,283,284],{"id":284},"架构对比",[19,286,288],{"id":287},"hexo-的架构","Hexo 的架构",[204,290,293],{"className":291,"code":292,"language":209},[207],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[41,294,292],{"__ignoreMap":212},[15,296,297,298,301,302,304,305,308],{},"Hexo 是",[30,299,300],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[41,303,148],{},"、",[41,306,307],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[19,310,312],{"id":311},"nuxt-的架构","Nuxt 的架构",[204,314,317],{"className":315,"code":316,"language":209},[207],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[41,318,316],{"__ignoreMap":212},[15,320,321,322,325,326,328,329,331,332,335],{},"Nuxt 是",[30,323,324],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[41,327,177],{}," 查询内容，",[41,330,173],{}," 管理异步数据，",[41,333,334],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[19,337,338],{"id":338},"数据流对比",[64,340,341,353],{},[67,342,343],{},[70,344,345,348,350],{},[73,346,347],{},"环节",[73,349,77],{},[73,351,352],{},"Nuxt",[82,354,355,368,381,397,408],{},[70,356,357,360,363],{},[87,358,359],{},"内容获取",[87,361,362],{},"读文件 → 模板注入变量",[87,364,365],{},[41,366,367],{},"queryCollection('posts').all()",[70,369,370,373,376],{},[87,371,372],{},"数据管理",[87,374,375],{},"无，模板即数据",[87,377,378,380],{},[41,379,173],{}," + 响应式",[70,382,383,386,391],{},[87,384,385],{},"站点配置",[87,387,388,390],{},[41,389,148],{}," + 主题 config",[87,392,393,396],{},[41,394,395],{},"useSite()"," composable",[70,398,399,402,405],{},[87,400,401],{},"主题",[87,403,404],{},"Stylus 变量 → 编译到 CSS",[87,406,407],{},"CSS 自定义属性 → 运行时切换",[70,409,410,413,416],{},[87,411,412],{},"交互状态",[87,414,415],{},"全局变量 + DOM 操作",[87,417,418],{},"Vue 响应式 + composables",[19,420,421],{"id":421},"预渲染策略",[15,423,424,425,427],{},"Hexo 每次 ",[41,426,43],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,429,430,431,434,435,438,439,442,443,446,447,450],{},"Nitro 的 ",[41,432,433],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[41,436,437],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[30,440,441],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[41,444,445],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[41,448,449],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[204,452,456],{"className":453,"code":454,"language":455,"meta":212,"style":212},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[41,457,458,471,487,519],{"__ignoreMap":212},[459,460,463,467],"span",{"class":461,"line":462},"line",1,[459,464,466],{"class":465},"sVyAn","prerender",[459,468,470],{"class":469},"sn6KH",": {\n",[459,472,474,477,480,484],{"class":461,"line":473},2,[459,475,476],{"class":465},"  crawlLinks",[459,478,479],{"class":469},": ",[459,481,483],{"class":482},"sVC51","true",[459,485,486],{"class":469},",\n",[459,488,490,493,496,500,503,506,508,511,513,516],{"class":461,"line":489},3,[459,491,492],{"class":465},"  routes",[459,494,495],{"class":469},": [",[459,497,499],{"class":498},"subq3","'\u002F'",[459,501,502],{"class":469},", ",[459,504,505],{"class":498},"'\u002Fabout'",[459,507,502],{"class":469},[459,509,510],{"class":498},"'\u002Fposts'",[459,512,502],{"class":469},[459,514,515],{"class":498},"'\u002Flinks'",[459,517,518],{"class":469},"],\n",[459,520,522],{"class":461,"line":521},4,[459,523,524],{"class":469},"}\n",[10,526,527],{"id":527},"迁移成本远低于预期",[15,529,530],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[532,533,534,538,541],"ol",{},[535,536,537],"li",{},"搭建 Nuxt 项目骨架",[535,539,540],{},"设计 CSS token 系统",[535,542,543],{},"编写几个核心组件",[15,545,546],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[50,548],{},[10,550,551],{"id":551},"总结",[15,553,554],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,556,557,560],{},[30,558,559],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[562,563,564],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":212,"searchDepth":473,"depth":473,"links":566},[567,571,575,581,587,588],{"id":12,"depth":473,"text":13,"children":568},[569,570],{"id":21,"depth":489,"text":22},{"id":36,"depth":489,"text":36},{"id":54,"depth":473,"text":55,"children":572},[573,574],{"id":155,"depth":489,"text":156},{"id":166,"depth":489,"text":167},{"id":187,"depth":473,"text":187,"children":576},[577,578,579,580],{"id":190,"depth":489,"text":191},{"id":226,"depth":489,"text":227},{"id":261,"depth":489,"text":262},{"id":268,"depth":489,"text":269},{"id":284,"depth":473,"text":284,"children":582},[583,584,585,586],{"id":287,"depth":489,"text":288},{"id":311,"depth":489,"text":312},{"id":338,"depth":489,"text":338},{"id":421,"depth":489,"text":421},{"id":527,"depth":473,"text":527},{"id":551,"depth":473,"text":551},null,"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验","md",{},true,"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":5,"description":592},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",[601,938,1323,1999],{"id":602,"title":603,"body":604,"categories":589,"cover":930,"date":931,"description":932,"extension":593,"meta":933,"navigation":595,"path":934,"seo":935,"stem":936,"tags":589,"__hash__":937},"posts\u002Fposts\u002Fbpe-tokenization-algorithm.md","BPE 分词算法原理讲解：大模型背后的词表构建基石",{"type":7,"value":605,"toc":922},[606,610,613,632,646,653,655,659,665,668,672,679,706,718,754,773,808,811,813,816,819,825,831,865,879,881,885,888,894,905,908],[10,607,609],{"id":608},"词表危机llm-如何认识世界","词表危机：LLM 如何认识世界？",[15,611,612],{},"在把人类语言喂给 Transformer 等深度学习模型之前，我们必须先将其切分成离散的“词元”（Token）。这个切分过程往往面临两难：",[15,614,615,616,619,620,623,624,627,628,631],{},"如果",[30,617,618],{},"按词切分（Word-level）","，比如把 ",[41,621,622],{},"machine learning"," 变成 ",[41,625,626],{},"[machine, learning]","，随着语料丰富，词汇表会膨胀到天文数字大小。而且在遇到网络造词、罕见拼写变形时，模型只能用 ",[41,629,630],{},"\u003CUNK>"," (未知) 符号糊弄过去，丢失极大的信息。",[15,633,634,635,638,639,642,643,645],{},"如果退而求其次",[30,636,637],{},"按字符切分（Character-level）","，比如拆成 ",[41,640,641],{},"[m, a, c, h, i, n, e, ...]","，虽然词表变小了且没有 ",[41,644,630],{}," 问题，但每个句子的序列长度会暴增。这直接会导致 Transformer 昂贵的注意力机制算力爆炸，且单个字母也很难承载复杂的语义。",[15,647,648,649,652],{},"那么，有没有一种两全其美的办法，既能把常见词当成整体处理，又能把生僻词拆成合理的词根？",[30,650,651],{},"BPE（字节对编码）"," 应运而生。",[50,654],{},[10,656,658],{"id":657},"bpe-是如何炼成的","BPE 是如何炼成的？",[15,660,661,662],{},"BPE（Byte Pair Encoding）原本是用于数据压缩的古老算法。其核心思路非常纯粹：",[30,663,664],{},"将文本中最高频出现的相邻符号对，合并成一个新的大符号。",[15,666,667],{},"通过在语料库上持续进行“频率统计 $\\to$ 贪心合并”，模型可以自动学出一套包含不同粒度的子词（Subword）词表。",[19,669,671],{"id":670},"模拟训练构造一个迷你词表","模拟训练：构造一个迷你词表",[15,673,674,675,678],{},"假设我们手头只有以下 4 个单词及其词频，为了清楚边界，我们给每个词结尾加一个特殊标记 ",[41,676,677],{},"\u003C\u002Fw>","：",[680,681,682,688,694,700],"ul",{},[535,683,684,687],{},[41,685,686],{},"low\u003C\u002Fw>"," （出现 5 次）",[535,689,690,693],{},[41,691,692],{},"lower\u003C\u002Fw>"," （出现 2 次）",[535,695,696,699],{},[41,697,698],{},"newest\u003C\u002Fw>"," （出现 6 次）",[535,701,702,705],{},[41,703,704],{},"widest\u003C\u002Fw>"," （出现 3 次）",[15,707,708,711,714,715,279],{},[30,709,710],{},"Step 1：拆成原子字符",[712,713],"br",{},"\n一开始，我们把所有词打碎，此时的基础词表只有拆开的单字符：",[41,716,717],{},"l, o, w, e, r, n, s, t, i, d, \u003C\u002Fw>",[15,719,720,723,725,726,729,730,733,734,737,738,741,742,745,746,749,750,753],{},[30,721,722],{},"Step 2：寻找最高频组合",[712,724],{},"\n扫描这批打碎的语料，统计相邻两两字符的出现频率。\n我们注意到 ",[41,727,728],{},"(e, s)"," 相邻的频率非常高：在 ",[41,731,732],{},"newest"," 中出现了 6 次，在 ",[41,735,736],{},"widest"," 中出现了 3 次，总计 ",[30,739,740],{},"9次","。\n由于它是最高频对，我们将 ",[41,743,744],{},"e"," 和 ",[41,747,748],{},"s"," 合并为新词元 ",[41,751,752],{},"es","，并将其郑重写入我们的词汇表中。",[15,755,756,759,761,762,765,766,769,770,279],{},[30,757,758],{},"Step 3：不断迭代",[712,760],{},"\n此时数据变成了 ",[41,763,764],{},"n e w es t \u003C\u002Fw>"," 等。我们继续扫描，发现 ",[41,767,768],{},"(es, t)"," 又紧挨着出现了 9 次。\n继续合并：我们得到新词元 ",[41,771,772],{},"est",[15,774,775,776,779,780,783,784,787,788,745,791,794,795,798,799,745,801,804,805,279],{},"之后 ",[41,777,778],{},"(est, \u003C\u002Fw>)"," 会被合并为 ",[41,781,782],{},"est\u003C\u002Fw>","，因为英文里 ",[41,785,786],{},"-est"," 作为后缀经常出现在词尾。再往后，",[41,789,790],{},"l",[41,792,793],{},"o"," 会合并为 ",[41,796,797],{},"lo","，接着 ",[41,800,797],{},[41,802,803],{},"w"," 合并为 ",[41,806,807],{},"low",[15,809,810],{},"只要我们将这个循环跑下去，设定一个目标词表大小（比如 32,000 或 64,000），算法就会在拼满后自动停止。最终生成的词汇库里，既有基础的单字符，也会包含大量高频的前缀、后缀和常用单词。",[50,812],{},[10,814,815],{"id":815},"推理阶段的切词艺术",[15,817,818],{},"词表炼成之后，对于任意一段全新的用户输入，BPE 是如何进行拆解的呢？",[15,820,821,822],{},"规则其实是死板而严格的：",[30,823,824],{},"绝对服从训练时生成的合并记录，依次尝试将字符组合起来。",[15,826,827,828,279],{},"举个例子，用户输入了一个模型从未在训练语料里见过的生造词 ",[41,829,830],{},"lowest",[532,832,833,839,853],{},[535,834,835,836],{},"BPE 先把它切得粉碎：",[41,837,838],{},"l o w e s t \u003C\u002Fw>",[535,840,841,842,844,845,847,848,844,850,852],{},"根据训练时学到的优先级，首先套用 ",[41,843,728],{}," $\\to$ ",[41,846,752],{}," 的规则，接着套用 ",[41,849,768],{},[41,851,772],{}," 的规则。",[535,854,855,856,745,859,862,863,279],{},"前半部分套用 ",[41,857,858],{},"(l, o)",[41,860,861],{},"(lo, w)"," 的规则，得到 ",[41,864,807],{},[15,866,867,868,870,871,745,873,875,876,878],{},"奇迹发生了——新造词 ",[41,869,830],{}," 被切成了 ",[41,872,807],{},[41,874,772],{}," 两个 Subword。模型虽然没背过这个词，但顺理成章地理解了这是“低”的“最高级”，不仅完全避免了抛出 ",[41,877,630],{}," 的尴尬，还精准洞察了它的词根逻辑。",[50,880],{},[10,882,884],{"id":883},"进化版bbpebyte-level-bpe","进化版：BBPE（Byte-Level BPE）",[15,886,887],{},"传统的 BPE 一般建立在 Unicode 字符上。然而，世界上的语言、符号极度繁杂，各种稀奇古怪的 emoji 层出不穷，光是把单字符穷举出来就已经是一个庞大的基座了。",[15,889,890,891],{},"后来，OpenAI 在设计 GPT-2 时另辟蹊径：",[30,892,893],{},"任何文本，在计算机底层不全是由 UTF-8 编码的字节（Byte）拼接而成的吗？",[15,895,896,897,900,901,904],{},"既然 1 个字节只有 256 种可能的取值，那就直接把这 ",[30,898,899],{},"256 个基础字节","作为最底层的原子字符！这就诞生了更加通用的 ",[30,902,903],{},"BBPE","（Byte-Level BPE）。",[15,906,907],{},"在这种架构下：",[680,909,910,916],{},[535,911,912,915],{},[30,913,914],{},"永远告别 OOV（未登录词）","：哪怕遇到一段乱码或者罕见的外星文，最后也一定兜底退化成这 256 种字节基础单元的拼接。",[535,917,918,921],{},[30,919,920],{},"词表空间极大释放","：把原本因为处理各国冷门文字而浪费的槽位省出来，让词表更加紧凑纯粹。现代绝大多数万亿参数的巨兽模型，都在沿用这项革命性的改进设计。",{"title":212,"searchDepth":473,"depth":473,"links":923},[924,925,928,929],{"id":608,"depth":473,"text":609},{"id":657,"depth":473,"text":658,"children":926},[927],{"id":670,"depth":489,"text":671},{"id":815,"depth":473,"text":815},{"id":883,"depth":473,"text":884},"\u002Fimg\u002Fpostcard4.jpg","2026-05-19","深入 Byte Pair Encoding (BPE) 的工作流程，理解从字符到子词的合并机制，探讨它为何成为现代 LLM 的标配",{},"\u002Fposts\u002Fbpe-tokenization-algorithm",{"title":603,"description":932},"posts\u002Fbpe-tokenization-algorithm","9zCuC2wb6rMfJiMOWGrAIjJ9BmpdIxbHF1vYD1t29oM",{"id":4,"title":5,"body":939,"categories":589,"cover":590,"date":591,"description":592,"extension":593,"meta":1321,"navigation":595,"path":596,"seo":1322,"stem":598,"tags":589,"__hash__":599},{"type":7,"value":940,"toc":1297},[941,943,945,947,949,953,955,961,963,965,969,1035,1037,1041,1043,1051,1053,1055,1057,1063,1068,1074,1076,1080,1085,1095,1097,1099,1101,1107,1109,1111,1113,1118,1126,1128,1133,1143,1145,1207,1209,1213,1225,1271,1273,1275,1283,1285,1287,1289,1291,1295],[10,942,13],{"id":12},[15,944,17],{},[19,946,22],{"id":21},[15,948,25],{},[15,950,28,951,33],{},[30,952,32],{},[19,954,36],{"id":36},[15,956,39,957,44,959,48],{},[41,958,43],{},[30,960,47],{},[50,962],{},[10,964,55],{"id":54},[15,966,58,967,62],{},[30,968,61],{},[64,970,971,981],{},[67,972,973],{},[70,974,975,977,979],{},[73,976],{},[73,978,77],{},[73,980,80],{},[82,982,983,993,1003,1013,1023],{},[70,984,985,989,991],{},[87,986,987],{},[30,988,91],{},[87,990,94],{},[87,992,97],{},[70,994,995,999,1001],{},[87,996,997],{},[30,998,104],{},[87,1000,107],{},[87,1002,110],{},[70,1004,1005,1009,1011],{},[87,1006,1007],{},[30,1008,117],{},[87,1010,120],{},[87,1012,123],{},[70,1014,1015,1019,1021],{},[87,1016,1017],{},[30,1018,130],{},[87,1020,133],{},[87,1022,136],{},[70,1024,1025,1029,1033],{},[87,1026,1027],{},[30,1028,143],{},[87,1030,1031,149],{},[41,1032,148],{},[87,1034,152],{},[19,1036,156],{"id":155},[15,1038,159,1039,163],{},[30,1040,162],{},[19,1042,167],{"id":166},[15,1044,170,1045,174,1047,178,1049,182],{},[41,1046,173],{},[41,1048,177],{},[41,1050,181],{},[50,1052],{},[10,1054,187],{"id":187},[19,1056,191]