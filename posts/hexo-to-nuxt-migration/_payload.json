[{"data":1,"prerenderedAt":1413},["ShallowReactive",2],{"post-hexo-to-nuxt-migration":3,"all-posts":607},{"id":4,"title":5,"body":6,"categories":596,"cover":597,"date":598,"description":599,"extension":600,"meta":601,"navigation":602,"path":603,"seo":604,"stem":605,"tags":596,"__hash__":606},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":8,"toc":572},"minimark",[9,14,18,23,31,34,46,49,53,60,163,167,174,178,197,199,202,206,217,227,238,242,248,254,273,277,280,284,287,289,292,296,302,316,320,326,343,346,426,429,435,458,532,535,538,551,554,556,559,562,568],[10,11,13],"h2",{"id":12},"为什么要离开-hexo","为什么要离开 Hexo？",[15,16,17],"p",{},"Hexo + Butterfly 这套组合颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，一些痛点逐渐暴露出来。",[19,20,22],"h3",{"id":21},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,24,25,26,30],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——写完文章 push 上去，PWA 缓存不更新，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。清理 Service Worker、硬刷新、改缓存策略，折腾一圈发现根本原因很简单：",[27,28,29],"strong",{},"生成的静态页面本质上是黑盒，你很难精确控制缓存行为","。",[19,32,33],{"id":33},"构建速度与生态",[15,35,36,37,41,42,45],{},"文章数量上来之后，",[38,39,40],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[27,43,44],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[47,48],"hr",{},[10,50,52],{"id":51},"为什么选-nuxt","为什么选 Nuxt？",[15,54,55,56,59],{},"看过 VitePress、Astro、Next.js，最终选了 ",[27,57,58],{},"Nuxt 4 SSG","。核心考量：",[61,62,63,78],"table",{},[64,65,66],"thead",{},[67,68,69,72,75],"tr",{},[70,71],"th",{},[70,73,74],{},"Hexo",[70,76,77],{},"Nuxt 4",[79,80,81,95,108,121,134,150],"tbody",{},[67,82,83,89,92],{},[84,85,86],"td",{},[27,87,88],{},"构建机制",[84,90,91],{},"CLI 全量生成静态文件",[84,93,94],{},"Nitro 引擎预渲染，增量构建",[67,96,97,102,105],{},[84,98,99],{},[27,100,101],{},"模板\u002F组件",[84,103,104],{},"EJS\u002FPug，无组件化",[84,106,107],{},"Vue 3 组件，自动导入",[67,109,110,115,118],{},[84,111,112],{},[27,113,114],{},"内容管理",[84,116,117],{},"front-matter + markdown",[84,119,120],{},"@nuxt\u002Fcontent v3，类型安全查询",[67,122,123,128,131],{},[84,124,125],{},[27,126,127],{},"交互",[84,129,130],{},"内联 script，靠 CDN",[84,132,133],{},"完整的 Vue 响应式生态",[67,135,136,141,147],{},[84,137,138],{},[27,139,140],{},"路由",[84,142,143,144],{},"配置文件 ",[38,145,146],{},"_config.yml",[84,148,149],{},"文件系统路由，动态参数",[67,151,152,157,160],{},[84,153,154],{},[27,155,156],{},"暗色模式",[84,158,159],{},"主题配置 + 手动脚本",[84,161,162],{},"localStorage + CSS 变量，SSR 安全",[19,164,166],{"id":165},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,168,169,170,173],{},"@nuxt\u002Fcontent v3 直接读 markdown，frontmatter 字段几乎不用改。这意味着",[27,171,172],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[19,175,177],{"id":176},"vue-生态的开发体验","Vue 生态的开发体验",[15,179,180,181,184,185,188,189,192,193,196],{},"组件化意味着每个 UI 单元是独立的、可复用的、可测试的。",[38,182,183],{},"useAsyncData"," + ",[38,186,187],{},"queryCollection"," 这套数据获取模式比 Hexo 的 ",[38,190,191],{},"_config + front-matter + theme"," 散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[38,194,195],{},"\u003Cscript>"," 标签。",[47,198],{},[10,200,201],{"id":201},"迁移过程",[19,203,205],{"id":204},"内容层零改动搬过来","内容层：零改动搬过来",[15,207,208,209,212,213,216],{},"所有 markdown 文件从 Hexo 的 ",[38,210,211],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[38,214,215],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[218,219,224],"pre",{"className":220,"code":222,"language":223},[221],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[38,225,222],{"__ignoreMap":226},"",[15,228,229,230,233,234,237],{},"多了个 ",[38,231,232],{},"description"," 字段用于 SEO 和列表摘要，去掉了 ",[38,235,236],{},"tags","（暂时没用）。内容正文一个字没改。",[19,239,241],{"id":240},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,243,244,245,247],{},"Hexo 的 URL 靠 ",[38,246,146],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[218,249,252],{"className":250,"code":251,"language":223},[221],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[38,253,251],{"__ignoreMap":226},[15,255,256,257,260,261,264,265,268,269,272],{},"区别在于 Nuxt 路由由 ",[38,258,259],{},"pages\u002F"," 目录结构决定，",[38,262,263],{},"posts\u002F[slug].vue"," 处理所有文章。配置了 ",[38,266,267],{},"trailingSlash: true"," 保证 URL 一致性。404 用 ",[38,270,271],{},"[...slug].vue"," 兜底。",[19,274,276],{"id":275},"设计系统从-stylus-变量到-css-自定义属性","设计系统：从 Stylus 变量到 CSS 自定义属性",[15,278,279],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移之后直接用 CSS 自定义属性，不需要重新编译样式，主题切换是即时的。",[19,281,283],{"id":282},"部署保持一致","部署：保持一致",[15,285,286],{},"CI 沿用 GitHub Actions，部署流程和原来基本一样。",[47,288],{},[10,290,291],{"id":291},"架构对比",[19,293,295],{"id":294},"hexo-的架构","Hexo 的架构",[218,297,300],{"className":298,"code":299,"language":223},[221],"Hexo CLI\n  ├── _config.yml        # 全局配置\n  ├── themes\u002Fbutterfly\u002F  # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml   # 主题配置\n  │   ├── layout\u002F       # EJS 模板\n  │   └── source\u002F       # 静态资源\n  ├── source\u002F_posts\u002F     # 文章 markdown\n  └── public\u002F            # 生成输出\n",[38,301,299],{"__ignoreMap":226},[15,303,304,305,308,309,311,312,315],{},"Hexo 是",[27,306,307],{},"生成器模式","：CLI 命令触发，读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容是分离的，但数据流是隐式的——配置散落在 ",[38,310,146],{},"、",[38,313,314],{},"_config.butterfly.yml","、frontmatter 三个地方，模板里用不同的变量名访问。",[19,317,319],{"id":318},"nuxt-的架构","Nuxt 的架构",[218,321,324],{"className":322,"code":323,"language":223},[221],"Nuxt App\n  ├── pages\u002F             # 文件系统路由 → SSG 预渲染\n  ├── components\u002F        # Vue 组件（自动导入）\n  ├── content\u002F           # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F        # 博客文章集合\n  │   └── pages\u002F        # 独立页面集合\n  ├── composables\u002F       # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F        # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器       # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F  # 纯静态文件\n",[38,325,323],{"__ignoreMap":226},[15,327,328,329,332,333,335,336,338,339,342],{},"Nuxt 是",[27,330,331],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[38,334,187],{}," 查询内容，",[38,337,183],{}," 管理异步数据，",[38,340,341],{},"useTheme()"," 封装主题逻辑。每一层职责清晰，不会出现 Hexo 那种\"配置在 A 处，变量在 B 处，效果在 C 处\"的情况。",[19,344,345],{"id":345},"数据流对比",[61,347,348,360],{},[64,349,350],{},[67,351,352,355,357],{},[70,353,354],{},"环节",[70,356,74],{},[70,358,359],{},"Nuxt",[79,361,362,375,388,404,415],{},[67,363,364,367,370],{},[84,365,366],{},"内容获取",[84,368,369],{},"读文件 → 模板注入变量",[84,371,372],{},[38,373,374],{},"queryCollection('posts').all()",[67,376,377,380,383],{},[84,378,379],{},"数据管理",[84,381,382],{},"无，模板即数据",[84,384,385,387],{},[38,386,183],{}," + 响应式",[67,389,390,393,398],{},[84,391,392],{},"站点配置",[84,394,395,397],{},[38,396,146],{}," + 主题 config",[84,399,400,403],{},[38,401,402],{},"useSite()"," composable",[67,405,406,409,412],{},[84,407,408],{},"主题",[84,410,411],{},"Stylus 变量 → 编译到 CSS",[84,413,414],{},"CSS 自定义属性 → 运行时切换",[67,416,417,420,423],{},[84,418,419],{},"交互状态",[84,421,422],{},"全局变量 + DOM 操作",[84,424,425],{},"Vue 响应式 + composables",[19,427,428],{"id":428},"预渲染策略",[15,430,431,432,434],{},"Hexo 每次 ",[38,433,40],{}," 都是全量重新生成所有页面。文章多了之后，这个时间变得不可忽视。",[15,436,437,438,441,442,445,446,449,450,453,454,457],{},"Nitro 的 ",[38,439,440],{},"crawlLinks: true"," 则是从 seed routes 出发，按 ",[38,443,444],{},"\u003Ca href>"," 链接爬取需要预渲染的页面。只渲染能找到的、被引用的页面。但要注意：",[27,447,448],{},"crawlLinks 不能替代显式 routes 声明","。如果你的导航是客户端 JS 动态生成的，或者某些页面没有直接的 ",[38,451,452],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。所以在 ",[38,455,456],{},"nitro.prerender.routes"," 里显式声明关键路由是个好习惯：",[218,459,463],{"className":460,"code":461,"language":462,"meta":226,"style":226},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[38,464,465,478,494,526],{"__ignoreMap":226},[466,467,470,474],"span",{"class":468,"line":469},"line",1,[466,471,473],{"class":472},"sVyAn","prerender",[466,475,477],{"class":476},"sn6KH",": {\n",[466,479,481,484,487,491],{"class":468,"line":480},2,[466,482,483],{"class":472},"  crawlLinks",[466,485,486],{"class":476},": ",[466,488,490],{"class":489},"sVC51","true",[466,492,493],{"class":476},",\n",[466,495,497,500,503,507,510,513,515,518,520,523],{"class":468,"line":496},3,[466,498,499],{"class":472},"  routes",[466,501,502],{"class":476},": [",[466,504,506],{"class":505},"subq3","'\u002F'",[466,508,509],{"class":476},", ",[466,511,512],{"class":505},"'\u002Fabout'",[466,514,509],{"class":476},[466,516,517],{"class":505},"'\u002Fposts'",[466,519,509],{"class":476},[466,521,522],{"class":505},"'\u002Flinks'",[466,524,525],{"class":476},"],\n",[466,527,529],{"class":468,"line":528},4,[466,530,531],{"class":476},"}\n",[10,533,534],{"id":534},"迁移成本远低于预期",[15,536,537],{},"说实话出发前我还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[539,540,541,545,548],"ol",{},[542,543,544],"li",{},"搭建 Nuxt 项目骨架",[542,546,547],{},"设计 CSS token 系统",[542,549,550],{},"写几个核心组件",[15,552,553],{},"借助claude code加在一起两天就搞定了。框架升级的收益是长期的，成本是一次性的。",[47,555],{},[10,557,558],{"id":558},"总结",[15,560,561],{},"迁移之前，在折腾 Hexo 的各种\"魔改\"时经常会想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于博客这种内容驱动的站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,563,564,567],{},[27,565,566],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[569,570,571],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":226,"searchDepth":480,"depth":480,"links":573},[574,578,582,588,594,595],{"id":12,"depth":480,"text":13,"children":575},[576,577],{"id":21,"depth":496,"text":22},{"id":33,"depth":496,"text":33},{"id":51,"depth":480,"text":52,"children":579},[580,581],{"id":165,"depth":496,"text":166},{"id":176,"depth":496,"text":177},{"id":201,"depth":480,"text":201,"children":583},[584,585,586,587],{"id":204,"depth":496,"text":205},{"id":240,"depth":496,"text":241},{"id":275,"depth":496,"text":276},{"id":282,"depth":496,"text":283},{"id":291,"depth":480,"text":291,"children":589},[590,591,592,593],{"id":294,"depth":496,"text":295},{"id":318,"depth":496,"text":319},{"id":345,"depth":496,"text":345},{"id":428,"depth":496,"text":428},{"id":534,"depth":480,"text":534},{"id":558,"depth":480,"text":558},null,"\u002Fimg\u002Fpostcard2.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验","md",{},true,"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":5,"description":599},"posts\u002Fhexo-to-nuxt-migration","7bA5FnXNCZWIU4IjBK4kyVQFy7pfJtb2RMCTmKdVaNc",[608,1022],{"id":609,"title":610,"body":611,"categories":596,"cover":1014,"date":1015,"description":1016,"extension":600,"meta":1017,"navigation":602,"path":1018,"seo":1019,"stem":1020,"tags":596,"__hash__":1021},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":7,"value":612,"toc":997},[613,617,620,624,627,642,646,649,710,717,731,753,755,759,762,766,777,803,807,818,820,824,827,831,870,874,899,903,925,929,950,980,982,985,988,991,994],[10,614,616],{"id":615},"折腾第一步让博客先跑起来","折腾第一步：让博客先跑起来",[15,618,619],{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[19,621,623],{"id":622},"_1-搞定基础环境","1. 搞定基础环境",[15,625,626],{},"备好两样工具：",[628,629,630,636],"ul",{},[542,631,632,635],{},[27,633,634],{},"Git & GitHub","：做版本控制和网页托管。",[542,637,638,641],{},[27,639,640],{},"Node.js","：Hexo 的运行基础，官网下个稳定版装上就行。",[19,643,645],{"id":644},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[15,647,648],{},"打开终端，敲几行命令搭好骨架：",[218,650,654],{"className":651,"code":652,"language":653,"meta":226,"style":226},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash",[38,655,656,662,677,695],{"__ignoreMap":226},[466,657,658],{"class":468,"line":469},[466,659,661],{"class":660},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[466,663,664,668,671,674],{"class":468,"line":480},[466,665,667],{"class":666},"sVbv2","npm",[466,669,670],{"class":505}," install",[466,672,673],{"class":489}," -g",[466,675,676],{"class":505}," hexo-cli\n",[466,678,679,682,685,688,692],{"class":468,"line":496},[466,680,681],{"class":666},"mkdir",[466,683,684],{"class":505}," your_blog",[466,686,687],{"class":476}," && ",[466,689,691],{"class":690},"sjrmR","cd",[466,693,694],{"class":505}," your_blog\n",[466,696,697,700,703,705,707],{"class":468,"line":528},[466,698,699],{"class":666},"hexo",[466,701,702],{"class":505}," init",[466,704,687],{"class":476},[466,706,667],{"class":666},[466,708,709],{"class":505}," install\n",[15,711,712,713,716],{},"接着装上 ",[27,714,715],{},"Butterfly"," 主题：",[218,718,720],{"className":651,"code":719,"language":653,"meta":226,"style":226},"npm install hexo-theme-butterfly\n",[38,721,722],{"__ignoreMap":226},[466,723,724,726,728],{"class":468,"line":469},[466,725,667],{"class":666},[466,727,670],{"class":505},[466,729,730],{"class":505}," hexo-theme-butterfly\n",[15,732,733,734,736,737,740,741,744,745,748,749,752],{},"修改根目录 ",[38,735,146],{},"，把 ",[38,738,739],{},"theme"," 设为 ",[38,742,743],{},"butterfly","。终端跑一句 ",[38,746,747],{},"hexo s","，打开 ",[38,750,751],{},"http:\u002F\u002Flocalhost:4000","——看到雏形加载出来的那一刻，还是挺有成就感的！",[47,754],{},[10,756,758],{"id":757},"部署上线让世界看到你的博客","部署上线：让世界看到你的博客",[15,760,761],{},"本地自嗨不够，得把它挂到网上。",[19,763,765],{"id":764},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[15,767,768,769,772,773,776],{},"装好 Git 部署插件 ",[38,770,771],{},"hexo-deployer-git","，在配置文件填上 GitHub 仓库地址和分支（推荐 ",[38,774,775],{},"main","）。然后执行经典的“三连”命令推送到云端：",[218,778,780],{"className":651,"code":779,"language":653,"meta":226,"style":226},"hexo clean && hexo g && hexo d \n",[38,781,782],{"__ignoreMap":226},[466,783,784,786,789,791,793,796,798,800],{"class":468,"line":469},[466,785,699],{"class":666},[466,787,788],{"class":505}," clean",[466,790,687],{"class":476},[466,792,699],{"class":666},[466,794,795],{"class":505}," g",[466,797,687],{"class":476},[466,799,699],{"class":666},[466,801,802],{"class":505}," d\n",[19,804,806],{"id":805},"_2-进阶玩法vercel-与评论系统部署","2. 进阶玩法：Vercel 与评论系统部署",[15,808,809,810,813,814,817],{},"如果想要国内访问更快，强烈推荐用 ",[27,811,812],{},"Vercel"," 托管静态页面。\n另外，我后来还折腾了 ",[27,815,816],{},"Twikoo"," 评论系统，同样用 Vercel 部署云函数。免费好用，不用操心服务器，完美契合静态博客。",[47,819],{},[10,821,823],{"id":822},"魔改与避坑指南那些折磨过我的-bug","🔨 魔改与避坑指南：那些折磨过我的 Bug",[15,825,826],{},"跟着教程走一帆风顺，自己动手加特效（比如轮播图、Aplayer 音乐）时，玄学问题就来了。盘点几个大坑：",[19,828,830],{"id":829},"坑一静态资源加载失败cdn-之痛","❌ 坑一：静态资源加载失败（CDN 之痛）",[15,832,833,836,837,840,841,844,845,311,848,851,852,855,856,858,859,864,865,30],{},[27,834,835],{},"现象","：本地跑得好好的，一部署线上控制台就一片红 ",[38,838,839],{},"ERR_ABORTED","，排版错乱、图标变方块。\n",[27,842,843],{},"原因","：老教程推荐的国内\u002F小众 CDN（如 ",[38,846,847],{},"tianli0.top",[38,849,850],{},"bootcdn","）很多已停运，或在 GitHub\u002FVercel 环境被拦截。\n",[27,853,854],{},"✅ 解决","：果断弃用！在 ",[38,857,314],{}," 里，把第三方资源统统换成国际大厂 CDN，比如 ",[27,860,861],{},[38,862,863],{},"unpkg.com","（最稳妥）或 ",[27,866,867],{},[38,868,869],{},"cdn.jsdelivr.net\u002Fnpm\u002F",[19,871,873],{"id":872},"坑二github-actions-自动部署页面不更新","❌ 坑二：GitHub Actions 自动部署页面不更新",[15,875,876,878,879,881,882,884,885,888,889,891,892,895,896,898],{},[27,877,835],{},"：Workflow 自动构建并推送到 ",[38,880,775],{}," 分支显示成功，但网页死活不更新。\n",[27,883,843],{},"：GitHub Pages 默认可能还在傻傻读取旧的 ",[38,886,887],{},"gh-pages"," 分支。\n",[27,890,854],{},"：去 GitHub 仓库的 ",[27,893,894],{},"Settings -> Pages","，把部署分支手动改为 ",[38,897,775],{},"，保存稍等片刻即可。",[19,900,902],{"id":901},"坑三vercel-部署重复构建报错","❌ 坑三：Vercel 部署重复构建报错",[15,904,905,907,908,910,911,913,914,916,917,920,921,924],{},[27,906,835],{},"：把跑过 Actions 的 ",[38,909,775],{}," 分支导入 Vercel，构建卡住甚至报错。\n",[27,912,843],{},"：Actions 已生成纯静态文件，但 Vercel 发现是 Hexo 项目，又自作多情帮你跑了一遍构建命令。\n",[27,915,854],{},"：在 Vercel 项目设置里找到 ",[27,918,919],{},"Build Command","，打开 Override 并",[27,922,923],{},"留空","。让 Vercel 把它当纯静态站点直接部署，清爽快速。",[19,926,928],{"id":927},"坑四本地预览和线上效果不一致最恶心的玄学","❌ 坑四：本地预览和线上效果不一致（最恶心的玄学）",[15,930,931,933,934,936,937,939,940,943,944,947,948,933],{},[27,932,835],{},"：",[38,935,747],{}," 本地看一切完美，推送到线上后，发现样式没变、自定义的特效出不来，甚至页面错乱。\n",[27,938,843],{},"：这通常和 ",[27,941,942],{},"缓存（浏览器\u002FCDN\u002FPWA 服务端缓存）"," 或 ",[27,945,946],{},"PJAX 异步加载"," 有关。本地是即时响应的，而线上部署后，浏览器或 JS 服务端（Service Worker）会强缓存旧文件。另外，如果加了自定义 JS 特效，由于 Butterfly 开启了 PJAX 无刷新跳转，换页时 JS 可能不会重新执行。\n",[27,949,854],{},[539,951,952,970],{},[542,953,954,957,958,961,962,965,966,969],{},[27,955,956],{},"清缓存","：遇事不决先 ",[38,959,960],{},"hexo clean","，线上调试务必用浏览器的 ",[27,963,964],{},"无痕模式"," 或强刷（",[38,967,968],{},"Ctrl + F5","）。如果开了 PWA，记得去控制台清理 Service Worker。",[542,971,972,975,976,979],{},[27,973,974],{},"PJAX 适配","：如果是自定义 JS 特效失效，要把 JS 代码包在 PJAX 重载事件里（如 ",[38,977,978],{},"document.addEventListener('pjax:complete', function() {...})","），确保每次切页都能重新触发。",[47,981],{},[10,983,984],{"id":984},"最终成果与碎碎念",[15,986,987],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[15,989,990],{},"建站最大的门槛其实是**“开始动手”**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[15,992,993],{},"折腾不息，共勉！",[569,995,996],{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":226,"searchDepth":480,"depth":480,"links":998},[999,1003,1007,1013],{"id":615,"depth":480,"text":616,"children":1000},[1001,1002],{"id":622,"depth":496,"text":623},{"id":644,"depth":496,"text":645},{"id":757,"depth":480,"text":758,"children":1004},[1005,1006],{"id":764,"depth":496,"text":765},{"id":805,"depth":496,"text":806},{"id":822,"depth":480,"text":823,"children":1008},[1009,1010,1011,1012],{"id":829,"depth":496,"text":830},{"id":872,"depth":496,"text":873},{"id":901,"depth":496,"text":902},{"id":927,"depth":496,"text":928},{"id":984,"depth":480,"text":984},"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。",{"一直想有块完全属于自己的“互联网自留地”，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":596},"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":610,"description":1016},"posts\u002Fhexo-blog-setup-guide","-iIvcr3dvTx3ccBXGF2yKcOcpJeLHu_Z2FimYTo3edg",{"id":4,"title":5,"body":1023,"categories":596,"cover":597,"date":598,"description":599,"extension":600,"meta":1411,"navigation":602,"path":603,"seo":1412,"stem":605,"tags":596,"__hash__":606},{"type":7,"value":1024,"toc":1387},[1025,1027,1029,1031,1035,1037,1043,1045,1047,1051,1127,1129,1133,1135,1145,1147,1149,1151,1157,1162,1168,1170,1174,1179,1189,1191,1193,1195,1197,1199,1201,1203,1208,1216,1218,1223,1233,1235,1297,1299,1303,1315,1361,1363,1365,1373,1375,1377,1379,1381,1385],[10,1026,13],{"id":12},[15,1028,17],{},[19,1030,22],{"id":21},[15,1032,25,1033,30],{},[27,1034,29],{},[19,1036,33],{"id":33},[15,1038,36,1039,41,1041,45],{},[38,104