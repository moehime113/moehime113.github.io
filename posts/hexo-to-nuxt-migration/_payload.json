[{"data":1,"prerenderedAt":1396},["ShallowReactive",2],{"post-hexo-to-nuxt-migration":3,"all-posts":600},{"id":4,"title":5,"body":6,"categories":589,"cover":590,"date":591,"description":592,"extension":593,"meta":594,"navigation":595,"path":596,"seo":597,"stem":598,"tags":589,"__hash__":599},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":8,"toc":565},"minimark",[9,14,18,23,26,34,37,49,52,56,63,153,157,164,168,183,185,188,192,203,213,224,228,234,240,259,263,266,270,280,282,285,289,295,309,313,319,336,339,419,422,428,451,525,528,531,544,547,549,552,555,561],[10,11,13],"h2",{"id":12},"为什么要离开-hexo","为什么要离开 Hexo？",[15,16,17],"p",{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[19,20,22],"h3",{"id":21},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,24,25],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,27,28,29,33],{},"问题根源在于：",[30,31,32],"strong",{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[19,35,36],{"id":36},"构建速度与生态",[15,38,39,40,44,45,48],{},"文章数量上来之后，",[41,42,43],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[30,46,47],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[50,51],"hr",{},[10,53,55],{"id":54},"为什么选-nuxt","为什么选 Nuxt？",[15,57,58,59,62],{},"看过 VitePress、Astro、Next.js，最终选了 ",[30,60,61],{},"Nuxt 4 SSG","。核心考量：",[64,65,66,81],"table",{},[67,68,69],"thead",{},[70,71,72,75,78],"tr",{},[73,74],"th",{},[73,76,77],{},"Hexo",[73,79,80],{},"Nuxt 4",[82,83,84,98,111,124,137],"tbody",{},[70,85,86,92,95],{},[87,88,89],"td",{},[30,90,91],{},"构建机制",[87,93,94],{},"CLI 全量生成静态文件",[87,96,97],{},"Nitro 引擎预渲染 + 增量构建",[70,99,100,105,108],{},[87,101,102],{},[30,103,104],{},"模板\u002F组件",[87,106,107],{},"EJS\u002FPug，无组件化",[87,109,110],{},"Vue 3 组件，自动导入",[70,112,113,118,121],{},[87,114,115],{},[30,116,117],{},"内容管理",[87,119,120],{},"front-matter + markdown",[87,122,123],{},"@nuxt\u002Fcontent v3，类型安全查询",[70,125,126,131,134],{},[87,127,128],{},[30,129,130],{},"交互",[87,132,133],{},"内联 script，靠 CDN",[87,135,136],{},"完整的 Vue 响应式生态",[70,138,139,144,150],{},[87,140,141],{},[30,142,143],{},"路由",[87,145,146,149],{},[41,147,148],{},"_config.yml"," permalink 配置",[87,151,152],{},"文件系统路由，动态参数",[19,154,156],{"id":155},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,158,159,160,163],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[30,161,162],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[19,165,167],{"id":166},"vue-生态的开发体验","Vue 生态的开发体验",[15,169,170,171,174,175,178,179,182],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[41,172,173],{},"useAsyncData"," + ",[41,176,177],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[41,180,181],{},"\u003Cscript>"," 标签。",[50,184],{},[10,186,187],{"id":187},"迁移过程",[19,189,191],{"id":190},"内容层零改动搬过来","内容层：零改动搬过来",[15,193,194,195,198,199,202],{},"所有 markdown 文件从 Hexo 的 ",[41,196,197],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[41,200,201],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[204,205,210],"pre",{"className":206,"code":208,"language":209},[207],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[41,211,208],{"__ignoreMap":212},"",[15,214,215,216,219,220,223],{},"多了 ",[41,217,218],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[41,221,222],{},"tags","。内容正文一个字没改。",[19,225,227],{"id":226},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,229,230,231,233],{},"Hexo 的 URL 靠 ",[41,232,148],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[204,235,238],{"className":236,"code":237,"language":209},[207],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[41,239,237],{"__ignoreMap":212},[15,241,242,243,246,247,250,251,254,255,258],{},"Nuxt 路由由 ",[41,244,245],{},"pages\u002F"," 目录结构决定，",[41,248,249],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[41,252,253],{},"trailingSlash: true"," 保证 URL 一致性，",[41,256,257],{},"[...slug].vue"," 兜底 404。",[19,260,262],{"id":261},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,264,265],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[19,267,269],{"id":268},"部署ci-保持不变","部署：CI 保持不变",[15,271,272,273,275,276,279],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[41,274,43],{}," 替换为 ",[41,277,278],{},"npm run build","。",[50,281],{},[10,283,284],{"id":284},"架构对比",[19,286,288],{"id":287},"hexo-的架构","Hexo 的架构",[204,290,293],{"className":291,"code":292,"language":209},[207],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[41,294,292],{"__ignoreMap":212},[15,296,297,298,301,302,304,305,308],{},"Hexo 是",[30,299,300],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[41,303,148],{},"、",[41,306,307],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[19,310,312],{"id":311},"nuxt-的架构","Nuxt 的架构",[204,314,317],{"className":315,"code":316,"language":209},[207],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[41,318,316],{"__ignoreMap":212},[15,320,321,322,325,326,328,329,331,332,335],{},"Nuxt 是",[30,323,324],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[41,327,177],{}," 查询内容，",[41,330,173],{}," 管理异步数据，",[41,333,334],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[19,337,338],{"id":338},"数据流对比",[64,340,341,353],{},[67,342,343],{},[70,344,345,348,350],{},[73,346,347],{},"环节",[73,349,77],{},[73,351,352],{},"Nuxt",[82,354,355,368,381,397,408],{},[70,356,357,360,363],{},[87,358,359],{},"内容获取",[87,361,362],{},"读文件 → 模板注入变量",[87,364,365],{},[41,366,367],{},"queryCollection('posts').all()",[70,369,370,373,376],{},[87,371,372],{},"数据管理",[87,374,375],{},"无，模板即数据",[87,377,378,380],{},[41,379,173],{}," + 响应式",[70,382,383,386,391],{},[87,384,385],{},"站点配置",[87,387,388,390],{},[41,389,148],{}," + 主题 config",[87,392,393,396],{},[41,394,395],{},"useSite()"," composable",[70,398,399,402,405],{},[87,400,401],{},"主题",[87,403,404],{},"Stylus 变量 → 编译到 CSS",[87,406,407],{},"CSS 自定义属性 → 运行时切换",[70,409,410,413,416],{},[87,411,412],{},"交互状态",[87,414,415],{},"全局变量 + DOM 操作",[87,417,418],{},"Vue 响应式 + composables",[19,420,421],{"id":421},"预渲染策略",[15,423,424,425,427],{},"Hexo 每次 ",[41,426,43],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,429,430,431,434,435,438,439,442,443,446,447,450],{},"Nitro 的 ",[41,432,433],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[41,436,437],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[30,440,441],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[41,444,445],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[41,448,449],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[204,452,456],{"className":453,"code":454,"language":455,"meta":212,"style":212},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[41,457,458,471,487,519],{"__ignoreMap":212},[459,460,463,467],"span",{"class":461,"line":462},"line",1,[459,464,466],{"class":465},"sVyAn","prerender",[459,468,470],{"class":469},"sn6KH",": {\n",[459,472,474,477,480,484],{"class":461,"line":473},2,[459,475,476],{"class":465},"  crawlLinks",[459,478,479],{"class":469},": ",[459,481,483],{"class":482},"sVC51","true",[459,485,486],{"class":469},",\n",[459,488,490,493,496,500,503,506,508,511,513,516],{"class":461,"line":489},3,[459,491,492],{"class":465},"  routes",[459,494,495],{"class":469},": [",[459,497,499],{"class":498},"subq3","'\u002F'",[459,501,502],{"class":469},", ",[459,504,505],{"class":498},"'\u002Fabout'",[459,507,502],{"class":469},[459,509,510],{"class":498},"'\u002Fposts'",[459,512,502],{"class":469},[459,514,515],{"class":498},"'\u002Flinks'",[459,517,518],{"class":469},"],\n",[459,520,522],{"class":461,"line":521},4,[459,523,524],{"class":469},"}\n",[10,526,527],{"id":527},"迁移成本远低于预期",[15,529,530],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[532,533,534,538,541],"ol",{},[535,536,537],"li",{},"搭建 Nuxt 项目骨架",[535,539,540],{},"设计 CSS token 系统",[535,542,543],{},"编写几个核心组件",[15,545,546],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[50,548],{},[10,550,551],{"id":551},"总结",[15,553,554],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,556,557,560],{},[30,558,559],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[562,563,564],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":212,"searchDepth":473,"depth":473,"links":566},[567,571,575,581,587,588],{"id":12,"depth":473,"text":13,"children":568},[569,570],{"id":21,"depth":489,"text":22},{"id":36,"depth":489,"text":36},{"id":54,"depth":473,"text":55,"children":572},[573,574],{"id":155,"depth":489,"text":156},{"id":166,"depth":489,"text":167},{"id":187,"depth":473,"text":187,"children":576},[577,578,579,580],{"id":190,"depth":489,"text":191},{"id":226,"depth":489,"text":227},{"id":261,"depth":489,"text":262},{"id":268,"depth":489,"text":269},{"id":284,"depth":473,"text":284,"children":582},[583,584,585,586],{"id":287,"depth":489,"text":288},{"id":311,"depth":489,"text":312},{"id":338,"depth":489,"text":338},{"id":421,"depth":489,"text":421},{"id":527,"depth":473,"text":527},{"id":551,"depth":473,"text":551},null,"\u002Fimg\u002Fpostcard2.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验","md",{},true,"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":5,"description":592},"posts\u002Fhexo-to-nuxt-migration","WLPbeyVHb4dJBAwiXKoGJw3ZexwamFKVaRB231SLgKk",[601,1011],{"id":602,"title":603,"body":604,"categories":589,"cover":1003,"date":1004,"description":1005,"extension":593,"meta":1006,"navigation":595,"path":1007,"seo":1008,"stem":1009,"tags":589,"__hash__":1010},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":7,"value":605,"toc":986},[606,610,613,617,620,635,639,700,703,717,739,741,745,749,752,766,776,802,806,813,815,818,821,825,835,841,861,865,870,878,890,894,902,907,920,924,932,940,944,969,971,974,977,980,983],[10,607,609],{"id":608},"折腾第一步让博客先跑起来","折腾第一步：让博客先跑起来",[15,611,612],{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[19,614,616],{"id":615},"_1-搞定基础环境","1. 搞定基础环境",[15,618,619],{},"备好两样工具：",[621,622,623,629],"ul",{},[535,624,625,628],{},[30,626,627],{},"Git & GitHub","：版本控制 + GitHub Pages 托管",[535,630,631,634],{},[30,632,633],{},"Node.js","：Hexo 运行基础，官网下载稳定版安装即可",[19,636,638],{"id":637},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[204,640,644],{"className":641,"code":642,"language":643,"meta":212,"style":212},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash",[41,645,646,652,667,685],{"__ignoreMap":212},[459,647,648],{"class":461,"line":462},[459,649,651],{"class":650},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[459,653,654,658,661,664],{"class":461,"line":473},[459,655,657],{"class":656},"sVbv2","npm",[459,659,660],{"class":498}," install",[459,662,663],{"class":482}," -g",[459,665,666],{"class":498}," hexo-cli\n",[459,668,669,672,675,678,682],{"class":461,"line":489},[459,670,671],{"class":656},"mkdir",[459,673,674],{"class":498}," your_blog",[459,676,677],{"class":469}," && ",[459,679,681],{"class":680},"sjrmR","cd",[459,683,684],{"class":498}," your_blog\n",[459,686,687,690,693,695,697],{"class":461,"line":521},[459,688,689],{"class":656},"hexo",[459,691,692],{"class":498}," init",[459,694,677],{"class":469},[459,696,657],{"class":656},[459,698,699],{"class":498}," install\n",[15,701,702],{},"安装 Butterfly 主题：",[204,704,706],{"className":641,"code":705,"language":643,"meta":212,"style":212},"npm install hexo-theme-butterfly\n",[41,707,708],{"__ignoreMap":212},[459,709,710,712,714],{"class":461,"line":462},[459,711,657],{"class":656},[459,713,660],{"class":498},[459,715,716],{"class":498}," hexo-theme-butterfly\n",[15,718,719,720,722,723,726,727,730,731,734,735,738],{},"修改根目录 ",[41,721,148],{},"，将 ",[41,724,725],{},"theme"," 设为 ",[41,728,729],{},"butterfly","。执行 ",[41,732,733],{},"hexo s","，打开 ",[41,736,737],{},"http:\u002F\u002Flocalhost:4000"," 即可预览。",[50,740],{},[10,742,744],{"id":743},"部署上线让世界看到你的博客","部署上线：让世界看到你的博客",[19,746,748],{"id":747},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[15,750,751],{},"安装部署插件：",[204,753,755],{"className":641,"code":754,"language":643,"meta":212,"style":212},"npm install hexo-deployer-git\n",[41,756,757],{"__ignoreMap":212},[459,758,759,761,763],{"class":461,"line":462},[459,760,657],{"class":656},[459,762,660],{"class":498},[459,764,765],{"class":498}," hexo-deployer-git\n",[15,767,768,769,771,772,775],{},"在 ",[41,770,148],{}," 中配置 GitHub 仓库地址和分支（推荐 ",[41,773,774],{},"main","），然后执行：",[204,777,779],{"className":641,"code":778,"language":643,"meta":212,"style":212},"hexo clean && hexo g && hexo d\n",[41,780,781],{"__ignoreMap":212},[459,782,783,785,788,790,792,795,797,799],{"class":461,"line":462},[459,784,689],{"class":656},[459,786,787],{"class":498}," clean",[459,789,677],{"class":469},[459,791,689],{"class":656},[459,793,794],{"class":498}," g",[459,796,677],{"class":469},[459,798,689],{"class":656},[459,800,801],{"class":498}," d\n",[19,803,805],{"id":804},"_2-进阶玩法vercel-托管","2. 进阶玩法：Vercel 托管",[15,807,808,809,812],{},"如果想要更快的国内访问速度，可用 ",[30,810,811],{},"Vercel"," 托管静态页面。Vercel 支持自定义域名，适合作为 GitHub Pages 的补充方案。",[50,814],{},[10,816,817],{"id":817},"魔改与避坑指南",[15,819,820],{},"跟着教程走一帆风顺，自己动手加特效（轮播图、Aplayer 音乐）时，玄学问题就来了。",[19,822,824],{"id":823},"坑一静态资源加载失败","❌ 坑一：静态资源加载失败",[15,826,827,830,831,834],{},[30,828,829],{},"现象","：本地正常，部署后控制台一片红 ",[41,832,833],{},"ERR_ABORTED","，排版错乱、图标变方块。",[15,836,837,840],{},[30,838,839],{},"原因","：部分国内 CDN 服务不稳定或已停运，在 GitHub Pages \u002F Vercel 环境可能被拦截。",[15,842,843,846,847,849,850,855,856,279],{},[30,844,845],{},"✅ 解决","：在 ",[41,848,307],{}," 中将第三方资源替换为可靠的公共 CDN，如 ",[30,851,852],{},[41,853,854],{},"unpkg.com"," 或 ",[30,857,858],{},[41,859,860],{},"cdn.jsdelivr.net\u002Fnpm\u002F",[19,862,864],{"id":863},"坑二github-actions-自动部署后页面不更新","❌ 坑二：GitHub Actions 自动部署后页面不更新",[15,866,867,869],{},[30,868,829],{},"：Workflow 显示构建成功，但网页内容未变化。",[15,871,872,874,875,877],{},[30,873,839],{},"：GitHub Pages 默认部署分支可能不是 ",[41,876,774],{},"，或存在缓存延迟。",[15,879,880,882,883,886,887,889],{},[30,881,845],{},"：前往仓库 ",[30,884,885],{},"Settings -> Pages","，确认部署分支为 ",[41,888,774],{},"，保存后等待片刻即可。",[19,891,893],{"id":892},"坑三vercel-重复构建","❌ 坑三：Vercel 重复构建",[15,895,896,898,899,901],{},[30,897,829],{},"：导入 Hexo 项目后 Vercel 再次执行 ",[41,900,43],{},"，导致构建失败或超时。",[15,903,904,906],{},[30,905,839],{},"：Vercel 检测到 Hexo 项目后自动添加了构建命令，与已生成的静态文件冲突。",[15,908,909,911,912,915,916,919],{},[30,910,845],{},"：在 Vercel 项目设置中找到 ",[30,913,914],{},"Build Command","，启用 Override 并",[30,917,918],{},"留空","，让 Vercel 直接部署现有静态文件。",[19,921,923],{"id":922},"坑四本地预览与线上效果不一致","❌ 坑四：本地预览与线上效果不一致",[15,925,926,928,929,931],{},[30,927,829],{},"：",[41,930,733],{}," 本地完美，部署后样式丢失或特效失效。",[15,933,934,928,936,939],{},[30,935,839],{},[30,937,938],{},"缓存问题","（浏览器\u002FCDN\u002FService Worker）是主要原因。另外，Butterfly 开启 PJAX 无刷新跳转后，自定义 JS 不会在页面切换时重新执行。",[15,941,942,928],{},[30,943,845],{},[532,945,946,959],{},[535,947,948,928,951,954,955,958],{},[30,949,950],{},"清理缓存",[41,952,953],{},"hexo clean"," + 浏览器无痕模式 + 强刷（",[41,956,957],{},"Ctrl + F5","）。如有 PWA，需清除 Service Worker。",[535,960,961,964,965,968],{},[30,962,963],{},"PJAX 适配","：将自定义 JS 包裹在 ",[41,966,967],{},"document.addEventListener('pjax:complete', function() {...})"," 中，确保每次切页重新触发。",[50,970],{},[10,972,973],{"id":973},"最终成果与碎碎念",[15,975,976],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[15,978,979],{},"建站最大的门槛其实是**\"开始动手\"**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[15,981,982],{},"折腾不息，共勉！",[562,984,985],{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":212,"searchDepth":473,"depth":473,"links":987},[988,992,996,1002],{"id":608,"depth":473,"text":609,"children":989},[990,991],{"id":615,"depth":489,"text":616},{"id":637,"depth":489,"text":638},{"id":743,"depth":473,"text":744,"children":993},[994,995],{"id":747,"depth":489,"text":748},{"id":804,"depth":489,"text":805},{"id":817,"depth":473,"text":817,"children":997},[998,999,1000,1001],{"id":823,"depth":489,"text":824},{"id":863,"depth":489,"text":864},{"id":892,"depth":489,"text":893},{"id":922,"depth":489,"text":923},{"id":973,"depth":473,"text":973},"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。",{"一直想有块完全属于自己的\"互联网自留地\"，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":589},"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":603,"description":1005},"posts\u002Fhexo-blog-setup-guide","4HAFjOV9mecL4xIvfuPYvhgKN1vVQGrnrG92lq58mbA",{"id":4,"title":5,"body":1012,"categories":589,"cover":590,"date":591,"description":592,"extension":593,"meta":1394,"navigation":595,"path":596,"seo":1395,"stem":598,"tags":589,"__hash__":599},{"type":7,"value":1013,"toc":1370},[1014,1016,1018,1020,1022,1026,1028,1034,1036,1038,1042,1108,1110,1114,1116,1124,1126,1128,1130,1136,1141,1147,1149,1153,1158,1168,1170,1172,1174,1180,1182,1184,1186,1191,1199,1201,1206,1216,1218,1280,1282,1286,1298,1344,1346,1348,1356,1358,1360,1362,1364,1368],[10,1015,13],{"id":12},[15,1017,17],{},[19,1019,22],{"id":21},[15,1021,25],{},[15,1023,28,1024,33],{},[30,1025,32],{},[19,1027,36],{"id":36},[15,1029,39,1030,44,1032,48],{},[41,1031,43],{},[30,1033,47],{},[50,1035],{},[10,1037,55],{"id":54},[15,1039,58,1040,62],{},[30,1041,61],{},[64,1043,1044,1054],{},[67,1045,1046],{},[70,1047,1048,1050,1052],{},[73,1049],{},[73,1051,77],{},[73,1053,80],{},[82,1055,1056,1066,1076,1086,1096],{},[70,1057,1058,1062,1064],{},[87,1059,1060],{},[30,1061,91],{},[87,1063,9