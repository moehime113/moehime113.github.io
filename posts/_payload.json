[{"data":1,"prerenderedAt":467},["ShallowReactive",2],{"all-posts":3},[4,31],{"id":5,"title":6,"body":7,"categories":18,"cover":20,"date":21,"description":22,"extension":23,"meta":24,"navigation":25,"path":26,"seo":27,"stem":28,"tags":29,"__hash__":30},"posts\u002Fposts\u002Ftest-1.md","测试文章 - 技术教程",{"type":8,"value":9,"toc":14},"minimark",[10],[11,12,13],"p",{},"这是一篇关于技术教程的测试文章。",{"title":15,"searchDepth":16,"depth":16,"links":17},"",2,[],[19],"嵌入式","\u002Fimg\u002Fpostcard2.jpg","2026-04-20","技术教程实践记录，整理常用技巧与问题处理方法","md",{"swiper_index":16},true,"\u002Fposts\u002Ftest-1",{"title":6,"description":22},"posts\u002Ftest-1",null,"M0HVp3JAWawPA4cK6QwCj9Jxjsce2rJGKzQkjHSNCt4",{"id":32,"title":33,"body":34,"categories":29,"cover":459,"date":460,"description":461,"extension":23,"meta":462,"navigation":25,"path":463,"seo":464,"stem":465,"tags":29,"__hash__":466},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":8,"value":35,"toc":442},[36,41,44,49,52,69,73,76,147,154,168,191,194,198,201,205,216,242,246,257,259,263,266,270,312,316,341,345,367,371,392,423,425,429,432,435,438],[37,38,40],"h2",{"id":39},"️-折腾第一步让博客先跑起来","🛠️ 折腾第一步：让博客先跑起来",[11,42,43],{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[45,46,48],"h3",{"id":47},"_1-搞定基础环境","1. 搞定基础环境",[11,50,51],{},"备好两样工具：",[53,54,55,63],"ul",{},[56,57,58,62],"li",{},[59,60,61],"strong",{},"Git & GitHub","：做版本控制和网页托管。",[56,64,65,68],{},[59,66,67],{},"Node.js","：Hexo 的运行基础，官网下个稳定版装上就行。",[45,70,72],{"id":71},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[11,74,75],{},"打开终端，敲几行命令搭好骨架：",[77,78,82],"pre",{"className":79,"code":80,"language":81,"meta":15,"style":15},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash",[83,84,85,94,111,131],"code",{"__ignoreMap":15},[86,87,90],"span",{"class":88,"line":89},"line",1,[86,91,93],{"class":92},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[86,95,96,100,104,108],{"class":88,"line":16},[86,97,99],{"class":98},"sVbv2","npm",[86,101,103],{"class":102},"subq3"," install",[86,105,107],{"class":106},"sVC51"," -g",[86,109,110],{"class":102}," hexo-cli\n",[86,112,114,117,120,124,128],{"class":88,"line":113},3,[86,115,116],{"class":98},"mkdir",[86,118,119],{"class":102}," your_blog",[86,121,123],{"class":122},"sn6KH"," && ",[86,125,127],{"class":126},"sjrmR","cd",[86,129,130],{"class":102}," your_blog\n",[86,132,134,137,140,142,144],{"class":88,"line":133},4,[86,135,136],{"class":98},"hexo",[86,138,139],{"class":102}," init",[86,141,123],{"class":122},[86,143,99],{"class":98},[86,145,146],{"class":102}," install\n",[11,148,149,150,153],{},"接着装上 ",[59,151,152],{},"Butterfly"," 主题：",[77,155,157],{"className":79,"code":156,"language":81,"meta":15,"style":15},"npm install hexo-theme-butterfly\n",[83,158,159],{"__ignoreMap":15},[86,160,161,163,165],{"class":88,"line":89},[86,162,99],{"class":98},[86,164,103],{"class":102},[86,166,167],{"class":102}," hexo-theme-butterfly\n",[11,169,170,171,174,175,178,179,182,183,186,187,190],{},"修改根目录 ",[83,172,173],{},"_config.yml","，把 ",[83,176,177],{},"theme"," 设为 ",[83,180,181],{},"butterfly","。终端跑一句 ",[83,184,185],{},"hexo s","，打开 ",[83,188,189],{},"http:\u002F\u002Flocalhost:4000","——看到雏形加载出来的那一刻，还是挺有成就感的！",[192,193],"hr",{},[37,195,197],{"id":196},"部署上线让世界看到你的博客","🚀 部署上线：让世界看到你的博客",[11,199,200],{},"本地自嗨不够，得把它挂到网上。",[45,202,204],{"id":203},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[11,206,207,208,211,212,215],{},"装好 Git 部署插件 ",[83,209,210],{},"hexo-deployer-git","，在配置文件填上 GitHub 仓库地址和分支（推荐 ",[83,213,214],{},"main","）。然后执行经典的“三连”命令推送到云端：",[77,217,219],{"className":79,"code":218,"language":81,"meta":15,"style":15},"hexo clean && hexo g && hexo d \n",[83,220,221],{"__ignoreMap":15},[86,222,223,225,228,230,232,235,237,239],{"class":88,"line":89},[86,224,136],{"class":98},[86,226,227],{"class":102}," clean",[86,229,123],{"class":122},[86,231,136],{"class":98},[86,233,234],{"class":102}," g",[86,236,123],{"class":122},[86,238,136],{"class":98},[86,240,241],{"class":102}," d\n",[45,243,245],{"id":244},"_2-进阶玩法vercel-与评论系统部署","2. 进阶玩法：Vercel 与评论系统部署",[11,247,248,249,252,253,256],{},"如果想要国内访问更快，强烈推荐用 ",[59,250,251],{},"Vercel"," 托管静态页面。\n另外，我后来还折腾了 ",[59,254,255],{},"Twikoo"," 评论系统，同样用 Vercel 部署云函数。免费好用，不用操心服务器，完美契合静态博客。",[192,258],{},[37,260,262],{"id":261},"魔改与避坑指南那些折磨过我的-bug","🔨 魔改与避坑指南：那些折磨过我的 Bug",[11,264,265],{},"跟着教程走一帆风顺，自己动手加特效（比如轮播图、Aplayer 音乐）时，玄学问题就来了。盘点几个大坑：",[45,267,269],{"id":268},"坑一静态资源加载失败cdn-之痛","❌ 坑一：静态资源加载失败（CDN 之痛）",[11,271,272,275,276,279,280,283,284,287,288,291,292,295,296,299,300,305,306,311],{},[59,273,274],{},"现象","：本地跑得好好的，一部署线上控制台就一片红 ",[83,277,278],{},"ERR_ABORTED","，排版错乱、图标变方块。\n",[59,281,282],{},"原因","：老教程推荐的国内\u002F小众 CDN（如 ",[83,285,286],{},"tianli0.top","、",[83,289,290],{},"bootcdn","）很多已停运，或在 GitHub\u002FVercel 环境被拦截。\n",[59,293,294],{},"✅ 解决","：果断弃用！在 ",[83,297,298],{},"_config.butterfly.yml"," 里，把第三方资源统统换成国际大厂 CDN，比如 ",[59,301,302],{},[83,303,304],{},"unpkg.com","（最稳妥）或 ",[59,307,308],{},[83,309,310],{},"cdn.jsdelivr.net\u002Fnpm\u002F","。",[45,313,315],{"id":314},"坑二github-actions-自动部署页面不更新","❌ 坑二：GitHub Actions 自动部署页面不更新",[11,317,318,320,321,323,324,326,327,330,331,333,334,337,338,340],{},[59,319,274],{},"：Workflow 自动构建并推送到 ",[83,322,214],{}," 分支显示成功，但网页死活不更新。\n",[59,325,282],{},"：GitHub Pages 默认可能还在傻傻读取旧的 ",[83,328,329],{},"gh-pages"," 分支。\n",[59,332,294],{},"：去 GitHub 仓库的 ",[59,335,336],{},"Settings -> Pages","，把部署分支手动改为 ",[83,339,214],{},"，保存稍等片刻即可。",[45,342,344],{"id":343},"坑三vercel-部署重复构建报错","❌ 坑三：Vercel 部署重复构建报错",[11,346,347,349,350,352,353,355,356,358,359,362,363,366],{},[59,348,274],{},"：把跑过 Actions 的 ",[83,351,214],{}," 分支导入 Vercel，构建卡住甚至报错。\n",[59,354,282],{},"：Actions 已生成纯静态文件，但 Vercel 发现是 Hexo 项目，又自作多情帮你跑了一遍构建命令。\n",[59,357,294],{},"：在 Vercel 项目设置里找到 ",[59,360,361],{},"Build Command","，打开 Override 并",[59,364,365],{},"留空","。让 Vercel 把它当纯静态站点直接部署，清爽快速。",[45,368,370],{"id":369},"坑四本地预览和线上效果不一致最恶心的玄学","❌ 坑四：本地预览和线上效果不一致（最恶心的玄学）",[11,372,373,375,376,378,379,381,382,385,386,389,390,375],{},[59,374,274],{},"：",[83,377,185],{}," 本地看一切完美，推送到线上后，发现样式没变、自定义的特效出不来，甚至页面错乱。\n",[59,380,282],{},"：这通常和 ",[59,383,384],{},"缓存（浏览器\u002FCDN\u002FPWA 服务端缓存）"," 或 ",[59,387,388],{},"PJAX 异步加载"," 有关。本地是即时响应的，而线上部署后，浏览器或 JS 服务端（Service Worker）会强缓存旧文件。另外，如果加了自定义 JS 特效，由于 Butterfly 开启了 PJAX 无刷新跳转，换页时 JS 可能不会重新执行。\n",[59,391,294],{},[393,394,395,413],"ol",{},[56,396,397,400,401,404,405,408,409,412],{},[59,398,399],{},"清缓存","：遇事不决先 ",[83,402,403],{},"hexo clean","，线上调试务必用浏览器的 ",[59,406,407],{},"无痕模式"," 或强刷（",[83,410,411],{},"Ctrl + F5","）。如果开了 PWA，记得去控制台清理 Service Worker。",[56,414,415,418,419,422],{},[59,416,417],{},"PJAX 适配","：如果是自定义 JS 特效失效，要把 JS 代码包在 PJAX 重载事件里（如 ",[83,420,421],{},"document.addEventListener('pjax:complete', function() {...})","），确保每次切页都能重新触发。",[192,424],{},[37,426,428],{"id":427},"最终成果与碎碎念","💡 最终成果与碎碎念",[11,430,431],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[11,433,434],{},"建站最大的门槛其实是**“开始动手”**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[11,436,437],{},"折腾不息，共勉！",[439,440,441],"style",{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":15,"searchDepth":16,"depth":16,"links":443},[444,448,452,458],{"id":39,"depth":16,"text":40,"children":445},[446,447],{"id":47,"depth":113,"text":48},{"id":71,"depth":113,"text":72},{"id":196,"depth":16,"text":197,"children":449},[450,451],{"id":203,"depth":113,"text":204},{"id":244,"depth":113,"text":245},{"id":261,"depth":16,"text":262,"children":453},[454,455,456,457],{"id":268,"depth":113,"text":269},{"id":314,"depth":113,"text":315},{"id":343,"depth":113,"text":344},{"id":369,"depth":113,"text":370},{"id":427,"depth":16,"text":428},"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。",{"一直想有块完全属于自己的“互联网自留地”，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":29},"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":33,"description":461},"posts\u002Fhexo-blog-setup-guide","HQU7S1_SXw8u818bsiWJu6Q2b1x6PS2Vk5Fv85HCetU",1777744647269]