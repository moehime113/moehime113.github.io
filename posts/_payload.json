[{"data":1,"prerenderedAt":719},["ShallowReactive",2],{"all-posts":3},[4,130],{"id":5,"title":6,"body":7,"categories":113,"cover":116,"date":117,"description":118,"extension":119,"meta":120,"navigation":121,"path":122,"seo":123,"stem":124,"tags":125,"__hash__":129},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 独立配置公开",{"type":8,"value":9,"toc":105},"minimark",[10,14,18,21,37,40,72,76,87,91],[11,12,13],"h2",{"id":13},"我的配置清单",[15,16,17],"p",{},"Ubuntu 26.04 现在已经是我的主力系统，日常办公和游戏都能覆盖。整理一版当前环境配置，也顺便做个记录。",[15,19,20],{},"惯例先贴系统信息：",[22,23,24,28,31,34],"ul",{},[25,26,27],"li",{},"OS：Ubuntu 26.04 LTS",[25,29,30],{},"Kernel：Linux 7.0.0-15-generic",[25,32,33],{},"CPU：Intel Core i7-14700H",[25,35,36],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[11,38,39],{"id":39},"系统与桌面环境",[22,41,42,45,48,51,54,57,60,63,66,69],{},[25,43,44],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[25,46,47],{},"桌面协议：Wayland",[25,49,50],{},"窗口管理：Mutter",[25,52,53],{},"Shell：zsh 5.9",[25,55,56],{},"终端：Ghostty",[25,58,59],{},"输入法：Fcitx5（小鹤音形）",[25,61,62],{},"主题：Orchis-dark",[25,64,65],{},"壁纸：Variety",[25,67,68],{},"截图：Flameshot",[25,70,71],{},"VPN：v2rayN（Linux 版本）",[11,73,75],{"id":74},"工作-学习","工作 \u002F 学习",[22,77,78,81,84],{},[25,79,80],{},"办公：WPS",[25,82,83],{},"编辑器：VS Code",[25,85,86],{},"AI 工具管理：CCSwitch（ccswitch）",[11,88,90],{"id":89},"生活-游戏","生活 \u002F 游戏",[22,92,93,96,99,102],{},[25,94,95],{},"游戏：Steam",[25,97,98],{},"兼容层：Proton GE",[25,100,101],{},"浏览器：Edge",[25,103,104],{},"聊天：微信 \u002F QQ",{"title":106,"searchDepth":107,"depth":107,"links":108},"",2,[109,110,111,112],{"id":13,"depth":107,"text":13},{"id":39,"depth":107,"text":39},{"id":74,"depth":107,"text":75},{"id":89,"depth":107,"text":90},[114,115],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单（办公、开发、游戏）。","md",{},true,"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":6,"description":118},"posts\u002Fubuntu-26-04-my-setup",[126,127,128],"Ubuntu","Wayland","桌面配置","rjkvnaXVfPdP06cHABPQ_-5D0ukHpPp14S2XFkbvgpg",{"id":131,"title":132,"body":133,"categories":710,"cover":711,"date":712,"description":713,"extension":119,"meta":714,"navigation":121,"path":715,"seo":716,"stem":717,"tags":710,"__hash__":718},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":8,"value":134,"toc":686},[135,139,142,147,150,158,161,173,176,180,187,277,281,288,292,307,309,312,316,327,336,347,351,357,363,382,386,389,393,403,405,408,412,418,432,436,442,459,462,542,545,551,574,647,650,653,665,668,670,673,676,682],[11,136,138],{"id":137},"为什么要离开-hexo","为什么要离开 Hexo？",[15,140,141],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[143,144,146],"h3",{"id":145},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,148,149],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,151,152,153,157],{},"问题根源在于：",[154,155,156],"strong",{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[143,159,160],{"id":160},"构建速度与生态",[15,162,163,164,168,169,172],{},"文章数量上来之后，",[165,166,167],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[154,170,171],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[174,175],"hr",{},[11,177,179],{"id":178},"为什么选-nuxt","为什么选 Nuxt？",[15,181,182,183,186],{},"看过 VitePress、Astro、Next.js，最终选了 ",[154,184,185],{},"Nuxt 4 SSG","。核心考量：",[188,189,190,205],"table",{},[191,192,193],"thead",{},[194,195,196,199,202],"tr",{},[197,198],"th",{},[197,200,201],{},"Hexo",[197,203,204],{},"Nuxt 4",[206,207,208,222,235,248,261],"tbody",{},[194,209,210,216,219],{},[211,212,213],"td",{},[154,214,215],{},"构建机制",[211,217,218],{},"CLI 全量生成静态文件",[211,220,221],{},"Nitro 引擎预渲染 + 增量构建",[194,223,224,229,232],{},[211,225,226],{},[154,227,228],{},"模板\u002F组件",[211,230,231],{},"EJS\u002FPug，无组件化",[211,233,234],{},"Vue 3 组件，自动导入",[194,236,237,242,245],{},[211,238,239],{},[154,240,241],{},"内容管理",[211,243,244],{},"front-matter + markdown",[211,246,247],{},"@nuxt\u002Fcontent v3，类型安全查询",[194,249,250,255,258],{},[211,251,252],{},[154,253,254],{},"交互",[211,256,257],{},"内联 script，靠 CDN",[211,259,260],{},"完整的 Vue 响应式生态",[194,262,263,268,274],{},[211,264,265],{},[154,266,267],{},"路由",[211,269,270,273],{},[165,271,272],{},"_config.yml"," permalink 配置",[211,275,276],{},"文件系统路由，动态参数",[143,278,280],{"id":279},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,282,283,284,287],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[154,285,286],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[143,289,291],{"id":290},"vue-生态的开发体验","Vue 生态的开发体验",[15,293,294,295,298,299,302,303,306],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[165,296,297],{},"useAsyncData"," + ",[165,300,301],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[165,304,305],{},"\u003Cscript>"," 标签。",[174,308],{},[11,310,311],{"id":311},"迁移过程",[143,313,315],{"id":314},"内容层零改动搬过来","内容层：零改动搬过来",[15,317,318,319,322,323,326],{},"所有 markdown 文件从 Hexo 的 ",[165,320,321],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[165,324,325],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[328,329,334],"pre",{"className":330,"code":332,"language":333},[331],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[165,335,332],{"__ignoreMap":106},[15,337,338,339,342,343,346],{},"多了 ",[165,340,341],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[165,344,345],{},"tags","。内容正文一个字没改。",[143,348,350],{"id":349},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,352,353,354,356],{},"Hexo 的 URL 靠 ",[165,355,272],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[328,358,361],{"className":359,"code":360,"language":333},[331],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[165,362,360],{"__ignoreMap":106},[15,364,365,366,369,370,373,374,377,378,381],{},"Nuxt 路由由 ",[165,367,368],{},"pages\u002F"," 目录结构决定，",[165,371,372],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[165,375,376],{},"trailingSlash: true"," 保证 URL 一致性，",[165,379,380],{},"[...slug].vue"," 兜底 404。",[143,383,385],{"id":384},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,387,388],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[143,390,392],{"id":391},"部署ci-保持不变","部署：CI 保持不变",[15,394,395,396,398,399,402],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[165,397,167],{}," 替换为 ",[165,400,401],{},"npm run build","。",[174,404],{},[11,406,407],{"id":407},"架构对比",[143,409,411],{"id":410},"hexo-的架构","Hexo 的架构",[328,413,416],{"className":414,"code":415,"language":333},[331],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[165,417,415],{"__ignoreMap":106},[15,419,420,421,424,425,427,428,431],{},"Hexo 是",[154,422,423],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[165,426,272],{},"、",[165,429,430],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[143,433,435],{"id":434},"nuxt-的架构","Nuxt 的架构",[328,437,440],{"className":438,"code":439,"language":333},[331],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[165,441,439],{"__ignoreMap":106},[15,443,444,445,448,449,451,452,454,455,458],{},"Nuxt 是",[154,446,447],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[165,450,301],{}," 查询内容，",[165,453,297],{}," 管理异步数据，",[165,456,457],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[143,460,461],{"id":461},"数据流对比",[188,463,464,476],{},[191,465,466],{},[194,467,468,471,473],{},[197,469,470],{},"环节",[197,472,201],{},[197,474,475],{},"Nuxt",[206,477,478,491,504,520,531],{},[194,479,480,483,486],{},[211,481,482],{},"内容获取",[211,484,485],{},"读文件 → 模板注入变量",[211,487,488],{},[165,489,490],{},"queryCollection('posts').all()",[194,492,493,496,499],{},[211,494,495],{},"数据管理",[211,497,498],{},"无，模板即数据",[211,500,501,503],{},[165,502,297],{}," + 响应式",[194,505,506,509,514],{},[211,507,508],{},"站点配置",[211,510,511,513],{},[165,512,272],{}," + 主题 config",[211,515,516,519],{},[165,517,518],{},"useSite()"," composable",[194,521,522,525,528],{},[211,523,524],{},"主题",[211,526,527],{},"Stylus 变量 → 编译到 CSS",[211,529,530],{},"CSS 自定义属性 → 运行时切换",[194,532,533,536,539],{},[211,534,535],{},"交互状态",[211,537,538],{},"全局变量 + DOM 操作",[211,540,541],{},"Vue 响应式 + composables",[143,543,544],{"id":544},"预渲染策略",[15,546,547,548,550],{},"Hexo 每次 ",[165,549,167],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,552,553,554,557,558,561,562,565,566,569,570,573],{},"Nitro 的 ",[165,555,556],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[165,559,560],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[154,563,564],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[165,567,568],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[165,571,572],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[328,575,579],{"className":576,"code":577,"language":578,"meta":106,"style":106},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[165,580,581,594,609,641],{"__ignoreMap":106},[582,583,586,590],"span",{"class":584,"line":585},"line",1,[582,587,589],{"class":588},"sVyAn","prerender",[582,591,593],{"class":592},"sn6KH",": {\n",[582,595,596,599,602,606],{"class":584,"line":107},[582,597,598],{"class":588},"  crawlLinks",[582,600,601],{"class":592},": ",[582,603,605],{"class":604},"sVC51","true",[582,607,608],{"class":592},",\n",[582,610,612,615,618,622,625,628,630,633,635,638],{"class":584,"line":611},3,[582,613,614],{"class":588},"  routes",[582,616,617],{"class":592},": [",[582,619,621],{"class":620},"subq3","'\u002F'",[582,623,624],{"class":592},", ",[582,626,627],{"class":620},"'\u002Fabout'",[582,629,624],{"class":592},[582,631,632],{"class":620},"'\u002Fposts'",[582,634,624],{"class":592},[582,636,637],{"class":620},"'\u002Flinks'",[582,639,640],{"class":592},"],\n",[582,642,644],{"class":584,"line":643},4,[582,645,646],{"class":592},"}\n",[11,648,649],{"id":649},"迁移成本远低于预期",[15,651,652],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[654,655,656,659,662],"ol",{},[25,657,658],{},"搭建 Nuxt 项目骨架",[25,660,661],{},"设计 CSS token 系统",[25,663,664],{},"编写几个核心组件",[15,666,667],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[174,669],{},[11,671,672],{"id":672},"总结",[15,674,675],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,677,678,681],{},[154,679,680],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[683,684,685],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":106,"searchDepth":107,"depth":107,"links":687},[688,692,696,702,708,709],{"id":137,"depth":107,"text":138,"children":689},[690,691],{"id":145,"depth":611,"text":146},{"id":160,"depth":611,"text":160},{"id":178,"depth":107,"text":179,"children":693},[694,695],{"id":279,"depth":611,"text":280},{"id":290,"depth":611,"text":291},{"id":311,"depth":107,"text":311,"children":697},[698,699,700,701],{"id":314,"depth":611,"text":315},{"id":349,"depth":611,"text":350},{"id":384,"depth":611,"text":385},{"id":391,"depth":611,"text":392},{"id":407,"depth":107,"text":407,"children":703},[704,705,706,707],{"id":410,"depth":611,"text":411},{"id":434,"depth":611,"text":435},{"id":461,"depth":611,"text":461},{"id":544,"depth":611,"text":544},{"id":649,"depth":107,"text":649},{"id":672,"depth":107,"text":672},null,"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":132,"description":713},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",1778836939229]