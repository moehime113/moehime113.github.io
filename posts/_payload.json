[{"data":1,"prerenderedAt":1738},["ShallowReactive",2],{"all-posts":3},[4,357,1039,1163],{"id":5,"title":6,"body":7,"categories":346,"cover":347,"date":348,"description":349,"extension":350,"meta":351,"navigation":352,"path":353,"seo":354,"stem":355,"tags":346,"__hash__":356},"posts\u002Fposts\u002Fbpe-tokenization-algorithm.md","BPE 分词算法原理讲解：大模型背后的词表构建基石",{"type":8,"value":9,"toc":335},"minimark",[10,15,19,40,54,61,64,68,74,77,82,89,117,130,166,185,220,223,225,228,231,237,243,278,292,294,298,301,307,318,321],[11,12,14],"h2",{"id":13},"词表危机llm-如何认识世界","词表危机：LLM 如何认识世界？",[16,17,18],"p",{},"在把人类语言喂给 Transformer 等深度学习模型之前，我们必须先将其切分成离散的“词元”（Token）。这个切分过程往往面临两难：",[16,20,21,22,26,27,31,32,35,36,39],{},"如果",[23,24,25],"strong",{},"按词切分（Word-level）","，比如把 ",[28,29,30],"code",{},"machine learning"," 变成 ",[28,33,34],{},"[machine, learning]","，随着语料丰富，词汇表会膨胀到天文数字大小。而且在遇到网络造词、罕见拼写变形时，模型只能用 ",[28,37,38],{},"\u003CUNK>"," (未知) 符号糊弄过去，丢失极大的信息。",[16,41,42,43,46,47,50,51,53],{},"如果退而求其次",[23,44,45],{},"按字符切分（Character-level）","，比如拆成 ",[28,48,49],{},"[m, a, c, h, i, n, e, ...]","，虽然词表变小了且没有 ",[28,52,38],{}," 问题，但每个句子的序列长度会暴增。这直接会导致 Transformer 昂贵的注意力机制算力爆炸，且单个字母也很难承载复杂的语义。",[16,55,56,57,60],{},"那么，有没有一种两全其美的办法，既能把常见词当成整体处理，又能把生僻词拆成合理的词根？",[23,58,59],{},"BPE（字节对编码）"," 应运而生。",[62,63],"hr",{},[11,65,67],{"id":66},"bpe-是如何炼成的","BPE 是如何炼成的？",[16,69,70,71],{},"BPE（Byte Pair Encoding）原本是用于数据压缩的古老算法。其核心思路非常纯粹：",[23,72,73],{},"将文本中最高频出现的相邻符号对，合并成一个新的大符号。",[16,75,76],{},"通过在语料库上持续进行“频率统计 $\\to$ 贪心合并”，模型可以自动学出一套包含不同粒度的子词（Subword）词表。",[78,79,81],"h3",{"id":80},"模拟训练构造一个迷你词表","模拟训练：构造一个迷你词表",[16,83,84,85,88],{},"假设我们手头只有以下 4 个单词及其词频，为了清楚边界，我们给每个词结尾加一个特殊标记 ",[28,86,87],{},"\u003C\u002Fw>","：",[90,91,92,99,105,111],"ul",{},[93,94,95,98],"li",{},[28,96,97],{},"low\u003C\u002Fw>"," （出现 5 次）",[93,100,101,104],{},[28,102,103],{},"lower\u003C\u002Fw>"," （出现 2 次）",[93,106,107,110],{},[28,108,109],{},"newest\u003C\u002Fw>"," （出现 6 次）",[93,112,113,116],{},[28,114,115],{},"widest\u003C\u002Fw>"," （出现 3 次）",[16,118,119,122,125,126,129],{},[23,120,121],{},"Step 1：拆成原子字符",[123,124],"br",{},"\n一开始，我们把所有词打碎，此时的基础词表只有拆开的单字符：",[28,127,128],{},"l, o, w, e, r, n, s, t, i, d, \u003C\u002Fw>","。",[16,131,132,135,137,138,141,142,145,146,149,150,153,154,157,158,161,162,165],{},[23,133,134],{},"Step 2：寻找最高频组合",[123,136],{},"\n扫描这批打碎的语料，统计相邻两两字符的出现频率。\n我们注意到 ",[28,139,140],{},"(e, s)"," 相邻的频率非常高：在 ",[28,143,144],{},"newest"," 中出现了 6 次，在 ",[28,147,148],{},"widest"," 中出现了 3 次，总计 ",[23,151,152],{},"9次","。\n由于它是最高频对，我们将 ",[28,155,156],{},"e"," 和 ",[28,159,160],{},"s"," 合并为新词元 ",[28,163,164],{},"es","，并将其郑重写入我们的词汇表中。",[16,167,168,171,173,174,177,178,181,182,129],{},[23,169,170],{},"Step 3：不断迭代",[123,172],{},"\n此时数据变成了 ",[28,175,176],{},"n e w es t \u003C\u002Fw>"," 等。我们继续扫描，发现 ",[28,179,180],{},"(es, t)"," 又紧挨着出现了 9 次。\n继续合并：我们得到新词元 ",[28,183,184],{},"est",[16,186,187,188,191,192,195,196,199,200,157,203,206,207,210,211,157,213,216,217,129],{},"之后 ",[28,189,190],{},"(est, \u003C\u002Fw>)"," 会被合并为 ",[28,193,194],{},"est\u003C\u002Fw>","，因为英文里 ",[28,197,198],{},"-est"," 作为后缀经常出现在词尾。再往后，",[28,201,202],{},"l",[28,204,205],{},"o"," 会合并为 ",[28,208,209],{},"lo","，接着 ",[28,212,209],{},[28,214,215],{},"w"," 合并为 ",[28,218,219],{},"low",[16,221,222],{},"只要我们将这个循环跑下去，设定一个目标词表大小（比如 32,000 或 64,000），算法就会在拼满后自动停止。最终生成的词汇库里，既有基础的单字符，也会包含大量高频的前缀、后缀和常用单词。",[62,224],{},[11,226,227],{"id":227},"推理阶段的切词艺术",[16,229,230],{},"词表炼成之后，对于任意一段全新的用户输入，BPE 是如何进行拆解的呢？",[16,232,233,234],{},"规则其实是死板而严格的：",[23,235,236],{},"绝对服从训练时生成的合并记录，依次尝试将字符组合起来。",[16,238,239,240,129],{},"举个例子，用户输入了一个模型从未在训练语料里见过的生造词 ",[28,241,242],{},"lowest",[244,245,246,252,266],"ol",{},[93,247,248,249],{},"BPE 先把它切得粉碎：",[28,250,251],{},"l o w e s t \u003C\u002Fw>",[93,253,254,255,257,258,260,261,257,263,265],{},"根据训练时学到的优先级，首先套用 ",[28,256,140],{}," $\\to$ ",[28,259,164],{}," 的规则，接着套用 ",[28,262,180],{},[28,264,184],{}," 的规则。",[93,267,268,269,157,272,275,276,129],{},"前半部分套用 ",[28,270,271],{},"(l, o)",[28,273,274],{},"(lo, w)"," 的规则，得到 ",[28,277,219],{},[16,279,280,281,283,284,157,286,288,289,291],{},"奇迹发生了——新造词 ",[28,282,242],{}," 被切成了 ",[28,285,219],{},[28,287,184],{}," 两个 Subword。模型虽然没背过这个词，但顺理成章地理解了这是“低”的“最高级”，不仅完全避免了抛出 ",[28,290,38],{}," 的尴尬，还精准洞察了它的词根逻辑。",[62,293],{},[11,295,297],{"id":296},"进化版bbpebyte-level-bpe","进化版：BBPE（Byte-Level BPE）",[16,299,300],{},"传统的 BPE 一般建立在 Unicode 字符上。然而，世界上的语言、符号极度繁杂，各种稀奇古怪的 emoji 层出不穷，光是把单字符穷举出来就已经是一个庞大的基座了。",[16,302,303,304],{},"后来，OpenAI 在设计 GPT-2 时另辟蹊径：",[23,305,306],{},"任何文本，在计算机底层不全是由 UTF-8 编码的字节（Byte）拼接而成的吗？",[16,308,309,310,313,314,317],{},"既然 1 个字节只有 256 种可能的取值，那就直接把这 ",[23,311,312],{},"256 个基础字节","作为最底层的原子字符！这就诞生了更加通用的 ",[23,315,316],{},"BBPE","（Byte-Level BPE）。",[16,319,320],{},"在这种架构下：",[90,322,323,329],{},[93,324,325,328],{},[23,326,327],{},"永远告别 OOV（未登录词）","：哪怕遇到一段乱码或者罕见的外星文，最后也一定兜底退化成这 256 种字节基础单元的拼接。",[93,330,331,334],{},[23,332,333],{},"词表空间极大释放","：把原本因为处理各国冷门文字而浪费的槽位省出来，让词表更加紧凑纯粹。现代绝大多数万亿参数的巨兽模型，都在沿用这项革命性的改进设计。",{"title":336,"searchDepth":337,"depth":337,"links":338},"",2,[339,340,344,345],{"id":13,"depth":337,"text":14},{"id":66,"depth":337,"text":67,"children":341},[342],{"id":80,"depth":343,"text":81},3,{"id":227,"depth":337,"text":227},{"id":296,"depth":337,"text":297},null,"\u002Fimg\u002Fpostcard4.jpg","2026-05-19","深入 Byte Pair Encoding (BPE) 的工作流程，理解从字符到子词的合并机制，探讨它为何成为现代 LLM 的标配","md",{},true,"\u002Fposts\u002Fbpe-tokenization-algorithm",{"title":6,"description":349},"posts\u002Fbpe-tokenization-algorithm","9zCuC2wb6rMfJiMOWGrAIjJ9BmpdIxbHF1vYD1t29oM",{"id":358,"title":359,"body":360,"categories":346,"cover":1032,"date":348,"description":1033,"extension":350,"meta":1034,"navigation":352,"path":1035,"seo":1036,"stem":1037,"tags":346,"__hash__":1038},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":8,"value":361,"toc":1012},[362,366,372,375,380,394,401,408,410,414,423,426,434,437,440,466,468,471,474,477,494,497,499,503,506,566,569,572,578,580,584,590,594,597,600,603,606,610,613,616,622,625,629,632,635,640,644,767,770,772,776,779,783,786,789,792,800,804,807,899,902,906,909,912,915,917,921,924,967,970,975,977,980,1006],[11,363,365],{"id":364},"前置知识什么是哈希hash算法","前置知识：什么是哈希（Hash）算法？",[16,367,368,369,129],{},"在深入 LSH 之前，我们需要先理解基础的",[23,370,371],{},"哈希算法",[16,373,374],{},"简单来说，哈希函数（Hash Function）就像是一个“数字指纹生成器”。它接收任意长度的数据（如一段文本、一篇文档），并将其映射为一个固定长度的较短字符串或数值（即哈希值或签名）。",[16,376,377],{},[23,378,379],{},"传统哈希算法（如 MD5、SHA-256）的核心特征是：",[244,381,382,388],{},[93,383,384,387],{},[23,385,386],{},"唯一性与确定性","：绝对相同的输入，一定会得到完全相同的哈希值。",[93,389,390,393],{},[23,391,392],{},"雪崩效应","：输入数据哪怕仅仅改变了一个标点符号，输出的哈希值也会变得面目全非、毫无规律。这在密码学中非常重要，能用来保证数据未被篡改。",[16,395,396,397,400],{},"然而，传统哈希的“雪崩效应”在",[23,398,399],{},"相似度检索","任务中反而成为了阻碍。如果我们想通过比对哈希值来判断两篇文章是否相似，传统哈希算法完全无能为力——因为两篇高度相似但不完全相同的文章，它们的哈希值是截然不同且没有任何关联的。",[16,402,403,404,407],{},"这也恰恰引出了本文的主角——",[23,405,406],{},"LSH（局部敏感哈希）","。它一反常态，特意设计出了一种**“让越相似的数据，越容易产生相同的哈希值（即越容易发生碰撞）”**的过滤机制。",[62,409],{},[11,411,413],{"id":412},"算法背景lsh解决了什么痛点","算法背景：LSH解决了什么痛点？",[16,415,416,417,129,420,422],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[23,418,419],{},"计算代价是否可接受",[123,421],{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[16,424,425],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[90,427,428,431],{},[93,429,430],{},"使高相似对象以较高概率落入同一桶（进入候选集）",[93,432,433],{},"使低相似对象以较高概率在早期被过滤",[16,435,436],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[78,438,439],{"id":439},"常见应用领域",[244,441,442,448,454,460],{},[93,443,444,447],{},[23,445,446],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[93,449,450,453],{},[23,451,452],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[93,455,456,459],{},[23,457,458],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[93,461,462,465],{},[23,463,464],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[62,467],{},[11,469,470],{"id":470},"示例文本集合",[16,472,473],{},"设文档集合：",[16,475,476],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[90,478,479,482,485,488,491],{},[93,480,481],{},"$d_1=\\text{“今天北京天气很好”}$",[93,483,484],{},"$d_2=\\text{“今天北京天气真好”}$",[93,486,487],{},"$d_3=\\text{“昨天上海天气很差”}$",[93,489,490],{},"$d_4=\\text{“今天北京天气挺好”}$",[93,492,493],{},"$d_5=\\text{“深度学习推荐系统”}$",[16,495,496],{},"直观上，$d_1$、$d_2$ 和 $d_4$ 句式高度相似（仅一字之差），而 $d_3$、$d_5$ 语义或结构上有显著差异。",[62,498],{},[11,500,502],{"id":501},"shingling文本-q-gram集合","Shingling（文本 → q-gram集合）",[16,504,505],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[507,508,509,522],"table",{},[510,511,512],"thead",{},[513,514,515,519],"tr",{},[516,517,518],"th",{},"文本",[516,520,521],{},"3-gram集合",[523,524,525,534,542,550,558],"tbody",{},[513,526,527,531],{},[528,529,530],"td",{},"d1",[528,532,533],{},"{今天北, 天北京, 北京天, 京天气, 天气很, 气很好}",[513,535,536,539],{},[528,537,538],{},"d2",[528,540,541],{},"{今天北, 天北京, 北京天, 京天气, 天气真, 气真好}",[513,543,544,547],{},[528,545,546],{},"d3",[528,548,549],{},"{昨天上, 天上海, 上海天, 海天气, 天气很, 气很差}",[513,551,552,555],{},[528,553,554],{},"d4",[528,556,557],{},"{今天北, 天北京, 北京天, 京天气, 天气挺, 气挺好}",[513,559,560,563],{},[528,561,562],{},"d5",[528,564,565],{},"{深度学, 度学习, 学习推, 习推荐, 推荐系, 荐系统}",[16,567,568],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[16,570,571],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[573,574,575],"blockquote",{},[16,576,577],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[62,579],{},[11,581,583],{"id":582},"minhash集合-签名向量","MinHash（集合 → 签名向量）",[16,585,586,589],{},[23,587,588],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[78,591,593],{"id":592},"_31-构造方式","3.1 构造方式",[16,595,596],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[16,598,599],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[16,601,602],{},"于是签名向量为：",[16,604,605],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[78,607,609],{"id":608},"_32-为什么可行","3.2 为什么可行",[16,611,612],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[16,614,615],{},"$$\nP(m_h(A)=m_h(B)) = J(A,B)\n$$",[16,617,618,621],{},[23,619,620],{},"简要证明","：\n哈希函数 $h$ 相当于对全集元素做了一次随机排列。考察两集合的并集 $A \\cup B$ 中的所有元素：\n要使 $m_h(A) = m_h(B)$，意味着 $A \\cup B$ 中经过哈希映射后值最小（即排在“最前面”）的那个元素，必须既属于 $A$ 也属于 $B$，也就是说必须属于交集 $A \\cap B$。\n因为哈希是完全随机的，$A \\cup B$ 中的每一个元素成为最小值的概率是完全相等的。所以这个最小元素正好属于交集 $A \\cap B$ 的概率，就是交集元素个数占并集元素个数的比例，即 $\\frac{|A \\cap B|}{|A \\cup B|} = J(A,B)$。",[16,623,624],{},"用 $k$ 个哈希后，可得无偏估计量：",[626,627,628],"div",{"v-pre":336},"\n$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_{i=1}^{k} I[m_i(A)=m_i(B)]\n$$\n",[16,630,631],{},"方差为：",[16,633,634],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[573,636,637],{},[16,638,639],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[78,641,643],{"id":642},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[507,645,646,668],{},[510,647,648],{},[513,649,650,652,655,657,659,662,665],{},[516,651,518],{},[516,653,654],{},"h1",[516,656,11],{},[516,658,78],{},[516,660,661],{},"h4",[516,663,664],{},"h5",[516,666,667],{},"h6",[523,669,670,692,709,730,746],{},[513,671,672,674,677,680,683,686,689],{},[528,673,530],{},[528,675,676],{},"12",[528,678,679],{},"7",[528,681,682],{},"5",[528,684,685],{},"20",[528,687,688],{},"11",[528,690,691],{},"3",[513,693,694,696,698,700,703,705,707],{},[528,695,538],{},[528,697,676],{},[528,699,679],{},[528,701,702],{},"6",[528,704,685],{},[528,706,688],{},[528,708,691],{},[513,710,711,713,716,719,722,725,727],{},[528,712,546],{},[528,714,715],{},"2",[528,717,718],{},"15",[528,720,721],{},"8",[528,723,724],{},"19",[528,726,679],{},[528,728,729],{},"4",[513,731,732,734,736,738,740,742,744],{},[528,733,554],{},[528,735,676],{},[528,737,679],{},[528,739,682],{},[528,741,724],{},[528,743,718],{},[528,745,721],{},[513,747,748,750,753,756,759,762,765],{},[528,749,562],{},[528,751,752],{},"30",[528,754,755],{},"14",[528,757,758],{},"22",[528,760,761],{},"33",[528,763,764],{},"28",[528,766,682],{},[16,768,769],{},"可以看出：$d_1$ 与 $d_4$ 在前三个哈希函数取值一致，而与 $d_2$ 在后三个哈希函数取值一致，这反映了它们较高的相似度。",[62,771],{},[11,773,775],{"id":774},"lsh-banding签名矩阵-候选对","LSH Banding（签名矩阵 → 候选对）",[16,777,778],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[78,780,782],{"id":781},"_41-切分规则","4.1 切分规则",[16,784,785],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[16,787,788],{},"$$\nk=b\\cdot r\n$$",[16,790,791],{},"例如：$k=6,b=2,r=3$。",[90,793,794,797],{},[93,795,796],{},"Band 1: $(h_1,h_2,h_3)$",[93,798,799],{},"Band 2: $(h_4,h_5,h_6)$",[78,801,803],{"id":802},"_42-候选判定","4.2 候选判定",[16,805,806],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[507,808,809,822],{},[510,810,811],{},[513,812,813,816,819],{},[516,814,815],{},"Band",[516,817,818],{},"桶",[516,820,821],{},"文档",[523,823,824,835,844,853,862,872,881,890],{},[513,825,826,829,832],{},[528,827,828],{},"1",[528,830,831],{},"B1-1",[528,833,834],{},"d1, d4",[513,836,837,839,842],{},[528,838,828],{},[528,840,841],{},"B1-2",[528,843,538],{},[513,845,846,848,851],{},[528,847,828],{},[528,849,850],{},"B1-3",[528,852,546],{},[513,854,855,857,860],{},[528,856,828],{},[528,858,859],{},"B1-4",[528,861,562],{},[513,863,864,866,869],{},[528,865,715],{},[528,867,868],{},"B2-1",[528,870,871],{},"d1, d2",[513,873,874,876,879],{},[528,875,715],{},[528,877,878],{},"B2-3",[528,880,546],{},[513,882,883,885,888],{},[528,884,715],{},[528,886,887],{},"B2-4",[528,889,554],{},[513,891,892,894,897],{},[528,893,715],{},[528,895,896],{},"B2-5",[528,898,562],{},[16,900,901],{},"在这里，$d_1,d_4$ 在 Band 1 碰撞、$d_1,d_2$ 在 Band 2 碰撞，它们都会被成功召回送入下一阶段。",[78,903,905],{"id":904},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[16,907,908],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[16,910,911],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[16,913,914],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[62,916],{},[11,918,920],{"id":919},"精确验证候选对-最终结果","精确验证（候选对 → 最终结果）",[16,922,923],{},"对候选集合中的文档对再计算真实 Jaccard：",[507,925,926,942],{},[510,927,928],{},[513,929,930,933,936,939],{},[516,931,932],{},"文本对",[516,934,935],{},"交集大小",[516,937,938],{},"并集大小",[516,940,941],{},"Jaccard",[523,943,944,956],{},[513,945,946,949,951,953],{},[528,947,948],{},"d1,d4",[528,950,729],{},[528,952,721],{},[528,954,955],{},"0.5",[513,957,958,961,963,965],{},[528,959,960],{},"d1,d2",[528,962,729],{},[528,964,721],{},[528,966,955],{},[16,968,969],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[573,971,972],{},[16,973,974],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[62,976],{},[11,978,979],{"id":979},"算法直观总结",[244,981,982,988,994,1000],{},[93,983,984,987],{},[23,985,986],{},"Shingling","：把文本变成可比较的集合表示。",[93,989,990,993],{},[23,991,992],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[93,995,996,999],{},[23,997,998],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[93,1001,1002,1005],{},[23,1003,1004],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[16,1007,1008,1011],{},[23,1009,1010],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":336,"searchDepth":337,"depth":337,"links":1013},[1014,1015,1018,1019,1020,1025,1030,1031],{"id":364,"depth":337,"text":365},{"id":412,"depth":337,"text":413,"children":1016},[1017],{"id":439,"depth":343,"text":439},{"id":470,"depth":337,"text":470},{"id":501,"depth":337,"text":502},{"id":582,"depth":337,"text":583,"children":1021},[1022,1023,1024],{"id":592,"depth":343,"text":593},{"id":608,"depth":343,"text":609},{"id":642,"depth":343,"text":643},{"id":774,"depth":337,"text":775,"children":1026},[1027,1028,1029],{"id":781,"depth":343,"text":782},{"id":802,"depth":343,"text":803},{"id":904,"depth":343,"text":905},{"id":919,"depth":337,"text":920},{"id":979,"depth":337,"text":979},"\u002Fimg\u002Fpostcard3.jpg","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用",{},"\u002Fposts\u002Flsh-minhash-deduplication",{"title":359,"description":1033},"posts\u002Flsh-minhash-deduplication","oG6H2fNbkQAmzn78pWFC0zQq-y8odaRz5akaYuGwnC8",{"id":1040,"title":1041,"body":1042,"categories":1148,"cover":1151,"date":1152,"description":1153,"extension":350,"meta":1154,"navigation":352,"path":1155,"seo":1156,"stem":1157,"tags":1158,"__hash__":1162},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":8,"value":1043,"toc":1142},[1044,1047,1050,1053,1060,1074,1077,1109,1113,1124,1128],[11,1045,1046],{"id":1046},"我的配置清单",[16,1048,1049],{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[16,1051,1052],{},"惯例先附上系统信息：",[16,1054,1055],{},[1056,1057],"img",{"alt":1058,"src":1059},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[90,1061,1062,1065,1068,1071],{},[93,1063,1064],{},"OS：Ubuntu 26.04 LTS",[93,1066,1067],{},"Kernel：Linux 7.0.0-15-generic",[93,1069,1070],{},"CPU：Intel Core i7-14700H",[93,1072,1073],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[11,1075,1076],{"id":1076},"系统与桌面环境",[90,1078,1079,1082,1085,1088,1091,1094,1097,1100,1103,1106],{},[93,1080,1081],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[93,1083,1084],{},"桌面协议：Wayland",[93,1086,1087],{},"窗口管理：Mutter",[93,1089,1090],{},"Shell：zsh 5.9",[93,1092,1093],{},"终端：Ghostty",[93,1095,1096],{},"输入法：Fcitx5（小鹤音形）",[93,1098,1099],{},"主题：Orchis-dark",[93,1101,1102],{},"壁纸：Variety",[93,1104,1105],{},"截图：Flameshot",[93,1107,1108],{},"VPN：v2rayN（Linux 版本）",[11,1110,1112],{"id":1111},"工作-学习","工作 \u002F 学习",[90,1114,1115,1118,1121],{},[93,1116,1117],{},"办公：WPS",[93,1119,1120],{},"编辑器：VS Code",[93,1122,1123],{},"AI 工具管理：CCSwitch（ccswitch）",[11,1125,1127],{"id":1126},"生活-游戏","生活 \u002F 游戏",[90,1129,1130,1133,1136,1139],{},[93,1131,1132],{},"游戏：Steam",[93,1134,1135],{},"兼容层：Proton GE",[93,1137,1138],{},"浏览器：Edge",[93,1140,1141],{},"聊天：微信 \u002F QQ",{"title":336,"searchDepth":337,"depth":337,"links":1143},[1144,1145,1146,1147],{"id":1046,"depth":337,"text":1046},{"id":1076,"depth":337,"text":1076},{"id":1111,"depth":337,"text":1112},{"id":1126,"depth":337,"text":1127},[1149,1150],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单",{},"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":1041,"description":1153},"posts\u002Fubuntu-26-04-my-setup",[1159,1160,1161],"Ubuntu","Wayland","桌面配置","yZYlhwCbitmtIMFYkRlb5os9JMJpWZH5UyymJQNZyxc",{"id":1164,"title":1165,"body":1166,"categories":346,"cover":1730,"date":1731,"description":1732,"extension":350,"meta":1733,"navigation":352,"path":1734,"seo":1735,"stem":1736,"tags":346,"__hash__":1737},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":8,"value":1167,"toc":1706},[1168,1172,1175,1179,1182,1189,1192,1203,1205,1209,1216,1300,1304,1311,1315,1330,1332,1335,1339,1350,1359,1370,1374,1380,1386,1405,1409,1412,1416,1425,1427,1430,1434,1440,1454,1458,1464,1481,1484,1564,1567,1573,1596,1668,1671,1674,1685,1688,1690,1693,1696,1702],[11,1169,1171],{"id":1170},"为什么要离开-hexo","为什么要离开 Hexo？",[16,1173,1174],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[78,1176,1178],{"id":1177},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[16,1180,1181],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[16,1183,1184,1185,1188],{},"问题根源在于：",[23,1186,1187],{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[78,1190,1191],{"id":1191},"构建速度与生态",[16,1193,1194,1195,1198,1199,1202],{},"文章数量上来之后，",[28,1196,1197],{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[23,1200,1201],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[62,1204],{},[11,1206,1208],{"id":1207},"为什么选-nuxt","为什么选 Nuxt？",[16,1210,1211,1212,1215],{},"看过 VitePress、Astro、Next.js，最终选了 ",[23,1213,1214],{},"Nuxt 4 SSG","。核心考量：",[507,1217,1218,1230],{},[510,1219,1220],{},[513,1221,1222,1224,1227],{},[516,1223],{},[516,1225,1226],{},"Hexo",[516,1228,1229],{},"Nuxt 4",[523,1231,1232,1245,1258,1271,1284],{},[513,1233,1234,1239,1242],{},[528,1235,1236],{},[23,1237,1238],{},"构建机制",[528,1240,1241],{},"CLI 全量生成静态文件",[528,1243,1244],{},"Nitro 引擎预渲染 + 增量构建",[513,1246,1247,1252,1255],{},[528,1248,1249],{},[23,1250,1251],{},"模板\u002F组件",[528,1253,1254],{},"EJS\u002FPug，无组件化",[528,1256,1257],{},"Vue 3 组件，自动导入",[513,1259,1260,1265,1268],{},[528,1261,1262],{},[23,1263,1264],{},"内容管理",[528,1266,1267],{},"front-matter + markdown",[528,1269,1270],{},"@nuxt\u002Fcontent v3，类型安全查询",[513,1272,1273,1278,1281],{},[528,1274,1275],{},[23,1276,1277],{},"交互",[528,1279,1280],{},"内联 script，靠 CDN",[528,1282,1283],{},"完整的 Vue 响应式生态",[513,1285,1286,1291,1297],{},[528,1287,1288],{},[23,1289,1290],{},"路由",[528,1292,1293,1296],{},[28,1294,1295],{},"_config.yml"," permalink 配置",[528,1298,1299],{},"文件系统路由，动态参数",[78,1301,1303],{"id":1302},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[16,1305,1306,1307,1310],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[23,1308,1309],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[78,1312,1314],{"id":1313},"vue-生态的开发体验","Vue 生态的开发体验",[16,1316,1317,1318,1321,1322,1325,1326,1329],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[28,1319,1320],{},"useAsyncData"," + ",[28,1323,1324],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[28,1327,1328],{},"\u003Cscript>"," 标签。",[62,1331],{},[11,1333,1334],{"id":1334},"迁移过程",[78,1336,1338],{"id":1337},"内容层零改动搬过来","内容层：零改动搬过来",[16,1340,1341,1342,1345,1346,1349],{},"所有 markdown 文件从 Hexo 的 ",[28,1343,1344],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[28,1347,1348],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[1351,1352,1357],"pre",{"className":1353,"code":1355,"language":1356},[1354],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[28,1358,1355],{"__ignoreMap":336},[16,1360,1361,1362,1365,1366,1369],{},"多了 ",[28,1363,1364],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[28,1367,1368],{},"tags","。内容正文一个字没改。",[78,1371,1373],{"id":1372},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[16,1375,1376,1377,1379],{},"Hexo 的 URL 靠 ",[28,1378,1295],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[1351,1381,1384],{"className":1382,"code":1383,"language":1356},[1354],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[28,1385,1383],{"__ignoreMap":336},[16,1387,1388,1389,1392,1393,1396,1397,1400,1401,1404],{},"Nuxt 路由由 ",[28,1390,1391],{},"pages\u002F"," 目录结构决定，",[28,1394,1395],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[28,1398,1399],{},"trailingSlash: true"," 保证 URL 一致性，",[28,1402,1403],{},"[...slug].vue"," 兜底 404。",[78,1406,1408],{"id":1407},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[16,1410,1411],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[78,1413,1415],{"id":1414},"部署ci-保持不变","部署：CI 保持不变",[16,1417,1418,1419,1421,1422,129],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[28,1420,1197],{}," 替换为 ",[28,1423,1424],{},"npm run build",[62,1426],{},[11,1428,1429],{"id":1429},"架构对比",[78,1431,1433],{"id":1432},"hexo-的架构","Hexo 的架构",[1351,1435,1438],{"className":1436,"code":1437,"language":1356},[1354],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[28,1439,1437],{"__ignoreMap":336},[16,1441,1442,1443,1446,1447,1449,1450,1453],{},"Hexo 是",[23,1444,1445],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[28,1448,1295],{},"、",[28,1451,1452],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[78,1455,1457],{"id":1456},"nuxt-的架构","Nuxt 的架构",[1351,1459,1462],{"className":1460,"code":1461,"language":1356},[1354],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[28,1463,1461],{"__ignoreMap":336},[16,1465,1466,1467,1470,1471,1473,1474,1476,1477,1480],{},"Nuxt 是",[23,1468,1469],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[28,1472,1324],{}," 查询内容，",[28,1475,1320],{}," 管理异步数据，",[28,1478,1479],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[78,1482,1483],{"id":1483},"数据流对比",[507,1485,1486,1498],{},[510,1487,1488],{},[513,1489,1490,1493,1495],{},[516,1491,1492],{},"环节",[516,1494,1226],{},[516,1496,1497],{},"Nuxt",[523,1499,1500,1513,1526,1542,1553],{},[513,1501,1502,1505,1508],{},[528,1503,1504],{},"内容获取",[528,1506,1507],{},"读文件 → 模板注入变量",[528,1509,1510],{},[28,1511,1512],{},"queryCollection('posts').all()",[513,1514,1515,1518,1521],{},[528,1516,1517],{},"数据管理",[528,1519,1520],{},"无，模板即数据",[528,1522,1523,1525],{},[28,1524,1320],{}," + 响应式",[513,1527,1528,1531,1536],{},[528,1529,1530],{},"站点配置",[528,1532,1533,1535],{},[28,1534,1295],{}," + 主题 config",[528,1537,1538,1541],{},[28,1539,1540],{},"useSite()"," composable",[513,1543,1544,1547,1550],{},[528,1545,1546],{},"主题",[528,1548,1549],{},"Stylus 变量 → 编译到 CSS",[528,1551,1552],{},"CSS 自定义属性 → 运行时切换",[513,1554,1555,1558,1561],{},[528,1556,1557],{},"交互状态",[528,1559,1560],{},"全局变量 + DOM 操作",[528,1562,1563],{},"Vue 响应式 + composables",[78,1565,1566],{"id":1566},"预渲染策略",[16,1568,1569,1570,1572],{},"Hexo 每次 ",[28,1571,1197],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[16,1574,1575,1576,1579,1580,1583,1584,1587,1588,1591,1592,1595],{},"Nitro 的 ",[28,1577,1578],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[28,1581,1582],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[23,1585,1586],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[28,1589,1590],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[28,1593,1594],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[1351,1597,1601],{"className":1598,"code":1599,"language":1600,"meta":336,"style":336},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[28,1602,1603,1616,1631,1662],{"__ignoreMap":336},[1604,1605,1608,1612],"span",{"class":1606,"line":1607},"line",1,[1604,1609,1611],{"class":1610},"sVyAn","prerender",[1604,1613,1615],{"class":1614},"sn6KH",": {\n",[1604,1617,1618,1621,1624,1628],{"class":1606,"line":337},[1604,1619,1620],{"class":1610},"  crawlLinks",[1604,1622,1623],{"class":1614},": ",[1604,1625,1627],{"class":1626},"sVC51","true",[1604,1629,1630],{"class":1614},",\n",[1604,1632,1633,1636,1639,1643,1646,1649,1651,1654,1656,1659],{"class":1606,"line":343},[1604,1634,1635],{"class":1610},"  routes",[1604,1637,1638],{"class":1614},": [",[1604,1640,1642],{"class":1641},"subq3","'\u002F'",[1604,1644,1645],{"class":1614},", ",[1604,1647,1648],{"class":1641},"'\u002Fabout'",[1604,1650,1645],{"class":1614},[1604,1652,1653],{"class":1641},"'\u002Fposts'",[1604,1655,1645],{"class":1614},[1604,1657,1658],{"class":1641},"'\u002Flinks'",[1604,1660,1661],{"class":1614},"],\n",[1604,1663,1665],{"class":1606,"line":1664},4,[1604,1666,1667],{"class":1614},"}\n",[11,1669,1670],{"id":1670},"迁移成本远低于预期",[16,1672,1673],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[244,1675,1676,1679,1682],{},[93,1677,1678],{},"搭建 Nuxt 项目骨架",[93,1680,1681],{},"设计 CSS token 系统",[93,1683,1684],{},"编写几个核心组件",[16,1686,1687],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[62,1689],{},[11,1691,1692],{"id":1692},"总结",[16,1694,1695],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[16,1697,1698,1701],{},[23,1699,1700],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[1703,1704,1705],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":336,"searchDepth":337,"depth":337,"links":1707},[1708,1712,1716,1722,1728,1729],{"id":1170,"depth":337,"text":1171,"children":1709},[1710,1711],{"id":1177,"depth":343,"text":1178},{"id":1191,"depth":343,"text":1191},{"id":1207,"depth":337,"text":1208,"children":1713},[1714,1715],{"id":1302,"depth":343,"text":1303},{"id":1313,"depth":343,"text":1314},{"id":1334,"depth":337,"text":1334,"children":1717},[1718,1719,1720,1721],{"id":1337,"depth":343,"text":1338},{"id":1372,"depth":343,"text":1373},{"id":1407,"depth":343,"text":1408},{"id":1414,"depth":343,"text":1415},{"id":1429,"depth":337,"text":1429,"children":1723},[1724,1725,1726,1727],{"id":1432,"depth":343,"text":1433},{"id":1456,"depth":343,"text":1457},{"id":1483,"depth":343,"text":1483},{"id":1566,"depth":343,"text":1566},{"id":1670,"depth":337,"text":1670},{"id":1692,"depth":337,"text":1692},"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":1165,"description":1732},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",1779202436318]