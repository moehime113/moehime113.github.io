[{"data":1,"prerenderedAt":1370},["ShallowReactive",2],{"all-posts":3},[4,671,795],{"id":5,"title":6,"body":7,"categories":660,"cover":660,"date":661,"description":662,"extension":663,"meta":664,"navigation":666,"path":667,"seo":668,"stem":669,"tags":660,"__hash__":670},"posts\u002Fposts\u002Flsh-minhash-deduplication.md","LSH算法原理讲解：从文本相似到大规模候选检索",{"type":8,"value":9,"toc":638},"minimark",[10,15,23,26,31,42,45,55,58,62,89,91,95,98,101,118,121,123,127,130,189,192,195,201,203,207,213,217,220,223,226,229,233,236,244,247,254,257,260,265,269,392,395,397,401,404,408,411,414,417,425,429,432,523,526,530,533,536,539,541,545,548,592,595,600,602,606,632],[11,12,14],"h1",{"id":13},"lsh算法原理讲解","LSH算法原理讲解",[16,17,18,22],"p",{},[19,20,21],"strong",{},"目标","：在海量文本中快速发现相似文档，避免 $O(n^2)$ 的全量两两比较。",[24,25],"hr",{},[27,28,30],"h2",{"id":29},"_0-算法背景lsh解决了什么痛点","0. 算法背景：LSH解决了什么痛点？",[16,32,33,34,37,38,41],{},"在实际系统中，“相似检索\u002F去重”的难点通常不在于“能否计算”，而在于",[19,35,36],{},"计算代价是否可接受","。",[39,40],"br",{},"\n当文档规模达到百万、千万级时，直接比较全部文档对几乎不可行。",[16,43,44],{},"LSH（Locality-Sensitive Hashing）的核心机制是：",[46,47,48,52],"ul",{},[49,50,51],"li",{},"使高相似对象以较高概率落入同一桶（进入候选集）",[49,53,54],{},"使低相似对象以较高概率在早期被过滤",[16,56,57],{},"因此，它特别适合“先粗筛、再精排”的检索流程。",[59,60,61],"h3",{"id":61},"常见应用领域",[63,64,65,71,77,83],"ol",{},[49,66,67,70],{},[19,68,69],{},"搜索与推荐","：相似文章召回、相似商品召回、候选集构建。",[49,72,73,76],{},[19,74,75],{},"数据清洗与去重","：网页去重、日志去重、训练语料去重。",[49,78,79,82],{},[19,80,81],{},"反作弊与内容安全","：近重复内容识别、模板化刷屏检测。",[49,84,85,88],{},[19,86,87],{},"大模型数据工程","：预训练\u002F微调语料去重，降低数据污染与过拟合风险。",[24,90],{},[27,92,94],{"id":93},"_1-示例文本集合","1. 示例文本集合",[16,96,97],{},"设文档集合：",[16,99,100],{},"$$\nD = {d_1,d_2,d_3,d_4,d_5}\n$$",[46,102,103,106,109,112,115],{},[49,104,105],{},"$d_1=\\text{“今天天气很好”}$",[49,107,108],{},"$d_2=\\text{“今天天气非常好”}$",[49,110,111],{},"$d_3=\\text{“昨天天气很差”}$",[49,113,114],{},"$d_4=\\text{“今天天气很好”}$",[49,116,117],{},"$d_5=\\text{“机器学习很有趣”}$",[16,119,120],{},"直观上，$d_1$ 与 $d_4$ 完全相同，$d_1$ 与 $d_2$ 高度相似，其余组合的相似度较低。",[24,122],{},[27,124,126],{"id":125},"_2-shingling文本-q-gram集合","2. Shingling（文本 → q-gram集合）",[16,128,129],{},"先将文本映射为字符 $q$-gram 集合。这里取字符 3-gram。",[131,132,133,146],"table",{},[134,135,136],"thead",{},[137,138,139,143],"tr",{},[140,141,142],"th",{},"文本",[140,144,145],{},"3-gram集合",[147,148,149,158,166,174,181],"tbody",{},[137,150,151,155],{},[152,153,154],"td",{},"d1",[152,156,157],{},"{今天天, 天天气, 天气很, 气很好}",[137,159,160,163],{},[152,161,162],{},"d2",[152,164,165],{},"{今天天, 天天气, 天气非, 气非常, 非常好}",[137,167,168,171],{},[152,169,170],{},"d3",[152,172,173],{},"{昨天天, 天天气, 天气很, 气很差}",[137,175,176,179],{},[152,177,178],{},"d4",[152,180,157],{},[137,182,183,186],{},[152,184,185],{},"d5",[152,187,188],{},"{机器学, 学习很, 习很有, 很有趣}",[16,190,191],{},"随后可用 Jaccard 相似度刻画集合之间的相似性：",[16,193,194],{},"$$\nJ(A,B)=\\frac{|A\\cap B|}{|A\\cup B|}\n$$",[196,197,198],"blockquote",{},[16,199,200],{},"小幅文本改动通常只影响局部 gram，因此 Jaccard 往往仍较高。",[24,202],{},[27,204,206],{"id":205},"_3-minhash集合-签名向量","3. MinHash（集合 → 签名向量）",[16,208,209,212],{},[19,210,211],{},"目的","：不直接计算交并集，也能快速估计 Jaccard 相似度。",[59,214,216],{"id":215},"_31-构造方式","3.1 构造方式",[16,218,219],{},"设有 $k$ 个哈希函数 $h_1,\\dots,h_k$，对集合 $S$ 定义：",[16,221,222],{},"$$\nm_(S)=\\min{h_i(g):g\\in S},\\quad i=1,\\dots,k\n$$",[16,224,225],{},"于是签名向量为：",[16,227,228],{},"$$\n\\text{sig}(S)=\\big(m_(S),m_(S),\\dots,m_(S)\\big)\n$$",[59,230,232],{"id":231},"_32-为什么可行","3.2 为什么可行",[16,234,235],{},"对两个集合 $A,B$，MinHash 的核心定理是：",[16,237,238,239,243],{},"$$\n\\Pr",[240,241,242],"span",{},"m_h(A)=m_h(B)"," = J(A,B)\n$$",[16,245,246],{},"用 $k$ 个哈希后，可得无偏估计量：",[16,248,249,250,253],{},"$$\n\\hat J(A,B)=\\frac{1}{k}\\sum_^k \\mathbf{1}",[240,251,252],{},"m_(A)=m_(B)","\n$$",[16,255,256],{},"方差为：",[16,258,259],{},"$$\n\\mathrm{Var}(\\hat J)=\\frac{J(1-J)}{k}\n$$",[196,261,262],{},[16,263,264],{},"$k$ 越大，估计越稳定，但存储和计算成本也越高。",[59,266,268],{"id":267},"_33-示例签名矩阵k6","3.3 示例签名矩阵（$k=6$）",[131,270,271,292],{},[134,272,273],{},[137,274,275,277,279,281,283,286,289],{},[140,276,142],{},[140,278,11],{},[140,280,27],{},[140,282,59],{},[140,284,285],{},"h4",[140,287,288],{},"h5",[140,290,291],{},"h6",[147,293,294,316,334,355,371],{},[137,295,296,298,301,304,307,310,313],{},[152,297,154],{},[152,299,300],{},"12",[152,302,303],{},"7",[152,305,306],{},"5",[152,308,309],{},"20",[152,311,312],{},"11",[152,314,315],{},"3",[137,317,318,320,322,324,327,330,332],{},[152,319,162],{},[152,321,300],{},[152,323,303],{},[152,325,326],{},"6",[152,328,329],{},"21",[152,331,312],{},[152,333,315],{},[137,335,336,338,341,344,347,350,352],{},[152,337,170],{},[152,339,340],{},"2",[152,342,343],{},"15",[152,345,346],{},"8",[152,348,349],{},"19",[152,351,303],{},[152,353,354],{},"4",[137,356,357,359,361,363,365,367,369],{},[152,358,178],{},[152,360,300],{},[152,362,303],{},[152,364,306],{},[152,366,309],{},[152,368,312],{},[152,370,315],{},[137,372,373,375,378,381,384,387,390],{},[152,374,185],{},[152,376,377],{},"30",[152,379,380],{},"14",[152,382,383],{},"22",[152,385,386],{},"33",[152,388,389],{},"28",[152,391,306],{},[16,393,394],{},"可以看出：$d_1$ 与 $d_4$ 完全一致，$d_1$ 与 $d_2$ 大部分行一致，符合直觉。",[24,396],{},[27,398,400],{"id":399},"_4-lsh-banding签名矩阵-候选对","4. LSH Banding（签名矩阵 → 候选对）",[16,402,403],{},"有了签名后，仍不想做全量比较，于是引入 Banding。",[59,405,407],{"id":406},"_41-切分规则","4.1 切分规则",[16,409,410],{},"将长度 $k$ 的签名切成 $b$ 个 band，每个 band 含 $r$ 行：",[16,412,413],{},"$$\nk=b\\cdot r\n$$",[16,415,416],{},"例如：$k=6,b=2,r=3$。",[46,418,419,422],{},[49,420,421],{},"Band 1: $(h_1,h_2,h_3)$",[49,423,424],{},"Band 2: $(h_4,h_5,h_6)$",[59,426,428],{"id":427},"_42-候选判定","4.2 候选判定",[16,430,431],{},"若两个文档在任一 band 完全相同，则在该 band 碰撞，成为候选对。",[131,433,434,447],{},[134,435,436],{},[137,437,438,441,444],{},[140,439,440],{},"Band",[140,442,443],{},"桶",[140,445,446],{},"文档",[147,448,449,460,469,478,487,496,505,514],{},[137,450,451,454,457],{},[152,452,453],{},"1",[152,455,456],{},"B1-1",[152,458,459],{},"d1, d4",[137,461,462,464,467],{},[152,463,453],{},[152,465,466],{},"B1-2",[152,468,162],{},[137,470,471,473,476],{},[152,472,453],{},[152,474,475],{},"B1-3",[152,477,170],{},[137,479,480,482,485],{},[152,481,453],{},[152,483,484],{},"B1-4",[152,486,185],{},[137,488,489,491,494],{},[152,490,340],{},[152,492,493],{},"B2-1",[152,495,459],{},[137,497,498,500,503],{},[152,499,340],{},[152,501,502],{},"B2-2",[152,504,162],{},[137,506,507,509,512],{},[152,508,340],{},[152,510,511],{},"B2-3",[152,513,170],{},[137,515,516,518,521],{},[152,517,340],{},[152,519,520],{},"B2-4",[152,522,185],{},[16,524,525],{},"因此 $d_1,d_4$ 会被稳定召回为候选。",[59,527,529],{"id":528},"_43-概率解释s曲线","4.3 概率解释（S曲线）",[16,531,532],{},"若两篇文本的真实相似度为 $s$，则其被召回为候选的概率为：",[16,534,535],{},"$$\nP_{\\text{cand}}(s)=1-(1-s^r)^b\n$$",[16,537,538],{},"这条曲线会在某一阈值附近快速上升，因此 LSH 能实现“高相似度优先召回、低相似度优先过滤”。",[24,540],{},[27,542,544],{"id":543},"_5-精确验证候选对-最终结果","5. 精确验证（候选对 → 最终结果）",[16,546,547],{},"对候选集合中的文档对再计算真实 Jaccard：",[131,549,550,566],{},[134,551,552],{},[137,553,554,557,560,563],{},[140,555,556],{},"文本对",[140,558,559],{},"交集大小",[140,561,562],{},"并集大小",[140,564,565],{},"Jaccard",[147,567,568,580],{},[137,569,570,573,575,577],{},[152,571,572],{},"d1,d4",[152,574,354],{},[152,576,354],{},[152,578,579],{},"1.0",[137,581,582,585,587,589],{},[152,583,584],{},"d1,d2",[152,586,315],{},[152,588,306],{},[152,590,591],{},"0.6",[16,593,594],{},"最终保留满足 $Jaccard \\ge \\tau$ 的文档对（$\\tau$ 为业务阈值）。",[196,596,597],{},[16,598,599],{},"这里需要注意：精确验证负责“剔除误报（假阳性）”，而召回上限由前面的 LSH 候选阶段决定。",[24,601],{},[27,603,605],{"id":604},"_6-算法直观总结","6. 算法直观总结",[63,607,608,614,620,626],{},[49,609,610,613],{},[19,611,612],{},"Shingling","：把文本变成可比较的集合表示。",[49,615,616,619],{},[19,617,618],{},"MinHash","：把集合压缩成固定长度签名，近似保留 Jaccard。",[49,621,622,625],{},[19,623,624],{},"LSH Banding","：用概率机制快速生成候选，避免全量比较。",[49,627,628,631],{},[19,629,630],{},"精确验证","：在候选上做高精度判定，得到最终相似对。",[16,633,634,637],{},[19,635,636],{},"核心思想","：用可控的概率近似换取数量级的效率提升，使海量文本相似检索在工程上可落地。",{"title":639,"searchDepth":640,"depth":640,"links":641},"",2,[642,646,647,648,653,658,659],{"id":29,"depth":640,"text":30,"children":643},[644],{"id":61,"depth":645,"text":61},3,{"id":93,"depth":640,"text":94},{"id":125,"depth":640,"text":126},{"id":205,"depth":640,"text":206,"children":649},[650,651,652],{"id":215,"depth":645,"text":216},{"id":231,"depth":645,"text":232},{"id":267,"depth":645,"text":268},{"id":399,"depth":640,"text":400,"children":654},[655,656,657],{"id":406,"depth":645,"text":407},{"id":427,"depth":645,"text":428},{"id":528,"depth":645,"text":529},{"id":543,"depth":640,"text":544},{"id":604,"depth":640,"text":605},null,"2026-05-19","通过 Shingling、MinHash 与 LSH Banding 串联，理解海量文本近似去重的数学原理与工程应用","md",{"caver":665},"\u002Fimg\u002Fpostcard3.jpg",true,"\u002Fposts\u002Flsh-minhash-deduplication",{"title":6,"description":662},"posts\u002Flsh-minhash-deduplication","CPt90-O0t4_W9HZZVR7dUXrW3KsRLmOyQRQfyzd6Zb8",{"id":672,"title":673,"body":674,"categories":780,"cover":783,"date":784,"description":785,"extension":663,"meta":786,"navigation":666,"path":787,"seo":788,"stem":789,"tags":790,"__hash__":794},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":8,"value":675,"toc":774},[676,679,682,685,692,706,709,741,745,756,760],[27,677,678],{"id":678},"我的配置清单",[16,680,681],{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[16,683,684],{},"惯例先附上系统信息：",[16,686,687],{},[688,689],"img",{"alt":690,"src":691},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[46,693,694,697,700,703],{},[49,695,696],{},"OS：Ubuntu 26.04 LTS",[49,698,699],{},"Kernel：Linux 7.0.0-15-generic",[49,701,702],{},"CPU：Intel Core i7-14700H",[49,704,705],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[27,707,708],{"id":708},"系统与桌面环境",[46,710,711,714,717,720,723,726,729,732,735,738],{},[49,712,713],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[49,715,716],{},"桌面协议：Wayland",[49,718,719],{},"窗口管理：Mutter",[49,721,722],{},"Shell：zsh 5.9",[49,724,725],{},"终端：Ghostty",[49,727,728],{},"输入法：Fcitx5（小鹤音形）",[49,730,731],{},"主题：Orchis-dark",[49,733,734],{},"壁纸：Variety",[49,736,737],{},"截图：Flameshot",[49,739,740],{},"VPN：v2rayN（Linux 版本）",[27,742,744],{"id":743},"工作-学习","工作 \u002F 学习",[46,746,747,750,753],{},[49,748,749],{},"办公：WPS",[49,751,752],{},"编辑器：VS Code",[49,754,755],{},"AI 工具管理：CCSwitch（ccswitch）",[27,757,759],{"id":758},"生活-游戏","生活 \u002F 游戏",[46,761,762,765,768,771],{},[49,763,764],{},"游戏：Steam",[49,766,767],{},"兼容层：Proton GE",[49,769,770],{},"浏览器：Edge",[49,772,773],{},"聊天：微信 \u002F QQ",{"title":639,"searchDepth":640,"depth":640,"links":775},[776,777,778,779],{"id":678,"depth":640,"text":678},{"id":708,"depth":640,"text":708},{"id":743,"depth":640,"text":744},{"id":758,"depth":640,"text":759},[781,782],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单",{},"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":673,"description":785},"posts\u002Fubuntu-26-04-my-setup",[791,792,793],"Ubuntu","Wayland","桌面配置","yZYlhwCbitmtIMFYkRlb5os9JMJpWZH5UyymJQNZyxc",{"id":796,"title":797,"body":798,"categories":660,"cover":1362,"date":1363,"description":1364,"extension":663,"meta":1365,"navigation":666,"path":1366,"seo":1367,"stem":1368,"tags":660,"__hash__":1369},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":8,"value":799,"toc":1338},[800,804,807,811,814,821,824,836,838,842,849,933,937,944,948,963,965,968,972,983,992,1003,1007,1013,1019,1038,1042,1045,1049,1058,1060,1063,1067,1073,1087,1091,1097,1114,1117,1197,1200,1206,1229,1300,1303,1306,1317,1320,1322,1325,1328,1334],[27,801,803],{"id":802},"为什么要离开-hexo","为什么要离开 Hexo？",[16,805,806],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[59,808,810],{"id":809},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[16,812,813],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[16,815,816,817,820],{},"问题根源在于：",[19,818,819],{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[59,822,823],{"id":823},"构建速度与生态",[16,825,826,827,831,832,835],{},"文章数量上来之后，",[828,829,830],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[19,833,834],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[24,837],{},[27,839,841],{"id":840},"为什么选-nuxt","为什么选 Nuxt？",[16,843,844,845,848],{},"看过 VitePress、Astro、Next.js，最终选了 ",[19,846,847],{},"Nuxt 4 SSG","。核心考量：",[131,850,851,863],{},[134,852,853],{},[137,854,855,857,860],{},[140,856],{},[140,858,859],{},"Hexo",[140,861,862],{},"Nuxt 4",[147,864,865,878,891,904,917],{},[137,866,867,872,875],{},[152,868,869],{},[19,870,871],{},"构建机制",[152,873,874],{},"CLI 全量生成静态文件",[152,876,877],{},"Nitro 引擎预渲染 + 增量构建",[137,879,880,885,888],{},[152,881,882],{},[19,883,884],{},"模板\u002F组件",[152,886,887],{},"EJS\u002FPug，无组件化",[152,889,890],{},"Vue 3 组件，自动导入",[137,892,893,898,901],{},[152,894,895],{},[19,896,897],{},"内容管理",[152,899,900],{},"front-matter + markdown",[152,902,903],{},"@nuxt\u002Fcontent v3，类型安全查询",[137,905,906,911,914],{},[152,907,908],{},[19,909,910],{},"交互",[152,912,913],{},"内联 script，靠 CDN",[152,915,916],{},"完整的 Vue 响应式生态",[137,918,919,924,930],{},[152,920,921],{},[19,922,923],{},"路由",[152,925,926,929],{},[828,927,928],{},"_config.yml"," permalink 配置",[152,931,932],{},"文件系统路由，动态参数",[59,934,936],{"id":935},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[16,938,939,940,943],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[19,941,942],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[59,945,947],{"id":946},"vue-生态的开发体验","Vue 生态的开发体验",[16,949,950,951,954,955,958,959,962],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[828,952,953],{},"useAsyncData"," + ",[828,956,957],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[828,960,961],{},"\u003Cscript>"," 标签。",[24,964],{},[27,966,967],{"id":967},"迁移过程",[59,969,971],{"id":970},"内容层零改动搬过来","内容层：零改动搬过来",[16,973,974,975,978,979,982],{},"所有 markdown 文件从 Hexo 的 ",[828,976,977],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[828,980,981],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[984,985,990],"pre",{"className":986,"code":988,"language":989},[987],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[828,991,988],{"__ignoreMap":639},[16,993,994,995,998,999,1002],{},"多了 ",[828,996,997],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[828,1000,1001],{},"tags","。内容正文一个字没改。",[59,1004,1006],{"id":1005},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[16,1008,1009,1010,1012],{},"Hexo 的 URL 靠 ",[828,1011,928],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[984,1014,1017],{"className":1015,"code":1016,"language":989},[987],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[828,1018,1016],{"__ignoreMap":639},[16,1020,1021,1022,1025,1026,1029,1030,1033,1034,1037],{},"Nuxt 路由由 ",[828,1023,1024],{},"pages\u002F"," 目录结构决定，",[828,1027,1028],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[828,1031,1032],{},"trailingSlash: true"," 保证 URL 一致性，",[828,1035,1036],{},"[...slug].vue"," 兜底 404。",[59,1039,1041],{"id":1040},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[16,1043,1044],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[59,1046,1048],{"id":1047},"部署ci-保持不变","部署：CI 保持不变",[16,1050,1051,1052,1054,1055,37],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[828,1053,830],{}," 替换为 ",[828,1056,1057],{},"npm run build",[24,1059],{},[27,1061,1062],{"id":1062},"架构对比",[59,1064,1066],{"id":1065},"hexo-的架构","Hexo 的架构",[984,1068,1071],{"className":1069,"code":1070,"language":989},[987],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[828,1072,1070],{"__ignoreMap":639},[16,1074,1075,1076,1079,1080,1082,1083,1086],{},"Hexo 是",[19,1077,1078],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[828,1081,928],{},"、",[828,1084,1085],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[59,1088,1090],{"id":1089},"nuxt-的架构","Nuxt 的架构",[984,1092,1095],{"className":1093,"code":1094,"language":989},[987],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[828,1096,1094],{"__ignoreMap":639},[16,1098,1099,1100,1103,1104,1106,1107,1109,1110,1113],{},"Nuxt 是",[19,1101,1102],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[828,1105,957],{}," 查询内容，",[828,1108,953],{}," 管理异步数据，",[828,1111,1112],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[59,1115,1116],{"id":1116},"数据流对比",[131,1118,1119,1131],{},[134,1120,1121],{},[137,1122,1123,1126,1128],{},[140,1124,1125],{},"环节",[140,1127,859],{},[140,1129,1130],{},"Nuxt",[147,1132,1133,1146,1159,1175,1186],{},[137,1134,1135,1138,1141],{},[152,1136,1137],{},"内容获取",[152,1139,1140],{},"读文件 → 模板注入变量",[152,1142,1143],{},[828,1144,1145],{},"queryCollection('posts').all()",[137,1147,1148,1151,1154],{},[152,1149,1150],{},"数据管理",[152,1152,1153],{},"无，模板即数据",[152,1155,1156,1158],{},[828,1157,953],{}," + 响应式",[137,1160,1161,1164,1169],{},[152,1162,1163],{},"站点配置",[152,1165,1166,1168],{},[828,1167,928],{}," + 主题 config",[152,1170,1171,1174],{},[828,1172,1173],{},"useSite()"," composable",[137,1176,1177,1180,1183],{},[152,1178,1179],{},"主题",[152,1181,1182],{},"Stylus 变量 → 编译到 CSS",[152,1184,1185],{},"CSS 自定义属性 → 运行时切换",[137,1187,1188,1191,1194],{},[152,1189,1190],{},"交互状态",[152,1192,1193],{},"全局变量 + DOM 操作",[152,1195,1196],{},"Vue 响应式 + composables",[59,1198,1199],{"id":1199},"预渲染策略",[16,1201,1202,1203,1205],{},"Hexo 每次 ",[828,1204,830],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[16,1207,1208,1209,1212,1213,1216,1217,1220,1221,1224,1225,1228],{},"Nitro 的 ",[828,1210,1211],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[828,1214,1215],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[19,1218,1219],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[828,1222,1223],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[828,1226,1227],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[984,1230,1234],{"className":1231,"code":1232,"language":1233,"meta":639,"style":639},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[828,1235,1236,1248,1263,1294],{"__ignoreMap":639},[240,1237,1240,1244],{"class":1238,"line":1239},"line",1,[240,1241,1243],{"class":1242},"sVyAn","prerender",[240,1245,1247],{"class":1246},"sn6KH",": {\n",[240,1249,1250,1253,1256,1260],{"class":1238,"line":640},[240,1251,1252],{"class":1242},"  crawlLinks",[240,1254,1255],{"class":1246},": ",[240,1257,1259],{"class":1258},"sVC51","true",[240,1261,1262],{"class":1246},",\n",[240,1264,1265,1268,1271,1275,1278,1281,1283,1286,1288,1291],{"class":1238,"line":645},[240,1266,1267],{"class":1242},"  routes",[240,1269,1270],{"class":1246},": [",[240,1272,1274],{"class":1273},"subq3","'\u002F'",[240,1276,1277],{"class":1246},", ",[240,1279,1280],{"class":1273},"'\u002Fabout'",[240,1282,1277],{"class":1246},[240,1284,1285],{"class":1273},"'\u002Fposts'",[240,1287,1277],{"class":1246},[240,1289,1290],{"class":1273},"'\u002Flinks'",[240,1292,1293],{"class":1246},"],\n",[240,1295,1297],{"class":1238,"line":1296},4,[240,1298,1299],{"class":1246},"}\n",[27,1301,1302],{"id":1302},"迁移成本远低于预期",[16,1304,1305],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[63,1307,1308,1311,1314],{},[49,1309,1310],{},"搭建 Nuxt 项目骨架",[49,1312,1313],{},"设计 CSS token 系统",[49,1315,1316],{},"编写几个核心组件",[16,1318,1319],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[24,1321],{},[27,1323,1324],{"id":1324},"总结",[16,1326,1327],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[16,1329,1330,1333],{},[19,1331,1332],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[1335,1336,1337],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":639,"searchDepth":640,"depth":640,"links":1339},[1340,1344,1348,1354,1360,1361],{"id":802,"depth":640,"text":803,"children":1341},[1342,1343],{"id":809,"depth":645,"text":810},{"id":823,"depth":645,"text":823},{"id":840,"depth":640,"text":841,"children":1345},[1346,1347],{"id":935,"depth":645,"text":936},{"id":946,"depth":645,"text":947},{"id":967,"depth":640,"text":967,"children":1349},[1350,1351,1352,1353],{"id":970,"depth":645,"text":971},{"id":1005,"depth":645,"text":1006},{"id":1040,"depth":645,"text":1041},{"id":1047,"depth":645,"text":1048},{"id":1062,"depth":640,"text":1062,"children":1355},[1356,1357,1358,1359],{"id":1065,"depth":645,"text":1066},{"id":1089,"depth":645,"text":1090},{"id":1116,"depth":645,"text":1116},{"id":1199,"depth":645,"text":1199},{"id":1302,"depth":640,"text":1302},{"id":1324,"depth":640,"text":1324},"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":797,"description":1364},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",1779193735089]