cd your_blog\nhexo init && npm install\n","bash",[42,645,646,652,667,685],{"__ignoreMap":213},[460,647,648],{"class":462,"line":463},[460,649,651],{"class":650},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[460,653,654,658,661,664],{"class":462,"line":474},[460,655,657],{"class":656},"sVbv2","npm",[460,659,660],{"class":499}," install",[460,662,663],{"class":483}," -g",[460,665,666],{"class":499}," hexo-cli\n",[460,668,669,672,675,678,682],{"class":462,"line":490},[460,670,671],{"class":656},"mkdir",[460,673,674],{"class":499}," your_blog",[460,676,677],{"class":470}," && ",[460,679,681],{"class":680},"sjrmR","cd",[460,683,684],{"class":499}," your_blog\n",[460,686,687,690,693,695,697],{"class":462,"line":522},[460,688,689],{"class":656},"hexo",[460,691,692],{"class":499}," init",[460,694,677],{"class":470},[460,696,657],{"class":656},[460,698,699],{"class":499}," install\n",[16,701,702],{},"安装 Butterfly 主题：",[205,704,706],{"className":641,"code":705,"language":643,"meta":213,"style":213},"npm install hexo-theme-butterfly\n",[42,707,708],{"__ignoreMap":213},[460,709,710,712,714],{"class":462,"line":463},[460,711,657],{"class":656},[460,713,660],{"class":499},[460,715,716],{"class":499}," hexo-theme-butterfly\n",[16,718,719,720,722,723,726,727,730,731,734,735,738],{},"修改根目录 ",[42,721,149],{},"，将 ",[42,724,725],{},"theme"," 设为 ",[42,728,729],{},"butterfly","。执行 ",[42,732,733],{},"hexo s","，打开 ",[42,736,737],{},"http:\u002F\u002Flocalhost:4000"," 即可预览。",[51,740],{},[11,742,744],{"id":743},"部署上线让世界看到你的博客","部署上线：让世界看到你的博客",[20,746,748],{"id":747},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[16,750,751],{},"安装部署插件：",[205,753,755],{"className":641,"code":754,"language":643,"meta":213,"style":213},"npm install hexo-deployer-git\n",[42,756,757],{"__ignoreMap":213},[460,758,759,761,763],{"class":462,"line":463},[460,760,657],{"class":656},[460,762,660],{"class":499},[460,764,765],{"class":499}," hexo-deployer-git\n",[16,767,768,769,771,772,775],{},"在 ",[42,770,149],{}," 中配置 GitHub 仓库地址和分支（推荐 ",[42,773,774],{},"main","），然后执行：",[205,777,779],{"className":641,"code":778,"language":643,"meta":213,"style":213},"hexo clean && hexo g && hexo d\n",[42,780,781],{"__ignoreMap":213},[460,782,783,785,788,790,792,795,797,799],{"class":462,"line":463},[460,784,689],{"class":656},[460,786,787],{"class":499}," clean",[460,789,677],{"class":470},[460,791,689],{"class":656},[460,793,794],{"class":499}," g",[460,796,677],{"class":470},[460,798,689],{"class":656},[460,800,801],{"class":499}," d\n",[20,803,805],{"id":804},"_2-进阶玩法vercel-托管","2. 进阶玩法：Vercel 托管",[16,807,808,809,812],{},"如果想要更快的国内访问速度，可用 ",[31,810,811],{},"Vercel"," 托管静态页面。Vercel 支持自定义域名，适合作为 GitHub Pages 的补充方案。",[51,814],{},[11,816,817],{"id":817},"魔改与避坑指南",[16,819,820],{},"跟着教程走一帆风顺，自己动手加特效（轮播图、Aplayer 音乐）时，玄学问题就来了。",[20,822,824],{"id":823},"坑一静态资源加载失败","❌ 坑一：静态资源加载失败",[16,826,827,830,831,834],{},[31,828,829],{},"现象","：本地正常，部署后控制台一片红 ",[42,832,833],{},"ERR_ABORTED","，排版错乱、图标变方块。",[16,836,837,840],{},[31,838,839],{},"原因","：部分国内 CDN 服务不稳定或已停运，在 GitHub Pages \u002F Vercel 环境可能被拦截。",[16,842,843,846,847,849,850,855,856,280],{},[31,844,845],{},"✅ 解决","：在 ",[42,848,308],{}," 中将第三方资源替换为可靠的公共 CDN，如 ",[31,851,852],{},[42,853,854],{},"unpkg.com"," 或 ",[31,857,858],{},[42,859,860],{},"cdn.jsdelivr.net\u002Fnpm\u002F",[20,862,864],{"id":863},"坑二github-actions-自动部署后页面不更新","❌ 坑二：GitHub Actions 自动部署后页面不更新",[16,866,867,869],{},[31,868,829],{},"：Workflow 显示构建成功，但网页内容未变化。",[16,871,872,874,875,877],{},[31,873,839],{},"：GitHub Pages 默认部署分支可能不是 ",[42,876,774],{},"，或存在缓存延迟。",[16,879,880,882,883,886,887,889],{},[31,881,845],{},"：前往仓库 ",[31,884,885],{},"Settings -> Pages","，确认部署分支为 ",[42,888,774],{},"，保存后等待片刻即可。",[20,891,893],{"id":892},"坑三vercel-重复构建","❌ 坑三：Vercel 重复构建",[16,895,896,898,899,901],{},[31,897,829],{},"：导入 Hexo 项目后 Vercel 再次执行 ",[42,900,44],{},"，导致构建失败或超时。",[16,903,904,906],{},[31,905,839],{},"：Vercel 检测到 Hexo 项目后自动添加了构建命令，与已生成的静态文件冲突。",[16,908,909,911,912,915,916,919],{},[31,910,845],{},"：在 Vercel 项目设置中找到 ",[31,913,914],{},"Build Command","，启用 Override 并",[31,917,918],{},"留空","，让 Vercel 直接部署现有静态文件。",[20,921,923],{"id":922},"坑四本地预览与线上效果不一致","❌ 坑四：本地预览与线上效果不一致",[16,925,926,928,929,931],{},[31,927,829],{},"：",[42,930,733],{}," 本地完美，部署后样式丢失或特效失效。",[16,933,934,928,936,939],{},[31,935,839],{},[31,937,938],{},"缓存问题","（浏览器\u002FCDN\u002FService Worker）是主要原因。另外，Butterfly 开启 PJAX 无刷新跳转后，自定义 JS 不会在页面切换时重新执行。",[16,941,942,928],{},[31,943,845],{},[533,945,946,959],{},[536,947,948,928,951,954,955,958],{},[31,949,950],{},"清理缓存",[42,952,953],{},"hexo clean"," + 浏览器无痕模式 + 强刷（",[42,956,957],{},"Ctrl + F5","）。如有 PWA，需清除 Service Worker。",[536,960,961,964,965,968],{},[31,962,963],{},"PJAX 适配","：将自定义 JS 包裹在 ",[42,966,967],{},"document.addEventListener('pjax:complete', function() {...})"," 中，确保每次切页重新触发。",[51,970],{},[11,972,973],{"id":973},"最终成果与碎碎念",[16,975,976],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[16,978,979],{},"建站最大的门槛其实是**\"开始动手\"**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[16,981,982],{},"折腾不息，共勉！",[563,984,985],{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":213,"searchDepth":474,"depth":474,"links":987},[988,992,996,1002],{"id":608,"depth":474,"text":609,"children":989},[990,991],{"id":615,"depth":490,"text":616},{"id":637,"depth":490,"text":638},{"id":743,"depth":474,"text":744,"children":993},[994,995],{"id":747,"depth":490,"text":748},{"id":804,"depth":490,"text":805},{"id":817,"depth":474,"text":817,"children":997},[998,999,1000,1001],{"id":823,"depth":490,"text":824},{"id":863,"depth":490,"text":864},{"id":892,"depth":490,"text":893},{"id":922,"depth":490,"text":923},{"id":973,"depth":474,"text":973},"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。",{"一直想有块完全属于自己的\"互联网自留地\"，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":590},"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":603,"description":1005},"posts\u002Fhexo-blog-setup-guide","4HAFjOV9mecL4xIvfuPYvhgKN1vVQGrnrG92lq58mbA",1777896646767]