[{"data":1,"prerenderedAt":1011},["ShallowReactive",2],{"all-posts":3},[4,601],{"id":5,"title":6,"body":7,"categories":590,"cover":591,"date":592,"description":593,"extension":594,"meta":595,"navigation":596,"path":597,"seo":598,"stem":599,"tags":590,"__hash__":600},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":8,"value":9,"toc":566},"minimark",[10,15,19,24,27,35,38,50,53,57,64,154,158,165,169,184,186,189,193,204,214,225,229,235,241,260,264,267,271,281,283,286,290,296,310,314,320,337,340,420,423,429,452,526,529,532,545,548,550,553,556,562],[11,12,14],"h2",{"id":13},"为什么要离开-hexo","为什么要离开 Hexo？",[16,17,18],"p",{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[20,21,23],"h3",{"id":22},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[16,25,26],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[16,28,29,30,34],{},"问题根源在于：",[31,32,33],"strong",{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[20,36,37],{"id":37},"构建速度与生态",[16,39,40,41,45,46,49],{},"文章数量上来之后，",[42,43,44],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[31,47,48],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[51,52],"hr",{},[11,54,56],{"id":55},"为什么选-nuxt","为什么选 Nuxt？",[16,58,59,60,63],{},"看过 VitePress、Astro、Next.js，最终选了 ",[31,61,62],{},"Nuxt 4 SSG","。核心考量：",[65,66,67,82],"table",{},[68,69,70],"thead",{},[71,72,73,76,79],"tr",{},[74,75],"th",{},[74,77,78],{},"Hexo",[74,80,81],{},"Nuxt 4",[83,84,85,99,112,125,138],"tbody",{},[71,86,87,93,96],{},[88,89,90],"td",{},[31,91,92],{},"构建机制",[88,94,95],{},"CLI 全量生成静态文件",[88,97,98],{},"Nitro 引擎预渲染 + 增量构建",[71,100,101,106,109],{},[88,102,103],{},[31,104,105],{},"模板\u002F组件",[88,107,108],{},"EJS\u002FPug，无组件化",[88,110,111],{},"Vue 3 组件，自动导入",[71,113,114,119,122],{},[88,115,116],{},[31,117,118],{},"内容管理",[88,120,121],{},"front-matter + markdown",[88,123,124],{},"@nuxt\u002Fcontent v3，类型安全查询",[71,126,127,132,135],{},[88,128,129],{},[31,130,131],{},"交互",[88,133,134],{},"内联 script，靠 CDN",[88,136,137],{},"完整的 Vue 响应式生态",[71,139,140,145,151],{},[88,141,142],{},[31,143,144],{},"路由",[88,146,147,150],{},[42,148,149],{},"_config.yml"," permalink 配置",[88,152,153],{},"文件系统路由，动态参数",[20,155,157],{"id":156},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[16,159,160,161,164],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[31,162,163],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[20,166,168],{"id":167},"vue-生态的开发体验","Vue 生态的开发体验",[16,170,171,172,175,176,179,180,183],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[42,173,174],{},"useAsyncData"," + ",[42,177,178],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[42,181,182],{},"\u003Cscript>"," 标签。",[51,185],{},[11,187,188],{"id":188},"迁移过程",[20,190,192],{"id":191},"内容层零改动搬过来","内容层：零改动搬过来",[16,194,195,196,199,200,203],{},"所有 markdown 文件从 Hexo 的 ",[42,197,198],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[42,201,202],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[205,206,211],"pre",{"className":207,"code":209,"language":210},[208],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[42,212,209],{"__ignoreMap":213},"",[16,215,216,217,220,221,224],{},"多了 ",[42,218,219],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[42,222,223],{},"tags","。内容正文一个字没改。",[20,226,228],{"id":227},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[16,230,231,232,234],{},"Hexo 的 URL 靠 ",[42,233,149],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[205,236,239],{"className":237,"code":238,"language":210},[208],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[42,240,238],{"__ignoreMap":213},[16,242,243,244,247,248,251,252,255,256,259],{},"Nuxt 路由由 ",[42,245,246],{},"pages\u002F"," 目录结构决定，",[42,249,250],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[42,253,254],{},"trailingSlash: true"," 保证 URL 一致性，",[42,257,258],{},"[...slug].vue"," 兜底 404。",[20,261,263],{"id":262},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[16,265,266],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[20,268,270],{"id":269},"部署ci-保持不变","部署：CI 保持不变",[16,272,273,274,276,277,280],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[42,275,44],{}," 替换为 ",[42,278,279],{},"npm run build","。",[51,282],{},[11,284,285],{"id":285},"架构对比",[20,287,289],{"id":288},"hexo-的架构","Hexo 的架构",[205,291,294],{"className":292,"code":293,"language":210},[208],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[42,295,293],{"__ignoreMap":213},[16,297,298,299,302,303,305,306,309],{},"Hexo 是",[31,300,301],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[42,304,149],{},"、",[42,307,308],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[20,311,313],{"id":312},"nuxt-的架构","Nuxt 的架构",[205,315,318],{"className":316,"code":317,"language":210},[208],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[42,319,317],{"__ignoreMap":213},[16,321,322,323,326,327,329,330,332,333,336],{},"Nuxt 是",[31,324,325],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[42,328,178],{}," 查询内容，",[42,331,174],{}," 管理异步数据，",[42,334,335],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[20,338,339],{"id":339},"数据流对比",[65,341,342,354],{},[68,343,344],{},[71,345,346,349,351],{},[74,347,348],{},"环节",[74,350,78],{},[74,352,353],{},"Nuxt",[83,355,356,369,382,398,409],{},[71,357,358,361,364],{},[88,359,360],{},"内容获取",[88,362,363],{},"读文件 → 模板注入变量",[88,365,366],{},[42,367,368],{},"queryCollection('posts').all()",[71,370,371,374,377],{},[88,372,373],{},"数据管理",[88,375,376],{},"无，模板即数据",[88,378,379,381],{},[42,380,174],{}," + 响应式",[71,383,384,387,392],{},[88,385,386],{},"站点配置",[88,388,389,391],{},[42,390,149],{}," + 主题 config",[88,393,394,397],{},[42,395,396],{},"useSite()"," composable",[71,399,400,403,406],{},[88,401,402],{},"主题",[88,404,405],{},"Stylus 变量 → 编译到 CSS",[88,407,408],{},"CSS 自定义属性 → 运行时切换",[71,410,411,414,417],{},[88,412,413],{},"交互状态",[88,415,416],{},"全局变量 + DOM 操作",[88,418,419],{},"Vue 响应式 + composables",[20,421,422],{"id":422},"预渲染策略",[16,424,425,426,428],{},"Hexo 每次 ",[42,427,44],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[16,430,431,432,435,436,439,440,443,444,447,448,451],{},"Nitro 的 ",[42,433,434],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[42,437,438],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[31,441,442],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[42,445,446],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[42,449,450],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[205,453,457],{"className":454,"code":455,"language":456,"meta":213,"style":213},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[42,458,459,472,488,520],{"__ignoreMap":213},[460,461,464,468],"span",{"class":462,"line":463},"line",1,[460,465,467],{"class":466},"sVyAn","prerender",[460,469,471],{"class":470},"sn6KH",": {\n",[460,473,475,478,481,485],{"class":462,"line":474},2,[460,476,477],{"class":466},"  crawlLinks",[460,479,480],{"class":470},": ",[460,482,484],{"class":483},"sVC51","true",[460,486,487],{"class":470},",\n",[460,489,491,494,497,501,504,507,509,512,514,517],{"class":462,"line":490},3,[460,492,493],{"class":466},"  routes",[460,495,496],{"class":470},": [",[460,498,500],{"class":499},"subq3","'\u002F'",[460,502,503],{"class":470},", ",[460,505,506],{"class":499},"'\u002Fabout'",[460,508,503],{"class":470},[460,510,511],{"class":499},"'\u002Fposts'",[460,513,503],{"class":470},[460,515,516],{"class":499},"'\u002Flinks'",[460,518,519],{"class":470},"],\n",[460,521,523],{"class":462,"line":522},4,[460,524,525],{"class":470},"}\n",[11,527,528],{"id":528},"迁移成本远低于预期",[16,530,531],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[533,534,535,539,542],"ol",{},[536,537,538],"li",{},"搭建 Nuxt 项目骨架",[536,540,541],{},"设计 CSS token 系统",[536,543,544],{},"编写几个核心组件",[16,546,547],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[51,549],{},[11,551,552],{"id":552},"总结",[16,554,555],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[16,557,558,561],{},[31,559,560],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[563,564,565],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":213,"searchDepth":474,"depth":474,"links":567},[568,572,576,582,588,589],{"id":13,"depth":474,"text":14,"children":569},[570,571],{"id":22,"de