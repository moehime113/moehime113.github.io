[{"data":1,"prerenderedAt":1022},["ShallowReactive",2],{"all-posts":3},[4,608],{"id":5,"title":6,"body":7,"categories":597,"cover":598,"date":599,"description":600,"extension":601,"meta":602,"navigation":603,"path":604,"seo":605,"stem":606,"tags":597,"__hash__":607},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":8,"value":9,"toc":573},"minimark",[10,15,19,24,32,35,47,50,54,61,164,168,175,179,198,200,203,207,218,228,239,243,249,255,274,278,281,285,288,290,293,297,303,317,321,327,344,347,427,430,436,459,533,536,539,552,555,557,560,563,569],[11,12,14],"h2",{"id":13},"为什么要离开-hexo","为什么要离开 Hexo？",[16,17,18],"p",{},"Hexo + Butterfly 这套组合颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，一些痛点逐渐暴露出来。",[20,21,23],"h3",{"id":22},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[16,25,26,27,31],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——写完文章 push 上去，PWA 缓存不更新，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。清理 Service Worker、硬刷新、改缓存策略，折腾一圈发现根本原因很简单：",[28,29,30],"strong",{},"生成的静态页面本质上是黑盒，你很难精确控制缓存行为","。",[20,33,34],{"id":34},"构建速度与生态",[16,36,37,38,42,43,46],{},"文章数量上来之后，",[39,40,41],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[28,44,45],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[48,49],"hr",{},[11,51,53],{"id":52},"为什么选-nuxt","为什么选 Nuxt？",[16,55,56,57,60],{},"看过 VitePress、Astro、Next.js，最终选了 ",[28,58,59],{},"Nuxt 4 SSG","。核心考量：",[62,63,64,79],"table",{},[65,66,67],"thead",{},[68,69,70,73,76],"tr",{},[71,72],"th",{},[71,74,75],{},"Hexo",[71,77,78],{},"Nuxt 4",[80,81,82,96,109,122,135,151],"tbody",{},[68,83,84,90,93],{},[85,86,87],"td",{},[28,88,89],{},"构建机制",[85,91,92],{},"CLI 全量生成静态文件",[85,94,95],{},"Nitro 引擎预渲染，增量构建",[68,97,98,103,106],{},[85,99,100],{},[28,101,102],{},"模板\u002F组件",[85,104,105],{},"EJS\u002FPug，无组件化",[85,107,108],{},"Vue 3 组件，自动导入",[68,110,111,116,119],{},[85,112,113],{},[28,114,115],{},"内容管理",[85,117,118],{},"front-matter + markdown",[85,120,121],{},"@nuxt\u002Fcontent v3，类型安全查询",[68,123,124,129,132],{},[85,125,126],{},[28,127,128],{},"交互",[85,130,131],{},"内联 script，靠 CDN",[85,133,134],{},"完整的 Vue 响应式生态",[68,136,137,142,148],{},[85,138,139],{},[28,140,141],{},"路由",[85,143,144,145],{},"配置文件 ",[39,146,147],{},"_config.yml",[85,149,150],{},"文件系统路由，动态参数",[68,152,153,158,161],{},[85,154,155],{},[28,156,157],{},"暗色模式",[85,159,160],{},"主题配置 + 手动脚本",[85,162,163],{},"localStorage + CSS 变量，SSR 安全",[20,165,167],{"id":166},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[16,169,170,171,174],{},"@nuxt\u002Fcontent v3 直接读 markdown，frontmatter 字段几乎不用改。这意味着",[28,172,173],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[20,176,178],{"id":177},"vue-生态的开发体验","Vue 生态的开发体验",[16,180,181,182,185,186,189,190,193,194,197],{},"组件化意味着每个 UI 单元是独立的、可复用的、可测试的。",[39,183,184],{},"useAsyncData"," + ",[39,187,188],{},"queryCollection"," 这套数据获取模式比 Hexo 的 ",[39,191,192],{},"_config + front-matter + theme"," 散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[39,195,196],{},"\u003Cscript>"," 标签。",[48,199],{},[11,201,202],{"id":202},"迁移过程",[20,204,206],{"id":205},"内容层零改动搬过来","内容层：零改动搬过来",[16,208,209,210,213,214,217],{},"所有 markdown 文件从 Hexo 的 ",[39,211,212],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[39,215,216],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[219,220,225],"pre",{"className":221,"code":223,"language":224},[222],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[39,226,223],{"__ignoreMap":227},"",[16,229,230,231,234,235,238],{},"多了个 ",[39,232,233],{},"description"," 字段用于 SEO 和列表摘要，去掉了 ",[39,236,237],{},"tags","（暂时没用）。内容正文一个字没改。",[20,240,242],{"id":241},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[16,244,245,246,248],{},"Hexo 的 URL 靠 ",[39,247,147],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[219,250,253],{"className":251,"code":252,"language":224},[222],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[39,254,252],{"__ignoreMap":227},[16,256,257,258,261,262,265,266,269,270,273],{},"区别在于 Nuxt 路由由 ",[39,259,260],{},"pages\u002F"," 目录结构决定，",[39,263,264],{},"posts\u002F[slug].vue"," 处理所有文章。配置了 ",[39,267,268],{},"trailingSlash: true"," 保证 URL 一致性。404 用 ",[39,271,272],{},"[...slug].vue"," 兜底。",[20,275,277],{"id":276},"设计系统从-stylus-变量到-css-自定义属性","设计系统：从 Stylus 变量到 CSS 自定义属性",[16,279,280],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移之后直接用 CSS 自定义属性，不需要重新编译样式，主题切换是即时的。",[20,282,284],{"id":283},"部署保持一致","部署：保持一致",[16,286,287],{},"CI 沿用 GitHub Actions，部署流程和原来基本一样。",[48,289],{},[11,291,292],{"id":292},"架构对比",[20,294,296],{"id":295},"hexo-的架构","Hexo 的架构",[219,298,301],{"className":299,"code":300,"language":224},[222],"Hexo CLI\n  ├── _config.yml        # 全局配置\n  ├── themes\u002Fbutterfly\u002F  # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml   # 主题配置\n  │   ├── layout\u002F       # EJS 模板\n  │   └── source\u002F       # 静态资源\n  ├── source\u002F_posts\u002F     # 文章 markdown\n  └── public\u002F            # 生成输出\n",[39,302,300],{"__ignoreMap":227},[16,304,305,306,309,310,312,313,316],{},"Hexo 是",[28,307,308],{},"生成器模式","：CLI 命令触发，读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容是分离的，但数据流是隐式的——配置散落在 ",[39,311,147],{},"、",[39,314,315],{},"_config.butterfly.yml","、frontmatter 三个地方，模板里用不同的变量名访问。",[20,318,320],{"id":319},"nuxt-的架构","Nuxt 的架构",[219,322,325],{"className":323,"code":324,"language":224},[222],"Nuxt App\n  ├── pages\u002F             # 文件系统路由 → SSG 预渲染\n  ├── components\u002F        # Vue 组件（自动导入）\n  ├── content\u002F           # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F        # 博客文章集合\n  │   └── pages\u002F        # 独立页面集合\n  ├── composables\u002F       # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F        # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器       # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F  # 纯静态文件\n",[39,326,324],{"__ignoreMap":227},[16,328,329,330,333,334,336,337,339,340,343],{},"Nuxt 是",[28,331,332],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[39,335,188],{}," 查询内容，",[39,338,184],{}," 管理异步数据，",[39,341,342],{},"useTheme()"," 封装主题逻辑。每一层职责清晰，不会出现 Hexo 那种\"配置在 A 处，变量在 B 处，效果在 C 处\"的情况。",[20,345,346],{"id":346},"数据流对比",[62,348,349,361],{},[65,350,351],{},[68,352,353,356,358],{},[71,354,355],{},"环节",[71,357,75],{},[71,359,360],{},"Nuxt",[80,362,363,376,389,405,416],{},[68,364,365,368,371],{},[85,366,367],{},"内容获取",[85,369,370],{},"读文件 → 模板注入变量",[85,372,373],{},[39,374,375],{},"queryCollection('posts').all()",[68,377,378,381,384],{},[85,379,380],{},"数据管理",[85,382,383],{},"无，模板即数据",[85,385,386,388],{},[39,387,184],{}," + 响应式",[68,390,391,394,399],{},[85,392,393],{},"站点配置",[85,395,396,398],{},[39,397,147],{}," + 主题 config",[85,400,401,404],{},[39,402,403],{},"useSite()"," composable",[68,406,407,410,413],{},[85,408,409],{},"主题",[85,411,412],{},"Stylus 变量 → 编译到 CSS",[85,414,415],{},"CSS 自定义属性 → 运行时切换",[68,417,418,421,424],{},[85,419,420],{},"交互状态",[85,422,423],{},"全局变量 + DOM 操作",[85,425,426],{},"Vue 响应式 + composables",[20,428,429],{"id":429},"预渲染策略",[16,431,432,433,435],{},"Hexo 每次 ",[39,434,41],{}," 都是全量重新生成所有页面。文章多了之后，这个时间变得不可忽视。",[16,437,438,439,442,443,446,447,450,451,454,455,458],{},"Nitro 的 ",[39,440,441],{},"crawlLinks: true"," 则是从 seed routes 出发，按 ",[39,444,445],{},"\u003Ca href>"," 链接爬取需要预渲染的页面。只渲染能找到的、被引用的页面。但要注意：",[28,448,449],{},"crawlLinks 不能替代显式 routes 声明","。如果你的导航是客户端 JS 动态生成的，或者某些页面没有直接的 ",[39,452,453],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。所以在 ",[39,456,457],{},"nitro.prerender.routes"," 里显式声明关键路由是个好习惯：",[219,460,464],{"className":461,"code":462,"language":463,"meta":227,"style":227},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[39,465,466,479,495,527],{"__ignoreMap":227},[467,468,471,475],"span",{"class":469,"line":470},"line",1,[467,472,474],{"class":473},"sVyAn","prerender",[467,476,478],{"class":477},"sn6KH",": {\n",[467,480,482,485,488,492],{"class":469,"line":481},2,[467,483,484],{"class":473},"  crawlLinks",[467,486,487],{"class":477},": ",[467,489,491],{"class":490},"sVC51","true",[467,493,494],{"class":477},",\n",[467,496,498,501,504,508,511,514,516,519,521,524],{"class":469,"line":497},3,[467,499,500],{"class":473},"  routes",[467,502,503],{"class":477},": [",[467,505,507],{"class":506},"subq3","'\u002F'",[467,509,510],{"class":477},", ",[467,512,513],{"class":506},"'\u002Fabout'",[467,515,510],{"class":477},[467,517,518],{"class":506},"'\u002Fposts'",[467,520,510],{"class":477},[467,522,523],{"class":506},"'\u002Flinks'",[467,525,526],{"class":477},"],\n",[467,528,530],{"class":469,"line":529},4,[467,531,532],{"class":477},"}\n",[11,534,535],{"id":535},"迁移成本远低于预期",[16,537,538],{},"说实话出发前我还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[540,541,542,546,549],"ol",{},[543,544,545],"li",{},"搭建 Nuxt 项目骨架",[543,547,548],{},"设计 CSS token 系统",[543,550,551],{},"写几个核心组件",[16,553,554],{},"借助claude code加在一起两天就搞定了。框架升级的收益是长期的，成本是一次性的。",[48,556],{},[11,558,559],{"id":559},"总结",[16,561,562],{},"迁移之前，在折腾 Hexo 的各种\"魔改\"时经常会想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于博客这种内容驱动的站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[16,564,565,568],{},[28,566,567],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[570,571,572],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":227,"searchDepth":481,"depth":481,"links":574},[575,579,583,589,595,596],{"id":13,"depth":481,"text":14,"children":576},[577,578],{"id":22,"depth":497,"text":23},{"id":34,"depth":497,"text":34},{"id":52,"depth":481,"text":53,"children":580},[581,582],{"id":166,"depth":497,"text":167},{"id":177,"depth":497,"text":178},{"id":202,"depth":481,"text":202,"children":584},[585,586,587,588],{"id":205,"depth":497,"text":206},{"id":241,"depth":497,"text":242},{"id":276,"depth":497,"text":277},{"id":283,"depth":497,"text":284},{"id":292,"depth":481,"text":292,"children":590},[591,592,593,594],{"id":295,"depth":497,"text":296},{"id":319,"depth":497,"text":320},{"id":346,"depth":497,"text":346},{"id":429,"depth":497,"text":429},{"id":535,"depth":481,"text":535},{"id":559,"depth":481,"text":559},null,"\u002Fimg\u002Fpostcard2.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验","md",{},true,"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":6,"description":600},"posts\u002Fhexo-to-nuxt-migration","7bA5FnXNCZWIU4IjBK4kyVQFy7pfJtb2RMCTmKdVaNc",{"id":609,"title":610,"body":611,"categories":597,"cover":1014,"date":1015,"description":1016,"extension":601,"meta":1017,"navigation":603,"path":1018,"seo":1019,"stem":1020,"tags":597,"__hash__":1021},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":8,"value":612,"toc":997},[613,617,620,624,627,642,646,649,710,717,731,753,755,759,762,766,777,803,807,818,820,824,827,831,870,874,899,903,925,929,950,980,982,985,988,991,994],[11,614,616],{"id":615},"折腾第一步让博客先跑起来","折腾第一步：让博客先跑起来",[16,618,619],{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[20,621,623],{"id":622},"_1-搞定基础环境","1. 搞定基础环境",[16,625,626],{},"备好两样工具：",[628,629,630,636],"ul",{},[543,631,632,635],{},[28,633,634],{},"Git & GitHub","：做版本控制和网页托管。",[543,637,638,641],{},[28,639,640],{},"Node.js","：Hexo 的运行基础，官网下个稳定版装上就行。",[20,643,645],{"id":644},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[16,647,648],{},"打开终端，敲几行命令搭好骨架：",[219,650,654],{"className":651,"code":652,"language":653,"meta":227,"style":227},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash",[39,655,656,662,677,695],{"__ignoreMap":227},[467,657,658],{"class":469,"line":470},[467,659,661],{"class":660},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[467,663,664,668,671,674],{"class":469,"line":481},[467,665,667],{"class":666},"sVbv2","npm",[467,669,670],{"class":506}," install",[467,672,673],{"class":490}," -g",[467,675,676],{"class":506}," hexo-cli\n",[467,678,679,682,685,688,692],{"class":469,"line":497},[467,680,681],{"class":666},"mkdir",[467,683,684],{"class":506}," your_blog",[467,686,687],{"class":477}," && ",[467,689,691],{"class":690},"sjrmR","cd",[467,693,694],{"class":506}," your_blog\n",[467,696,697,700,703,705,707],{"class":469,"line":529},[467,698,699],{"class":666},"hexo",[467,701,702],{"class":506}," init",[467,704,687],{"class":477},[467,706,667],{"class":666},[467,708,709],{"class":506}," install\n",[16,711,712,713,716],{},"接着装上 ",[28,714,715],{},"Butterfly"," 主题：",[219,718,720],{"className":651,"code":719,"language":653,"meta":227,"style":227},"npm install hexo-theme-butterfly\n",[39,721,722],{"__ignoreMap":227},[467,723,724,726,728],{"class":469,"line":470},[467,725,667],{"class":666},[467,727,670],{"class":506},[467,729,730],{"class":506}," hexo-theme-butterfly\n",[16,732,733,734,736,737,740,741,744,745,748,749,752],{},"修改根目录 ",[39,735,147],{},"，把 ",[39,738,739],{},"theme"," 设为 ",[39,742,743],{},"butterfly","。终端跑一句 ",[39,746,747],{},"hexo s","，打开 ",[39,750,751],{},"http:\u002F\u002Flocalhost:4000","——看到雏形加载出来的那一刻，还是挺有成就感的！",[48,754],{},[11,756,758],{"id":757},"部署上线让世界看到你的博客","部署上线：让世界看到你的博客",[16,760,761],{},"本地自嗨不够，得把它挂到网上。",[20,763,765],{"id":764},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[16,767,768,769,772,773,776],{},"装好 Git 部署插件 ",[39,770,771],{},"hexo-deployer-git","，在配置文件填上 GitHub 仓库地址和分支（推荐 ",[39,774,775],{},"main","）。然后执行经典的“三连”命令推送到云端：",[219,778,780],{"className":651,"code":779,"language":653,"meta":227,"style":227},"hexo clean && hexo g && hexo d \n",[39,781,782],{"__ignoreMap":227},[467,783,784,786,789,791,793,796,798,800],{"class":469,"line":470},[467,785,699],{"class":666},[467,787,788],{"class":506}," clean",[467,790,687],{"class":477},[467,792,699],{"class":666},[467,794,795],{"class":506}," g",[467,797,687],{"class":477},[467,799,699],{"class":666},[467,801,802],{"class":506}," d\n",[20,804,806],{"id":805},"_2-进阶玩法vercel-与评论系统部署","2. 进阶玩法：Vercel 与评论系统部署",[16,808,809,810,813,814,817],{},"如果想要国内访问更快，强烈推荐用 ",[28,811,812],{},"Vercel"," 托管静态页面。\n另外，我后来还折腾了 ",[28,815,816],{},"Twikoo"," 评论系统，同样用 Vercel 部署云函数。免费好用，不用操心服务器，完美契合静态博客。",[48,819],{},[11,821,823],{"id":822},"魔改与避坑指南那些折磨过我的-bug","🔨 魔改与避坑指南：那些折磨过我的 Bug",[16,825,826],{},"跟着教程走一帆风顺，自己动手加特效（比如轮播图、Aplayer 音乐）时，玄学问题就来了。盘点几个大坑：",[20,828,830],{"id":829},"坑一静态资源加载失败cdn-之痛","❌ 坑一：静态资源加载失败（CDN 之痛）",[16,832,833,836,837,840,841,844,845,312,848,851,852,855,856,858,859,864,865,31],{},[28,834,835],{},"现象","：本地跑得好好的，一部署线上控制台就一片红 ",[39,838,839],{},"ERR_ABORTED","，排版错乱、图标变方块。\n",[28,842,843],{},"原因","：老教程推荐的国内\u002F小众 CDN（如 ",[39,846,847],{},"tianli0.top",[39,849,850],{},"bootcdn","）很多已停运，或在 GitHub\u002FVercel 环境被拦截。\n",[28,853,854],{},"✅ 解决","：果断弃用！在 ",[39,857,315],{}," 里，把第三方资源统统换成国际大厂 CDN，比如 ",[28,860,861],{},[39,862,863],{},"unpkg.com","（最稳妥）或 ",[28,866,867],{},[39,868,869],{},"cdn.jsdelivr.net\u002Fnpm\u002F",[20,871,873],{"id":872},"坑二github-actions-自动部署页面不更新","❌ 坑二：GitHub Actions 自动部署页面不更新",[16,875,876,878,879,881,882,884,885,888,889,891,892,895,896,898],{},[28,877,835],{},"：Workflow 自动构建并推送到 ",[39,880,775],{}," 分支显示成功，但网页死活不更新。\n",[28,883,843],{},"：GitHub Pages 默认可能还在傻傻读取旧的 ",[39,886,887],{},"gh-pages"," 分支。\n",[28,890,854],{},"：去 GitHub 仓库的 ",[28,893,894],{},"Settings -> Pages","，把部署分支手动改为 ",[39,897,775],{},"，保存稍等片刻即可。",[20,900,902],{"id":901},"坑三vercel-部署重复构建报错","❌ 坑三：Vercel 部署重复构建报错",[16,904,905,907,908,910,911,913,914,916,917,920,921,924],{},[28,906,835],{},"：把跑过 Actions 的 ",[39,909,775],{}," 分支导入 Vercel，构建卡住甚至报错。\n",[28,912,843],{},"：Actions 已生成纯静态文件，但 Vercel 发现是 Hexo 项目，又自作多情帮你跑了一遍构建命令。\n",[28,915,854],{},"：在 Vercel 项目设置里找到 ",[28,918,919],{},"Build Command","，打开 Override 并",[28,922,923],{},"留空","。让 Vercel 把它当纯静态站点直接部署，清爽快速。",[20,926,928],{"id":927},"坑四本地预览和线上效果不一致最恶心的玄学","❌ 坑四：本地预览和线上效果不一致（最恶心的玄学）",[16,930,931,933,934,936,937,939,940,943,944,947,948,933],{},[28,932,835],{},"：",[39,935,747],{}," 本地看一切完美，推送到线上后，发现样式没变、自定义的特效出不来，甚至页面错乱。\n",[28,938,843],{},"：这通常和 ",[28,941,942],{},"缓存（浏览器\u002FCDN\u002FPWA 服务端缓存）"," 或 ",[28,945,946],{},"PJAX 异步加载"," 有关。本地是即时响应的，而线上部署后，浏览器或 JS 服务端（Service Worker）会强缓存旧文件。另外，如果加了自定义 JS 特效，由于 Butterfly 开启了 PJAX 无刷新跳转，换页时 JS 可能不会重新执行。\n",[28,949,854],{},[540,951,952,970],{},[543,953,954,957,958,961,962,965,966,969],{},[28,955,956],{},"清缓存","：遇事不决先 ",[39,959,960],{},"hexo clean","，线上调试务必用浏览器的 ",[28,963,964],{},"无痕模式"," 或强刷（",[39,967,968],{},"Ctrl + F5","）。如果开了 PWA，记得去控制台清理 Service Worker。",[543,971,972,975,976,979],{},[28,973,974],{},"PJAX 适配","：如果是自定义 JS 特效失效，要把 JS 代码包在 PJAX 重载事件里（如 ",[39,977,978],{},"document.addEventListener('pjax:complete', function() {...})","），确保每次切页都能重新触发。",[48,981],{},[11,983,984],{"id":984},"最终成果与碎碎念",[16,986,987],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[16,989,990],{},"建站最大的门槛其实是**“开始动手”**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[16,992,993],{},"折腾不息，共勉！",[570,995,996],{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":227,"searchDepth":481,"depth":481,"links":998},[999,1003,1007,1013],{"id":615,"depth":481,"text":616,"children":1000},[1001,1002],{"id":622,"depth":497,"text":623},{"id":644,"depth":497,"text":645},{"id":757,"depth":481,"text":758,"children":1004},[1005,1006],{"id":764,"depth":497,"text":765},{"id":805,"depth":497,"text":806},{"id":822,"depth":481,"text":823,"children":1008},[1009,1010,1011,1012],{"id":829,"depth":497,"text":830},{"id":872,"depth":497,"text":873},{"id":901,"depth":497,"text":902},{"id":927,"depth":497,"text":928},{"id":984,"depth":481,"text":984},"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。",{"一直想有块完全属于自己的“互联网自留地”，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":597},"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":610,"description":1016},"posts\u002Fhexo-blog-setup-guide","-iIvcr3dvTx3ccBXGF2yKcOcpJeLHu_Z2FimYTo3edg",1777822814492]