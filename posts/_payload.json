[{"data":1,"prerenderedAt":726},["ShallowReactive",2],{"all-posts":3},[4,137],{"id":5,"title":6,"body":7,"categories":120,"cover":123,"date":124,"description":125,"extension":126,"meta":127,"navigation":128,"path":129,"seo":130,"stem":131,"tags":132,"__hash__":136},"posts\u002Fposts\u002Fubuntu-26-04-my-setup.md","我的 Ubuntu 26.04 配置",{"type":8,"value":9,"toc":112},"minimark",[10,14,18,21,28,44,47,79,83,94,98],[11,12,13],"h2",{"id":13},"我的配置清单",[15,16,17],"p",{},"Ubuntu 26.04 已成为我的主力操作系统，能够轻松满足日常办公和游戏需求。以下是当前环境的详细配置，供参考和记录。",[15,19,20],{},"惯例先附上系统信息：",[15,22,23],{},[24,25],"img",{"alt":26,"src":27},"我的桌面展示","\u002Fimg\u002Fimages\u002Fubuntu.png",[29,30,31,35,38,41],"ul",{},[32,33,34],"li",{},"OS：Ubuntu 26.04 LTS",[32,36,37],{},"Kernel：Linux 7.0.0-15-generic",[32,39,40],{},"CPU：Intel Core i7-14700H",[32,42,43],{},"GPU：NVIDIA GeForce RTX 4060 Max-Q",[11,45,46],{"id":46},"系统与桌面环境",[29,48,49,52,55,58,61,64,67,70,73,76],{},[32,50,51],{},"系统：Ubuntu 26.04 LTS \u002F 备用 Windows 11 双系统",[32,53,54],{},"桌面协议：Wayland",[32,56,57],{},"窗口管理：Mutter",[32,59,60],{},"Shell：zsh 5.9",[32,62,63],{},"终端：Ghostty",[32,65,66],{},"输入法：Fcitx5（小鹤音形）",[32,68,69],{},"主题：Orchis-dark",[32,71,72],{},"壁纸：Variety",[32,74,75],{},"截图：Flameshot",[32,77,78],{},"VPN：v2rayN（Linux 版本）",[11,80,82],{"id":81},"工作-学习","工作 \u002F 学习",[29,84,85,88,91],{},[32,86,87],{},"办公：WPS",[32,89,90],{},"编辑器：VS Code",[32,92,93],{},"AI 工具管理：CCSwitch（ccswitch）",[11,95,97],{"id":96},"生活-游戏","生活 \u002F 游戏",[29,99,100,103,106,109],{},[32,101,102],{},"游戏：Steam",[32,104,105],{},"兼容层：Proton GE",[32,107,108],{},"浏览器：Edge",[32,110,111],{},"聊天：微信 \u002F QQ",{"title":113,"searchDepth":114,"depth":114,"links":115},"",2,[116,117,118,119],{"id":13,"depth":114,"text":13},{"id":46,"depth":114,"text":46},{"id":81,"depth":114,"text":82},{"id":96,"depth":114,"text":97},[121,122],"Linux","我的配置","\u002Fimg\u002Fpostcard2.jpg","2026-05-15","Ubuntu 26.04 主力环境配置清单","md",{},true,"\u002Fposts\u002Fubuntu-26-04-my-setup",{"title":6,"description":125},"posts\u002Fubuntu-26-04-my-setup",[133,134,135],"Ubuntu","Wayland","桌面配置","yZYlhwCbitmtIMFYkRlb5os9JMJpWZH5UyymJQNZyxc",{"id":138,"title":139,"body":140,"categories":717,"cover":718,"date":719,"description":720,"extension":126,"meta":721,"navigation":128,"path":722,"seo":723,"stem":724,"tags":717,"__hash__":725},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":8,"value":141,"toc":693},[142,146,149,154,157,165,168,180,183,187,194,284,288,295,299,314,316,319,323,334,343,354,358,364,370,389,393,396,400,410,412,415,419,425,439,443,449,466,469,549,552,558,581,654,657,660,672,675,677,680,683,689],[11,143,145],{"id":144},"为什么要离开-hexo","为什么要离开 Hexo？",[15,147,148],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[150,151,153],"h3",{"id":152},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,155,156],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,158,159,160,164],{},"问题根源在于：",[161,162,163],"strong",{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[150,166,167],{"id":167},"构建速度与生态",[15,169,170,171,175,176,179],{},"文章数量上来之后，",[172,173,174],"code",{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[161,177,178],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[181,182],"hr",{},[11,184,186],{"id":185},"为什么选-nuxt","为什么选 Nuxt？",[15,188,189,190,193],{},"看过 VitePress、Astro、Next.js，最终选了 ",[161,191,192],{},"Nuxt 4 SSG","。核心考量：",[195,196,197,212],"table",{},[198,199,200],"thead",{},[201,202,203,206,209],"tr",{},[204,205],"th",{},[204,207,208],{},"Hexo",[204,210,211],{},"Nuxt 4",[213,214,215,229,242,255,268],"tbody",{},[201,216,217,223,226],{},[218,219,220],"td",{},[161,221,222],{},"构建机制",[218,224,225],{},"CLI 全量生成静态文件",[218,227,228],{},"Nitro 引擎预渲染 + 增量构建",[201,230,231,236,239],{},[218,232,233],{},[161,234,235],{},"模板\u002F组件",[218,237,238],{},"EJS\u002FPug，无组件化",[218,240,241],{},"Vue 3 组件，自动导入",[201,243,244,249,252],{},[218,245,246],{},[161,247,248],{},"内容管理",[218,250,251],{},"front-matter + markdown",[218,253,254],{},"@nuxt\u002Fcontent v3，类型安全查询",[201,256,257,262,265],{},[218,258,259],{},[161,260,261],{},"交互",[218,263,264],{},"内联 script，靠 CDN",[218,266,267],{},"完整的 Vue 响应式生态",[201,269,270,275,281],{},[218,271,272],{},[161,273,274],{},"路由",[218,276,277,280],{},[172,278,279],{},"_config.yml"," permalink 配置",[218,282,283],{},"文件系统路由，动态参数",[150,285,287],{"id":286},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,289,290,291,294],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[161,292,293],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[150,296,298],{"id":297},"vue-生态的开发体验","Vue 生态的开发体验",[15,300,301,302,305,306,309,310,313],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[172,303,304],{},"useAsyncData"," + ",[172,307,308],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[172,311,312],{},"\u003Cscript>"," 标签。",[181,315],{},[11,317,318],{"id":318},"迁移过程",[150,320,322],{"id":321},"内容层零改动搬过来","内容层：零改动搬过来",[15,324,325,326,329,330,333],{},"所有 markdown 文件从 Hexo 的 ",[172,327,328],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[172,331,332],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[335,336,341],"pre",{"className":337,"code":339,"language":340},[338],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[172,342,339],{"__ignoreMap":113},[15,344,345,346,349,350,353],{},"多了 ",[172,347,348],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[172,351,352],{},"tags","。内容正文一个字没改。",[150,355,357],{"id":356},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,359,360,361,363],{},"Hexo 的 URL 靠 ",[172,362,279],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[335,365,368],{"className":366,"code":367,"language":340},[338],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[172,369,367],{"__ignoreMap":113},[15,371,372,373,376,377,380,381,384,385,388],{},"Nuxt 路由由 ",[172,374,375],{},"pages\u002F"," 目录结构决定，",[172,378,379],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[172,382,383],{},"trailingSlash: true"," 保证 URL 一致性，",[172,386,387],{},"[...slug].vue"," 兜底 404。",[150,390,392],{"id":391},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,394,395],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[150,397,399],{"id":398},"部署ci-保持不变","部署：CI 保持不变",[15,401,402,403,405,406,409],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[172,404,174],{}," 替换为 ",[172,407,408],{},"npm run build","。",[181,411],{},[11,413,414],{"id":414},"架构对比",[150,416,418],{"id":417},"hexo-的架构","Hexo 的架构",[335,420,423],{"className":421,"code":422,"language":340},[338],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[172,424,422],{"__ignoreMap":113},[15,426,427,428,431,432,434,435,438],{},"Hexo 是",[161,429,430],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[172,433,279],{},"、",[172,436,437],{},"_config.butterfly.yml","、frontmatter 三处，模板里用不同变量名访问。",[150,440,442],{"id":441},"nuxt-的架构","Nuxt 的架构",[335,444,447],{"className":445,"code":446,"language":340},[338],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[172,448,446],{"__ignoreMap":113},[15,450,451,452,455,456,458,459,461,462,465],{},"Nuxt 是",[161,453,454],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[172,457,308],{}," 查询内容，",[172,460,304],{}," 管理异步数据，",[172,463,464],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[150,467,468],{"id":468},"数据流对比",[195,470,471,483],{},[198,472,473],{},[201,474,475,478,480],{},[204,476,477],{},"环节",[204,479,208],{},[204,481,482],{},"Nuxt",[213,484,485,498,511,527,538],{},[201,486,487,490,493],{},[218,488,489],{},"内容获取",[218,491,492],{},"读文件 → 模板注入变量",[218,494,495],{},[172,496,497],{},"queryCollection('posts').all()",[201,499,500,503,506],{},[218,501,502],{},"数据管理",[218,504,505],{},"无，模板即数据",[218,507,508,510],{},[172,509,304],{}," + 响应式",[201,512,513,516,521],{},[218,514,515],{},"站点配置",[218,517,518,520],{},[172,519,279],{}," + 主题 config",[218,522,523,526],{},[172,524,525],{},"useSite()"," composable",[201,528,529,532,535],{},[218,530,531],{},"主题",[218,533,534],{},"Stylus 变量 → 编译到 CSS",[218,536,537],{},"CSS 自定义属性 → 运行时切换",[201,539,540,543,546],{},[218,541,542],{},"交互状态",[218,544,545],{},"全局变量 + DOM 操作",[218,547,548],{},"Vue 响应式 + composables",[150,550,551],{"id":551},"预渲染策略",[15,553,554,555,557],{},"Hexo 每次 ",[172,556,174],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,559,560,561,564,565,568,569,572,573,576,577,580],{},"Nitro 的 ",[172,562,563],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[172,566,567],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[161,570,571],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[172,574,575],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[172,578,579],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[335,582,586],{"className":583,"code":584,"language":585,"meta":113,"style":113},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[172,587,588,601,616,648],{"__ignoreMap":113},[589,590,593,597],"span",{"class":591,"line":592},"line",1,[589,594,596],{"class":595},"sVyAn","prerender",[589,598,600],{"class":599},"sn6KH",": {\n",[589,602,603,606,609,613],{"class":591,"line":114},[589,604,605],{"class":595},"  crawlLinks",[589,607,608],{"class":599},": ",[589,610,612],{"class":611},"sVC51","true",[589,614,615],{"class":599},",\n",[589,617,619,622,625,629,632,635,637,640,642,645],{"class":591,"line":618},3,[589,620,621],{"class":595},"  routes",[589,623,624],{"class":599},": [",[589,626,628],{"class":627},"subq3","'\u002F'",[589,630,631],{"class":599},", ",[589,633,634],{"class":627},"'\u002Fabout'",[589,636,631],{"class":599},[589,638,639],{"class":627},"'\u002Fposts'",[589,641,631],{"class":599},[589,643,644],{"class":627},"'\u002Flinks'",[589,646,647],{"class":599},"],\n",[589,649,651],{"class":591,"line":650},4,[589,652,653],{"class":599},"}\n",[11,655,656],{"id":656},"迁移成本远低于预期",[15,658,659],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[661,662,663,666,669],"ol",{},[32,664,665],{},"搭建 Nuxt 项目骨架",[32,667,668],{},"设计 CSS token 系统",[32,670,671],{},"编写几个核心组件",[15,673,674],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[181,676],{},[11,678,679],{"id":679},"总结",[15,681,682],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,684,685,688],{},[161,686,687],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[690,691,692],"style",{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":113,"searchDepth":114,"depth":114,"links":694},[695,699,703,709,715,716],{"id":144,"depth":114,"text":145,"children":696},[697,698],{"id":152,"depth":618,"text":153},{"id":167,"depth":618,"text":167},{"id":185,"depth":114,"text":186,"children":700},[701,702],{"id":286,"depth":618,"text":287},{"id":297,"depth":618,"text":298},{"id":318,"depth":114,"text":318,"children":704},[705,706,707,708],{"id":321,"depth":618,"text":322},{"id":356,"depth":618,"text":357},{"id":391,"depth":618,"text":392},{"id":398,"depth":618,"text":399},{"id":414,"depth":114,"text":414,"children":710},[711,712,713,714],{"id":417,"depth":618,"text":418},{"id":441,"depth":618,"text":442},{"id":468,"depth":618,"text":468},{"id":551,"depth":618,"text":551},{"id":656,"depth":114,"text":656},{"id":679,"depth":114,"text":679},null,"\u002Fimg\u002Fpostcard1.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":139,"description":720},"posts\u002Fhexo-to-nuxt-migration","clFgBvIWOydjta0ge01Vk3opOc08eoVz4e3TVnf-1us",1778837999101]