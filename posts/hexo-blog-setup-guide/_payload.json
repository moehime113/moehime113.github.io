[{"data":1,"prerenderedAt":1292},["ShallowReactive",2],{"post-hexo-blog-setup-guide":3,"all-posts":445},{"id":4,"title":5,"body":6,"categories":434,"cover":435,"date":436,"description":437,"extension":438,"meta":439,"navigation":440,"path":441,"seo":442,"stem":443,"tags":434,"__hash__":444},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":7,"value":8,"toc":417},"minimark",[9,14,18,23,26,43,47,50,123,130,144,167,170,174,177,181,192,218,222,233,235,239,242,246,288,292,317,321,343,347,368,399,401,404,407,410,413],[10,11,13],"h2",{"id":12},"折腾第一步让博客先跑起来","折腾第一步：让博客先跑起来",[15,16,17],"p",{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[19,20,22],"h3",{"id":21},"_1-搞定基础环境","1. 搞定基础环境",[15,24,25],{},"备好两样工具：",[27,28,29,37],"ul",{},[30,31,32,36],"li",{},[33,34,35],"strong",{},"Git & GitHub","：做版本控制和网页托管。",[30,38,39,42],{},[33,40,41],{},"Node.js","：Hexo 的运行基础，官网下个稳定版装上就行。",[19,44,46],{"id":45},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[15,48,49],{},"打开终端，敲几行命令搭好骨架：",[51,52,57],"pre",{"className":53,"code":54,"language":55,"meta":56,"style":56},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash","",[58,59,60,69,87,107],"code",{"__ignoreMap":56},[61,62,65],"span",{"class":63,"line":64},"line",1,[61,66,68],{"class":67},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[61,70,72,76,80,84],{"class":63,"line":71},2,[61,73,75],{"class":74},"sVbv2","npm",[61,77,79],{"class":78},"subq3"," install",[61,81,83],{"class":82},"sVC51"," -g",[61,85,86],{"class":78}," hexo-cli\n",[61,88,90,93,96,100,104],{"class":63,"line":89},3,[61,91,92],{"class":74},"mkdir",[61,94,95],{"class":78}," your_blog",[61,97,99],{"class":98},"sn6KH"," && ",[61,101,103],{"class":102},"sjrmR","cd",[61,105,106],{"class":78}," your_blog\n",[61,108,110,113,116,118,120],{"class":63,"line":109},4,[61,111,112],{"class":74},"hexo",[61,114,115],{"class":78}," init",[61,117,99],{"class":98},[61,119,75],{"class":74},[61,121,122],{"class":78}," install\n",[15,124,125,126,129],{},"接着装上 ",[33,127,128],{},"Butterfly"," 主题：",[51,131,133],{"className":53,"code":132,"language":55,"meta":56,"style":56},"npm install hexo-theme-butterfly\n",[58,134,135],{"__ignoreMap":56},[61,136,137,139,141],{"class":63,"line":64},[61,138,75],{"class":74},[61,140,79],{"class":78},[61,142,143],{"class":78}," hexo-theme-butterfly\n",[15,145,146,147,150,151,154,155,158,159,162,163,166],{},"修改根目录 ",[58,148,149],{},"_config.yml","，把 ",[58,152,153],{},"theme"," 设为 ",[58,156,157],{},"butterfly","。终端跑一句 ",[58,160,161],{},"hexo s","，打开 ",[58,164,165],{},"http:\u002F\u002Flocalhost:4000","——看到雏形加载出来的那一刻，还是挺有成就感的！",[168,169],"hr",{},[10,171,173],{"id":172},"部署上线让世界看到你的博客","部署上线：让世界看到你的博客",[15,175,176],{},"本地自嗨不够，得把它挂到网上。",[19,178,180],{"id":179},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[15,182,183,184,187,188,191],{},"装好 Git 部署插件 ",[58,185,186],{},"hexo-deployer-git","，在配置文件填上 GitHub 仓库地址和分支（推荐 ",[58,189,190],{},"main","）。然后执行经典的“三连”命令推送到云端：",[51,193,195],{"className":53,"code":194,"language":55,"meta":56,"style":56},"hexo clean && hexo g && hexo d \n",[58,196,197],{"__ignoreMap":56},[61,198,199,201,204,206,208,211,213,215],{"class":63,"line":64},[61,200,112],{"class":74},[61,202,203],{"class":78}," clean",[61,205,99],{"class":98},[61,207,112],{"class":74},[61,209,210],{"class":78}," g",[61,212,99],{"class":98},[61,214,112],{"class":74},[61,216,217],{"class":78}," d\n",[19,219,221],{"id":220},"_2-进阶玩法vercel-与评论系统部署","2. 进阶玩法：Vercel 与评论系统部署",[15,223,224,225,228,229,232],{},"如果想要国内访问更快，强烈推荐用 ",[33,226,227],{},"Vercel"," 托管静态页面。\n另外，我后来还折腾了 ",[33,230,231],{},"Twikoo"," 评论系统，同样用 Vercel 部署云函数。免费好用，不用操心服务器，完美契合静态博客。",[168,234],{},[10,236,238],{"id":237},"魔改与避坑指南那些折磨过我的-bug","🔨 魔改与避坑指南：那些折磨过我的 Bug",[15,240,241],{},"跟着教程走一帆风顺，自己动手加特效（比如轮播图、Aplayer 音乐）时，玄学问题就来了。盘点几个大坑：",[19,243,245],{"id":244},"坑一静态资源加载失败cdn-之痛","❌ 坑一：静态资源加载失败（CDN 之痛）",[15,247,248,251,252,255,256,259,260,263,264,267,268,271,272,275,276,281,282,287],{},[33,249,250],{},"现象","：本地跑得好好的，一部署线上控制台就一片红 ",[58,253,254],{},"ERR_ABORTED","，排版错乱、图标变方块。\n",[33,257,258],{},"原因","：老教程推荐的国内\u002F小众 CDN（如 ",[58,261,262],{},"tianli0.top","、",[58,265,266],{},"bootcdn","）很多已停运，或在 GitHub\u002FVercel 环境被拦截。\n",[33,269,270],{},"✅ 解决","：果断弃用！在 ",[58,273,274],{},"_config.butterfly.yml"," 里，把第三方资源统统换成国际大厂 CDN，比如 ",[33,277,278],{},[58,279,280],{},"unpkg.com","（最稳妥）或 ",[33,283,284],{},[58,285,286],{},"cdn.jsdelivr.net\u002Fnpm\u002F","。",[19,289,291],{"id":290},"坑二github-actions-自动部署页面不更新","❌ 坑二：GitHub Actions 自动部署页面不更新",[15,293,294,296,297,299,300,302,303,306,307,309,310,313,314,316],{},[33,295,250],{},"：Workflow 自动构建并推送到 ",[58,298,190],{}," 分支显示成功，但网页死活不更新。\n",[33,301,258],{},"：GitHub Pages 默认可能还在傻傻读取旧的 ",[58,304,305],{},"gh-pages"," 分支。\n",[33,308,270],{},"：去 GitHub 仓库的 ",[33,311,312],{},"Settings -> Pages","，把部署分支手动改为 ",[58,315,190],{},"，保存稍等片刻即可。",[19,318,320],{"id":319},"坑三vercel-部署重复构建报错","❌ 坑三：Vercel 部署重复构建报错",[15,322,323,325,326,328,329,331,332,334,335,338,339,342],{},[33,324,250],{},"：把跑过 Actions 的 ",[58,327,190],{}," 分支导入 Vercel，构建卡住甚至报错。\n",[33,330,258],{},"：Actions 已生成纯静态文件，但 Vercel 发现是 Hexo 项目，又自作多情帮你跑了一遍构建命令。\n",[33,333,270],{},"：在 Vercel 项目设置里找到 ",[33,336,337],{},"Build Command","，打开 Override 并",[33,340,341],{},"留空","。让 Vercel 把它当纯静态站点直接部署，清爽快速。",[19,344,346],{"id":345},"坑四本地预览和线上效果不一致最恶心的玄学","❌ 坑四：本地预览和线上效果不一致（最恶心的玄学）",[15,348,349,351,352,354,355,357,358,361,362,365,366,351],{},[33,350,250],{},"：",[58,353,161],{}," 本地看一切完美，推送到线上后，发现样式没变、自定义的特效出不来，甚至页面错乱。\n",[33,356,258],{},"：这通常和 ",[33,359,360],{},"缓存（浏览器\u002FCDN\u002FPWA 服务端缓存）"," 或 ",[33,363,364],{},"PJAX 异步加载"," 有关。本地是即时响应的，而线上部署后，浏览器或 JS 服务端（Service Worker）会强缓存旧文件。另外，如果加了自定义 JS 特效，由于 Butterfly 开启了 PJAX 无刷新跳转，换页时 JS 可能不会重新执行。\n",[33,367,270],{},[369,370,371,389],"ol",{},[30,372,373,376,377,380,381,384,385,388],{},[33,374,375],{},"清缓存","：遇事不决先 ",[58,378,379],{},"hexo clean","，线上调试务必用浏览器的 ",[33,382,383],{},"无痕模式"," 或强刷（",[58,386,387],{},"Ctrl + F5","）。如果开了 PWA，记得去控制台清理 Service Worker。",[30,390,391,394,395,398],{},[33,392,393],{},"PJAX 适配","：如果是自定义 JS 特效失效，要把 JS 代码包在 PJAX 重载事件里（如 ",[58,396,397],{},"document.addEventListener('pjax:complete', function() {...})","），确保每次切页都能重新触发。",[168,400],{},[10,402,403],{"id":403},"最终成果与碎碎念",[15,405,406],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[15,408,409],{},"建站最大的门槛其实是**“开始动手”**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[15,411,412],{},"折腾不息，共勉！",[414,415,416],"style",{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":56,"searchDepth":71,"depth":71,"links":418},[419,423,427,433],{"id":12,"depth":71,"text":13,"children":420},[421,422],{"id":21,"depth":89,"text":22},{"id":45,"depth":89,"text":46},{"id":172,"depth":71,"text":173,"children":424},[425,426],{"id":179,"depth":89,"text":180},{"id":220,"depth":89,"text":221},{"id":237,"depth":71,"text":238,"children":428},[429,430,431,432],{"id":244,"depth":89,"text":245},{"id":290,"depth":89,"text":291},{"id":319,"depth":89,"text":320},{"id":345,"depth":89,"text":346},{"id":403,"depth":71,"text":403},null,"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。","md",{"一直想有块完全属于自己的“互联网自留地”，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":434},true,"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":5,"description":437},"posts\u002Fhexo-blog-setup-guide","-iIvcr3dvTx3ccBXGF2yKcOcpJeLHu_Z2FimYTo3edg",[446,716],{"id":4,"title":5,"body":447,"categories":434,"cover":435,"date":436,"description":437,"extension":438,"meta":714,"navigation":440,"path":441,"seo":715,"stem":443,"tags":434,"__hash__":444},{"type":7,"value":448,"toc":697},[449,451,453,455,457,467,469,471,513,517,529,541,543,545,547,549,555,577,579,585,587,589,591,593,617,619,635,637,651,653,667,685,687,689,691,693,695],[10,450,13],{"id":12},[15,452,17],{},[19,454,22],{"id":21},[15,456,25],{},[27,458,459,463],{},[30,460,461,36],{},[33,462,35],{},[30,464,465,42],{},[33,466,41],{},[19,468,46],{"id":45},[15,470,49],{},[51,472,473],{"className":53,"code":54,"language":55,"meta":56,"style":56},[58,474,475,479,489,501],{"__ignoreMap":56},[61,476,477],{"class":63,"line":64},[61,478,68],{"class":67},[61,480,481,483,485,487],{"class":63,"line":71},[61,482,75],{"class":74},[61,484,79],{"class":78},[61,486,83],{"class":82},[61,488,86],{"class":78},[61,490,491,493,495,497,499],{"class":63,"line":89},[61,492,92],{"class":74},[61,494,95],{"class":78},[61,496,99],{"class":98},[61,498,103],{"class":102},[61,500,106],{"class":78},[61,502,503,505,507,509,511],{"class":63,"line":109},[61,504,112],{"class":74},[61,506,115],{"class":78},[61,508,99],{"class":98},[61,510,75],{"class":74},[61,512,122],{"class":78},[15,514,125,515,129],{},[33,516,128],{},[51,518,519],{"className":53,"code":132,"language":55,"meta":56,"style":56},[58,520,521],{"__ignoreMap":56},[61,522,523,525,527],{"class":63,"line":64},[61,524,75],{"class":74},[61,526,79],{"class":78},[61,528,143],{"class":78},[15,530,146,531,150,533,154,535,158,537,162,539,166],{},[58,532,149],{},[58,534,153],{},[58,536,157],{},[58,538,161],{},[58,540,165],{},[168,542],{},[10,544,173],{"id":172},[15,546,176],{},[19,548,180],{"id":179},[15,550,183,551,187,553,191],{},[58,552,186],{},[58,554,190],{},[51,556,557],{"className":53,"code":194,"language":55,"meta":56,"style":56},[58,558,559],{"__ignoreMap":56},[61,560,561,563,565,567,569,571,573,575],{"class":63,"line":64},[61,562,112],{"class":74},[61,564,203],{"class":78},[61,566,99],{"class":98},[61,568,112],{"class":74},[61,570,210],{"class":78},[61,572,99],{"class":98},[61,574,112],{"class":74},[61,576,217],{"class":78},[19,578,221],{"id":220},[15,580,224,581,228,583,232],{},[33,582,227],{},[33,584,231],{},[168,586],{},[10,588,238],{"id":237},[15,590,241],{},[19,592,245],{"id":244},[15,594,595,251,597,255,599,259,601,263,603,267,605,271,607,275,609,281,613,287],{},[33,596,250],{},[58,598,254],{},[33,600,258],{},[58,602,262],{},[58,604,266],{},[33,606,270],{},[58,608,274],{},[33,610,611],{},[58,612,280],{},[33,614,615],{},[58,616,286],{},[19,618,291],{"id":290},[15,620,621,296,623,299,625,302,627,306,629,309,631,313,633,316],{},[33,622,250],{},[58,624,190],{},[33,626,258],{},[58,628,305],{},[33,630,270],{},[33,632,312],{},[58,634,190],{},[19,636,320],{"id":319},[15,638,639,325,641,328,643,331,645,334,647,338,649,342],{},[33,640,250],{},[58,642,190],{},[33,644,258],{},[33,646,270],{},[33,648,337],{},[33,650,341],{},[19,652,346],{"id":345},[15,654,655,351,657,354,659,357,661,361,663,365,665,351],{},[33,656,250],{},[58,658,161],{},[33,660,258],{},[33,662,360],{},[33,664,364],{},[33,666,270],{},[369,668,669,679],{},[30,670,671,376,673,380,675,384,677,388],{},[33,672,375],{},[58,674,379],{},[33,676,383],{},[58,678,387],{},[30,680,681,394,683,398],{},[33,682,393],{},[58,684,397],{},[168,686],{},[10,688,403],{"id":403},[15,690,406],{},[15,692,409],{},[15,694,412],{},[414,696,416],{},{"title":56,"searchDepth":71,"depth":71,"links":698},[699,703,707,713],{"id":12,"depth":71,"text":13,"children":700},[701,702],{"id":21,"depth":89,"text":22},{"id":45,"depth":89,"text":46},{"id":172,"depth":71,"text":173,"children":704},[705,706],{"id":179,"depth":89,"text":180},{"id":220,"depth":89,"text":221},{"id":237,"depth":71,"text":238,"children":708},[709,710,711,712],{"id":244,"depth":89,"text":245},{"id":290,"depth":89,"text":291},{"id":319,"depth":89,"text":320},{"id":345,"depth":89,"text":346},{"id":403,"depth":71,"text":403},{"一直想有块完全属于自己的“互联网自留地”，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":434},{"title":5,"description":437},{"id":717,"title":718,"body":719,"categories":434,"cover":1284,"date":1285,"description":1286,"extension":438,"meta":1287,"navigation":440,"path":1288,"seo":1289,"stem":1290,"tags":434,"__hash__":1291},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":720,"toc":1260},[721,725,728,732,738,741,752,754,758,765,867,871,878,882,901,903,906,910,921,929,940,944,950,956,975,979,982,986,989,991,994,998,1004,1016,1020,1026,1043,1046,1126,1129,1135,1158,1223,1226,1229,1240,1243,1245,1248,1251,1257],[10,722,724],{"id":723},"为什么要离开-hexo","为什么要离开 Hexo？",[15,726,727],{},"Hexo + Butterfly 这套组合颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，一些痛点逐渐暴露出来。",[19,729,731],{"id":730},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,733,734,735,287],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——写完文章 push 上去，PWA 缓存不更新，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。清理 Service Worker、硬刷新、改缓存策略，折腾一圈发现根本原因很简单：",[33,736,737],{},"生成的静态页面本质上是黑盒，你很难精确控制缓存行为",[19,739,740],{"id":740},"构建速度与生态",[15,742,743,744,747,748,751],{},"文章数量上来之后，",[58,745,746],{},"hexo g"," 的时间肉眼可见地变长。Hexo 的机制是",[33,749,750],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[168,753],{},[10,755,757],{"id":756},"为什么选-nuxt","为什么选 Nuxt？",[15,759,760,761,764],{},"看过 VitePress、Astro、Next.js，最终选了 ",[33,762,763],{},"Nuxt 4 SSG","。核心考量：",[766,767,768,783],"table",{},[769,770,771],"thead",{},[772,773,774,777,780],"tr",{},[775,776],"th",{},[775,778,779],{},"Hexo",[775,781,782],{},"Nuxt 4",[784,785,786,800,813,826,839,854],"tbody",{},[772,787,788,794,797],{},[789,790,791],"td",{},[33,792,793],{},"构建机制",[789,795,796],{},"CLI 全量生成静态文件",[789,798,799],{},"Nitro 引擎预渲染，增量构建",[772,801,802,807,810],{},[789,803,804],{},[33,805,806],{},"模板\u002F组件",[789,808,809],{},"EJS\u002FPug，无组件化",[789,811,812],{},"Vue 3 组件，自动导入",[772,814,815,820,823],{},[789,816,817],{},[33,818,819],{},"内容管理",[789,821,822],{},"front-matter + markdown",[789,824,825],{},"@nuxt\u002Fcontent v3，类型安全查询",[772,827,828,833,836],{},[789,829,830],{},[33,831,832],{},"交互",[789,834,835],{},"内联 script，靠 CDN",[789,837,838],{},"完整的 Vue 响应式生态",[772,840,841,846,851],{},[789,842,843],{},[33,844,845],{},"路由",[789,847,848,849],{},"配置文件 ",[58,850,149],{},[789,852,853],{},"文件系统路由，动态参数",[772,855,856,861,864],{},[789,857,858],{},[33,859,860],{},"暗色模式",[789,862,863],{},"主题配置 + 手动脚本",[789,865,866],{},"localStorage + CSS 变量，SSR 安全",[19,868,870],{"id":869},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,872,873,874,877],{},"@nuxt\u002Fcontent v3 直接读 markdown，frontmatter 字段几乎不用改。这意味着",[33,875,876],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[19,879,881],{"id":880},"vue-生态的开发体验","Vue 生态的开发体验",[15,883,884,885,888,889,892,893,896,897,900],{},"组件化意味着每个 UI 单元是独立的、可复用的、可测试的。",[58,886,887],{},"useAsyncData"," + ",[58,890,891],{},"queryCollection"," 这套数据获取模式比 Hexo 的 ",[58,894,895],{},"_config + front-matter + theme"," 散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[58,898,899],{},"\u003Cscript>"," 标签。",[168,902],{},[10,904,905],{"id":905},"迁移过程",[19,907,909],{"id":908},"内容层零改动搬过来","内容层：零改动搬过来",[15,911,912,913,916,917,920],{},"所有 markdown 文件从 Hexo 的 ",[58,914,915],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[58,918,919],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[51,922,927],{"className":923,"code":925,"language":926},[924],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[58,928,925],{"__ignoreMap":56},[15,930,931,932,935,936,939],{},"多了个 ",[58,933,934],{},"description"," 字段用于 SEO 和列表摘要，去掉了 ",[58,937,938],{},"tags","（暂时没用）。内容正文一个字没改。",[19,941,943],{"id":942},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,945,946,947,949],{},"Hexo 的 URL 靠 ",[58,948,149],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[51,951,954],{"className":952,"code":953,"language":926},[924],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[58,955,953],{"__ignoreMap":56},[15,957,958,959,962,963,966,967,970,971,974],{},"区别在于 Nuxt 路由由 ",[58,960,961],{},"pages\u002F"," 目录结构决定，",[58,964,965],{},"posts\u002F[slug].vue"," 处理所有文章。配置了 ",[58,968,969],{},"trailingSlash: true"," 保证 URL 一致性。404 用 ",[58,972,973],{},"[...slug].vue"," 兜底。",[19,976,978],{"id":977},"设计系统从-stylus-变量到-css-自定义属性","设计系统：从 Stylus 变量到 CSS 自定义属性",[15,980,981],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移之后直接用 CSS 自定义属性，不需要重新编译样式，主题切换是即时的。",[19,983,985],{"id":984},"部署保持一致","部署：保持一致",[15,987,988],{},"CI 沿用 GitHub Actions，部署流程和原来基本一样。",[168,990],{},[10,992,993],{"id":993},"架构对比",[19,995,997],{"id":996},"hexo-的架构","Hexo 的架构",[51,999,1002],{"className":1000,"code":1001,"language":926},[924],"Hexo CLI\n  ├── _config.yml        # 全局配置\n  ├── themes\u002Fbutterfly\u002F  # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml   # 主题配置\n  │   ├── layout\u002F       # EJS 模板\n  │   └── source\u002F       # 静态资源\n  ├── source\u002F_posts\u002F     # 文章 markdown\n  └── public\u002F            # 生成输出\n",[58,1003,1001],{"__ignoreMap":56},[15,1005,1006,1007,1010,1011,263,1013,1015],{},"Hexo 是",[33,1008,1009],{},"生成器模式","：CLI 命令触发，读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容是分离的，但数据流是隐式的——配置散落在 ",[58,1012,149],{},[58,1014,274],{},"、frontmatter 三个地方，模板里用不同的变量名访问。",[19,1017,1019],{"id":1018},"nuxt-的架构","Nuxt 的架构",[51,1021,1024],{"className":1022,"code":1023,"language":926},[924],"Nuxt App\n  ├── pages\u002F             # 文件系统路由 → SSG 预渲染\n  ├── components\u002F        # Vue 组件（自动导入）\n  ├── content\u002F           # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F        # 博客文章集合\n  │   └── pages\u002F        # 独立页面集合\n  ├── composables\u002F       # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F        # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器       # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F  # 纯静态文件\n",[58,1025,1023],{"__ignoreMap":56},[15,1027,1028,1029,1032,1033,1035,1036,1038,1039,1042],{},"Nuxt 是",[33,1030,1031],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[58,1034,891],{}," 查询内容，",[58,1037,887],{}," 管理异步数据，",[58,1040,1041],{},"useTheme()"," 封装主题逻辑。每一层职责清晰，不会出现 Hexo 那种\"配置在 A 处，变量在 B 处，效果在 C 处\"的情况。",[19,1044,1045],{"id":1045},"数据流对比",[766,1047,1048,1060],{},[769,1049,1050],{},[772,1051,1052,1055,1057],{},[775,1053,1054],{},"环节",[775,1056,779],{},[775,1058,1059],{},"Nuxt",[784,1061,1062,1075,1088,1104,1115],{},[772,1063,1064,1067,1070],{},[789,1065,1066],{},"内容获取",[789,1068,1069],{},"读文件 → 模板注入变量",[789,1071,1072],{},[58,1073,1074],{},"queryCollection('posts').all()",[772,1076,1077,1080,1083],{},[789,1078,1079],{},"数据管理",[789,1081,1082],{},"无，模板即数据",[789,1084,1085,1087],{},[58,1086,887],{}," + 响应式",[772,1089,1090,1093,1098],{},[789,1091,1092],{},"站点配置",[789,1094,1095,1097],{},[58,1096,149],{}," + 主题 config",[789,1099,1100,1103],{},[58,1101,1102],{},"useSite()"," composable",[772,1105,1106,1109,1112],{},[789,1107,1108],{},"主题",[789,1110,1111],{},"Stylus 变量 → 编译到 CSS",[789,1113,1114],{},"CSS 自定义属性 → 运行时切换",[772,1116,1117,1120,1123],{},[789,1118,1119],{},"交互状态",[789,1121,1122],{},"全局变量 + DOM 操作",[789,1124,1125],{},"Vue 响应式 + composables",[19,1127,1128],{"id":1128},"预渲染策略",[15,1130,1131,1132,1134],{},"Hexo 每次 ",[58,1133,746],{}," 都是全量重新生成所有页面。文章多了之后，这个时间变得不可忽视。",[15,1136,1137,1138,1141,1142,1145,1146,1149,1150,1153,1154,1157],{},"Nitro 的 ",[58,1139,1140],{},"crawlLinks: true"," 则是从 seed routes 出发，按 ",[58,1143,1144],{},"\u003Ca href>"," 链接爬取需要预渲染的页面。只渲染能找到的、被引用的页面。但要注意：",[33,1147,1148],{},"crawlLinks 不能替代显式 routes 声明","。如果你的导航是客户端 JS 动态生成的，或者某些页面没有直接的 ",[58,1151,1152],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。所以在 ",[58,1155,1156],{},"nitro.prerender.routes"," 里显式声明关键路由是个好习惯：",[51,1159,1163],{"className":1160,"code":1161,"language":1162,"meta":56,"style":56},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[58,1164,1165,1174,1188,1218],{"__ignoreMap":56},[61,1166,1167,1171],{"class":63,"line":64},[61,1168,1170],{"class":1169},"sVyAn","prerender",[61,1172,1173],{"class":98},": {\n",[61,1175,1176,1179,1182,1185],{"class":63,"line":71},[61,1177,1178],{"class":1169},"  crawlLinks",[61,1180,1181],{"class":98},": ",[61,1183,1184],{"class":82},"true",[61,1186,1187],{"class":98},",\n",[61,1189,1190,1193,1196,1199,1202,1205,1207,1210,1212,1215],{"class":63,"line":89},[61,1191,1192],{"class":1169},"  routes",[61,1194,1195],{"class":98},": [",[61,1197,1198],{"class":78},"'\u002F'",[61,1200,1201],{"class":98},", ",[61,1203,1204],{"class":78},"'\u002Fabout'",[61,1206,1201],{"class":98},[61,1208,1209],{"class":78},"'\u002Fposts'",[61,1211,1201],{"class":98},[61,1213,1214],{"class":78},"'\u002Flinks'",[61,1216,1217],{"class":98},"],\n",[61,1219,1220],{"class":63,"line":109},[61,1221,1222],{"class":98},"}\n",[10,1224,1225],{"id":1225},"迁移成本远低于预期",[15,1227,1228],{},"说实话出发前我还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[369,1230,1231,1234,1237],{},[30,1232,1233],{},"搭建 Nuxt 项目骨架",[30,1235,1236],{},"设计 CSS token 系统",[30,1238,1239],{},"写几个核心组件",[15,1241,1242],{},"借助claude code加在一起两天就搞定了。框架升级的收益是长期的，成本是一次性的。",[168,1244],{},[10,1246,1247],{"id":1247},"总结",[15,1249,1250],{},"迁移之前，在折腾 Hexo 的各种\"魔改\"时经常会想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于博客这种内容驱动的站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,1252,1253,1256],{},[33,1254,1255],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[414,1258,1259],{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":56,"searchDepth":71,"depth":71,"links":1261},[1262,1266,1270,1276,1282,1283],{"id":723,"depth":71,"text":724,"children":1263},[1264,1265],{"id":730,"depth":89,"text":731},{"id":740,"depth":89,"text":740},{"id":756,"depth":71,"text":757,"children":1267},[1268,1269],{"id":869,"depth":89,"text":870},{"id":880,"depth":89,"text":881},{"id":905,"depth":71,"text":905,"children":1271},[1272,1273,1274,1275],{"id":908,"depth":89,"text":909},{"id":942,"depth":89,"text":943},{"id":977,"depth":89,"text":978},{"id":984,"depth":89,"text":985},{"id":993,"depth":71,"text":993,"children":1277},[1278,1279,1280,1281],{"id":996,"depth":89,"text":997},{"id":1018,"depth":89,"text":1019},{"id":1045,"depth":89,"text":1045},{"id":1128,"depth":89,"text":1128},{"id":1225,"depth":71,"text":1225},{"id":1247,"depth":71,"text":1247},"\u002Fimg\u002Fpostcard2.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":718,"description":1286},"posts\u002Fhexo-to-nuxt-migration","7bA5FnXNCZWIU4IjBK4kyVQFy7pfJtb2RMCTmKdVaNc",1777820636310]