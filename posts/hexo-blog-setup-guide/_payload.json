[{"data":1,"prerenderedAt":1293},["ShallowReactive",2],{"post-hexo-blog-setup-guide":3,"all-posts":441},{"id":4,"title":5,"body":6,"categories":430,"cover":431,"date":432,"description":433,"extension":434,"meta":435,"navigation":436,"path":437,"seo":438,"stem":439,"tags":430,"__hash__":440},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":7,"value":8,"toc":413},"minimark",[9,14,18,23,26,43,47,120,123,137,160,163,167,171,174,188,198,224,228,235,237,240,243,247,257,263,285,289,294,302,314,318,327,332,345,349,357,365,369,395,397,400,403,406,409],[10,11,13],"h2",{"id":12},"折腾第一步让博客先跑起来","折腾第一步：让博客先跑起来",[15,16,17],"p",{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[19,20,22],"h3",{"id":21},"_1-搞定基础环境","1. 搞定基础环境",[15,24,25],{},"备好两样工具：",[27,28,29,37],"ul",{},[30,31,32,36],"li",{},[33,34,35],"strong",{},"Git & GitHub","：版本控制 + GitHub Pages 托管",[30,38,39,42],{},[33,40,41],{},"Node.js","：Hexo 运行基础，官网下载稳定版安装即可",[19,44,46],{"id":45},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[48,49,54],"pre",{"className":50,"code":51,"language":52,"meta":53,"style":53},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash","",[55,56,57,66,84,104],"code",{"__ignoreMap":53},[58,59,62],"span",{"class":60,"line":61},"line",1,[58,63,65],{"class":64},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[58,67,69,73,77,81],{"class":60,"line":68},2,[58,70,72],{"class":71},"sVbv2","npm",[58,74,76],{"class":75},"subq3"," install",[58,78,80],{"class":79},"sVC51"," -g",[58,82,83],{"class":75}," hexo-cli\n",[58,85,87,90,93,97,101],{"class":60,"line":86},3,[58,88,89],{"class":71},"mkdir",[58,91,92],{"class":75}," your_blog",[58,94,96],{"class":95},"sn6KH"," && ",[58,98,100],{"class":99},"sjrmR","cd",[58,102,103],{"class":75}," your_blog\n",[58,105,107,110,113,115,117],{"class":60,"line":106},4,[58,108,109],{"class":71},"hexo",[58,111,112],{"class":75}," init",[58,114,96],{"class":95},[58,116,72],{"class":71},[58,118,119],{"class":75}," install\n",[15,121,122],{},"安装 Butterfly 主题：",[48,124,126],{"className":50,"code":125,"language":52,"meta":53,"style":53},"npm install hexo-theme-butterfly\n",[55,127,128],{"__ignoreMap":53},[58,129,130,132,134],{"class":60,"line":61},[58,131,72],{"class":71},[58,133,76],{"class":75},[58,135,136],{"class":75}," hexo-theme-butterfly\n",[15,138,139,140,143,144,147,148,151,152,155,156,159],{},"修改根目录 ",[55,141,142],{},"_config.yml","，将 ",[55,145,146],{},"theme"," 设为 ",[55,149,150],{},"butterfly","。执行 ",[55,153,154],{},"hexo s","，打开 ",[55,157,158],{},"http:\u002F\u002Flocalhost:4000"," 即可预览。",[161,162],"hr",{},[10,164,166],{"id":165},"部署上线让世界看到你的博客","部署上线：让世界看到你的博客",[19,168,170],{"id":169},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[15,172,173],{},"安装部署插件：",[48,175,177],{"className":50,"code":176,"language":52,"meta":53,"style":53},"npm install hexo-deployer-git\n",[55,178,179],{"__ignoreMap":53},[58,180,181,183,185],{"class":60,"line":61},[58,182,72],{"class":71},[58,184,76],{"class":75},[58,186,187],{"class":75}," hexo-deployer-git\n",[15,189,190,191,193,194,197],{},"在 ",[55,192,142],{}," 中配置 GitHub 仓库地址和分支（推荐 ",[55,195,196],{},"main","），然后执行：",[48,199,201],{"className":50,"code":200,"language":52,"meta":53,"style":53},"hexo clean && hexo g && hexo d\n",[55,202,203],{"__ignoreMap":53},[58,204,205,207,210,212,214,217,219,221],{"class":60,"line":61},[58,206,109],{"class":71},[58,208,209],{"class":75}," clean",[58,211,96],{"class":95},[58,213,109],{"class":71},[58,215,216],{"class":75}," g",[58,218,96],{"class":95},[58,220,109],{"class":71},[58,222,223],{"class":75}," d\n",[19,225,227],{"id":226},"_2-进阶玩法vercel-托管","2. 进阶玩法：Vercel 托管",[15,229,230,231,234],{},"如果想要更快的国内访问速度，可用 ",[33,232,233],{},"Vercel"," 托管静态页面。Vercel 支持自定义域名，适合作为 GitHub Pages 的补充方案。",[161,236],{},[10,238,239],{"id":239},"魔改与避坑指南",[15,241,242],{},"跟着教程走一帆风顺，自己动手加特效（轮播图、Aplayer 音乐）时，玄学问题就来了。",[19,244,246],{"id":245},"坑一静态资源加载失败","❌ 坑一：静态资源加载失败",[15,248,249,252,253,256],{},[33,250,251],{},"现象","：本地正常，部署后控制台一片红 ",[55,254,255],{},"ERR_ABORTED","，排版错乱、图标变方块。",[15,258,259,262],{},[33,260,261],{},"原因","：部分国内 CDN 服务不稳定或已停运，在 GitHub Pages \u002F Vercel 环境可能被拦截。",[15,264,265,268,269,272,273,278,279,284],{},[33,266,267],{},"✅ 解决","：在 ",[55,270,271],{},"_config.butterfly.yml"," 中将第三方资源替换为可靠的公共 CDN，如 ",[33,274,275],{},[55,276,277],{},"unpkg.com"," 或 ",[33,280,281],{},[55,282,283],{},"cdn.jsdelivr.net\u002Fnpm\u002F","。",[19,286,288],{"id":287},"坑二github-actions-自动部署后页面不更新","❌ 坑二：GitHub Actions 自动部署后页面不更新",[15,290,291,293],{},[33,292,251],{},"：Workflow 显示构建成功，但网页内容未变化。",[15,295,296,298,299,301],{},[33,297,261],{},"：GitHub Pages 默认部署分支可能不是 ",[55,300,196],{},"，或存在缓存延迟。",[15,303,304,306,307,310,311,313],{},[33,305,267],{},"：前往仓库 ",[33,308,309],{},"Settings -> Pages","，确认部署分支为 ",[55,312,196],{},"，保存后等待片刻即可。",[19,315,317],{"id":316},"坑三vercel-重复构建","❌ 坑三：Vercel 重复构建",[15,319,320,322,323,326],{},[33,321,251],{},"：导入 Hexo 项目后 Vercel 再次执行 ",[55,324,325],{},"hexo g","，导致构建失败或超时。",[15,328,329,331],{},[33,330,261],{},"：Vercel 检测到 Hexo 项目后自动添加了构建命令，与已生成的静态文件冲突。",[15,333,334,336,337,340,341,344],{},[33,335,267],{},"：在 Vercel 项目设置中找到 ",[33,338,339],{},"Build Command","，启用 Override 并",[33,342,343],{},"留空","，让 Vercel 直接部署现有静态文件。",[19,346,348],{"id":347},"坑四本地预览与线上效果不一致","❌ 坑四：本地预览与线上效果不一致",[15,350,351,353,354,356],{},[33,352,251],{},"：",[55,355,154],{}," 本地完美，部署后样式丢失或特效失效。",[15,358,359,353,361,364],{},[33,360,261],{},[33,362,363],{},"缓存问题","（浏览器\u002FCDN\u002FService Worker）是主要原因。另外，Butterfly 开启 PJAX 无刷新跳转后，自定义 JS 不会在页面切换时重新执行。",[15,366,367,353],{},[33,368,267],{},[370,371,372,385],"ol",{},[30,373,374,353,377,380,381,384],{},[33,375,376],{},"清理缓存",[55,378,379],{},"hexo clean"," + 浏览器无痕模式 + 强刷（",[55,382,383],{},"Ctrl + F5","）。如有 PWA，需清除 Service Worker。",[30,386,387,390,391,394],{},[33,388,389],{},"PJAX 适配","：将自定义 JS 包裹在 ",[55,392,393],{},"document.addEventListener('pjax:complete', function() {...})"," 中，确保每次切页重新触发。",[161,396],{},[10,398,399],{"id":399},"最终成果与碎碎念",[15,401,402],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[15,404,405],{},"建站最大的门槛其实是**\"开始动手\"**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[15,407,408],{},"折腾不息，共勉！",[410,411,412],"style",{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":53,"searchDepth":68,"depth":68,"links":414},[415,419,423,429],{"id":12,"depth":68,"text":13,"children":416},[417,418],{"id":21,"depth":86,"text":22},{"id":45,"depth":86,"text":46},{"id":165,"depth":68,"text":166,"children":420},[421,422],{"id":169,"depth":86,"text":170},{"id":226,"depth":86,"text":227},{"id":239,"depth":68,"text":239,"children":424},[425,426,427,428],{"id":245,"depth":86,"text":246},{"id":287,"depth":86,"text":288},{"id":316,"depth":86,"text":317},{"id":347,"depth":86,"text":348},{"id":399,"depth":68,"text":399},null,"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。","md",{"一直想有块完全属于自己的\"互联网自留地\"，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":430},true,"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":5,"description":433},"posts\u002Fhexo-blog-setup-guide","4HAFjOV9mecL4xIvfuPYvhgKN1vVQGrnrG92lq58mbA",[442,724],{"id":4,"title":5,"body":443,"categories":430,"cover":431,"date":432,"description":433,"extension":434,"meta":722,"navigation":436,"path":437,"seo":723,"stem":439,"tags":430,"__hash__":440},{"type":7,"value":444,"toc":705},[445,447,449,451,453,463,465,507,509,521,533,535,537,539,541,553,559,581,583,587,589,591,593,595,601,605,619,621,625,631,639,641,647,651,659,661,667,673,677,693,695,697,699,701,703],[10,446,13],{"id":12},[15,448,17],{},[19,450,22],{"id":21},[15,452,25],{},[27,454,455,459],{},[30,456,457,36],{},[33,458,35],{},[30,460,461,42],{},[33,462,41],{},[19,464,46],{"id":45},[48,466,467],{"className":50,"code":51,"language":52,"meta":53,"style":53},[55,468,469,473,483,495],{"__ignoreMap":53},[58,470,471],{"class":60,"line":61},[58,472,65],{"class":64},[58,474,475,477,479,481],{"class":60,"line":68},[58,476,72],{"class":71},[58,478,76],{"class":75},[58,480,80],{"class":79},[58,482,83],{"class":75},[58,484,485,487,489,491,493],{"class":60,"line":86},[58,486,89],{"class":71},[58,488,92],{"class":75},[58,490,96],{"class":95},[58,492,100],{"class":99},[58,494,103],{"class":75},[58,496,497,499,501,503,505],{"class":60,"line":106},[58,498,109],{"class":71},[58,500,112],{"class":75},[58,502,96],{"class":95},[58,504,72],{"class":71},[58,506,119],{"class":75},[15,508,122],{},[48,510,511],{"className":50,"code":125,"language":52,"meta":53,"style":53},[55,512,513],{"__ignoreMap":53},[58,514,515,517,519],{"class":60,"line":61},[58,516,72],{"class":71},[58,518,76],{"class":75},[58,520,136],{"class":75},[15,522,139,523,143,525,147,527,151,529,155,531,159],{},[55,524,142],{},[55,526,146],{},[55,528,150],{},[55,530,154],{},[55,532,158],{},[161,534],{},[10,536,166],{"id":165},[19,538,170],{"id":169},[15,540,173],{},[48,542,543],{"className":50,"code":176,"language":52,"meta":53,"style":53},[55,544,545],{"__ignoreMap":53},[58,546,547,549,551],{"class":60,"line":61},[58,548,72],{"class":71},[58,550,76],{"class":75},[58,552,187],{"class":75},[15,554,190,555,193,557,197],{},[55,556,142],{},[55,558,196],{},[48,560,561],{"className":50,"code":200,"language":52,"meta":53,"style":53},[55,562,563],{"__ignoreMap":53},[58,564,565,567,569,571,573,575,577,579],{"class":60,"line":61},[58,566,109],{"class":71},[58,568,209],{"class":75},[58,570,96],{"class":95},[58,572,109],{"class":71},[58,574,216],{"class":75},[58,576,96],{"class":95},[58,578,109],{"class":71},[58,580,223],{"class":75},[19,582,227],{"id":226},[15,584,230,585,234],{},[33,586,233],{},[161,588],{},[10,590,239],{"id":239},[15,592,242],{},[19,594,246],{"id":245},[15,596,597,252,599,256],{},[33,598,251],{},[55,600,255],{},[15,602,603,262],{},[33,604,261],{},[15,606,607,268,609,272,611,278,615,284],{},[33,608,267],{},[55,610,271],{},[33,612,613],{},[55,614,277],{},[33,616,617],{},[55,618,283],{},[19,620,288],{"id":287},[15,622,623,293],{},[33,624,251],{},[15,626,627,298,629,301],{},[33,628,261],{},[55,630,196],{},[15,632,633,306,635,310,637,313],{},[33,634,267],{},[33,636,309],{},[55,638,196],{},[19,640,317],{"id":316},[15,642,643,322,645,326],{},[33,644,251],{},[55,646,325],{},[15,648,649,331],{},[33,650,261],{},[15,652,653,336,655,340,657,344],{},[33,654,267],{},[33,656,339],{},[33,658,343],{},[19,660,348],{"id":347},[15,662,663,353,665,356],{},[33,664,251],{},[55,666,154],{},[15,668,669,353,671,364],{},[33,670,261],{},[33,672,363],{},[15,674,675,353],{},[33,676,267],{},[370,678,679,687],{},[30,680,681,353,683,380,685,384],{},[33,682,376],{},[55,684,379],{},[55,686,383],{},[30,688,689,390,691,394],{},[33,690,389],{},[55,692,393],{},[161,694],{},[10,696,399],{"id":399},[15,698,402],{},[15,700,405],{},[15,702,408],{},[410,704,412],{},{"title":53,"searchDepth":68,"depth":68,"links":706},[707,711,715,721],{"id":12,"depth":68,"text":13,"children":708},[709,710],{"id":21,"depth":86,"text":22},{"id":45,"depth":86,"text":46},{"id":165,"depth":68,"text":166,"children":712},[713,714],{"id":169,"depth":86,"text":170},{"id":226,"depth":86,"text":227},{"id":239,"depth":68,"text":239,"children":716},[717,718,719,720],{"id":245,"depth":86,"text":246},{"id":287,"depth":86,"text":288},{"id":316,"depth":86,"text":317},{"id":347,"depth":86,"text":348},{"id":399,"depth":68,"text":399},{"一直想有块完全属于自己的\"互联网自留地\"，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":430},{"title":5,"description":433},{"id":725,"title":726,"body":727,"categories":430,"cover":1285,"date":1286,"description":1287,"extension":434,"meta":1288,"navigation":436,"path":1289,"seo":1290,"stem":1291,"tags":430,"__hash__":1292},"posts\u002Fposts\u002Fhexo-to-nuxt-migration.md","从 Hexo 到 Nuxt：博客迁移全记录",{"type":7,"value":728,"toc":1261},[729,733,736,740,743,750,753,763,765,769,776,865,869,876,880,895,897,900,904,915,923,934,938,944,950,969,973,976,980,989,991,994,998,1004,1017,1021,1027,1044,1047,1127,1130,1136,1159,1224,1227,1230,1241,1244,1246,1249,1252,1258],[10,730,732],{"id":731},"为什么要离开-hexo","为什么要离开 Hexo？",[15,734,735],{},"Hexo + Butterfly 颜值没得说，Butterfly 的设计审美我很喜欢。但随着博客越折腾越复杂，痛点逐渐暴露出来。",[19,737,739],{"id":738},"pjax-与-pwa-的相爱相杀","PJAX 与 PWA 的相爱相杀",[15,741,742],{},"Butterfly 内置了 PJAX 局部刷新和 PWA 离线缓存。单独看每个都是好东西，合在一起就变成了玄学——发布新文章后，读者看到的永远是旧版。无痕模式打开是新的，正常模式死活不刷新。",[15,744,745,746,749],{},"问题根源在于：",[33,747,748],{},"Hexo 生成的静态页面是黑盒，精确控制缓存行为非常困难","。Service Worker 缓存策略、CDN 边缘缓存、浏览器缓存层层叠加，调试起来如同开盲盒。",[19,751,752],{"id":752},"构建速度与生态",[15,754,755,756,758,759,762],{},"文章数量上来之后，",[55,757,325],{}," 的时间肉眼可见地变长。Hexo 的机制是",[33,760,761],{},"全量生成","，每次都要把所有页面重新渲染一遍。插件生态虽然丰富，但质量参差不齐，主题和插件之间的耦合经常让人头疼。",[161,764],{},[10,766,768],{"id":767},"为什么选-nuxt","为什么选 Nuxt？",[15,770,771,772,775],{},"看过 VitePress、Astro、Next.js，最终选了 ",[33,773,774],{},"Nuxt 4 SSG","。核心考量：",[777,778,779,794],"table",{},[780,781,782],"thead",{},[783,784,785,788,791],"tr",{},[786,787],"th",{},[786,789,790],{},"Hexo",[786,792,793],{},"Nuxt 4",[795,796,797,811,824,837,850],"tbody",{},[783,798,799,805,808],{},[800,801,802],"td",{},[33,803,804],{},"构建机制",[800,806,807],{},"CLI 全量生成静态文件",[800,809,810],{},"Nitro 引擎预渲染 + 增量构建",[783,812,813,818,821],{},[800,814,815],{},[33,816,817],{},"模板\u002F组件",[800,819,820],{},"EJS\u002FPug，无组件化",[800,822,823],{},"Vue 3 组件，自动导入",[783,825,826,831,834],{},[800,827,828],{},[33,829,830],{},"内容管理",[800,832,833],{},"front-matter + markdown",[800,835,836],{},"@nuxt\u002Fcontent v3，类型安全查询",[783,838,839,844,847],{},[800,840,841],{},[33,842,843],{},"交互",[800,845,846],{},"内联 script，靠 CDN",[800,848,849],{},"完整的 Vue 响应式生态",[783,851,852,857,862],{},[800,853,854],{},[33,855,856],{},"路由",[800,858,859,861],{},[55,860,142],{}," permalink 配置",[800,863,864],{},"文件系统路由，动态参数",[19,866,868],{"id":867},"最大的吸引力内容格式不变","最大的吸引力：内容格式不变",[15,870,871,872,875],{},"@nuxt\u002Fcontent v3 直接读取 markdown，frontmatter 字段几乎不用改。这意味着",[33,873,874],{},"迁移成本大头不在内容，只在工程搭建","。所有文章原封不动搬过来就能用。",[19,877,879],{"id":878},"vue-生态的开发体验","Vue 生态的开发体验",[15,881,882,883,886,887,890,891,894],{},"组件化意味着每个 UI 单元独立、可复用、可测试。",[55,884,885],{},"useAsyncData"," + ",[55,888,889],{},"queryCollection"," 这套数据获取模式比 Hexo 的散落配置清晰太多。写交互不需要 hack，不需要往 HTML 里塞 ",[55,892,893],{},"\u003Cscript>"," 标签。",[161,896],{},[10,898,899],{"id":899},"迁移过程",[19,901,903],{"id":902},"内容层零改动搬过来","内容层：零改动搬过来",[15,905,906,907,910,911,914],{},"所有 markdown 文件从 Hexo 的 ",[55,908,909],{},"source\u002F_posts\u002F"," 复制到 Nuxt 的 ",[55,912,913],{},"content\u002Fposts\u002F","。frontmatter 稍微做了统一：",[48,916,921],{"className":917,"code":919,"language":920},[918],"language-text","Hexo:        title, date, tags, categories, cover\nNuxt:        title, date, description, categories, cover\n","text",[55,922,919],{"__ignoreMap":53},[15,924,925,926,929,930,933],{},"多了 ",[55,927,928],{},"description"," 字段用于 SEO 和列表摘要，暂时去掉 ",[55,931,932],{},"tags","。内容正文一个字没改。",[19,935,937],{"id":936},"路由从-permalink-到文件系统","路由：从 permalink 到文件系统",[15,939,940,941,943],{},"Hexo 的 URL 靠 ",[55,942,142],{}," 里的 permalink 模式定义。Nuxt 直接用文件系统路由：",[48,945,948],{"className":946,"code":947,"language":920},[918],"Hexo:  \u002Fposts\u002Fhexo-setup\u002F\nNuxt:  \u002Fposts\u002Fhexo-to-nuxt-migration\u002F\n",[55,949,947],{"__ignoreMap":53},[15,951,952,953,956,957,960,961,964,965,968],{},"Nuxt 路由由 ",[55,954,955],{},"pages\u002F"," 目录结构决定，",[55,958,959],{},"posts\u002F[...slug].vue"," 处理所有文章详情页。",[55,962,963],{},"trailingSlash: true"," 保证 URL 一致性，",[55,966,967],{},"[...slug].vue"," 兜底 404。",[19,970,972],{"id":971},"设计系统从-stylus-到-css-自定义属性","设计系统：从 Stylus 到 CSS 自定义属性",[15,974,975],{},"Hexo + Butterfly 用 Stylus 预处理器定义主题变量，迁移后直接使用 CSS 自定义属性，不需要编译，主题切换是即时的。",[19,977,979],{"id":978},"部署ci-保持不变","部署：CI 保持不变",[15,981,982,983,985,986,284],{},"GitHub Actions 流程基本沿用原配置，只将构建命令从 ",[55,984,325],{}," 替换为 ",[55,987,988],{},"npm run build",[161,990],{},[10,992,993],{"id":993},"架构对比",[19,995,997],{"id":996},"hexo-的架构","Hexo 的架构",[48,999,1002],{"className":1000,"code":1001,"language":920},[918],"Hexo CLI\n  ├── _config.yml              # 全局配置\n  ├── themes\u002Fbutterfly\u002F        # 主题（模板 + 样式 + 脚本）\n  │   ├── _config.yml         # 主题配置\n  │   ├── layout\u002F             # EJS 模板\n  │   └── source\u002F             # 静态资源\n  ├── source\u002F_posts\u002F           # 文章 markdown\n  └── public\u002F                  # 生成输出\n",[55,1003,1001],{"__ignoreMap":53},[15,1005,1006,1007,1010,1011,1013,1014,1016],{},"Hexo 是",[33,1008,1009],{},"生成器模式","：CLI 触发后读取配置 + 文章 + 主题，全量渲染成 HTML。主题和内容分离，但数据流是隐式的——配置散落在 ",[55,1012,142],{},"、",[55,1015,271],{},"、frontmatter 三处，模板里用不同变量名访问。",[19,1018,1020],{"id":1019},"nuxt-的架构","Nuxt 的架构",[48,1022,1025],{"className":1023,"code":1024,"language":920},[918],"Nuxt App\n  ├── pages\u002F                   # 文件系统路由 → SSG 预渲染\n  ├── components\u002F              # Vue 组件（自动导入）\n  ├── content\u002F                 # Markdown 内容（@nuxt\u002Fcontent）\n  │   ├── posts\u002F              # 博客文章集合\n  │   └── pages\u002F              # 独立页面集合\n  ├── composables\u002F             # 可组合逻辑（useTheme, useSite）\n  ├── assets\u002Fcss\u002F              # 设计系统（tokens + base）\n  └── Nitro 引擎\n      ├── 预渲染器              # crawlLinks 自动发现页面\n      └── 输出 .output\u002Fpublic\u002F # 纯静态文件\n",[55,1026,1024],{"__ignoreMap":53},[15,1028,1029,1030,1033,1034,1036,1037,1039,1040,1043],{},"Nuxt 是",[33,1031,1032],{},"框架模式","：内容、组件、路由、构建都被统一管理。数据流是显式的——",[55,1035,889],{}," 查询内容，",[55,1038,885],{}," 管理异步数据，",[55,1041,1042],{},"useTheme()"," 封装主题逻辑。每一层职责清晰。",[19,1045,1046],{"id":1046},"数据流对比",[777,1048,1049,1061],{},[780,1050,1051],{},[783,1052,1053,1056,1058],{},[786,1054,1055],{},"环节",[786,1057,790],{},[786,1059,1060],{},"Nuxt",[795,1062,1063,1076,1089,1105,1116],{},[783,1064,1065,1068,1071],{},[800,1066,1067],{},"内容获取",[800,1069,1070],{},"读文件 → 模板注入变量",[800,1072,1073],{},[55,1074,1075],{},"queryCollection('posts').all()",[783,1077,1078,1081,1084],{},[800,1079,1080],{},"数据管理",[800,1082,1083],{},"无，模板即数据",[800,1085,1086,1088],{},[55,1087,885],{}," + 响应式",[783,1090,1091,1094,1099],{},[800,1092,1093],{},"站点配置",[800,1095,1096,1098],{},[55,1097,142],{}," + 主题 config",[800,1100,1101,1104],{},[55,1102,1103],{},"useSite()"," composable",[783,1106,1107,1110,1113],{},[800,1108,1109],{},"主题",[800,1111,1112],{},"Stylus 变量 → 编译到 CSS",[800,1114,1115],{},"CSS 自定义属性 → 运行时切换",[783,1117,1118,1121,1124],{},[800,1119,1120],{},"交互状态",[800,1122,1123],{},"全局变量 + DOM 操作",[800,1125,1126],{},"Vue 响应式 + composables",[19,1128,1129],{"id":1129},"预渲染策略",[15,1131,1132,1133,1135],{},"Hexo 每次 ",[55,1134,325],{}," 都是全量重新生成所有页面。文章多了之后，构建时间变得不可忽视。",[15,1137,1138,1139,1142,1143,1146,1147,1150,1151,1154,1155,1158],{},"Nitro 的 ",[55,1140,1141],{},"crawlLinks: true"," 从 seed routes 出发，按 ",[55,1144,1145],{},"\u003Ca href>"," 链接爬取需要预渲染的页面，只渲染可被发现的页面。但 ",[33,1148,1149],{},"crawlLinks 不能替代显式 routes 声明","——如果导航是客户端 JS 动态生成的，或某些页面没有直接的 ",[55,1152,1153],{},"\u003Ca>"," 链接指向，crawlLinks 可能漏掉它们。在 ",[55,1156,1157],{},"nitro.prerender.routes"," 里显式声明关键路由是好习惯：",[48,1160,1164],{"className":1161,"code":1162,"language":1163,"meta":53,"style":53},"language-ts shiki shiki-themes one-dark-pro","prerender: {\n  crawlLinks: true,\n  routes: ['\u002F', '\u002Fabout', '\u002Fposts', '\u002Flinks'],\n}\n","ts",[55,1165,1166,1175,1189,1219],{"__ignoreMap":53},[58,1167,1168,1172],{"class":60,"line":61},[58,1169,1171],{"class":1170},"sVyAn","prerender",[58,1173,1174],{"class":95},": {\n",[58,1176,1177,1180,1183,1186],{"class":60,"line":68},[58,1178,1179],{"class":1170},"  crawlLinks",[58,1181,1182],{"class":95},": ",[58,1184,1185],{"class":79},"true",[58,1187,1188],{"class":95},",\n",[58,1190,1191,1194,1197,1200,1203,1206,1208,1211,1213,1216],{"class":60,"line":86},[58,1192,1193],{"class":1170},"  routes",[58,1195,1196],{"class":95},": [",[58,1198,1199],{"class":75},"'\u002F'",[58,1201,1202],{"class":95},", ",[58,1204,1205],{"class":75},"'\u002Fabout'",[58,1207,1202],{"class":95},[58,1209,1210],{"class":75},"'\u002Fposts'",[58,1212,1202],{"class":95},[58,1214,1215],{"class":75},"'\u002Flinks'",[58,1217,1218],{"class":95},"],\n",[58,1220,1221],{"class":60,"line":106},[58,1222,1223],{"class":95},"}\n",[10,1225,1226],{"id":1226},"迁移成本远低于预期",[15,1228,1229],{},"说实话出发前还挺忐忑的，担心工程量会很大。结果发现 markdown 内容零改动，核心工作量只在：",[370,1231,1232,1235,1238],{},[30,1233,1234],{},"搭建 Nuxt 项目骨架",[30,1236,1237],{},"设计 CSS token 系统",[30,1239,1240],{},"编写几个核心组件",[15,1242,1243],{},"借助 Claude Code 辅助，两天完成。框架升级收益是长期的，成本是一次性的。",[161,1245],{},[10,1247,1248],{"id":1248},"总结",[15,1250,1251],{},"迁移之前，在折腾 Hexo 各种\"魔改\"时经常想——\"要是能直接用 Vue 写就好了\"。Node.js 生态的 SSG 方案已经非常成熟，对于内容驱动的博客站点，用 Nuxt + @nuxt\u002Fcontent 几乎是最佳实践。",[15,1253,1254,1257],{},[33,1255,1256],{},"如果你的博客内容主要是 markdown，而你又有点前端基础，迁移到 Nuxt 绝对值得。"," 内容不用动，开发体验质变，交互能力完全释放。",[410,1259,1260],{},"html pre.shiki code .sVyAn, html code.shiki .sVyAn{--shiki-default:#E06C75}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":53,"searchDepth":68,"depth":68,"links":1262},[1263,1267,1271,1277,1283,1284],{"id":731,"depth":68,"text":732,"children":1264},[1265,1266],{"id":738,"depth":86,"text":739},{"id":752,"depth":86,"text":752},{"id":767,"depth":68,"text":768,"children":1268},[1269,1270],{"id":867,"depth":86,"text":868},{"id":878,"depth":86,"text":879},{"id":899,"depth":68,"text":899,"children":1272},[1273,1274,1275,1276],{"id":902,"depth":86,"text":903},{"id":936,"depth":86,"text":937},{"id":971,"depth":86,"text":972},{"id":978,"depth":86,"text":979},{"id":993,"depth":68,"text":993,"children":1278},[1279,1280,1281,1282],{"id":996,"depth":86,"text":997},{"id":1019,"depth":86,"text":1020},{"id":1046,"depth":86,"text":1046},{"id":1129,"depth":86,"text":1129},{"id":1226,"depth":68,"text":1226},{"id":1248,"depth":68,"text":1248},"\u002Fimg\u002Fpostcard2.jpg","2026-05-03","记录将个人博客从 Hexo + Butterfly 迁移到 Nuxt 4 SSG 的过程和体验",{},"\u002Fposts\u002Fhexo-to-nuxt-migration",{"title":726,"description":1287},"posts\u002Fhexo-to-nuxt-migration","WLPbeyVHb4dJBAwiXKoGJw3ZexwamFKVaRB231SLgKk",1777896646832]