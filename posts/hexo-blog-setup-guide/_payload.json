[{"data":1,"prerenderedAt":737},["ShallowReactive",2],{"post-hexo-blog-setup-guide":3,"all-posts":446},{"id":4,"title":5,"body":6,"categories":435,"cover":436,"date":437,"description":438,"extension":439,"meta":440,"navigation":441,"path":442,"seo":443,"stem":444,"tags":435,"__hash__":445},"posts\u002Fposts\u002Fhexo-blog-setup-guide.md","Hexo 博客建站实录",{"type":7,"value":8,"toc":418},"minimark",[9,14,18,23,26,43,47,50,123,130,144,167,170,174,177,181,192,218,222,233,235,239,242,246,288,292,317,321,343,347,368,399,401,405,408,411,414],[10,11,13],"h2",{"id":12},"️-折腾第一步让博客先跑起来","🛠️ 折腾第一步：让博客先跑起来",[15,16,17],"p",{},"建站就像搭积木，环境弄好，剩下就是顺水推舟。",[19,20,22],"h3",{"id":21},"_1-搞定基础环境","1. 搞定基础环境",[15,24,25],{},"备好两样工具：",[27,28,29,37],"ul",{},[30,31,32,36],"li",{},[33,34,35],"strong",{},"Git & GitHub","：做版本控制和网页托管。",[30,38,39,42],{},[33,40,41],{},"Node.js","：Hexo 的运行基础，官网下个稳定版装上就行。",[19,44,46],{"id":45},"_2-初始化-hexo-与主题","2. 初始化 Hexo 与主题",[15,48,49],{},"打开终端，敲几行命令搭好骨架：",[51,52,57],"pre",{"className":53,"code":54,"language":55,"meta":56,"style":56},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash","",[58,59,60,69,87,107],"code",{"__ignoreMap":56},[61,62,65],"span",{"class":63,"line":64},"line",1,[61,66,68],{"class":67},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[61,70,72,76,80,84],{"class":63,"line":71},2,[61,73,75],{"class":74},"sVbv2","npm",[61,77,79],{"class":78},"subq3"," install",[61,81,83],{"class":82},"sVC51"," -g",[61,85,86],{"class":78}," hexo-cli\n",[61,88,90,93,96,100,104],{"class":63,"line":89},3,[61,91,92],{"class":74},"mkdir",[61,94,95],{"class":78}," your_blog",[61,97,99],{"class":98},"sn6KH"," && ",[61,101,103],{"class":102},"sjrmR","cd",[61,105,106],{"class":78}," your_blog\n",[61,108,110,113,116,118,120],{"class":63,"line":109},4,[61,111,112],{"class":74},"hexo",[61,114,115],{"class":78}," init",[61,117,99],{"class":98},[61,119,75],{"class":74},[61,121,122],{"class":78}," install\n",[15,124,125,126,129],{},"接着装上 ",[33,127,128],{},"Butterfly"," 主题：",[51,131,133],{"className":53,"code":132,"language":55,"meta":56,"style":56},"npm install hexo-theme-butterfly\n",[58,134,135],{"__ignoreMap":56},[61,136,137,139,141],{"class":63,"line":64},[61,138,75],{"class":74},[61,140,79],{"class":78},[61,142,143],{"class":78}," hexo-theme-butterfly\n",[15,145,146,147,150,151,154,155,158,159,162,163,166],{},"修改根目录 ",[58,148,149],{},"_config.yml","，把 ",[58,152,153],{},"theme"," 设为 ",[58,156,157],{},"butterfly","。终端跑一句 ",[58,160,161],{},"hexo s","，打开 ",[58,164,165],{},"http:\u002F\u002Flocalhost:4000","——看到雏形加载出来的那一刻，还是挺有成就感的！",[168,169],"hr",{},[10,171,173],{"id":172},"部署上线让世界看到你的博客","🚀 部署上线：让世界看到你的博客",[15,175,176],{},"本地自嗨不够，得把它挂到网上。",[19,178,180],{"id":179},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[15,182,183,184,187,188,191],{},"装好 Git 部署插件 ",[58,185,186],{},"hexo-deployer-git","，在配置文件填上 GitHub 仓库地址和分支（推荐 ",[58,189,190],{},"main","）。然后执行经典的“三连”命令推送到云端：",[51,193,195],{"className":53,"code":194,"language":55,"meta":56,"style":56},"hexo clean && hexo g && hexo d \n",[58,196,197],{"__ignoreMap":56},[61,198,199,201,204,206,208,211,213,215],{"class":63,"line":64},[61,200,112],{"class":74},[61,202,203],{"class":78}," clean",[61,205,99],{"class":98},[61,207,112],{"class":74},[61,209,210],{"class":78}," g",[61,212,99],{"class":98},[61,214,112],{"class":74},[61,216,217],{"class":78}," d\n",[19,219,221],{"id":220},"_2-进阶玩法vercel-与评论系统部署","2. 进阶玩法：Vercel 与评论系统部署",[15,223,224,225,228,229,232],{},"如果想要国内访问更快，强烈推荐用 ",[33,226,227],{},"Vercel"," 托管静态页面。\n另外，我后来还折腾了 ",[33,230,231],{},"Twikoo"," 评论系统，同样用 Vercel 部署云函数。免费好用，不用操心服务器，完美契合静态博客。",[168,234],{},[10,236,238],{"id":237},"魔改与避坑指南那些折磨过我的-bug","🔨 魔改与避坑指南：那些折磨过我的 Bug",[15,240,241],{},"跟着教程走一帆风顺，自己动手加特效（比如轮播图、Aplayer 音乐）时，玄学问题就来了。盘点几个大坑：",[19,243,245],{"id":244},"坑一静态资源加载失败cdn-之痛","❌ 坑一：静态资源加载失败（CDN 之痛）",[15,247,248,251,252,255,256,259,260,263,264,267,268,271,272,275,276,281,282,287],{},[33,249,250],{},"现象","：本地跑得好好的，一部署线上控制台就一片红 ",[58,253,254],{},"ERR_ABORTED","，排版错乱、图标变方块。\n",[33,257,258],{},"原因","：老教程推荐的国内\u002F小众 CDN（如 ",[58,261,262],{},"tianli0.top","、",[58,265,266],{},"bootcdn","）很多已停运，或在 GitHub\u002FVercel 环境被拦截。\n",[33,269,270],{},"✅ 解决","：果断弃用！在 ",[58,273,274],{},"_config.butterfly.yml"," 里，把第三方资源统统换成国际大厂 CDN，比如 ",[33,277,278],{},[58,279,280],{},"unpkg.com","（最稳妥）或 ",[33,283,284],{},[58,285,286],{},"cdn.jsdelivr.net\u002Fnpm\u002F","。",[19,289,291],{"id":290},"坑二github-actions-自动部署页面不更新","❌ 坑二：GitHub Actions 自动部署页面不更新",[15,293,294,296,297,299,300,302,303,306,307,309,310,313,314,316],{},[33,295,250],{},"：Workflow 自动构建并推送到 ",[58,298,190],{}," 分支显示成功，但网页死活不更新。\n",[33,301,258],{},"：GitHub Pages 默认可能还在傻傻读取旧的 ",[58,304,305],{},"gh-pages"," 分支。\n",[33,308,270],{},"：去 GitHub 仓库的 ",[33,311,312],{},"Settings -> Pages","，把部署分支手动改为 ",[58,315,190],{},"，保存稍等片刻即可。",[19,318,320],{"id":319},"坑三vercel-部署重复构建报错","❌ 坑三：Vercel 部署重复构建报错",[15,322,323,325,326,328,329,331,332,334,335,338,339,342],{},[33,324,250],{},"：把跑过 Actions 的 ",[58,327,190],{}," 分支导入 Vercel，构建卡住甚至报错。\n",[33,330,258],{},"：Actions 已生成纯静态文件，但 Vercel 发现是 Hexo 项目，又自作多情帮你跑了一遍构建命令。\n",[33,333,270],{},"：在 Vercel 项目设置里找到 ",[33,336,337],{},"Build Command","，打开 Override 并",[33,340,341],{},"留空","。让 Vercel 把它当纯静态站点直接部署，清爽快速。",[19,344,346],{"id":345},"坑四本地预览和线上效果不一致最恶心的玄学","❌ 坑四：本地预览和线上效果不一致（最恶心的玄学）",[15,348,349,351,352,354,355,357,358,361,362,365,366,351],{},[33,350,250],{},"：",[58,353,161],{}," 本地看一切完美，推送到线上后，发现样式没变、自定义的特效出不来，甚至页面错乱。\n",[33,356,258],{},"：这通常和 ",[33,359,360],{},"缓存（浏览器\u002FCDN\u002FPWA 服务端缓存）"," 或 ",[33,363,364],{},"PJAX 异步加载"," 有关。本地是即时响应的，而线上部署后，浏览器或 JS 服务端（Service Worker）会强缓存旧文件。另外，如果加了自定义 JS 特效，由于 Butterfly 开启了 PJAX 无刷新跳转，换页时 JS 可能不会重新执行。\n",[33,367,270],{},[369,370,371,389],"ol",{},[30,372,373,376,377,380,381,384,385,388],{},[33,374,375],{},"清缓存","：遇事不决先 ",[58,378,379],{},"hexo clean","，线上调试务必用浏览器的 ",[33,382,383],{},"无痕模式"," 或强刷（",[58,386,387],{},"Ctrl + F5","）。如果开了 PWA，记得去控制台清理 Service Worker。",[30,390,391,394,395,398],{},[33,392,393],{},"PJAX 适配","：如果是自定义 JS 特效失效，要把 JS 代码包在 PJAX 重载事件里（如 ",[58,396,397],{},"document.addEventListener('pjax:complete', function() {...})","），确保每次切页都能重新触发。",[168,400],{},[10,402,404],{"id":403},"最终成果与碎碎念","💡 最终成果与碎碎念",[15,406,407],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[15,409,410],{},"建站最大的门槛其实是**“开始动手”**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[15,412,413],{},"折腾不息，共勉！",[415,416,417],"style",{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":56,"searchDepth":71,"depth":71,"links":419},[420,424,428,434],{"id":12,"depth":71,"text":13,"children":421},[422,423],{"id":21,"depth":89,"text":22},{"id":45,"depth":89,"text":46},{"id":172,"depth":71,"text":173,"children":425},[426,427],{"id":179,"depth":89,"text":180},{"id":220,"depth":89,"text":221},{"id":237,"depth":71,"text":238,"children":429},[430,431,432,433],{"id":244,"depth":89,"text":245},{"id":290,"depth":89,"text":291},{"id":319,"depth":89,"text":320},{"id":345,"depth":89,"text":346},{"id":403,"depth":71,"text":404},null,"\u002Fimg\u002Fpostcard1.jpg","2026-04-18","记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。","md",{"一直想有块完全属于自己的“互联网自留地”，不受平台限制，能自由定义细节。比了一圈，最后敲定了轻快高颜值的组合：**Hexo** + **Butterfly** 主题。\n下面聊聊我从零搭建、魔改到上线的真实体验，顺便盘点那些让人抓狂的坑，帮大家少走弯路。":435},true,"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":5,"description":438},"posts\u002Fhexo-blog-setup-guide","HQU7S1_SXw8u818bsiWJu6Q2b1x6PS2Vk5Fv85HCetU",[447,717],{"id":4,"title":5,"body":448,"categories":435,"cover":436,"date":437,"description":438,"extension":439,"meta":715,"navigation":441,"path":442,"seo":716,"stem":444,"tags":435,"__hash__":445},{"type":7,"value":449,"toc":698},[450,452,454,456,458,468,470,472,514,518,530,542,544,546,548,550,556,578,580,586,588,590,592,594,618,620,636,638,652,654,668,686,688,690,692,694,696],[10,451,13],{"id":12},[15,453,17],{},[19,455,22],{"id":21},[15,457,25],{},[27,459,460,464],{},[30,461,462,36],{},[33,463,35],{},[30,465,466,42],{},[33,467,41],{},[19,469,46],{"id":45},[15,471,49],{},[51,473,474],{"className":53,"code":54,"language":55,"meta":56,"style":56},[58,475,476,480,490,502],{"__ignoreMap":56},[61,477,478],{"class":63,"line":64},[61,479,68],{"class":67},[61,481,482,484,486,488],{"class":63,"line":71},[61,483,75],{"class":74},[61,485,79],{"class":78},[61,487,83],{"class":82},[61,489,86],{"class":78},[61,491,492,494,496,498,500],{"class":63,"line":89},[61,493,92],{"class":74},[61,495,95],{"class":78},[61,497,99],{"class":98},[61,499,103],{"class":102},[61,501,106],{"class":78},[61,503,504,506,508,510,512],{"class":63,"line":109},[61,505,112],{"class":74},[61,507,115],{"class":78},[61,509,99],{"class":98},[61,511,75],{"class":74},[61,513,122],{"class":78},[15,515,125,516,129],{},[33,517,128],{},[51,519,520],{"className":53,"code":132,"language":55,"meta":56,"style":56},[58,521,522],{"__ignoreMap":56},[61,523,524,526,528],{"class":63,"line":64},[61,525,75],{"class":74},[61,527,79],{"class":78},[61,529,143],{"class":78},[15,531,146,532,150,534,154,536,158,538,162,540,166],{},[58,533,149],{},[58,