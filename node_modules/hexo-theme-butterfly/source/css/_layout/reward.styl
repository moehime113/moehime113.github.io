.post-reward
  position: relative
  margin-top: 3rem
  width: 100%
  text-align: center

  .reward-button
    position: relative
    display: inline-block
    padding: .35rem 1.35rem
    background: var(--btn-bg)
    color: var(--btn-color)
    transition: all .4s
    border-radius: 30px
    font-weight: 600
    letter-spacing: .4px
    box-shadow: 0 8px 20px rgba(0, 0, 0, .08)

    &:hover
      box-shadow: inset 20em 0 0 0 var(--btn-hover-color)
      transform: translateY(-1px)

      .reward-main
        display: flex

    .reward-main
      position: absolute
      bottom: 40px
      left: 50%
      transform: translateX(-50%)
      z-index: 100
      display: none
      padding: 0 0 15px
      width: auto

      .reward-all
        display: flex
        justify-content: center
        align-items: flex-start
        gap: .4rem
        margin: 0
        padding: 1rem .5rem
        border-radius: 12px
        background: var(--reward-pop)

        &:before
          position: absolute
          bottom: -10px
          left: 0
          width: 100%
          height: 20px
          content: ''

        &:after
          position: absolute
          right: 0
          bottom: 2px
          left: 0
          margin: 0 auto
          width: 0
          height: 0
          border-top: 13px solid var(--reward-pop)
          border-right: 13px solid transparent
          border-left: 13px solid transparent
          content: ''

        .reward-item
          display: inline-block
          width: 130px
          padding: 0
          list-style-type: none
          text-align: center
          vertical-align: top

          img
            width: 130px
            height: 130px
            object-fit: cover

          .post-qr-code-desc
            display: none
