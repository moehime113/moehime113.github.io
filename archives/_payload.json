Hexo 与主题",[15,278,279],{},"打开终端，敲几行命令搭好骨架：",[281,282,286],"pre",{"className":283,"code":284,"language":285,"meta":115,"style":115},"language-bash shiki shiki-themes one-dark-pro","# 安装 hexo-cli，初始化博客目录\nnpm install -g hexo-cli\nmkdir your_blog && cd your_blog\nhexo init && npm install\n","bash",[95,287,288,297,314,333],{"__ignoreMap":115},[289,290,293],"span",{"class":291,"line":292},"line",1,[289,294,296],{"class":295},"sV9Aq","# 安装 hexo-cli，初始化博客目录\n",[289,298,299,303,307,311],{"class":291,"line":116},[289,300,302],{"class":301},"sVbv2","npm",[289,304,306],{"class":305},"subq3"," install",[289,308,310],{"class":309},"sVC51"," -g",[289,312,313],{"class":305}," hexo-cli\n",[289,315,316,319,322,326,330],{"class":291,"line":191},[289,317,318],{"class":301},"mkdir",[289,320,321],{"class":305}," your_blog",[289,323,325],{"class":324},"sn6KH"," && ",[289,327,329],{"class":328},"sjrmR","cd",[289,331,332],{"class":305}," your_blog\n",[289,334,335,338,341,343,345],{"class":291,"line":171},[289,336,337],{"class":301},"hexo",[289,339,340],{"class":305}," init",[289,342,325],{"class":324},[289,344,302],{"class":301},[289,346,347],{"class":305}," install\n",[15,349,350,351,353],{},"接着装上 ",[228,352,234],{}," 主题：",[281,355,357],{"className":283,"code":356,"language":285,"meta":115,"style":115},"npm install hexo-theme-butterfly\n",[95,358,359],{"__ignoreMap":115},[289,360,361,363,365],{"class":291,"line":292},[289,362,302],{"class":301},[289,364,306],{"class":305},[289,366,367],{"class":305}," hexo-theme-butterfly\n",[15,369,370,371,374,375,378,379,382,383,386,387,390],{},"修改根目录 ",[95,372,373],{},"_config.yml","，把 ",[95,376,377],{},"theme"," 设为 ",[95,380,381],{},"butterfly","。终端跑一句 ",[95,384,385],{},"hexo s","，打开 ",[95,388,389],{},"http:\u002F\u002Flocalhost:4000","——看到雏形加载出来的那一刻，还是挺有成就感的！",[240,392],{},[35,394,396],{"id":395},"部署上线让世界看到你的博客","🚀 部署上线：让世界看到你的博客",[15,398,399],{},"本地自嗨不够，得把它挂到网上。",[250,401,403],{"id":402},"_1-部署到-github-pages","1. 部署到 GitHub Pages",[15,405,406,407,410,411,414],{},"装好 Git 部署插件 ",[95,408,409],{},"hexo-deployer-git","，在配置文件填上 GitHub 仓库地址和分支（推荐 ",[95,412,413],{},"main","）。然后执行经典的“三连”命令推送到云端：",[281,416,418],{"className":283,"code":417,"language":285,"meta":115,"style":115},"hexo clean && hexo g && hexo d \n",[95,419,420],{"__ignoreMap":115},[289,421,422,424,427,429,431,434,436,438],{"class":291,"line":292},[289,423,337],{"class":301},[289,425,426],{"class":305}," clean",[289,428,325],{"class":324},[289,430,337],{"class":301},[289,432,433],{"class":305}," g",[289,435,325],{"class":324},[289,437,337],{"class":301},[289,439,440],{"class":305}," d\n",[250,442,444],{"id":443},"_2-进阶玩法vercel-与评论系统部署","2. 进阶玩法：Vercel 与评论系统部署",[15,446,447,448,451,452,455],{},"如果想要国内访问更快，强烈推荐用 ",[228,449,450],{},"Vercel"," 托管静态页面。\n另外，我后来还折腾了 ",[228,453,454],{},"Twikoo"," 评论系统，同样用 Vercel 部署云函数。免费好用，不用操心服务器，完美契合静态博客。",[240,457],{},[35,459,461],{"id":460},"魔改与避坑指南那些折磨过我的-bug","🔨 魔改与避坑指南：那些折磨过我的 Bug",[15,463,464],{},"跟着教程走一帆风顺，自己动手加特效（比如轮播图、Aplayer 音乐）时，玄学问题就来了。盘点几个大坑：",[250,466,468],{"id":467},"坑一静态资源加载失败cdn-之痛","❌ 坑一：静态资源加载失败（CDN 之痛）",[15,470,471,474,475,478,479,482,483,486,487,490,491,494,495,498,499,504,505,510],{},[228,472,473],{},"现象","：本地跑得好好的，一部署线上控制台就一片红 ",[95,476,477],{},"ERR_ABORTED","，排版错乱、图标变方块。\n",[228,480,481],{},"原因","：老教程推荐的国内\u002F小众 CDN（如 ",[95,484,485],{},"tianli0.top","、",[95,488,489],{},"bootcdn","）很多已停运，或在 GitHub\u002FVercel 环境被拦截。\n",[228,492,493],{},"✅ 解决","：果断弃用！在 ",[95,496,497],{},"_config.butterfly.yml"," 里，把第三方资源统统换成国际大厂 CDN，比如 ",[228,500,501],{},[95,502,503],{},"unpkg.com","（最稳妥）或 ",[228,506,507],{},[95,508,509],{},"cdn.jsdelivr.net\u002Fnpm\u002F","。",[250,512,514],{"id":513},"坑二github-actions-自动部署页面不更新","❌ 坑二：GitHub Actions 自动部署页面不更新",[15,516,517,519,520,522,523,525,526,529,530,532,533,536,537,539],{},[228,518,473],{},"：Workflow 自动构建并推送到 ",[95,521,413],{}," 分支显示成功，但网页死活不更新。\n",[228,524,481],{},"：GitHub Pages 默认可能还在傻傻读取旧的 ",[95,527,528],{},"gh-pages"," 分支。\n",[228,531,493],{},"：去 GitHub 仓库的 ",[228,534,535],{},"Settings -> Pages","，把部署分支手动改为 ",[95,538,413],{},"，保存稍等片刻即可。",[250,541,543],{"id":542},"坑三vercel-部署重复构建报错","❌ 坑三：Vercel 部署重复构建报错",[15,545,546,548,549,551,552,554,555,557,558,561,562,565],{},[228,547,473],{},"：把跑过 Actions 的 ",[95,550,413],{}," 分支导入 Vercel，构建卡住甚至报错。\n",[228,553,481],{},"：Actions 已生成纯静态文件，但 Vercel 发现是 Hexo 项目，又自作多情帮你跑了一遍构建命令。\n",[228,556,493],{},"：在 Vercel 项目设置里找到 ",[228,559,560],{},"Build Command","，打开 Override 并",[228,563,564],{},"留空","。让 Vercel 把它当纯静态站点直接部署，清爽快速。",[250,567,569],{"id":568},"坑四本地预览和线上效果不一致最恶心的玄学","❌ 坑四：本地预览和线上效果不一致（最恶心的玄学）",[15,571,572,574,575,577,578,580,581,584,585,588,589,574],{},[228,573,473],{},"：",[95,576,385],{}," 本地看一切完美，推送到线上后，发现样式没变、自定义的特效出不来，甚至页面错乱。\n",[228,579,481],{},"：这通常和 ",[228,582,583],{},"缓存（浏览器\u002FCDN\u002FPWA 服务端缓存）"," 或 ",[228,586,587],{},"PJAX 异步加载"," 有关。本地是即时响应的，而线上部署后，浏览器或 JS 服务端（Service Worker）会强缓存旧文件。另外，如果加了自定义 JS 特效，由于 Butterfly 开启了 PJAX 无刷新跳转，换页时 JS 可能不会重新执行。\n",[228,590,493],{},[592,593,594,612],"ol",{},[261,595,596,599,600,603,604,607,608,611],{},[228,597,598],{},"清缓存","：遇事不决先 ",[95,601,602],{},"hexo clean","，线上调试务必用浏览器的 ",[228,605,606],{},"无痕模式"," 或强刷（",[95,609,610],{},"Ctrl + F5","）。如果开了 PWA，记得去控制台清理 Service Worker。",[261,613,614,617,618,621],{},[228,615,616],{},"PJAX 适配","：如果是自定义 JS 特效失效，要把 JS 代码包在 PJAX 重载事件里（如 ",[95,619,620],{},"document.addEventListener('pjax:complete', function() {...})","），确保每次切页都能重新触发。",[240,623],{},[35,625,627],{"id":626},"最终成果与碎碎念","💡 最终成果与碎碎念",[15,629,630],{},"折腾一圈，看着博客从简陋页面一点点加上昼夜切换、音乐播放、评论留言，变成现在的顺眼模样，所有头秃时刻都值了。",[15,632,633],{},"建站最大的门槛其实是**“开始动手”**。很多时候我们怕报错、怕踩坑，但正是这些折腾，让你摸清了前端、Git、部署的皮毛。博客搭好只是第一步，希望未来我们都能在这块小小的自留地里，坚持记录真实的生活与思考。",[15,635,636],{},"折腾不息，共勉！",[638,639,640],"style",{},"html pre.shiki code .sV9Aq, html code.shiki .sV9Aq{--shiki-default:#7F848E;--shiki-default-font-style:italic}html pre.shiki code .sVbv2, html code.shiki .sVbv2{--shiki-default:#61AFEF}html pre.shiki code .subq3, html code.shiki .subq3{--shiki-default:#98C379}html pre.shiki code .sVC51, html code.shiki .sVC51{--shiki-default:#D19A66}html pre.shiki code .sn6KH, html code.shiki .sn6KH{--shiki-default:#ABB2BF}html pre.shiki code .sjrmR, html code.shiki .sjrmR{--shiki-default:#56B6C2}html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}",{"title":115,"searchDepth":116,"depth":116,"links":642},[643,644,648,652,658],{"id":222,"depth":116,"text":223},{"id":244,"depth":116,"text":245,"children":645},[646,647],{"id":252,"depth":191,"text":253},{"id":275,"depth":191,"text":276},{"id":395,"depth":116,"text":396,"children":649},[650,651],{"id":402,"depth":191,"text":403},{"id":443,"depth":191,"text":444},{"id":460,"depth":116,"text":461,"children":653},[654,655,656,657],{"id":467,"depth":191,"text":468},{"id":513,"depth":191,"text":514},{"id":542,"depth":191,"text":543},{"id":568,"depth":191,"text":569},{"id":626,"depth":116,"text":627},"记录使用 Hexo + Butterfly 搭建个人博客的完整过程与真实体验。",{"date":661,"categories":662},"2024-06-15",[130],"\u002Fposts\u002Fhexo-blog-setup-guide",{"title":217,"description":659},"posts\u002Fhexo-blog-setup-guide","WneeeiP1P91Gc1p57Eglj3iu9MQyOSPPWSOE3SB9a6c",[668,734,744,754,764,774],{"id":5,"title":6,"body":669,"description":123,"extension":124,"meta":730,"navigation":131,"path":132,"seo":733,"stem":134,"__hash__":135},{"type":8,"value":670,"toc":723},[671,673,680,682,684,686,688,690,698,700,702,704,706,708,710,712,714,718],[11,672,13],{"id":13},[15,674,675,29],{},[18,676,678],{"className":677,"ariaHidden":24},[21,22,23],[26,679],{"xLinkHref":28},[11,681,33],{"id":32},[35,683,38],{"id":37},[15,685,41],{},[15,687,44],{},[35,689,48],{"id":47},[15,691